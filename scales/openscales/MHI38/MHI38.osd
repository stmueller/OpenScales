  "translations": {
    "en": {
      "mhi_inst": "These questions are about how you feel and how things have been with you during <b>the past month</b>. For each question, please indicate the one answer that comes closest to the way you have been feeling.",
      "mhi_freq1": "All of the time",
      "mhi_freq2": "Most of the time",
      "mhi_freq3": "A good bit of the time",
      "mhi_freq4": "Some of the time",
      "mhi_freq5": "A little of the time",
      "mhi_freq6": "None of the time",
      "mhi_often1": "Always",
      "mhi_often2": "Very often",
      "mhi_often3": "Fairly often",
      "mhi_often4": "Sometimes",
      "mhi_often5": "Almost never",
      "mhi_often6": "Never",
      "mhi_happy1": "Extremely happy, could not have been more satisfied or pleased",
      "mhi_happy2": "Very happy most of the time",
      "mhi_happy3": "Generally satisfied, pleased",
      "mhi_happy4": "Sometimes fairly satisfied, sometimes fairly unhappy",
      "mhi_happy5": "Generally dissatisfied, unhappy",
      "mhi_happy6": "Very dissatisfied, unhappy most of the time",
      "mhi_nerves1": "Extremely so, to the point where I could not take care of things",
      "mhi_nerves2": "Very much bothered",
      "mhi_nerves3": "Bothered quite a bit",
      "mhi_nerves4": "Bothered some, enough to notice",
      "mhi_nerves5": "Bothered just a little",
      "mhi_nerves6": "Not bothered at all",
      "mhi_suicide1": "Yes, constantly",
      "mhi_suicide2": "Yes, very often",
      "mhi_suicide3": "Yes, fairly often",
      "mhi_suicide4": "Yes, a couple of times",
      "mhi_suicide5": "Yes, once",
      "mhi_suicide6": "No, never",
