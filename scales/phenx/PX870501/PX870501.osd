    "_scoring_notes": "<div class=\"rich-text-field-label\"><p>Scoring:<br /><br /><span style=\"font-weight: normal;\">A score for each subscale can be computed as either a total score or an average for the individual items. Higher scores indicate greater reactions for each subscale.</span><br /><br /><span style=\"font-weight: normal;\"><span style=\"text-decoration: underline;\">Positive Reappraisal</span>: items 2, 5, 8, 11, 16, 19, 23, 29, 32, 33, 36, 40, 43, 47, 53, 56, 57, 59, 68, 70, 71</span><br /><br /><span style=\"font-weight: normal;\"><span style=\"text-decoration: underline;\">Avoidance</span>: items 4, 6, 13, 18, 24, 30, 35, 38, 41, 42, 45, 51, 52, 54, 58, 61, 62, 64, 66, 72</span><br /><br /><span style=\"font-weight: normal;\"><span style=\"text-decoration: underline;\">Loss of Control</span>: items 1, 3, 7, 9, 12, 14, 15, 17, 20, 21, 22, 25, 26, 27, 31, 34, 37, 39, 44, 46, 48, 49, 50, 60, 63, 67, 69, 28, 65</span></p></div>",
    "likert_options": {
