{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Dietary Supplements Use",
      "code": "PX050501",
      "abbreviation": "PX050501",
      "description": "These self-administered questions ask how many times per week a supplement was taken and for how many years.",
      "domain": "Health",
      "citation": "Murphy, S. P., Wilkens, L. R., Yonemori, K. M., & Steffen, A. (2009). Development of a supplement composition database for the SURE-QX, a publicly available questionnaire to quantify intakes from commonly consumed dietary supplements. Poster presented at the Eighth International Food Data Conference, Bangkok, Thailand. Murphy, S. P., Wilkens, L. R., Yonemori, K. M., & Steffen, A. (2009). Development of the SURE-QX, a publicly available questionnaire to quantify intakes from commonly consumed dietary supplements. Poster presented at the Seventh International Conference on Diet and Activity Methods, Washington, DC. [PhenX: https://www.phenxtoolkit.org/protocols/view/50501]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/50501"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
