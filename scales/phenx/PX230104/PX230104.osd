      "psychopathologyquestionnaire_felt_fat_opt_3": "13-15 days",
      "psychopathologyquestionnaire_felt_fat_opt_4": "16-22 days",
      "psychopathologyquestionnaire_felt_fat_opt_5": "23-27 days",
      "psychopathologyquestionnaire_felt_fat_opt_6": "every day",
      "psychopathologyquestionnaire_desire_lose_weight": "On how many of the past 28 days, have you had a strong desire to lose weight?",
      "psychopathologyquestionnaire_desire_lose_weight_opt_0": "No days",
      "psychopathologyquestionnaire_desire_lose_weight_opt_1": "1-5 days",
      "psychopathologyquestionnaire_desire_lose_weight_opt_2": "6-12 days",
      "psychopathologyquestionnaire_desire_lose_weight_opt_3": "13-15 days",
      "psychopathologyquestionnaire_desire_lose_weight_opt_4": "16-22 days",
      "psychopathologyquestionnaire_desire_lose_weight_opt_5": "23-27 days",
      "psychopathologyquestionnaire_desire_lose_weight_opt_6": "every day",
      "q13_18_230104": "Questions 13--18: Please select the appropriate answer to the right. Remember that the questions only refer to the past four weeks (28 days).",
      "psychopathologyquestionnaire_unusualamount": "Over the past four weeks (28 days), how many times have you eaten what other people would regard as an unusually large amount of food (given the circumstances)?",
      "psychopathologyquestionnaire_lossofcontrol_eating": "Over the past four weeks (28 days), on how many of these times did you have a sense of having lost control over your eating (at the time that you were eating)?",
      "psychopathologyquestionnaire_lossofcontrol_episodes": "Over the past four weeks (28 days), how many DAYS have such episodes of overeating occurred (i.e., you have eaten an unusually large amount of food and have had a sense of loss of control at the time)?",
      "psychopathologyquestionnaire_control_weightshape_vomit": "Over the past four weeks (28 days), how many times have you made yourself sick (vomit) as a means of controlling your shape or weight?",
      "psychopathologyquestionnaire_control_weightshape_laxatives": "Over the past four weeks (28 days), how many times have you taken laxatives as a means of controlling your shape or weight?",
      "psychopathologyquestionnaire_control_weightshape_exercise": "Over the past four weeks (28 days), how many times have you exercised in a \"driven\" or \"compulsive\" way as a means of controlling your weight, shape, or amount of fat, or to burn off calories?",
      "psychopathologyquestionnaire_eat_secretly": "Over the past 28 days, on how many days have you eaten in secret (i.e., furtively)? Do not count episodes of binge eating",
      "psychopathologyquestionnaire_eat_secretly_opt_0": "No days",
      "psychopathologyquestionnaire_eat_secretly_opt_1": "1-5 days",
      "psychopathologyquestionnaire_eat_secretly_opt_2": "6-12 days",
      "psychopathologyquestionnaire_eat_secretly_opt_3": "13-15 days",
      "psychopathologyquestionnaire_eat_secretly_opt_4": "16-22 days",
      "psychopathologyquestionnaire_eat_secretly_opt_5": "23-27 days",
      "psychopathologyquestionnaire_eat_secretly_opt_6": "every day",
      "ppq_eat_affect_shape": "On what proportion of the times that you have eaten have you felt guilty (felt that you've done wrong) because of its effect on your shape or weight?......Do not count episodes of binge eating",
      "ppq_eat_affect_shape_opt_0": "No days",
      "ppq_eat_affect_shape_opt_1": "1-5 days",
      "ppq_eat_affect_shape_opt_2": "6-12 days",
      "ppq_eat_affect_shape_opt_3": "13-15 days",
      "ppq_eat_affect_shape_opt_4": "16-22 days",
      "ppq_eat_affect_shape_opt_5": "23-27 days",
      "ppq_eat_affect_shape_opt_6": "every day",
      "psychopathologyquestionnaire_others_seeing_you_eat": "Over the past 28 days, how concerned have you been about other people seeing you eat? Do not count episodes of binge eating",
      "psychopathologyquestionnaire_others_seeing_you_eat_opt_0": "No days",
      "psychopathologyquestionnaire_others_seeing_you_eat_opt_1": "1-5 days",
      "psychopathologyquestionnaire_others_seeing_you_eat_opt_2": "6-12 days",
      "psychopathologyquestionnaire_others_seeing_you_eat_opt_3": "13-15 days",
      "psychopathologyquestionnaire_others_seeing_you_eat_opt_4": "16-22 days",
      "psychopathologyquestionnaire_others_seeing_you_eat_opt_5": "23-27 days",
      "psychopathologyquestionnaire_others_seeing_you_eat_opt_6": "every day",
      "q22_28_230104": "Questions 22 to 28: Please select the appropriate answer on the right. Remember that the questions only refer to the past four weeks (28 days).",
      "psychopathologyquestionnaire_judgeyourself_influence_weight": "Over the past 28 days, has your weight influenced how you think about (judge) yourself as a person?",
      "psychopathologyquestionnaire_judgeyourself_influence_weight_opt_0": "Not at all",
      "psychopathologyquestionnaire_judgeyourself_influence_weight_opt_1": "1",
      "psychopathologyquestionnaire_judgeyourself_influence_weight_opt_2": "Slightly",
      "psychopathologyquestionnaire_judgeyourself_influence_weight_opt_3": "3",
