  "translations": {
    "en": {
      "pregnancy_difficulties_health_problems": "Are you feeling bothered, upset or worried at this point in your pregnancy about the effect of ongoing health problems such as high blood pressure of diabetes on your pregnancy?",
      "pregnancy_difficulties_health_problems_opt_01": "Not at all",
      "pregnancy_difficulties_health_problems_opt_02": "Somewhat",
      "pregnancy_difficulties_health_problems_opt_03": "Very much",
      "pregnancy_difficulties_feeling_tired": "Are you feeling bothered, upset or worried at this point in your pregnancy about feeling tired and having low energy during your pregnancy?",
      "pregnancy_difficulties_feeling_tired_opt_01": "Not at all",
      "pregnancy_difficulties_feeling_tired_opt_02": "Somewhat",
      "pregnancy_difficulties_feeling_tired_opt_03": "Very much",
      "pregnancy_difficulties_medical_bills": "Are you feeling bothered, upset or worried at this point in your pregnancy about paying for your medical care during pregnancy?",
      "pregnancy_difficulties_medical_bills_opt_01": "Not at all",
      "pregnancy_difficulties_medical_bills_opt_02": "Somewhat",
      "pregnancy_difficulties_medical_bills_opt_03": "Very much",
      "pregnancy_difficulties_body_shape_weight": "Are you feeling bothered, upset or worried at this point in your pregnancy about changes in your weight and body shape during pregnancy?",
      "pregnancy_difficulties_body_shape_weight_opt_01": "Not at all",
      "pregnancy_difficulties_body_shape_weight_opt_02": "Somewhat",
      "pregnancy_difficulties_body_shape_weight_opt_03": "Very much",
      "pregnancy_difficulties_unhealthy_baby": "Are you feeling bothered, upset or worried at this point in your pregnancy about whether you might have an unhealthy baby?",
      "pregnancy_difficulties_unhealthy_baby_opt_01": "Not at all",
      "pregnancy_difficulties_unhealthy_baby_opt_02": "Somewhat",
      "pregnancy_difficulties_unhealthy_baby_opt_03": "Very much",
      "pregnancy_difficulties_vomiting": "Are you feeling bothered, upset or worried at this point in your pregnancy about physical symptoms of pregnancy such as vomiting?",
      "pregnancy_difficulties_vomiting_opt_01": "Not at all",
      "pregnancy_difficulties_vomiting_opt_02": "Somewhat",
      "pregnancy_difficulties_vomiting_opt_03": "Very much",
      "pregnancy_difficulties_swollen_feet": "Are you feeling bothered, upset or worried at this point in your pregnancy about physical symptoms of pregnancy such as swollen feet?",
      "pregnancy_difficulties_swollen_feet_opt_01": "Not at all",
      "pregnancy_difficulties_swollen_feet_opt_02": "Somewhat",
      "pregnancy_difficulties_swollen_feet_opt_03": "Very much",
      "pregnancy_difficulties_backaches": "Are you feeling bothered, upset or worried at this point in your pregnancy about physical symptoms of pregnancy such as backaches?",
      "pregnancy_difficulties_backaches_opt_01": "Not at all",
      "pregnancy_difficulties_backaches_opt_02": "Somewhat",
      "pregnancy_difficulties_backaches_opt_03": "Very much",
      "pregnancy_difficulties_quality_medical_care": "Are you feeling bothered, upset or worried at this point in your pregnancy about the quality of your medical care during pregnancy?",
      "pregnancy_difficulties_quality_medical_care_opt_01": "Not at all",
      "pregnancy_difficulties_quality_medical_care_opt_02": "Somewhat",
      "pregnancy_difficulties_quality_medical_care_opt_03": "Very much",
      "pregnancy_difficulties_family_issues": "Are you feeling bothered, upset or worried at this point in your pregnancy about working or caring for your family during pregnancy?",
      "pregnancy_difficulties_family_issues_opt_01": "Not at all",
      "pregnancy_difficulties_family_issues_opt_02": "Somewhat",
      "pregnancy_difficulties_family_issues_opt_03": "Very much",
      "pregnancy_difficulties_alcohol_cigarettes_drugs": "Are you feeling bothered, upset or worried at this point in your pregnancy about whether the baby might be affected by alcohol, cigarettes, or drugs that you have taken?",
      "pregnancy_difficulties_alcohol_cigarettes_drugs_opt_01": "Not at all",
      "pregnancy_difficulties_alcohol_cigarettes_drugs_opt_02": "Somewhat",
      "pregnancy_difficulties_alcohol_cigarettes_drugs_opt_03": "Very much",
      "pregnancy_difficulties_other_things": "Are you feeling bothered, upset or worried at this point in your pregnancy about other thanks that have to do with your pregnancy, the birth, or the baby?",
      "pregnancy_difficulties_other_things_opt_01": "Not at all",
      "pregnancy_difficulties_other_things_opt_02": "Somewhat",
      "pregnancy_difficulties_other_things_opt_03": "Very much",
      "pregnancy_difficulties_describe": "If you answered \"somewhat\" or \"very much\" to \"other things\" [(1) above], will you please list what those things are?",
      "likert_1": "Not at all",
      "likert_2": "Somewhat",
      "likert_3": "Very much"
    }
  }
