{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Gaming Disorder Symptom Questionnaire",
      "code": "GDSQ21",
      "abbreviation": "GDSQ-21",
      "description": "21-item Gaming Disorder Symptom Questionnaire with 3 subscales. Items 1-13 use a 5-point frequency scale (0=Never to 4=Almost daily). Items 14-21 use a two-part format: (a) frequency (0-4), then (b) yes/no continuation question (only if a≥1). Score for items 14-21 = a × b. Originally developed in Chinese.",
      "citation": "Zhang, L., Luo, T., Hao, W., Cao, Y., Yuan, M., & Liao, Y. (2022). Gaming Disorder Symptom Questionnaire: The development and validation of a screening tool for ICD-11 gaming disorder in adolescents. Frontiers in Psychiatry, 13, 848157. https://doi.org/10.3389/fpsyt.2022.848157",
      "license": "CC BY 4.0",
      "license_explanation": "Published in Frontiers in Psychiatry under Creative Commons Attribution 4.0 International License.",
      "license_url": "https://creativecommons.org/licenses/by/4.0/",
      "version": "1.0",
      "url": "https://doi.org/10.3389/fpsyt.2022.848157",
      "domain": "Technology"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 0,
      "max": 4,
      "labels": [
        "likert_0",
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "impaired_control",
        "name": "Impaired Control",
        "description": "Difficulty controlling the onset, frequency, intensity, duration, and termination of gaming."
      },
      {
        "id": "increasing_priority",
        "name": "Increasing Priority",
        "description": "Gaming takes precedence over other life interests and daily activities."
      },
      {
        "id": "continued_use",
        "name": "Continued Use Despite Negative Consequences",
        "description": "Continuation or escalation of gaming despite negative consequences."
      }
    ],
    "items": [
