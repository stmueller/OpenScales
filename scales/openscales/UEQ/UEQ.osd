      "ueq_11_left": "ಪ್ರತಿರೋಧಿಸುವ",
      "ueq_11_right": "ಬೆಂಬಲಿಸುವ",
      "ueq_12_text": "ಒಳ್ಳೆಯ                    ಕೆಟ್ಟ",
      "ueq_12_left": "ಒಳ್ಳೆಯ",
      "ueq_12_right": "ಕೆಟ್ಟ",
