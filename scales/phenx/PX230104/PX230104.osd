      "psychopathologyquestionnaire_upset_weigh_yourself_opt_4": "Moderately",
      "psychopathologyquestionnaire_upset_weigh_yourself_opt_5": "5",
      "psychopathologyquestionnaire_upset_weigh_yourself_opt_6": "Markedly",
      "psychopathologyquestionnaire_dissatisfaction_weight": "Over the past 28 days, how dissatisfied have you been with your weight?",
      "psychopathologyquestionnaire_dissatisfaction_weight_opt_0": "Not at all",
      "psychopathologyquestionnaire_dissatisfaction_weight_opt_1": "1",
      "psychopathologyquestionnaire_dissatisfaction_weight_opt_2": "Slightly",
