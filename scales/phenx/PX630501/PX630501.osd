  "translations": {
    "en": {
      "info_630501": "Medical Outcomes Study (MOS) Social Support SurveyPeople sometimes look to others for companionship, assistance, or other types of support. How often is each of the following kinds of support available to you if you need it? Select one in each box.",
      "support_confined_bed": "Someone to help you if you were confined to bed.",
      "support_listen": "Someone you can count on to listen to you when you need to talk.",
      "support_good_advice": "Someone to give you good advice about a crisis.",
      "support_transport_doctor": "Someone to take you to the doctor if you needed it.",
      "support_love_affection": "Someone who shows you love and affection.",
      "support_good_time": "Someone to have a good time with.",
      "support_information_help": "Someone to give you information to help you understand a situation.",
      "support_confide_problems": "Someone to confide in or talk to about yourself or your problems.",
      "support_hugs": "Someone who hugs you.",
      "support_relax": "Someone to get together with for relaxation.",
      "support_prepare_meals": "Someone to prepare your meals if you were unable to do it yourself.",
      "support_advice_want": "Someone whose advice you really want.",
      "support_do_things_with": "Someone to do things with to help get your mind off things.",
      "support_help_chores": "Someone to help with daily chores if you were sick.",
      "support_share_worries_fears": "Someone to share your most private worries and fears with.",
      "support_turn_to_problems": "Someone to turn to for suggestions about how to deal with a personal problem.",
      "support_do_enjoyable_things": "Someone to do something enjoyable with.",
      "support_understands_problems": "Someone who understands your problems.",
      "support_love_feel_wanted": "Someone to love and make you feel wanted.",
      "likert_1": "1- none of the time",
      "likert_2": "2- A little of the time",
      "likert_3": "3- Some of the Time",
      "likert_4": "4- Most of the Time",
      "likert_5": "5- All of the Time"
    }
  }
}
