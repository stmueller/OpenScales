      "support_understands_problems_opt_5": "5- All of the Time",
      "support_love_feel_wanted": "Someone to love and make you feel wanted.",
      "support_love_feel_wanted_opt_1": "1- none of the time",
      "support_love_feel_wanted_opt_2": "2- A little of the time",
      "support_love_feel_wanted_opt_3": "3- Some of the Time",
      "support_love_feel_wanted_opt_4": "4- Most of the Time",
      "support_love_feel_wanted_opt_5": "5- All of the Time",
      "scoring_630501": "Scoring:A score for each social support subscale can be computed as either a total score or an average for the individual items. Higher scores indicate more support.Emotional/informational support: items 2, 3, 7, 8, 12, 15, 16, 18Tangible support: items 1, 4, 11, 14Affectionate support: items 5, 9, 19Positive social interaction: items 6, 10, 17"
    }
  }
