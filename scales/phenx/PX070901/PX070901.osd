  "translations": {
    "en": {
      "chest_x_ray": "During the past three years, have you had a chest x-ray?",
      "chest_x_ray_opt_1": "No",
      "chest_x_ray_opt_2": "Yes, once",
      "chest_x_ray_opt_3": "Yes, more than once",
      "chest_x_ray_opt_4": "Don't know",
