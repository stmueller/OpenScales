  "translations": {
    "en": {
      "likert_0": "Never",
      "likert_1": "Sometimes",
      "likert_2": "Often",
      "likert_3": "Always",
      "question_head": "Please indicate how often each of the following statements applies to you in the past 12 months.",
      "debrief": "Thank you for completing the Gaming Hazard Assessment Scale.",
      "ghas1": "I can't control how long or how often I play games.",
      "ghas2": "I play games more or for longer than I want.",
      "ghas3": "Once I start playing, it's hard to stop.",
      "ghas5": "I keep playing games even if I have lost interest or feel bored with the game itself.",
      "ghas8": "I prefer playing games to participating in other entertainment activities.",
      "ghas9": "I feel like there's no fun in life except playing games.",
      "ghas10": "When not playing games, I'm still thinking about games or game-related things.",
      "ghas11": "I get excited when I see or hear something about games.",
      "ghas12": "I have thoughts or urges to play games when I see or hear something related to the games.",
      "ghas14": "I get irritable when I'm asked to stop the game or reduce gaming time.",
      "ghas18": "I have tried to reduce gaming time or stop playing but failed.",
      "ghas21": "The actual gaming time is longer than promised.",
      "ghas26": "I have conflict with family members other than parents due to playing games.",
      "ghas27": "I seldom go out because of playing games.",
      "ghas28": "I rarely socialize with people because of playing games.",
      "ghas30": "I have serious sleep problems (e.g., insomnia, wakefulness) caused by playing games.",
      "ghas33": "Playing games costs a lot of money and lowers my living standards.",
      "ghas34": "I delay important things (e.g., exams, job hunting) because of playing games.",
      "ghas4": "I keep playing games even if I have lost interest or feel bored with the game itself.",
      "ghas6": "The actual gaming time is longer than promised.",
      "ghas7": "I feel like there's no fun in life except playing games.",
      "ghas13": "I delay important things (e.g., exams, job hunting) because of playing games.",
      "ghas15": "When not playing games, I'm still thinking about games or game-related things.",
      "ghas16": "I get excited when I see or hear something about games.",
      "ghas17": "I have thoughts or urges to play games when I see or hear something related to the games."
    }
  }
}
