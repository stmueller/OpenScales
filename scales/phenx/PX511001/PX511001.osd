  "translations": {
    "en": {
      "sources_of_cannabis_marijuana_typrecord_id": "Record ID",
      "sources_of_cannabis_marijuana_type": "In the past 12 months, have you gotten any type of marijuana from the following sources? SELECT ALL THAT APPLY.",
      "sources_of_cannabis_marijuana_type_opt_1": "I made or grew my own",
      "sources_of_cannabis_marijuana_type_opt_2": "From a family member or friend",
      "sources_of_cannabis_marijuana_type_opt_3": "From a dealer (in person)",
      "sources_of_cannabis_marijuana_type_opt_4": "Internet delivery service or mail order (delivered to me)",
      "sources_of_cannabis_marijuana_type_opt_5": "From a store, co-operative or dispensary",
      "sources_of_cannabis_marijuana_type_opt_6": "Other (please specify without providing any identifiable information):",
      "sources_of_cannabis_marijuana_type_opt_7": "I haven't obtained marijuana from any source in the past 12 months",
      "sources_of_cannabis_marijuana_type_opt_-77": "Don't Know",
      "sources_of_cannabis_marijuana_type_opt_-88": "Refuse to answer",
      "sources_of_cannabis_marijuana_type_other": "In the past 12 months, have you gotten any type of marijuana from the following sources? Other (please specify without providing any identifiable information):",
      "sources_of_cannabis_family_friend_marijuana": "In the past 12 months, where did your family member or friend get the marijuana they gave to you? SELECT ALL THAT APPLY.",
      "sources_of_cannabis_family_friend_marijuana_opt_1": "Made or grew my own",
      "sources_of_cannabis_family_friend_marijuana_opt_2": "Internet",
      "sources_of_cannabis_family_friend_marijuana_opt_3": "Dealer",
      "sources_of_cannabis_family_friend_marijuana_opt_4": "Legal/authorized store, co-operative or dispensary",
      "sources_of_cannabis_family_friend_marijuana_opt_5": "Illegal/unauthorized store, co-operative or dispensary",
      "sources_of_cannabis_family_friend_marijuana_opt_6": "Other",
      "sources_of_cannabis_online_marijuana": "Where did you buy your marijuana online in the past 12 months? SELECT ALL THAT APPLY.",
      "sources_of_cannabis_online_marijuana_opt_1": "An authorized/legal website",
      "sources_of_cannabis_online_marijuana_opt_2": "An unauthorized/illegal website, private delivery service, or dealer not affiliated with a dispensary/co-operative",
      "sources_of_cannabis_online_marijuana_opt_3": "Other online source (please specify without providing any identifiable information):",
      "sources_of_cannabis_online_marijuana_other": "Where did you buy your marijuana online in the past 12 months? Other online source (please specify without providing any identifiable information):",
      "sources_of_cannabis_marijuana_physical_store": "From what type of PHYSICAL store or dispensary did you buy marijuana in the past 12 months? SELECT ALL THAT APPLY.",
      "sources_of_cannabis_marijuana_physical_store_opt_1": "A legal medical dispensary or co-operative",
      "sources_of_cannabis_marijuana_physical_store_opt_2": "A legal recreational store",
      "sources_of_cannabis_marijuana_physical_store_opt_3": "An illegal or unauthorized store/dispensary",
      "sources_of_cannabis_marijuana_physical_store_opt_4": "Other type of store/dispensary (please specify without providing any identifiable information):",
      "sources_of_cannabis_marijuana_physical_store_other": "From what type of PHYSICAL store or dispensary did you buy marijuana in the past 12 months? Other type of store/dispensary (please specify without providing any identifiable information):"
    }
