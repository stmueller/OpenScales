{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "User Experience Questionnaire - Short Version",
      "code": "UEQS",
      "abbreviation": "UEQ-S",
      "description": "8-item short version of the User Experience Questionnaire measuring pragmatic and hedonic quality of interactive products using semantic differential items on a 7-point scale (-3 to +3).",
      "citation": "Schrepp, M., Hinderks, A., & Thomaschewski, J. (2017). Design and Evaluation of a Short Version of the User Experience Questionnaire (UEQ-S). International Journal of Interactive Multimedia and Artificial Intelligence, 4(6), 103-108. https://doi.org/10.9781/ijimai.2017.09.001",
      "license": "free to use",
      "version": "1.0",
      "url": "https://www.ueq-online.org/"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 7,
      "min": 1,
      "max": 7,
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "pragmatic_quality",
        "name": "Pragmatic Quality",
        "abbreviation": "PQ",
        "description": "Task-oriented quality aspects: supportiveness, ease of use, efficiency, clarity"
      },
      {
        "id": "hedonic_quality",
        "name": "Hedonic Quality",
        "abbreviation": "HQ",
        "description": "Non-task-oriented quality aspects: excitement, interest, inventiveness, novelty"
      },
      {
        "id": "overall",
        "name": "Overall UX",
        "abbreviation": "UX",
        "description": "Overall user experience score across all items"
      }
    ],
    "items": [
      {
        "id": "UEQS01",
        "type": "likert",
        "text_key": "UEQS01",
        "likert_labels": [
          "UEQS01_left",
          "blank",
          "blank",
          "blank",
          "blank",
          "blank",
          "UEQS01_right"
        ],
        "dimension": "pragmatic_quality"
      },
      {
        "id": "UEQS02",
        "type": "likert",
        "text_key": "UEQS02",
        "likert_labels": [
          "UEQS02_left",
          "blank",
          "blank",
          "blank",
          "blank",
          "blank",
          "UEQS02_right"
        ],
        "dimension": "pragmatic_quality"
      },
      {
        "id": "UEQS03",
        "type": "likert",
        "text_key": "UEQS03",
        "likert_labels": [
          "UEQS03_left",
          "blank",
          "blank",
          "blank",
          "blank",
          "blank",
          "UEQS03_right"
        ],
        "dimension": "pragmatic_quality"
      },
      {
        "id": "UEQS04",
        "type": "likert",
        "text_key": "UEQS04",
        "likert_labels": [
          "UEQS04_left",
          "blank",
          "blank",
          "blank",
          "blank",
          "blank",
          "UEQS04_right"
        ],
        "dimension": "pragmatic_quality"
      },
      {
        "id": "UEQS05",
        "type": "likert",
        "text_key": "UEQS05",
        "likert_labels": [
          "UEQS05_left",
          "blank",
          "blank",
          "blank",
          "blank",
          "blank",
          "UEQS05_right"
        ],
        "dimension": "hedonic_quality"
      },
      {
        "id": "UEQS06",
        "type": "likert",
        "text_key": "UEQS06",
        "likert_labels": [
          "UEQS06_left",
          "blank",
          "blank",
          "blank",
          "blank",
          "blank",
          "UEQS06_right"
        ],
        "dimension": "hedonic_quality"
      },
      {
        "id": "UEQS07",
        "type": "likert",
        "text_key": "UEQS07",
        "likert_labels": [
          "UEQS07_left",
          "blank",
          "blank",
          "blank",
          "blank",
          "blank",
          "UEQS07_right"
        ],
        "dimension": "hedonic_quality"
      },
      {
        "id": "UEQS08",
        "type": "likert",
        "text_key": "UEQS08",
        "likert_labels": [
          "UEQS08_left",
          "blank",
          "blank",
          "blank",
          "blank",
          "blank",
          "UEQS08_right"
        ],
        "dimension": "hedonic_quality"
      }
    ],
    "scoring": {
      "pragmatic_quality": {
        "method": "mean_coded",
        "items": [
          "UEQS01",
          "UEQS02",
          "UEQS03",
          "UEQS04"
        ],
        "description": "Mean pragmatic quality score (1-7 scale). Subtract 4 for standard UEQ -3 to +3 scale.",
        "item_coding": {
          "UEQS01": 1,
          "UEQS02": 1,
          "UEQS03": 1,
          "UEQS04": 1
        },
        "transform": [
          {
            "op": "subtract",
            "value": 4
          }
        ]
      },
      "hedonic_quality": {
        "method": "mean_coded",
        "items": [
          "UEQS05",
          "UEQS06",
          "UEQS07",
          "UEQS08"
        ],
        "description": "Mean hedonic quality score (1-7 scale). Subtract 4 for standard UEQ -3 to +3 scale.",
        "item_coding": {
          "UEQS05": 1,
          "UEQS06": 1,
          "UEQS07": 1,
          "UEQS08": 1
        },
        "transform": [
          {
            "op": "subtract",
            "value": 4
          }
        ]
      },
      "overall": {
        "method": "mean_coded",
        "items": [
          "UEQS01",
          "UEQS02",
          "UEQS03",
          "UEQS04",
          "UEQS05",
          "UEQS06",
          "UEQS07",
          "UEQS08"
        ],
        "description": "Overall UX score (1-7 scale). Subtract 4 for standard UEQ -3 to +3 scale.",
        "item_coding": {
          "UEQS01": 1,
          "UEQS02": 1,
          "UEQS03": 1,
          "UEQS04": 1,
          "UEQS05": 1,
          "UEQS06": 1,
          "UEQS07": 1,
          "UEQS08": 1
        },
        "transform": [
          {
            "op": "subtract",
            "value": 4
          }
        ]
      }
    },
    "report": {
      "template": "standard",
      "include": [
        "timestamp",
        "completion_time",
        "dimension_scores"
      ],
      "header": "The UEQ-S measures pragmatic and hedonic quality of interactive products. Scores are transformed to a -3 to +3 scale (subtract 4 from raw means).",
      "footer_refs": [
        "Schrepp, M., Hinderks, A., & Thomaschewski, J. (2017). Design and Evaluation of a Short Version of the User Experience Questionnaire (UEQ-S). IJIMAI, 4(6), 103-108.",
        "See <a href='https://www.ueq-online.org/'>https://www.ueq-online.org/</a> for more information and benchmark data."
      ]
    },
    "data_output": {
      "individual_file": "UEQS-{subnum}.csv",
      "pooled_file": "UEQS-pooled.csv",
      "report_file": "UEQS-report-{subnum}.html",
      "columns": "subnum,order,time,qnum,ques,dim,valence,resp,rt",
      "pooled_columns": "subnum,timestamp,time,UEQS01,UEQS02,UEQS03,UEQS04,UEQS05,UEQS06,UEQS07,UEQS08,pragmatic_quality,hedonic_quality,overall"
    }
  },
