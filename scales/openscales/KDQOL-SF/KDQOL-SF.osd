{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Kidney Disease Quality of Life Short Form v1.3",
      "code": "KDQOL-SF",
      "abbreviation": "KDQOL-SF",
      "description": "KDQOL-SF v1.3: 36-item SF-36 health survey plus 46 kidney disease-specific items across 10 dimensions: Burden, Cognitive/Social Function, Symptoms/Problems, Effects on Daily Life, Sexual Function, Sleep, Social Support, Dialysis Care Satisfaction, Work Status, and Overall Health Rating. Public Domain (RAND/University of Arizona).",
      "citation": "Hays, R.D., Kallich, J.D., Mapes, D.L., Coons, S.J., & Carter, W.B. (1994). Development of the Kidney Disease Quality of Life (KDQOL) instrument. Quality of Life Research, 3(5), 329–338. https://doi.org/10.1007/BF00451725",
      "license": "Public Domain",
      "version": "1.3",
      "url": "https://www.rand.org/health-care/surveys_tools/kdqol.html",
      "domain": "Health",
      "license_explanation": "RAND Corporation places their health survey instruments in the public domain. RAND explicitly states these instruments are available for use without permission or fee.",
      "license_url": "https://www.rand.org/health-care/surveys_tools/kdqol.html",
      "n_items": 79
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "dimensions": [
      {
        "id": "sf36_physical_function",
        "name": "SF-36 Physical Functioning",
        "abbreviation": "PF",
        "description": "SF-36 Physical Functioning subscale (10 items). Items: kdqolsf1–kdqolsf10.",
        "enabled_param": null
      },
      {
        "id": "sf36_role_physical",
        "name": "SF-36 Role Limitations — Physical",
        "abbreviation": "RP",
        "description": "SF-36 Role Limitations due to physical health (4 items). Items: kdqolsf11–kdqolsf14.",
        "enabled_param": null
      },
      {
        "id": "sf36_role_emotional",
        "name": "SF-36 Role Limitations — Emotional",
        "abbreviation": "RE",
        "description": "SF-36 Role Limitations due to emotional problems (3 items). Items: kdqolsf15–kdqolsf17.",
        "enabled_param": null
      },
      {
        "id": "sf36_energy_fatigue",
        "name": "SF-36 Energy/Fatigue",
        "abbreviation": "EF",
        "description": "SF-36 Energy/Fatigue (Vitality) subscale (4 items). Items: kdqolsf23, kdqolsf27, kdqolsf29, kdqolsf31.",
        "enabled_param": null
      },
      {
        "id": "sf36_emotional_wellbeing",
        "name": "SF-36 Emotional Well-Being",
        "abbreviation": "EWB",
        "description": "SF-36 Mental Health subscale (5 items). Items: kdqolsf24, kdqolsf25, kdqolsf26, kdqolsf28, kdqolsf30.",
        "enabled_param": null
      },
      {
        "id": "sf36_social_function",
        "name": "SF-36 Social Functioning",
        "abbreviation": "SF",
        "description": "SF-36 Social Functioning subscale (2 items). Items: kdqolsf18, kdqolsf32.",
        "enabled_param": null
      },
      {
        "id": "sf36_pain",
        "name": "SF-36 Pain",
        "abbreviation": "PAIN",
        "description": "SF-36 Bodily Pain subscale (2 items). Items: kdqolsf19, kdqolsf20.",
        "enabled_param": null
      },
      {
        "id": "sf36_general_health",
        "name": "SF-36 General Health",
        "abbreviation": "GH",
        "description": "SF-36 General Health subscale (5 items). Items: kdqolsf21, kdqolsf33–kdqolsf36.",
        "enabled_param": null
      },
      {
        "id": "burden",
        "name": "Burden of Kidney Disease",
        "description": "Section 12. How true/false are statements about kidney disease burden (4 items)."
      },
      {
        "id": "cognitive_social",
        "name": "Cognitive Function / Quality of Social Interaction",
        "description": "Section 13. How often during the past 4 weeks (6 items, 6-pt freq)."
      },
      {
        "id": "symptoms",
        "name": "Symptoms/Problems",
        "description": "Section 14. Extent bothered by symptoms during past 4 weeks (13 items)."
      },
      {
        "id": "effects",
        "name": "Effects of Kidney Disease on Daily Life",
        "description": "Section 15. How much kidney disease bothers you in daily life areas (8 items)."
      },
      {
        "id": "sexual_function",
        "name": "Sexual Function",
        "description": "Section 16. Sexual activity and problems (3 items)."
      },
      {
        "id": "sleep",
        "name": "Sleep",
        "description": "Sections 17-18. Sleep quality rating and frequency items."
      },
      {
        "id": "social_support",
        "name": "Social Support",
        "description": "Section 19. Satisfaction with family and friends (2 items)."
      },
      {
        "id": "work_status",
        "name": "Work Status",
        "description": "Sections 20-21. Employment status (2 items)."
      },
      {
        "id": "overall_health",
        "name": "Overall Health Rating",
        "description": "Section 22. Overall health rating 0-10."
      },
      {
        "id": "dialysis_care",
        "name": "Satisfaction with Dialysis Care",
        "description": "Sections 23-24. Satisfaction with care and dialysis staff support (3 items)."
      }
    ],
