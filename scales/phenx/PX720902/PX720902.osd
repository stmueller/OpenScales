  "translations": {
    "en": {
      "mother_and_baby_health_last_pregnancy_occur": "For your last pregnancy, did any of the following occur? Choose all that apply.",
      "mother_and_baby_health_last_pregnancy_occur_opt_1": "Preterm birth (birth of baby less than 37 weeks gestational age)",
      "mother_and_baby_health_last_pregnancy_occur_opt_2": "Baby with low birth weight (less than 5 pounds 8 ounces)",
      "mother_and_baby_health_last_pregnancy_occur_opt_3": "Baby with birth defects",
      "mother_and_baby_health_last_pregnancy_occur_opt_4": "Placenta previa",
      "mother_and_baby_health_last_pregnancy_occur_opt_5": "Placenta abruption",
      "mother_and_baby_health_last_pregnancy_occur_opt_6": "Pre-eclampsia",
      "mother_and_baby_health_last_pregnancy_occur_opt_7": "None of the above",
      "mother_and_baby_health_last_pregnancy_occur_opt_(-8)": "DON'T KNOW",
      "mother_and_baby_health_last_pregnancy_occur_opt_(-9)": "REFUSED",
      "mother_and_baby_health_last_pregnancy_condition": "During your most recent pregnancy, did a healthcare provider tell you that you had any of the following health conditions?",
      "mother_and_baby_health_last_pregnancy_condition_opt_1": "Gestational diabetes (diabetes that started during this pregnancy)",
      "mother_and_baby_health_last_pregnancy_condition_opt_2": "High blood pressure (that started during this pregnancy), pre-eclampsia, or eclampsia",
      "mother_and_baby_health_last_pregnancy_condition_opt_3": "Depression",
      "mother_and_baby_health_last_pregnancy_condition_opt_4": "Anxiety",
      "mother_and_baby_health_last_pregnancy_outcome": "What was the outcome of your last pregnancy?",
      "mother_and_baby_health_last_pregnancy_outcome_opt_1": "Live birth",
      "mother_and_baby_health_last_pregnancy_outcome_opt_2": "Miscarriage",
      "mother_and_baby_health_last_pregnancy_outcome_opt_3": "Abortion",
      "mother_and_baby_health_last_pregnancy_outcome_opt_4": "Ectopic or tubal pregnancy",
      "mother_and_baby_health_last_pregnancy_outcome_opt_5": "Stillbirth",
      "mother_and_baby_health_last_pregnancy_outcome_opt_6": "None of the above",
      "mother_and_baby_health_last_pregnancy_outcome_opt_(-8)": "DON'T KNOW",
      "mother_and_baby_health_last_pregnancy_outcome_opt_(-9)": "REFUSED",
      "mother_and_baby_health_3_months_before_pregnant_cigarettes_average_day": "In the 3 months before you got pregnant, how many cigarettes did you smoke on an average day?",
      "mother_and_baby_health_3_months_before_pregnant_cigarettes_average_day_opt_1": "More than one pack (21 or more cigarettes)",
      "mother_and_baby_health_3_months_before_pregnant_cigarettes_average_day_opt_2": "One-half to one pack (11 to 20 cigarettes)",
      "mother_and_baby_health_3_months_before_pregnant_cigarettes_average_day_opt_3": "Less than half a pack (1 to 10 cigarettes)",
      "mother_and_baby_health_3_months_before_pregnant_cigarettes_average_day_opt_4": "I didn't smoke then",
      "mother_and_baby_health_last_3_months_pregnant_cigarettes_average_day": "In the last 3 months of your pregnancy, how many cigarettes did you smoke on an average day?",
      "mother_and_baby_health_last_3_months_pregnant_cigarettes_average_day_opt_1": "More than one pack (21 or more cigarettes)",
      "mother_and_baby_health_last_3_months_pregnant_cigarettes_average_day_opt_2": "One-half to one pack (11 to 20 cigarettes)",
      "mother_and_baby_health_last_3_months_pregnant_cigarettes_average_day_opt_3": "Less than half a pack (1 to 10 cigarettes)",
      "mother_and_baby_health_last_3_months_pregnant_cigarettes_average_day_opt_4": "I didn't smoke then",
      "mother_and_baby_health_quit_smoking_around_pregnancy": "Did you quit smoking around the time of your most recent pregnancy? Check ONE answer.",
      "mother_and_baby_health_quit_smoking_around_pregnancy_opt_1": "No",
      "mother_and_baby_health_quit_smoking_around_pregnancy_opt_2": "No, but I cut back",
      "mother_and_baby_health_quit_smoking_around_pregnancy_opt_3": "Yes, I quit before I found out I was pregnant",
      "mother_and_baby_health_quit_smoking_around_pregnancy_opt_4": "Yes, I quit when I found out I was pregnant",
      "mother_and_baby_health_quit_smoking_around_pregnancy_opt_5": "Yes, I quit later in my pregnancy",
      "mother_and_baby_health_3_months_before_pregnant_e_cig_vape": "During the 3 months before you got pregnant, on average, how often did you use e-cigarettes (vapes) or other electronic nicotine products?",
      "mother_and_baby_health_3_months_before_pregnant_e_cig_vape_opt_1": "Everyday",
      "mother_and_baby_health_3_months_before_pregnant_e_cig_vape_opt_2": "Some days",
      "mother_and_baby_health_3_months_before_pregnant_e_cig_vape_opt_3": "I didn't use e-cigarettes or other electronic nicotine products then",
      "mother_and_baby_health_last_3_months_pregnant_e_cig_vape": "During the last 3 months of your pregnancy, how often did you use e-cigarettes (vapes) or other electronic nicotine products?",
      "mother_and_baby_health_last_3_months_pregnant_e_cig_vape_opt_1": "Everyday",
      "mother_and_baby_health_last_3_months_pregnant_e_cig_vape_opt_2": "Some days",
      "mother_and_baby_health_last_3_months_pregnant_e_cig_vape_opt_3": "I didn't use e-cigarettes or other electronic nicotine products then",
      "mother_and_baby_health_after_born_hospital_stay": "After your baby was born, how long did he or she stay in the hospital?",
      "mother_and_baby_health_after_born_hospital_stay_opt_1": "Less than 3 days",
      "mother_and_baby_health_after_born_hospital_stay_opt_2": "3 to 5 days",
      "mother_and_baby_health_after_born_hospital_stay_opt_3": "6 to 14 days",
      "mother_and_baby_health_after_born_hospital_stay_opt_4": "More than 14 days",
      "mother_and_baby_health_after_born_hospital_stay_opt_5": "My baby was not born in a hospital",
      "mother_and_baby_health_after_born_hospital_stay_opt_6": "My baby is still in the hospital",
      "mother_and_baby_health_newborn_alive_now": "Is your baby alive now?",
      "mother_and_baby_health_newborn_alive_now_opt_1": "No",
      "mother_and_baby_health_newborn_alive_now_opt_2": "Yes",
      "likert_1": "Gestational diabetes (diabetes that started during this pregnancy)",
      "likert_2": "High blood pressure (that started during this pregnancy), pre-eclampsia, or eclampsia",
      "likert_3": "Depression",
      "likert_4": "Anxiety"
    }
