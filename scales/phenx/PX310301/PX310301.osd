  "translations": {
    "en": {
      "awareness_pharmacogenomics_side_effect_medication_experience": "Have you ever experienced a side effect of a medication?",
      "awareness_pharmacogenomics_side_effect_medication_experience_opt_1": "Yes",
      "awareness_pharmacogenomics_side_effect_medication_experience_opt_2": "No",
      "awareness_pharmacogenomics_side_effect_medication_experience_opt_3": "No, but a family member has",
      "awareness_pharmacogenomics_side_effect_medication_experience_opt_4": "I do not know",
      "awareness_pharmacogenomics_side_effect_medication_stopped": "Have you ever stopped taking a medication because of the side effects of this medication?",
      "awareness_pharmacogenomics_side_effect_medication_stopped_opt_1": "Yes",
      "awareness_pharmacogenomics_side_effect_medication_stopped_opt_2": "No",
      "awareness_pharmacogenomics_side_effect_medication_stopped_opt_3": "I do not know",
      "awareness_pharmacogenomics_medication_stopped_did_not_work": "Have you ever stopped taking a medication because you felt that it did not work?",
      "awareness_pharmacogenomics_medication_stopped_did_not_work_opt_1": "Yes",
      "awareness_pharmacogenomics_medication_stopped_did_not_work_opt_2": "No",
      "awareness_pharmacogenomics_medication_stopped_did_not_work_opt_3": "I do not know",
      "awareness_pharmacogenomics_differences_body_response_medication": "Do you think that there could be differences between people in their body's response to medication due to differences in their DNA?",
      "awareness_pharmacogenomics_differences_body_response_medication_opt_1": "Yes",
      "awareness_pharmacogenomics_differences_body_response_medication_opt_2": "No",
      "awareness_pharmacogenomics_differences_body_response_medication_opt_3": "I do not know",
      "awareness_pharmacogenomics_dna_knowledge_reduce_side_effects": "Do you think that determining the differences in DNA that are associated with the effect of medication will help to reduce (future) side effects?",
      "awareness_pharmacogenomics_dna_knowledge_reduce_side_effects_opt_1": "Yes",
      "awareness_pharmacogenomics_dna_knowledge_reduce_side_effects_opt_2": "No",
      "awareness_pharmacogenomics_dna_knowledge_reduce_side_effects_opt_3": "I do not know",
      "awareness_pharmacogenomics_dna_knowledge_improve_treatment": "Do you think that knowing the differences in DNA that are associated with the effect of medication will help improve (future) drug treatment?",
      "awareness_pharmacogenomics_dna_knowledge_improve_treatment_opt_1": "Yes",
      "awareness_pharmacogenomics_dna_knowledge_improve_treatment_opt_2": "No",
      "awareness_pharmacogenomics_dna_knowledge_improve_treatment_opt_3": "I do not know",
      "awareness_pharmacogenomics_heard": "Before you received this questionnaire, have you ever heard of the term \\pharmacogenetics\\?",
      "awareness_pharmacogenomics_heard_opt_1": "Yes",
      "awareness_pharmacogenomics_heard_opt_2": "No",
      "awareness_pharmacogenomics_meaning": "Before you received this questionnaire, did you know the meaning of \\pharmacogenetics\\?",
      "awareness_pharmacogenomics_meaning_opt_1": "Yes",
      "awareness_pharmacogenomics_meaning_opt_2": "No",
      "awareness_pharmacogenomics_test": "Have you ever had a pharmacogenetic test? In a pharmacogenetic test, your hereditary traits related to effect of a medication will be examined",
      "awareness_pharmacogenomics_test_opt_1": "Yes",
      "awareness_pharmacogenomics_test_opt_2": "No",
      "awareness_pharmacogenomics_test_opt_3": "No, but I have had another kind of DNA test",
      "awareness_pharmacogenomics_test_opt_4": "I do not know",
      "awareness_pharmacogenomics_test_other_person": "Do you know someone who has had a pharmacogenetic test?",
      "awareness_pharmacogenomics_test_other_person_opt_1": "Yes",
      "awareness_pharmacogenomics_test_other_person_opt_2": "No",
      "awareness_pharmacogenomics_test_other_person_opt_3": "No, but I know someone who has had another type of DNA-test",
      "awareness_pharmacogenomics_dna_information_future_treatment": "Suppose that your DNA is associated with the effects of your medication. Would you allow your doctor to use the information about your DNA in your future treatment?",
      "awareness_pharmacogenomics_dna_information_future_treatment_opt_1": "Yes",
      "awareness_pharmacogenomics_dna_information_future_treatment_opt_2": "No",
      "awareness_pharmacogenomics_dna_information_future_treatment_opt_3": "I don't know, I have never thought about this",
      "awareness_pharmacogenomics_dna_information_future_treatment_opt_4": "I have been thinking about this, but do not know yet",
      "awareness_pharmacogenomics_dna_test_before_prescription": "Are you willing to have a DNA test before a certain medication is prescribed?",
      "awareness_pharmacogenomics_dna_test_before_prescription_opt_1": "Yes",
      "awareness_pharmacogenomics_dna_test_before_prescription_opt_2": "No",
      "awareness_pharmacogenomics_dna_test_before_prescription_opt_3": "I do not know",
      "awareness_pharmacogenomics_pharmacogenomic_information_use_treatment": "Do you want your pharmacogenetic information to be used in your treatment with medicines?",
      "awareness_pharmacogenomics_pharmacogenomic_information_use_treatment_opt_1": "Yes, during the whole treatment",
      "awareness_pharmacogenomics_pharmacogenomic_information_use_treatment_opt_2": "Yes, but only during my (potential) pregnancy",
      "awareness_pharmacogenomics_pharmacogenomic_information_use_treatment_opt_3": "No",
      "awareness_pharmacogenomics_pharmacogenomic_information_use_treatment_opt_4": "No opinion, I don't know",
      "awareness_pharmacogenomics_partake_future_research": "Would you take part in future research related to pharmacogenetics?",
      "awareness_pharmacogenomics_partake_future_research_opt_1": "Yes",
      "awareness_pharmacogenomics_partake_future_research_opt_2": "No",
      "awareness_pharmacogenomics_partake_future_research_opt_3": "I do not know",
      "awareness_pharmacogenomics_partake_future_research_reason_decline": "If not, or in doubt, what is the reason (multiple answers are correct)?",
      "awareness_pharmacogenomics_partake_future_research_reason_decline_opt_1": "I do not allow my DNA/genetic information to be used in research",
      "awareness_pharmacogenomics_partake_future_research_reason_decline_opt_2": "I do not understand the benefit of genetic testing",
      "awareness_pharmacogenomics_partake_future_research_reason_decline_opt_3": "I am worried about the consequences",
      "awareness_pharmacogenomics_partake_future_research_reason_decline_opt_4": "I am not interested in pharmacogenetic research",
      "awareness_pharmacogenomics_partake_future_research_reason_decline_opt_5": "Other",
      "awareness_pharmacogenomics_partake_future_research_reason_decline_other": "If Other, please describe",
      "awareness_pharmacogenomics_dna_test_knowledge": "Would you like to learn more about DNA tests for pharmacogenetics?",
      "awareness_pharmacogenomics_dna_test_knowledge_opt_1": "Yes",
      "awareness_pharmacogenomics_dna_test_knowledge_opt_2": "No",
      "awareness_pharmacogenomics_dna_test_knowledge_opt_3": "I don't know",
      "awareness_pharmacogenomics_dna_test_information_source": "Which method of getting information about DNA tests for pharmacogenetics do you prefer (multiple answers are correct)?",
      "awareness_pharmacogenomics_dna_test_information_source_opt_1": "Internet",
      "awareness_pharmacogenomics_dna_test_information_source_opt_2": "Information leaflet",
      "awareness_pharmacogenomics_dna_test_information_source_opt_3": "Advice from your pharmacist",
      "awareness_pharmacogenomics_dna_test_information_source_opt_4": "Advice from your GP",
      "awareness_pharmacogenomics_dna_test_information_source_opt_5": "Other",
      "awareness_pharmacogenomics_dna_test_information_source_other": "If Other, please describe:"
    }
  }
