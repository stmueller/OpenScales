  "definition": {
    "scale_info": {
      "name": "Expectancies for Medical Cannabis Use",
      "code": "PX520408",
      "abbreviation": "PX520408",
      "description": "The Cannabis Effects Expectancy Questionnaire–Medical (CEEQ-M) is a self-administered, 21-item questionnaire that assesses what expectations people have for the use of cannabis for medical symptoms. The CEEQ-M is the first longitudinally validated instrument of its kind, providing insights into how ",
      "domain": "Substance Use",
      "citation": "Martin-Willett, R., Elmore, J. S., Phillips, P. X., & Bidwell, L. C. (2024). Meaningfully characterizing cannabis use for research and clinical settings: A comprehensive review of existing measures and proposed future directions. Psychiatry and Clinical Psychopharmacology, 34(1), 82–93. doi.org/10.5152/pcp.2024.23645 [PhenX: https://www.phenxtoolkit.org/protocols/view/520408]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/520408"
    },
    "implementation": {
