  "translations": {
    "en": {
      "purpose_201001": "The purpose of the scale is to identify the problems your tinnitus may be causing you. Check \"Yes,\" \"Sometimes,\" or \"No\" for each question. Do not skip a question.",
      "difficult_to_concentrate": "Because of your tinnitus is it difficult to concentrate?",
      "difficult_to_concentrate_opt_1": "Yes",
      "difficult_to_concentrate_opt_2": "Sometimes",
      "difficult_to_concentrate_opt_3": "No",
      "difficult_to_hear_people": "Does the loudness of your tinnitus make it difficult for you to hear people?",
      "difficult_to_hear_people_opt_1": "Yes",
      "difficult_to_hear_people_opt_2": "Sometimes",
      "difficult_to_hear_people_opt_3": "No",
      "tinnitus_angry": "Does your tinnitus make you angry?",
      "tinnitus_angry_opt_1": "Yes",
      "tinnitus_angry_opt_2": "Sometimes",
      "tinnitus_angry_opt_3": "No",
      "tinnitus_confused": "Does your tinnitus make you feel confused?",
      "tinnitus_confused_opt_1": "Yes",
      "tinnitus_confused_opt_2": "Sometimes",
      "tinnitus_confused_opt_3": "No",
      "tinnitus_desperate": "Because of your tinnitus do you feel desperate?",
      "tinnitus_desperate_opt_1": "Yes",
      "tinnitus_desperate_opt_2": "Sometimes",
      "tinnitus_desperate_opt_3": "No",
      "tinnitus_complain": "Do you complain a great deal about your tinnitus?",
      "tinnitus_complain_opt_1": "Yes",
      "tinnitus_complain_opt_2": "Sometimes",
      "tinnitus_complain_opt_3": "No",
      "tinnitus_sleeplessness": "Because of your tinnitus do you have trouble falling to sleep at night?",
      "tinnitus_sleeplessness_opt_1": "Yes",
      "tinnitus_sleeplessness_opt_2": "Sometimes",
      "tinnitus_sleeplessness_opt_3": "No",
      "tinnitus_cannot_escape": "Do you feel that you cannot escape your tinnitus?",
      "tinnitus_cannot_escape_opt_1": "Yes",
      "tinnitus_cannot_escape_opt_2": "Sometimes",
      "tinnitus_cannot_escape_opt_3": "No",
      "tinnitus_interfere_social_activity": "Does your tinnitus interfere with your ability to enjoy social activities (such as going out to dinner, to the movies)?",
      "tinnitus_interfere_social_activity_opt_1": "Yes",
      "tinnitus_interfere_social_activity_opt_2": "Sometimes",
      "tinnitus_interfere_social_activity_opt_3": "No",
      "tinnitus_frustrated": "Because of your tinnitus do you feel frustrated?",
      "tinnitus_frustrated_opt_1": "Yes",
      "tinnitus_frustrated_opt_2": "Sometimes",
      "tinnitus_frustrated_opt_3": "No",
      "tinnitus_terrible_disease": "Because of your tinnitus do you feel that you have a terrible disease?",
      "tinnitus_terrible_disease_opt_1": "Yes",
      "tinnitus_terrible_disease_opt_2": "Sometimes",
      "tinnitus_terrible_disease_opt_3": "No",
      "tinnitus_difficult_enjoy_life": "Does your tinnitus make it difficult for you to enjoy life?",
      "tinnitus_difficult_enjoy_life_opt_1": "Yes",
      "tinnitus_difficult_enjoy_life_opt_2": "Sometimes",
      "tinnitus_difficult_enjoy_life_opt_3": "No",
      "tinnitus_interfere_job_household": "Does your tinnitus interfere with your job or household duties?",
      "tinnitus_interfere_job_household_opt_1": "Yes",
      "tinnitus_interfere_job_household_opt_2": "Sometimes",
      "tinnitus_interfere_job_household_opt_3": "No",
      "tinnitus_irritable": "Because of your tinnitus do you find that you are often irritable?",
      "tinnitus_irritable_opt_1": "Yes",
      "tinnitus_irritable_opt_2": "Sometimes",
      "tinnitus_irritable_opt_3": "No",
      "tinnitus_difficult_to_read": "Because of your tinnitus is it difficult for you to read?",
      "tinnitus_difficult_to_read_opt_1": "Yes",
      "tinnitus_difficult_to_read_opt_2": "Sometimes",
      "tinnitus_difficult_to_read_opt_3": "No",
      "tinnitus_upset": "Does your tinnitus make you upset?",
      "tinnitus_upset_opt_1": "Yes",
      "tinnitus_upset_opt_2": "Sometimes",
      "tinnitus_upset_opt_3": "No",
      "tinnitus_stressed_relationships": "Do you feel that your tinnitus problem has placed stressed on your relationship with members of your family and friends?",
      "tinnitus_stressed_relationships_opt_1": "Yes",
      "tinnitus_stressed_relationships_opt_2": "Sometimes",
      "tinnitus_stressed_relationships_opt_3": "No",
      "tinnitus_difficult_focus_otherthings": "Do you find it difficult to focus your attention away from your tinnitus and on other things?",
      "tinnitus_difficult_focus_otherthings_opt_1": "Yes",
      "tinnitus_difficult_focus_otherthings_opt_2": "Sometimes",
      "tinnitus_difficult_focus_otherthings_opt_3": "No",
      "tinnitus_no_control": "Do you feel that you have no control over your tinnitus?",
      "tinnitus_no_control_opt_1": "Yes",
      "tinnitus_no_control_opt_2": "Sometimes",
      "tinnitus_no_control_opt_3": "No",
      "tinnitus_tired": "Because of your tinnitus do you often feel tired?",
      "tinnitus_tired_opt_1": "Yes",
      "tinnitus_tired_opt_2": "Sometimes",
      "tinnitus_tired_opt_3": "No",
      "tinnitus_depressed": "Because of your tinnitus do you feel depressed?",
      "tinnitus_depressed_opt_1": "Yes",
      "tinnitus_depressed_opt_2": "Sometimes",
      "tinnitus_depressed_opt_3": "No",
      "tinnitus_anxious": "Does your tinnitus make you feel anxious?",
      "tinnitus_anxious_opt_1": "Yes",
      "tinnitus_anxious_opt_2": "Sometimes",
      "tinnitus_anxious_opt_3": "No",
      "tinnitus_no_longer_cope": "Do you feel that you can no longer cope with your tinnitus?",
      "tinnitus_no_longer_cope_opt_1": "Yes",
      "tinnitus_no_longer_cope_opt_2": "Sometimes",
      "tinnitus_no_longer_cope_opt_3": "No",
      "tinnitus_worse_under_stress": "Does your tinnitus get worse when are you are under stress?",
      "tinnitus_worse_under_stress_opt_1": "Yes",
      "tinnitus_worse_under_stress_opt_2": "Sometimes",
      "tinnitus_worse_under_stress_opt_3": "No",
      "tinnitus_insecure": "Does your tinnitus make you feel insecure?",
      "tinnitus_insecure_opt_1": "Yes",
      "tinnitus_insecure_opt_2": "Sometimes",
      "tinnitus_insecure_opt_3": "No",
      "scoring_201001": "Scoring:Yes = 4Sometimes = 2No = 0Total scale ranges from 0 to 100 with higher scores representing greater perceived handicap."
    }
  }
}
