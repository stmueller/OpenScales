      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/70801]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/70801"
    },
