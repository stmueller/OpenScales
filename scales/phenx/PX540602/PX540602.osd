      "pxt540602_willing_to_try_something_new_opt_3": "Very true",
      "excited_and_full_of_energy": "I feel excited and full of energy when I get something that I want.",
      "excited_and_full_of_energy_opt_0": "Not true",
      "excited_and_full_of_energy_opt_1": "Somewhat true",
      "excited_and_full_of_energy_opt_2": "True",
      "excited_and_full_of_energy_opt_3": "Very true",
      "hurt_when_scolded": "I am hurt when people scold me or tell me that I do something wrong.",
