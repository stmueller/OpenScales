  "translations": {
    "en": {
      "covid_vaccination_adult_ever_given": "Have you ever been given a vaccine for COVID-19 or enrolled in the COVID-19 clinical vaccine trials?",
      "covid_vaccination_adult_ever_given_opt_1": "Yes",
      "covid_vaccination_adult_ever_given_opt_2": "No",
      "covid_vaccination_adult_ever_given_opt_3": "Don't know",
      "covid_vaccination_adult_ever_given_opt_4": "Refuse to answer",
      "covid_vaccination_adult_number_doses": "How many doses of the COVID-19 vaccine have you received to date?",
      "covid_vaccination_adult_number_doses_opt_1": "1",
      "covid_vaccination_adult_number_doses_opt_2": "2",
      "covid_vaccination_adult_number_doses_opt_3": "3",
      "covid_vaccination_adult_number_doses_opt_4": "Other (specify)",
      "covid_vaccination_adult_number_doses_opt_5": "Refuse to answer",
      "covid_vaccination_adult_number_doses_other": "Please specify the other number of doses of the COVID-19 vaccine you have received to date:",
      "covid_vaccination_adult_dose_first": "Which COVID-19 vaccine trial or vaccine were you given as your first dose?",
      "covid_vaccination_adult_dose_first_other": "Please specify other COVID-19 vaccine you were given as your first dose:",
      "covid_vaccination_adult_dose_placebo": "If you participated in the COVID-19 clinical vaccine trials, do you know if you received a placebo or the vaccine? A placebo is a harmless substance that looks like the vaccine being tested, but does not contain active ingredients.",
      "covid_vaccination_adult_dose_placebo_opt_1": "I received a placebo",
      "covid_vaccination_adult_dose_placebo_opt_2": "I received the vaccine",
      "covid_vaccination_adult_dose_placebo_opt_3": "I was not part of the COVID-19 clinical vaccine trials",
      "covid_vaccination_adult_dose_placebo_opt_4": "Don't know",
      "covid_vaccination_adult_dose_placebo_opt_5": "Refuse to answer",
      "covid_vaccination_adult_dose_first_month": "In which month did you receive the first dose of the COVID-19 vaccine? *must provide value",
      "covid_vaccination_adult_dose_first_day": "On which day did you receive the first dose of the COVID-19 vaccine? *must provide value",
      "covid_vaccination_adult_dose_first_year": "In which year did you receive the first dose of the COVID-19 vaccine? *must provide value",
      "covid_vaccination_adult_dose_second": "Which COVID-19 vaccine trial or vaccine were you given as your second dose?",
      "covid_vaccination_adult_dose_second_other": "Please specify other COVID-19 vaccine you were given as your second dose",
      "covid_vaccination_adult_dose_second_month": "In which month did you receive or will you receive the second dose of the COVID-19 vaccine? *must provide value",
      "covid_vaccination_adult_dose_second_day": "On which day did you receive or will you receive the second dose of the COVID-19 vaccine? *must provide value",
      "covid_vaccination_adult_dose_second_year": "In which year did you receive or will you receive the second dose of the COVID-19 vaccine? *must provide value",
      "covid_vaccination_adult_dose_third": "Which COVID-19 vaccine trial or vaccine were you given as your third dose?",
      "covid_vaccination_adult_dose_third_other": "Please specify other COVID-19 vaccine you were given as your third dose",
      "covid_vaccination_adult_dose_third_month": "In which month did you receive or will you receive the third dose of the COVID-19 vaccine? *must provide value",
      "covid_vaccination_adult_dose_third_day": "On which day did you receive or will you receive the third dose of the COVID-19 vaccine? *must provide value",
      "covid_vaccination_adult_dose_third_year": "In which year did you receive or will you receive the third dose of the COVID-19 vaccine? *must provide value",
      "likert_1": "Moderna mRNA vaccine",
      "likert_2": "Pfizer mRNA vaccine",
      "likert_3": "AstraZeneca attenuated viral vaccine",
      "likert_4": "Johnson & Johnson",
      "likert_5": "Novavax",
      "likert_6": "Other (specify)",
      "likert_7": "Don't know",
      "likert_8": "Refuse to answer"
    }
  }
