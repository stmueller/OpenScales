{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Personal and Family History of Respiratory Symptoms/Diseases - Child",
      "code": "PX090902",
      "abbreviation": "PX090902",
      "description": "Age-specific questions are asked in this protocol to two different age ranges of children. For children ages 13 and 14, questions are asked directly to the child. For children 6 or 7 years old, questions are asked of the parents.",
      "domain": "Health",
      "citation": "Beasley, R. (1998). Worldwide variation in prevalence of symptoms of asthma, allergic rhinoconjunctivitis, and atopic eczema: ISAAC. The Lancet, 351 (9111), 1225-1232. [PhenX: https://www.phenxtoolkit.org/protocols/view/90902]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/90902"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
