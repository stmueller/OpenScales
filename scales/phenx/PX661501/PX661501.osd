      "recovery_selfassessment_administrator_facilities_opt_7": "Don't know",
      "recovery_selfassessment_administrator_encouragement": "Staff encourage program participants to have hope and high expectations for their recovery. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_administrator_encouragement_opt_1": "1",
      "recovery_selfassessment_administrator_encouragement_opt_2": "2",
      "recovery_selfassessment_administrator_encouragement_opt_3": "3",
