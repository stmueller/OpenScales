    "scoring": {
      "cardiac_distress": {
        "method": "sum_coded",
        "items": [
          "cdisf1_d",
          "cdisf2_d",
          "cdisf3_d",
          "cdisf4_d",
          "cdisf5_d",
          "cdisf6_d",
          "cdisf7_d",
          "cdisf8_d",
          "cdisf9_d",
          "cdisf10_d",
          "cdisf11_d",
          "cdisf12_d"
        ],
        "description": "Sum of distress ratings (0-36). Scores >13 indicate significant cardiac distress.",
        "norms": {
          "thresholds": [
            {
              "min": 0,
              "max": 13,
              "label": "Below Threshold"
            },
            {
              "min": 14,
              "max": 36,
              "label": "Significant Cardiac Distress"
            }
          ]
        },
        "item_coding": {
          "cdisf1_d": 1,
          "cdisf2_d": 1,
          "cdisf3_d": 1,
          "cdisf4_d": 1,
          "cdisf5_d": 1,
          "cdisf6_d": 1,
