  "definition": {
    "scale_info": {
      "name": "Emotional State - Child",
      "code": "PX180502",
      "abbreviation": "PX180502",
      "description": "The Positive Affect and Negative Affect Schedule-Child Form (PANAS-C) is a 30-item, self-report questionnaire used to measure the respondent’s emotions during the past few weeks. The items are grouped into the subscales indicated in the title of the protocol: positive affect and negative affect. The",
      "domain": "Mental Health",
      "citation": "Laurent, J., Catanzaro, S. J., & Joiner, T. E., Jr. (2004). Development and preliminary validation of the Physiological Hyperarousal Scale for Children. Psychological Assessment, 16 (4), 373-380. [PhenX: https://www.phenxtoolkit.org/protocols/view/180502]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/180502"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
