          "scs9",
          "scs14",
          "scs17",
          "scs22"
        ]
      },
      "over_identification": {
        "description": "Mean of items 2, 6, 20, 24, reverse-scored (range 1–5). Higher scores indicate less over-identification (more self-compassion).",
        "method": "mean_coded",
        "items": {
          "scs2": -1,
          "scs6": -1,
          "scs20": -1,
          "scs24": -1
        }
      },
      "total": {
        "description": "Total self-compassion: mean of all 26 items after reverse-scoring negative subscales (range 1–5).",
        "method": "mean_coded",
        "items": {
          "scs1": -1,
          "scs2": -1,
          "scs3": 1,
