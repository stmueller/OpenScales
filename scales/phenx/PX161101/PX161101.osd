  "translations": {
    "en": {
      "used_needle_to_inject_drugs": "Have you ever, even once, used a needle to inject a drug not prescribed by a doctor?",
      "which_drugs_injected": "Which of the following drugs have you injected using a needle?",
      "which_drugs_injected_opt_1": "Cocaine",
      "which_drugs_injected_opt_2": "Heroin",
      "which_drugs_injected_opt_3": "Methamphetamine",
      "which_drugs_injected_opt_4": "Steroids",
      "which_drugs_injected_opt_5": "Any other drugs",
      "age_first_used_needle": "How old were you when you first used a needle to inject any drug not prescribed by a doctor?",
      "age_first_used_needle_coded": "How old were you when you first used a needle to inject any drug not prescribed by a doctor?",
      "how_long_since_injected_drugs": "How long ago has it been since you last used a needle to inject a drug not prescribed by a doctor?",
      "howlong_since_injected_drugs_units_opt_1": "Days",
      "howlong_since_injected_drugs_units_opt_2": "Weeks",
      "howlong_since_injected_drugs_units_opt_3": "Months",
      "howlong_since_injected_drugs_units_opt_4": "Years",
      "how_many_times_injected_drugs": "During your life, altogether how many times have you injected drugs not prescribed by a doctor?",
      "how_many_times_injected_drugs_opt_1": "Once",
      "how_many_times_injected_drugs_opt_2": "2-5 times",
      "how_many_times_injected_drugs_opt_3": "6-19 times",
      "how_many_times_injected_drugs_opt_4": "20-49 times",
      "how_many_times_injected_drugs_opt_5": "50-99 times",
      "how_many_times_injected_drugs_opt_6": "100 times or more",
      "how_often_injected": "Think about the period of your life when you injected drugs the most often. How often did you inject then?",
      "how_often_injected_opt_1": "More than once a day",
      "how_often_injected_opt_2": "About once a day",
      "how_often_injected_opt_3": "At least once a week but not every day",
      "how_often_injected_opt_4": "At least once a month but not every week",
      "how_often_injected_opt_5": "Less than once a month",
      "drug_treatment_program": "Have you ever been in a drug treatment or drug rehabilitation program?",
      "opt_1": "Yes",
      "opt_2": "No",
      "opt_3": "Refused",
      "opt_4": "Don't Know"
    }
  }
}
