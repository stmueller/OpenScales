    "scoring": {
      "controlling": {
        "description": "Controlling Meaning: mean of items 1-3. Range 1-7.",
        "method": "mean_coded",
        "items": [
          "fmcr1",
          "fmcr2",
          "fmcr3"
        ]
      },
      "informative": {
        "description": "Informative Meaning: mean of items 4-7. Range 1-7.",
        "method": "mean_coded",
        "items": [
          "fmcr4",
          "fmcr5",
          "fmcr6",
          "fmcr7"
        ]
      }
    }
  },
  "translations": {
    "en": {
      "likert_1": "Strongly Disagree",
      "likert_2": "Disagree",
      "likert_3": "Somewhat Disagree",
      "likert_4": "Neither Agree nor Disagree",
      "likert_5": "Somewhat Agree",
      "likert_6": "Agree",
      "likert_7": "Strongly Agree",
      "question_head": "Please indicate your level of agreement with each of the following statements.",
      "fmcr1": "My boss tries to motivate me by promising to financially reward me if I do well.",
      "fmcr2": "The only reason my boss rewards me financially is to make me work harder.",
      "fmcr3": "My boss only uses cash rewards so that I stay focused on tasks during work.",
      "fmcr4": "My boss displays confidence in my ability to work when s/he gives me a cash reward.",
      "fmcr5": "My boss encourages me to work when s/he gives me a cash reward.",
      "fmcr6": "My boss provides me with positive feedback when s/he gives me a cash reward.",
      "fmcr7": "My boss cares about my work when s/he gives me a cash reward.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
