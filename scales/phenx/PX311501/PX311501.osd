    "scale_info": {
      "name": "Sharing Genomic Information with Relatives",
      "code": "PX311501",
      "abbreviation": "PX311501",
      "description": "This series of questions can be used to determine who the individual shared his or her genetic tests results with, if anyone, and why it was important to share the results.",
      "domain": "Health",
      "citation": "Manuscripts are in progress. [PhenX: https://www.phenxtoolkit.org/protocols/view/311501]",
