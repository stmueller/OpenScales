        ],
        "name": "General-Usefulness (composite)"
      },
      "total": {
        "description": "Mean of all 16 EBQ items (1-7). Higher-order maladaptive beliefs about emotions factor. Higher scores indicate stronger overall beliefs that emotions are uncontrollable and useless.",
        "method": "mean_coded",
        "items": [
          "ebq1",
          "ebq2",
          "ebq3",
