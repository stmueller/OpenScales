  "translations": {
    "en": {
      "sec_voice_handicap_index_title": "Voice Handicap Index",
      "nstructions_these_are_stat": "Instructions: These are statements that many people have used to describe their voices and the effects of their voices on their lives. Check the response that indicates how frequently you have the same experience.",
