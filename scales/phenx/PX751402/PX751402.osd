  "translations": {
    "en": {
      "sec_tobacco_cessation_program_title": "Tobacco Cessation Program",
      "worksite_policies_offered_incentive": "Our worksite: Has in the past 12 months, offered incentives to employees to quit tobacco use.",
      "worksite_policies_offered_incentive_opt_1": "Yes",
      "worksite_policies_offered_incentive_opt_2": "No",
      "worksite_policies_offered_incentive_opt_3": "Not Sure",
      "worksite_policies_offered_incentive_opt_4": "N/A",
      "worksite_policies_offered_help": "Our worksite: Has in the past 12 months, offered employees who use tobacco products, a quit tobacco program or any other help to quit tobacco.",
      "worksite_policies_offered_help_opt_1": "Yes",
      "worksite_policies_offered_help_opt_2": "No",
      "worksite_policies_offered_help_opt_3": "Not Sure",
      "worksite_policies_offered_help_opt_4": "N/A",
      "worksite_policies_offered_nrt": "Our worksite: Has in the past 12 months, offered free nicotine replacement therapy (NRT) to employees who use tobacco products to help quit.",
      "worksite_policies_offered_nrt_opt_1": "Yes",
      "worksite_policies_offered_nrt_opt_2": "No",
      "worksite_policies_offered_nrt_opt_3": "Not Sure",
      "worksite_policies_offered_nrt_opt_4": "N/A",
      "sec_worksite_tobacco_policies_title": "Worksite Tobacco Policies",
      "worksite_policies_proximity_restriction_policy": "Our worksite: Has adopted a policy that restricts smoking within a certain distance from the entrance of the building.",
      "worksite_policies_proximity_restriction_policy_opt_1": "Yes",
      "worksite_policies_proximity_restriction_policy_opt_2": "No",
      "worksite_policies_proximity_restriction_policy_opt_3": "Not Sure",
      "worksite_policies_proximity_restriction_policy_opt_4": "N/A",
      "worksite_policies_designated_smoking_location": "Our worksite: Allows smoking outside only in certain places.",
      "worksite_policies_designated_smoking_location_opt_1": "Yes",
      "worksite_policies_designated_smoking_location_opt_2": "No",
      "worksite_policies_designated_smoking_location_opt_3": "Not Sure",
      "worksite_policies_designated_smoking_location_opt_4": "N/A",
      "worksite_policies_prohibited_outdoors": "Our worksite: Has a policy that prohibits smoking in outdoor work areas.",
      "worksite_policies_prohibited_outdoors_opt_1": "Yes",
      "worksite_policies_prohibited_outdoors_opt_2": "No",
      "worksite_policies_prohibited_outdoors_opt_3": "Not Sure",
      "worksite_policies_prohibited_outdoors_opt_4": "N/A",
      "worksite_policies_prohibited_campus": "Our worksite: Has adopted a policy that prohibits smoking on the whole worksite campus.",
      "worksite_policies_prohibited_campus_opt_1": "Yes",
      "worksite_policies_prohibited_campus_opt_2": "No",
      "worksite_policies_prohibited_campus_opt_3": "Not Sure",
      "worksite_policies_prohibited_campus_opt_4": "N/A",
      "worksite_policies_prohibited_agency_vehicle": "Our worksite: Has adopted a policy that prohibits smoking in all company or agency vehicles.",
      "worksite_policies_prohibited_agency_vehicle_opt_1": "Yes",
      "worksite_policies_prohibited_agency_vehicle_opt_2": "No",
      "worksite_policies_prohibited_agency_vehicle_opt_3": "Not Sure",
      "worksite_policies_prohibited_agency_vehicle_opt_4": "N/A",
      "worksite_policies_prohibited_chew": "Our worksite: Has adopted a policy that prohibits the use of chewing tobacco, snuff, snus, or dip in the workplace.",
      "worksite_policies_prohibited_chew_opt_1": "Yes",
      "worksite_policies_prohibited_chew_opt_2": "No",
      "worksite_policies_prohibited_chew_opt_3": "Not Sure",
      "worksite_policies_prohibited_chew_opt_4": "N/A",
      "worksite_policies_prohibited_ecig": "Our worksite: Has adopted a policy that prohibits the use of electronic tobacco products such as e-cigarettes in the workplace.",
      "worksite_policies_prohibited_ecig_opt_1": "Yes",
      "worksite_policies_prohibited_ecig_opt_2": "No",
      "worksite_policies_prohibited_ecig_opt_3": "Not Sure",
      "worksite_policies_prohibited_ecig_opt_4": "N/A"
    }
  }
