  "translations": {
    "en": {
      "q31_inst": "This survey asks about your health and daily activities. <b>Answer every question.</b> If you are unsure about how to answer a question, please give the best answer you can.",
      "freq_head": "How much of the time during the <b>past 4 weeks</b>...",
      "freq1": "All of the time",
      "freq2": "Most of the time",
      "freq3": "A good bit of the time",
      "freq4": "Some of the time",
      "freq5": "A little of the time",
      "freq6": "None of the time",
      "qol0": "Worst possible quality of life (as bad as or worse than being dead)",
      "qol10": "Best possible quality of life",
      "qol_1": "Very well: could hardly be better",
      "qol_2": "Pretty good",
      "qol_3": "Good & bad parts about equal",
      "qol_4": "Pretty bad",
      "qol_5": "Very bad: could hardly be worse",
      "mem_1": "Yes, a great deal",
      "mem_2": "Yes, somewhat",
      "mem_3": "Only a little",
      "mem_4": "No, not at all",
      "act_1": "A great deal",
      "act_2": "A lot",
      "act_3": "Somewhat",
      "act_4": "Only a little",
      "act_5": "Not at all",
      "fear_1": "Very fearful",
      "fear_2": "Somewhat fearful",
      "fear_3": "Not very fearful",
      "fear_4": "Not fearful at all",
      "worryhurt_1": "Worry a lot",
      "worryhurt_2": "Occasionally worry",
      "worryhurt_3": "Don't worry at all",
      "worry4_1": "Very worried",
      "worry4_2": "Somewhat worried",
      "worry4_3": "Not very worried",
      "worry4_4": "Not at all worried",
      "bother_1": "Not at all bothersome",
      "bother_2": "Slightly bothersome",
      "bother_3": "Moderately bothersome",
      "bother_4": "Quite a bit bothersome",
      "bother_5": "Extremely bothersome",
      "vas_lo": "Worst imaginable Health (as bad as or worse than being dead)",
      "vas_hi": "Best imaginable Health",
      "q1": "Overall, how would you rate your quality of life?",
      "q2_head": "These questions are about how you <b>FEEL</b> and how things have been with you during the <b>past 4 weeks</b>. For each question, please indicate the one answer that comes closest to the way you have been feeling.",
      "q2": "Did you feel full of pep?",
      "q3": "Have you been a very nervous person?",
      "q4": "Have you felt so down in the dumps that nothing could cheer you up?",
      "q5": "Have you felt calm and peaceful?",
      "q6": "Did you have a lot of energy?",
      "q7": "Have you felt downhearted and blue?",
      "q8": "Did you feel worn out?",
      "q9": "Have you been a happy person?",
      "q10": "Did you feel tired?",
      "q11": "Have you worried about having another seizure?",
      "q12": "Did you have difficulty reasoning and solving problems (such as making plans, making decisions, learning new things)?",
      "q13": "Has your epilepsy limited your social activities (such as visiting with friends or close relatives)?",
      "q14": "How has the <b>QUALITY OF YOUR LIFE</b> been during the <b>past 4 weeks</b> (that is, how have things been going for you)?",
      "q15_head": "The following questions are about <b>MEMORY</b>.",
      "q15": "In the past 4 weeks, have you had any trouble with your memory?",
      "q16_head": "Select <b>how often</b> in the <b>past 4 weeks</b> you have had trouble <i>remembering</i> or <b>how often</b> this memory problem has interfered with your normal work or living.",
      "q16": "Trouble remembering things people tell you",
      "q17_head": "The following questions are about <b>CONCENTRATION</b> problems you may have. Indicate <b>how often</b> in the <b>past 4 weeks</b> you had trouble concentrating or <b>how often</b> these problems interfered with your normal work or living.",
      "q17": "Trouble concentrating on reading",
      "q18": "Trouble concentrating on doing one thing at a time",
      "q19_head": "The following questions are about problems you may have with certain <b>ACTIVITIES</b>. Indicate for <b>how much</b> during the <b>past 4 weeks</b> your epilepsy or antiepileptic medication has caused trouble with...",
      "q19": "Leisure time (such as hobbies, going out)",
      "q20": "Driving",
      "q21_head": "The following questions relate to the way you <b>FEEL</b> about your <b>seizures</b>.",
      "q21": "How fearful are you of having a seizure during the next month?",
      "q22": "Do you worry about hurting or injuring yourself during a seizure?",
      "q23": "How worried are you about being embarrassed or having social problems as a result of having a seizure in the next month?",
      "q24": "How worried are you that your epilepsy medications may be bad for you in the long run?",
      "q25_head": "For each of these <b>PROBLEMS</b>, indicate <b>how much they bother you</b>.",
      "q25": "Seizures",
      "q26": "Memory difficulties",
      "q27": "Work limitations",
      "q28": "Social limitations",
      "q29": "Physical effects of antiepileptic medication",
      "q30": "Mental effects of antiepileptic medication",
      "q31": "How good or bad do you think your health is? On the scale below, the best imaginable state of health is 100 and the worst imaginable state is 0. Please indicate how you feel about your health. <b>Please consider your epilepsy as part of your health when you answer this question.</b>",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}