{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Words Can Harm Scale",
      "code": "WCHS",
      "abbreviation": "WCHS",
      "description": "10-item scale measuring the belief that words can cause lasting psychological harm. Items assess attitudes about speech in general and about reading words specifically. Responses on a 1–100 sliding scale (1 = Strongly disagree, 25 = Somewhat disagree, 50 = Neither agree nor disagree, 75 = Somewhat agree, 100 = Strongly agree). Total score is the mean of all 10 items.",
      "citation": "Lovett, B. J., & Bhatt, R. (2025). Words Can Harm Scale (WCHS). PsyArXiv. https://osf.io/gf8j5/overview",
      "license": "CC BY 4.0",
      "license_url": "https://osf.io/gf8j5/overview",
      "version": "1.0",
      "url": "https://osf.io/gf8j5/overview",
      "domain": "Mental Health"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "dimensions": [
      {
        "id": "total",
        "name": "Total WCHS",
        "abbreviation": "TOT",
        "description": "Mean of all 10 items (1–100). Higher scores indicate stronger belief that words can cause lasting psychological harm."
      }
    ],
