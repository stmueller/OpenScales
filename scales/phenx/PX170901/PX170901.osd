      "grp6_opt_1": "Daytime (6am-6pm)",
      "grp6_opt_2": "Night (6:01pm to 5:59am)",
      "grp6_opt_3": "Other",
      "grp6_opt_4": "Unknown",
      "grp7_opt_1": "No",
      "grp7_opt_2": "Yes",
      "grp7_opt_3": "n/a (no hospitalization)",
      "grp7_opt_4": "Unknown",
      "grp8_opt_1": "Fall from standing height or less-includes most injuries due to tripping over something, slips in the shower or bathtub, or falling out of a chair or bed (unless standing on it), in which the participant lands on the surface at the same height as the surface he/she was standing on",
      "grp8_opt_2": "Falls on stairs, steps or curbs-includes all falls during change of level, such as stepping up or down stairs, steps, or curbs",
      "grp8_opt_3": "Fall from more than standing height, but NOT on stairs-includes falls from heights such as off a ladder or while standing on a table or chair, off a porch, out of a window, etc.",
      "grp8_opt_4": "Minimal trauma other than a fall-includes vertebral fractures associated with coughing, stepping down a step, etc., and rib or other fractures associated with turning over in bed, etc.",
      "grp8_opt_5": "Moderate trauma other than a fall-includes collisions with objects during normal activities (e.g. stub toe, hit hand against door frame, walking into door), twisting or turning ankle (or ankle fractures).",
      "grp8_opt_6": "Severe trauma other than a fall-includes motor vehicle accidents, struck by a car, hit by rapidly moving projectile (golf ball, golf club), assault",
      "grp8_opt_7": "Pathologic fracture-usually associated with cancer in bone",
      "grp8_opt_8": "Unknown/Don't know"
