      "recovery_selfassessment_administrator_encouragement_opt_7": "Don't know",
      "recovery_selfassessment_administrator_flexibility": "Program participants can change their clinician or case manager if they wish. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_administrator_flexibility_opt_1": "1",
      "recovery_selfassessment_administrator_flexibility_opt_2": "2",
