  "translations": {
    "en": {
      "likert_1": "Very Rarely or Never",
      "likert_2": "Rarely",
      "likert_3": "Sometimes",
      "likert_4": "Often",
      "likert_5": "Very Often or Always",
      "question_head": "Please think about what you have been doing and experiencing during the past four weeks. Then report how much you experienced each of the following feelings, using the scale below.",
      "spane1": "Positive",
      "spane2": "Negative",
      "spane3": "Good",
      "spane4": "Bad",
      "spane5": "Pleasant",
      "spane6": "Unpleasant",
      "spane7": "Happy",
      "spane8": "Sad",
      "spane9": "Afraid",
      "spane10": "Joyful",
      "spane11": "Angry",
      "spane12": "Contented",
