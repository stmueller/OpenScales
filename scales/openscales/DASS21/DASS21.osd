    "ru": {
      "d1": "Мне было трудно сбросить напряжение",
      "d2": "Я ощущал/а сухость во рту",
      "d3": "Я вообще не испытывал/ла никаких положительных чувств",
      "d4": "Я ощущал/а, что мое дыхание затруднено (напр. чрезвычайно быстрое дыхание, одышка в отсутствие физических нагрузок)",
      "d5": "Мне было трудно заставить себя сделать что-либо.",
      "d6": "Я был склонен/на слишком сильно реагировать на ситуацию",
      "d7": "Я ощущал/а тремор (напр. в руках)",
      "d8": "Я чувствовал/ла, что трачу слишком много нервной энергии",
      "d9": "Меня беспокоили ситуации, в которых я могу поддаться панике и вести себя глупо.",
      "d10": "Я чувствовал/а, что у меня нет ничего впереди",
      "d11": "Я чувствовал/а растущее волнение.",
      "d12": "Мне было трудно расслабиться",
      "d13": "Я чувствовал/а упадок духа и меланхолию",
      "d14": "Я нетерпимо относился/лась ко всему, что мешало мне заниматься тем, что я делаю",
      "d15": "Я ощущал/а, что я близок/ка к панике",
      "d16": "Я не в состоянии проявлять энтузиазм по отношению к чему-либо",
      "d17": "Я чувствовал/а, что немногого стою как личность",
      "d18": "Я чувствовал/а, что был/а весьма раздражителен/льна",
      "d19": "Я замечал/а, что происходит с моим сердцем без всяких физических нагрузок (напр. ощущение усиливающегося сердцебиения или пропущенного удара)",
      "d20": "Я ощущал/а беспричинный страх",
      "d21": "Я чувствовал/а, что жизнь бессмысленна",
      "debrief": ""
    },
    "sk": {
      "likert_1": "1    2   3",
      "likert_2": "- Platí to pre mňa čiastočne, niekedy",
      "likert_3": "- Platí to pre mňa do značnej miery alebo značnú časť času",
      "likert_4": "- Platí to pre mňa úplne alebo väčšinu času",
      "d1": "Nahnevali ma triviálne veci.",
      "d2": "Pociťoval som sucho v ústach.",
      "d3": "Neprežíval som žiadne pozitívne pocity.",
      "d4": "Mal som problém s dýchaním (napr. dýchal som veľmi rýchlo alebo som lapal po",
      "d5": "Nemal som síl pokračovať.",
      "d6": "V určitých situáciách som reagoval prehnane.",
      "d7": "Mal som pocit, že sa trasiem (napr. nohy, kolená apod.).",
      "d8": "Bolo pre mňa ťažké relaxovať.",
      "d9": "Ocitol som sa v situáciách, v ktorých som cítil takú úzkosť, že mi odľahlo, keď",
      "d10": "Mal som pocit, že neexistuje nič, na čo by som sa tešil.",
      "d11": "Zistil som, že sa dosť rýchlo nahnevám.",
      "d12": "Cítil som sa veľmi nervózne a musel som s tým niečo urobiť.",
      "d13": "Cítil som sa smutný a depresívny.",
      "d14": "Bol som nepokojný, keď som kdekoľvek meškal (kvôli výťahu, premávke, keď som",
      "d15": "Mal som pocit, že omdliem.",
      "d16": "Mal som pocit, že som stratil záujem o všetko.",
      "d17": "Mal som pocit, že ako človek za veľa nestojím.",
      "d18": "Cítil som, že reagujem precitlivelo.",
      "d19": "Potil som sa, aj keď nebolo teplo a nevykonával som fyzickú aktivitu (napr. dlane).",
      "d20": "Bál som sa aj bez zjavného dôvodu.",
      "d21": "Cítil som, že život nemá zmysel.",
      "debrief": ""
    },
    "sl": {
      "d1": "Opazil sem, da so me vznemirile čisto nepomembne reči.",
      "d2": "Opazil sem, da imam suha usta.",
      "d3": "Zdelo se mi je, da sploh ne morem biti dobro razpoložen.",
      "d4": "Ne da bi se posebej naprezal, sem imel težave z dihanjem (izjemno",
      "d5": "Nisem mogel normalno funkcionirati.",
      "d6": "Pretirano sem reagiral na situacije.",
      "d7": "Imel sem občutek slabotnosti (npr. popustile so mi noge).",
      "d8": "Težko sem se sprostil.",
      "d9": "Znašel sem se v situacijah, ki so bile tako mučne, da sem čutil veliko",
      "d10": "Zdelo se mi je, da se nimam česa veseliti.",
      "d11": "Opazil sem, da se hitro razburim.",
      "d12": "Imel sem občutek da sem precej nervozen.",
      "d13": "Počutil sem se potrto in depresivno.",
      "d14": "Opazil sem, da postanem nepotrpežljiv, ko sem kakorkoli zapravljal",
      "d15": "Imel sem vrtoglavice.",
      "d16": "Zdelo se mi je, da me sploh nobena stvar več ne zanima.",
      "d17": "Počutil sem se, da kot oseba nisem veliko vreden.",
      "d18": "Zdelo se mi je da sem precej občutljiv.",
      "d19": "Opazno sem se potil (npr. potne roke) brez fizičnega napora ali visokih",
      "d20": "Strah me je bilo brez utemeljenega razloga.",
      "d21": "Mislil sem, da ni vredno živeti.",
      "debrief": ""
    },
    "sq": {
      "likert_1": "Aspak nuk Pajtohem",
      "likert_2": "Nuk Pajtohem",
      "likert_3": "Pajtohem",
      "likert_4": "Gjithsesi Pajtohem",
      "d1": "E kam vështir të relaksohem",
      "d2": "Goja më thahet",
      "d3": "Nuk kam përjetu ndjenjat pozitive",
      "d4": "Kam vështërsi në frymemarje (p.sh; edhe pse nuk bëjë ushtrime fizike, veshtërsi në frymarje apo ritëm të shpejt në zemer kam)",
      "d5": "Punët që dua të bëjë, e kam të vështir tija fillojë",
      "d6": "Reagojë shpejt ndaj ngjarjeve",
      "d7": "Ndjej dridhje në trupe (p.sh; dridhja e duarve)",
      "d8": "Ndjej se shum energji hargjoj si skak i nervozës",
      "d9": "Shqetësohem për shkak të situatave ku mund të dukem qesharak dhe të më kaplojë paniku",
      "d10": "Nuk pres asgjë dhe nuk shpresojë azgjë",
      "d11": "Bie shpejt në provokime",
      "d12": "Kam vështërsi të relaksohem",
      "d13": "Ndjehem i trishtuar dhe i len pas dore",
      "d14": "Nuk toleroj pengesa në punë",
      "d15": "Mua më kapë paniku shum leht",
      "d16": "Unë nuk jam entuziast dhe i gëzuar për të bërë diçka",
      "d17": "E ndjej vetën si njeri i pa vlefshëm",
      "d18": "Jam tepër i ndjeshëm dhe prekem shpejt",
      "d19": "Pa asnjë aktivitet fizik ndjej ritme të shpejta të rrahjes së zemrës (p.sh; rrahjet të forta të zemrës dhe të ndyshueshme)",
      "d20": "Friksohem pa ndonjë arsye",
      "d21": "Ndjej se jeta nuk ka kuptim, nuk ja vlen të jetohet",
      "debrief": ""
    },
    "sr": {
      "likert_1": "Ni malo",
      "likert_2": "Pomalo ili ponekad",
      "likert_3": "U priličnoj meri ili često",
      "likert_4": "Uglavnom ili skoro uvek",
      "d1": "Bilo mi je teško da se smirim.",
      "d2": "Primetio/la sam da mi se suše usta",
      "d3": "Nisam imao/la nikakvo lepo osećanje",
      "d4": "Imao/la sam poteškoća sa disanjem (recimo, osetio/la sam ubrzano disanje",
      "d5": "Primetio sam da mi je teško da ostvarim inicijativu i započnem bilo šta.",
      "d6": "Preterano reagujem u nekim situacijama.",
      "d7": "Osetio/la sam da se tresem (napr. tresle su mi se ruke).",
      "d8": "Primetio/la sam da koristim dosta “nervozne energije” .",
      "d9": "Bojao/la sam se situacija u kojima bih mogao/la da se uspanicim i",
      "d10": "Osećao/la sam da nemam čemu da se nadam.",
      "d11": "Primetio sam da se nerviram.",
      "d12": "Teško mi je da se opustim.",
      "d13": "Osećao/la sam se tužno i jadno.",
      "d14": "Nerviralo me je kada me nešto prekida u onome što radim",
      "d15": "Osećao/la sam da sam blizu panike.",
      "d16": "Ništa nije moglo da me zainteresuje",
      "d17": "Osećao/la sam se da kao osoba ne vredim mnogo.",
      "d18": "Bio/la sam jako osetljiv.",
      "d19": "Osetio/la sam rad srca iako se nisam fizički zamorio/la (napr. lupanje srca,",
      "d20": "Osećao/la sam se uplašeno bez razloga.",
      "d21": "Osećao sam da je život besmislen.",
      "debrief": ""
    },
    "sv": {
      "likert_1": "Stämde inte alls in på mig",
      "likert_2": "Stämde in på mig till viss del, eller viss del av tiden",
      "likert_3": "Stämde in på mig i ganska hög grad, eller stor del av tiden",
      "likert_4": "Stämde in på mig i mycket hög grad, eller nästan hela tiden",
      "d1": "Jag hade svårt att varva ner",
      "d2": "Jag kände mig torr i munnen",
      "d3": "Jag verkade inte kunna känna några positiva känslor alls",
      "d4": "Jag hade andningsproblem (t.ex. snabb andning, andfåddhet utan kroppsansträngning)",
      "d5": "Jag hade svårt att komma igång med saker",
      "d6": "Jag hade en tendens att överreagera i olika situationer",
      "d7": "Jag darrade/skakade (t.ex. i händerna)",
      "d8": "Jag kände att jag gjorde av med energi på att oroa mig",
      "d9": "Jag oroade mig över situationer där jag kanske skulle gripas av panik och göra bort mig",
      "d10": "Jag tyckte att jag inte hade någonting att se fram emot",
      "d11": "Jag kände att jag blev upprörd",
      "d12": "Jag hade svårt att slappna av",
      "d13": "Jag kände mig nedstämd och deppig",
      "d14": "Jag blev irriterad på allt som avbröt mig i det jag höll på med",
      "d15": "Jag kände att jag var nära att gripas av panik",
      "d16": "Jag kunde inte känna mig entusiastisk över någonting",
      "d17": "Jag kände att jag inte var värd någonting som människa",
      "d18": "Jag var ganska lättstött",
      "d19": "Jag kände av mitt hjärta trots att jag inte ansträngde mig fysiskt (t.ex. att hjärtat slog snabbare eller hoppade över ett slag)",
      "d20": "Jag kände mig rädd utan någon verklig anledning",
      "d21": "Jag tyckte att livet var meningslöst",
      "debrief": ""
    },
