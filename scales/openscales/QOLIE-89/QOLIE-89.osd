      "qolie89_act2": "A lot",
      "qolie89_act3": "Somewhat",
      "qolie89_act4": "Only a little",
      "qolie89_act5": "Not at all",
      "qolie89_q65": "Working",
      "qolie89_q66": "Friendships and relationships (romantic)",
      "qolie89_q67": "Leisure time (such as hobbies, going out)",
      "qolie89_q68": "Driving",
