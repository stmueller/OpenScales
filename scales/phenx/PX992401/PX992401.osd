      "comorbidities_covid_impact_pre_existing_condition_opt_18": "Other GI issues",
      "comorbidities_covid_impact_pre_existing_condition_opt_19": "Asthma",
      "comorbidities_covid_impact_pre_existing_condition_opt_20": "COPD",
      "comorbidities_covid_impact_pre_existing_condition_opt_21": "Tuberculosis",
      "comorbidities_covid_impact_pre_existing_condition_opt_22": "Eczema",
      "comorbidities_covid_impact_pre_existing_condition_opt_23": "Viral skin conditions (cold sores, herpes, warts, molluscum)",
      "comorbidities_covid_impact_pre_existing_condition_opt_24": "Dementia",
