  "translations": {
    "en": {
      "info_220704": "The Newcastle Mitochondrial Disease Adult Scale (NMDAS)",
      "mitochondrial_disease_adult_name": "Full Name",
      "mitochondrial_disease_adult_dob": "Date of Birth",
      "mitochondrial_disease_adult_date": "Today's Date",
      "mitochondrial_disease_adult_height": "Height",
      "mitochondrial_disease_adult_fvc1": "Forced Vital Capacity - 1st attempt",
      "mitochondrial_disease_adult_fvc2": "Forced Vital Capacity - 2nd attempt",
      "mitochondrial_disease_adult_fvc3": "Forced Vital Capacity - 3rd attempt",
      "section_i_220704": "Section I- Current FunctionRate function over the preceding 4 week period, according to patient and/or caregiver interview only. The clinician's subjective judgement of functional ability should not be taken into account.",
      "mitochondrial_disease_adult_current_vision": "Rate function over the preceding 4 week period, according to patient and/or caregiver interview only.  - Vision usual glasses or contact lenses",
      "mitochondrial_disease_adult_current_vision_opt_1": "0. Normal",
      "mitochondrial_disease_adult_current_vision_opt_2": "1. No functional impairment but aware of worsened acuities.",
      "mitochondrial_disease_adult_current_vision_opt_3": "2. Mild - difficulty with small print or text on television.",
      "mitochondrial_disease_adult_current_vision_opt_4": "3. Moderate - difficulty outside the home (eg bus numbers, road signs or  shopping).",
      "mitochondrial_disease_adult_current_vision_opt_5": "4. Severe - difficulty recognising faces.",
      "mitochondrial_disease_adult_current_vision_opt_6": "5. Unable to navigate without help (eg carer, dog, cane).",
      "mitochondrial_disease_adult_current_hearing": "Rate function over the preceding 4 week period, according to patient and/or caregiver interview only.  - Hearing with or without hearing aid",
      "mitochondrial_disease_adult_current_hearing_opt_1": "0. Normal",
      "mitochondrial_disease_adult_current_hearing_opt_2": "1. No communication problems but aware of tinnitus or deterioration from prior 'normal hearing.",
      "mitochondrial_disease_adult_current_hearing_opt_3": "2. Mild deafness (eg missing words in presence of background noise). Fully corrected with hearing aid.",
      "mitochondrial_disease_adult_current_hearing_opt_4": "3. Moderate deafness (eg regularly requiring repetition). Not fully corrected with hearing aid.",
      "mitochondrial_disease_adult_current_hearing_opt_5": "4. Severe deafness - poor hearing even with aid (see 3 above).",
      "mitochondrial_disease_adult_current_hearing_opt_6": "5. End stage - virtually no hearing despite aid. Relies heavily on non-verbal communication (eg lip reading) or has cochlear implant",
      "mitochondrial_disease_adult_current_speech": "Rate function over the preceding 4 week period, according to patient and/or caregiver interview only.  - Speech",
      "mitochondrial_disease_adult_current_speech_opt_1": "0. Normal",
      "mitochondrial_disease_adult_current_speech_opt_2": "1. Communication unaffected but patient or others aware of changes in speech patterns or quality.",
      "mitochondrial_disease_adult_current_speech_opt_3": "2. Mild difficulties - usually understood and rarely asked to repeat things",
      "mitochondrial_disease_adult_current_speech_opt_4": "3. Moderate difficulties - poorly understood by strangers and frequently asked to repeat things.",
      "mitochondrial_disease_adult_current_speech_opt_5": "4. Severe difficulties - poorly understood by family or friends.",
      "mitochondrial_disease_adult_current_speech_opt_6": "5. Not understood by family or friends. Requires communication aid.",
      "mitochondrial_disease_adult_current_swallowing": "Rate function over the preceding 4 week period, according to patient and/or caregiver interview only.  - Swallowing",
      "mitochondrial_disease_adult_current_swallowing_opt_1": "0. Normal",
      "mitochondrial_disease_adult_current_swallowing_opt_2": "1. Mild - sensation of solids 'sticking' (occasional).",
      "mitochondrial_disease_adult_current_swallowing_opt_3": "2. Sensation of solids 'sticking' (most meals) or need to modify diet (eg    avoidance of steak/salad).",
      "mitochondrial_disease_adult_current_swallowing_opt_4": "3. Difficulty swallowing solids - affecting meal size or duration. Coughing,  choking or nasal regurgitation infrequent (1 to 4 times per month) but more than peers.",
      "mitochondrial_disease_adult_current_swallowing_opt_5": "4. Requires adapted diet - regular coughing, choking, or nasal regurgitation  (more than once per week).",
      "mitochondrial_disease_adult_current_swallowing_opt_6": "5. Requiring enteral feeding (eg PEG).",
      "mitochondrial_disease_adult_currenthandwriting": "Rate function over the preceding 4 week period, according to patient and/or caregiver interview only.  - Handwriting",
      "mitochondrial_disease_adult_currenthandwriting_opt_1": "0. Normal",
      "mitochondrial_disease_adult_currenthandwriting_opt_2": "1. Writing speed unaffected but aware of increasing untidiness.",
      "mitochondrial_disease_adult_currenthandwriting_opt_3": "2. Mild - Has to write slower to maintain tidiness/legibility.",
      "mitochondrial_disease_adult_currenthandwriting_opt_4": "3. Moderate - Handwriting takes at least twice as long or resorts to printing (must previously have used joined writing).",
      "mitochondrial_disease_adult_currenthandwriting_opt_5": "4. Severe - Handwriting mostly illegible. Printing very slow and untidy (eg 'THE BLACK CAT' takes in excess of 30 seconds).",
      "mitochondrial_disease_adult_currenthandwriting_opt_6": "5. Unable to write. No legible words.",
      "mitochondrial_disease_adult_current_cuttingfood": "Rate function over the preceding 4 week period, according to patient and/or caregiver interview only.  - Cutting food and handling utensils (irrespective of contributory factors - eg weakness, coordination, cognitive function etc. This is also true for questions 7-10)",
      "mitochondrial_disease_adult_current_cuttingfood_opt_1": "0. Normal",
      "mitochondrial_disease_adult_current_cuttingfood_opt_2": "1. Slightly slow and/or clumsy but minimal effect on meal duration.",
      "mitochondrial_disease_adult_current_cuttingfood_opt_3": "2. Slow and/or clumsy with extended meal duration, but no help required",
      "mitochondrial_disease_adult_current_cuttingfood_opt_4": "3. Difficulty cutting up food and inaccuracy of transfer pronounced. Can manage alone but avoids problem foods (eg peas) or carer typically offers minor assistance (eg cutting up steak).",
      "mitochondrial_disease_adult_current_cuttingfood_opt_5": "4. Unable to cut up food. Can pass food to mouth with great effort or inaccuracy. Resultant intake minimal. Requires major assistance.",
      "mitochondrial_disease_adult_current_cuttingfood_opt_6": "5. Needs to be fed.",
      "mitochondrial_disease_adult_current_dressing": "Rate function over the preceding 4 week period, according to patient and/or caregiver interview only.  - Dressing",
      "mitochondrial_disease_adult_current_dressing_opt_1": "0. Normal",
      "mitochondrial_disease_adult_current_dressing_opt_2": "1. Occasional difficulties (eg shoe laces, buttons etc) but no real impact on time or effort taken to dress.",
      "mitochondrial_disease_adult_current_dressing_opt_3": "2. Mild - Dressing takes longer and requires more effort than expected at the patient's age. No help required.",
      "mitochondrial_disease_adult_current_dressing_opt_4": "3. Moderate - Can dress unaided but takes at least twice as long and is a major effort. Carer typically helps with difficult tasks such as shoe laces or buttons.",
      "mitochondrial_disease_adult_current_dressing_opt_5": "4. Severe - Unable to dress without help but some tasks completed unaided.",
      "mitochondrial_disease_adult_current_dressing_opt_6": "5. Needs to be dressed.",
      "mitochondrial_disease_adult_current_hygiene": "Rate function over the preceding 4 week period, according to patient and/or caregiver interview only.  - Hygiene",
      "mitochondrial_disease_adult_current_hygiene_opt_1": "0. Normal",
      "mitochondrial_disease_adult_current_hygiene_opt_2": "1. Occasional difficulties only but no real impact on time or effort required.",
      "mitochondrial_disease_adult_current_hygiene_opt_3": "2. Mild - hygienic care takes longer but quality unaffected.",
      "mitochondrial_disease_adult_current_hygiene_opt_4": "3. Moderate - bathes and showers alone with difficulty or needs bath chair / modifications. Dextrous tasks (eg brushing teeth, combing hair) performed poorly.",
      "mitochondrial_disease_adult_current_hygiene_opt_5": "4. Severe - unable to bathe or shower without help. Major difficulty using toilet alone. Dextrous tasks require help.",
      "mitochondrial_disease_adult_current_hygiene_opt_6": "5. Dependent upon carers to wash, bathe, and toilet.",
      "mitochondrial_disease_adult_current_exercisetolerance": "Rate function over the preceding 4 week period, according to patient and/or caregiver interview only.  - Exercise Tolerance",
      "mitochondrial_disease_adult_current_exercisetolerance_opt_1": "0. Normal",
      "mitochondrial_disease_adult_current_exercisetolerance_opt_2": "1. Unlimited on flat - symptomatic on inclines or stairs.",
      "mitochondrial_disease_adult_current_exercisetolerance_opt_3": "2. Able to walk < 1000m on the flat. Restricted on inclines or stairs - rest needed after 1 flight (12 steps).",
      "mitochondrial_disease_adult_current_exercisetolerance_opt_4": "3. Able to walk < 500m on the flat. Rest needed after 8 steps on stairs.",
      "mitochondrial_disease_adult_current_exercisetolerance_opt_5": "4. Able to walk < 100m on the flat. Rest needed after 4 steps on stairs.",
      "mitochondrial_disease_adult_current_exercisetolerance_opt_6": "5. Able to walk < 25m on the flat. Unable to do stairs alone.",
      "mitochondrial_disease_adult_current_gaitstability": "Rate function over the preceding 4 week period, according to patient and/or caregiver interview only.  - Gait Stability",
      "mitochondrial_disease_adult_current_gaitstability_opt_1": "0. Normal",
      "mitochondrial_disease_adult_current_gaitstability_opt_2": "1. Normal gait - occasional difficulties on turns, uneven ground, or if required to balance on narrow base.",
      "mitochondrial_disease_adult_current_gaitstability_opt_3": "2. Gait reasonably steady. Aware of impaired balance. Occasionally off balance when walking.",
      "mitochondrial_disease_adult_current_gaitstability_opt_4": "3. Unsteady gait. Always off balance when walking. Occasional falls. Gait steady with support of stick or person.",
      "mitochondrial_disease_adult_current_gaitstability_opt_5": "4. Gait grossly unsteady without support. High likelihood of falls. Can only walk short distances (< 10m) without support.",
      "mitochondrial_disease_adult_current_gaitstability_opt_6": "5. Unable to walk without support. Falls on standing.",
      "section_ii_220704": "Section II - System Specific InvolvementRate function according to patient and/or caregiver interview and consultation with the medical notes. Each inquiry should take into account the situation for the preceding 12 month period only, unless otherwise stated in the question.",
      "mitochondrial_disease_adult_system_psychiatric": "System Specific Inviolvment - Each inquiry should take into account the situation for the preceding 12 month period only, unless otherwise stated in the question. - Psychiatric",
      "mitochondrial_disease_adult_system_psychiatric_opt_1": "0. None",
      "mitochondrial_disease_adult_system_psychiatric_opt_2": "1. Mild & transient (eg reactive depression) - lasting less than 3 months.",
      "mitochondrial_disease_adult_system_psychiatric_opt_3": "2. Mild & persistent (lasting more than 3 months) or recurrent. Patient has consulted GP.",
      "mitochondrial_disease_adult_system_psychiatric_opt_4": "3. Moderate & warranting specialist treatment (e.g. from a psychiatrist) - eg. bipolar disorder or depression with vegetative symptoms (insomnia, anorexia, abulia etc).",
      "mitochondrial_disease_adult_system_psychiatric_opt_5": "4. Severe (eg self harm - psychosis etc).",
      "mitochondrial_disease_adult_system_psychiatric_opt_6": "5. Institutionalised or suicide attempt.",
      "mitochondrial_disease_adult_system_migraine": "System Specific Inviolvment - Each inquiry should take into account the situation for the preceding 12 month period only, unless otherwise stated in the question. - Migraine Headaches During the last 3 months, how many days have headaches prevented the patient from functioning normally at school, work, or in the home?",
      "mitochondrial_disease_adult_system_migraine_opt_1": "0. No past history.",
      "mitochondrial_disease_adult_system_migraine_opt_2": "1. Asymptomatic but past history of migraines.",
      "mitochondrial_disease_adult_system_migraine_opt_3": "2. One day per month.",
      "mitochondrial_disease_adult_system_migraine_opt_4": "3. Two days per month.",
      "mitochondrial_disease_adult_system_migraine_opt_5": "4. Three days per month.",
      "mitochondrial_disease_adult_system_migraine_opt_6": "5. Four days per month or more.",
      "mitochondrial_disease_adult_system_seizures": "System Specific Inviolvment - Each inquiry should take into account the situation for the preceding 12 month period only, unless otherwise stated in the question. - Seizures",
      "mitochondrial_disease_adult_system_seizures_opt_1": "0. No past history.",
      "mitochondrial_disease_adult_system_seizures_opt_2": "1. Asymptomatic but past history of epilepsy.",
      "mitochondrial_disease_adult_system_seizures_opt_3": "2. Myoclonic or simple partial seizures only.",
      "mitochondrial_disease_adult_system_seizures_opt_4": "3. Multiple absence, complex partial, or myoclonic seizures affecting function or single generalized seizure.",
      "mitochondrial_disease_adult_system_seizures_opt_5": "4. Multiple generalised seizures.",
      "mitochondrial_disease_adult_system_seizures_opt_6": "5. Status epilepticus.",
      "mitochondrial_disease_adult_system_strokeepisodes": "System Specific Inviolvment - Each inquiry should take into account the situation for the preceding 12 month period only, unless otherwise stated in the question. - Stroke-like episodes (exclude focal deficits felt to be of vascular aetiology)",
      "mitochondrial_disease_adult_system_strokeepisodes_opt_1": "0. None.",
      "mitochondrial_disease_adult_system_strokeepisodes_opt_2": "1. Transient focal sensory symptoms only (less than 24 hours).",
      "mitochondrial_disease_adult_system_strokeepisodes_opt_3": "2. Transient focal motor symptoms only (less than 24 hours).",
      "mitochondrial_disease_adult_system_strokeepisodes_opt_4": "3. Single stroke-like episode affecting one hemisphere (more than 24 hours).",
      "mitochondrial_disease_adult_system_strokeepisodes_opt_5": "4. Single stroke-like episode affecting both hemispheres (more than 24 hours).",
      "mitochondrial_disease_adult_system_strokeepisodes_opt_6": "5. Multiple stroke-like episodes (more than 24 hours each).",
      "mitochondrial_disease_adult_system_encephalopathic": "System Specific Inviolvment - Each inquiry should take into account the situation for the preceding 12 month period only, unless otherwise stated in the question. - Encephalopathic Episodes",
      "mitochondrial_disease_adult_system_encephalopathic_opt_1": "0. No past history.",
      "mitochondrial_disease_adult_system_encephalopathic_opt_2": "1. Asymptomatic but past history of encephalopathy.",
      "mitochondrial_disease_adult_system_encephalopathic_opt_3": "2. Mild - single episode of personality or behavioural change but retaining orientation in time/place/person.",
      "mitochondrial_disease_adult_system_encephalopathic_opt_4": "3. Moderate - single episode of confusion or disorientation in time, place or person.",
      "mitochondrial_disease_adult_system_encephalopathic_opt_5": "4. Severe - multiple moderate episodes (as above) or emergency hospital admission due to encephalopathy without associated seizures or stroke-like episodes.",
      "mitochondrial_disease_adult_system_encephalopathic_opt_6": "5. Very severe - in association with seizures, strokes or gross lactic acidaemia.",
      "mitochondrial_disease_adult_system_gastro": "System Specific Inviolvment - Each inquiry should take into account the situation for the preceding 12 month period only, unless otherwise stated in the question. - Gastro-intestinal symptoms",
      "mitochondrial_disease_adult_system_gastro_opt_1": "0. None.",
      "mitochondrial_disease_adult_system_gastro_opt_2": "1. Mild constipation only or past history of bowel resection for dysmotility.",
      "mitochondrial_disease_adult_system_gastro_opt_3": "2. Occasional symptoms of 'irritable bowel' (pain, bloating or diarrhoea) with long spells of normality.",
      "mitochondrial_disease_adult_system_gastro_opt_4": "3. Frequent symptoms (as above) most weeks or severe constipation with bowels open less than once/week or need for daily medications.",
      "mitochondrial_disease_adult_system_gastro_opt_5": "4. Dysmotility requiring admission or persistent and/or recurrent anorexia/vomiting/weight loss.",
      "mitochondrial_disease_adult_system_gastro_opt_6": "5. Surgical procedures or resections for gastrointestinal dysmotility.",
      "mitochondrial_disease_adult_system_diabetes": "System Specific Inviolvment - Each inquiry should take into account the situation for the preceding 12 month period only, unless otherwise stated in the question. - Diabetes mellitus",
      "mitochondrial_disease_adult_system_diabetes_opt_1": "0. None.",
      "mitochondrial_disease_adult_system_diabetes_opt_2": "1. Past history of gestational diabetes or transient glucose intolerance related to intercurrent illness.",
      "mitochondrial_disease_adult_system_diabetes_opt_3": "2. Impaired glucose tolerance (in absence of intercurrent illness).",
      "mitochondrial_disease_adult_system_diabetes_opt_4": "3. NIDDM (diet).",
      "mitochondrial_disease_adult_system_diabetes_opt_5": "4. NIDDM (tablets).",
      "mitochondrial_disease_adult_system_diabetes_opt_6": "5. DM requiring insulin (irrespective of treatment at onset).",
      "mitochondrial_disease_adult_system_respiratorymuscle_weakness": "System Specific Inviolvment - Each inquiry should take into account the situation for the preceding 12 month period only, unless otherwise stated in the question. - Respiratory muscle weakness",
      "mitochondrial_disease_adult_system_respiratorymuscle_weakness_opt_1": "0. FVC normal (>= 85% predicted).",
      "mitochondrial_disease_adult_system_respiratorymuscle_weakness_opt_2": "1. FVC < 85% predicted.",
      "mitochondrial_disease_adult_system_respiratorymuscle_weakness_opt_3": "2. FVC < 75% predicted.",
      "mitochondrial_disease_adult_system_respiratorymuscle_weakness_opt_4": "3. FVC < 65% predicted.",
      "mitochondrial_disease_adult_system_respiratorymuscle_weakness_opt_5": "4. FVC < 55% predicted.",
      "mitochondrial_disease_adult_system_respiratorymuscle_weakness_opt_6": "5. FVC < 45% predicted or ventilator support for over 6 hours per 24 hr period (not for OSA alone).",
      "mitochondrial_disease_adult_system_cardiovascular": "System Specific Inviolvment - Each inquiry should take into account the situation for the preceding 12 month period only, unless otherwise stated in the question. - Cardiovascular system",
      "mitochondrial_disease_adult_system_cardiovascular_opt_1": "0. None.",
      "mitochondrial_disease_adult_system_cardiovascular_opt_2": "1. Asymptomatic ECG change.",
      "mitochondrial_disease_adult_system_cardiovascular_opt_3": "2. Asymptomatic LVH on echo or non-sustained brady/tachyarrhythmia on ECG.",
      "mitochondrial_disease_adult_system_cardiovascular_opt_4": "3. Sustained or symptomatic arrhythmia, LVH or cardiomyopathy. Dilated chambers or reduced function on echo. Mobitz II AV block or greater.",
      "mitochondrial_disease_adult_system_cardiovascular_opt_5": "4. Requires pacemaker, defibrillator, arrhythmia ablation, or LVEF < 35% on echocardiogram.",
      "mitochondrial_disease_adult_system_cardiovascular_opt_6": "5. Symptoms of left ventricular failure with clinical and/or x-ray evidence of pulmonary oedema or LVEF < 30% on echocardiogram.",
      "section_iii_220704": "Section III - Current Clinical AssessmentRate current status according to examination performed at the time of assessment",
      "mitochondrial_disease_adult_currentclinical_visualacuity": "Rate current status according to examination performed at the time of assessment.  Visual acuity with usual glasses, contact lenses or pinhole.",
      "mitochondrial_disease_adult_currentclinical_visualacuity_opt_1": "0. CSD >= 12           (ie normal vision - 6/6, 6/6 or better).",
      "mitochondrial_disease_adult_currentclinical_visualacuity_opt_2": "1. CSD >= 18           (eg 6/9, 6/9).",
      "mitochondrial_disease_adult_currentclinical_visualacuity_opt_3": "2. CSD >= 36           (eg 6/12, 6/24).",
      "mitochondrial_disease_adult_currentclinical_visualacuity_opt_4": "3. CSD >= 60           (eg 6/24, 6/36).",
      "mitochondrial_disease_adult_currentclinical_visualacuity_opt_5": "4. CSD >= 96           (eg 6/60, 6/36).",
      "mitochondrial_disease_adult_currentclinical_visualacuity_opt_6": "5. CSD >= 120         (eg 6/60, 6/60 or worse).",
      "mitochondrial_disease_adult_currentclinical_ptosis": "Rate current status according to examination performed at the time of assessment. Ptosis",
      "mitochondrial_disease_adult_currentclinical_ptosis_opt_1": "0. None.",
      "mitochondrial_disease_adult_currentclinical_ptosis_opt_2": "1. Mild ptosis - not obscuring either pupil.",
      "mitochondrial_disease_adult_currentclinical_ptosis_opt_3": "2. Unilateral ptosis obscuring < 1/3 of pupil.",
      "mitochondrial_disease_adult_currentclinical_ptosis_opt_4": "3. Bilateral ptosis obscuring < 1/3 or unilateral ptosis obscuring > 1/3 of pupil or prior unilateral surgery.",
      "mitochondrial_disease_adult_currentclinical_ptosis_opt_5": "4. Bilateral ptosis obscuring > 1/3 of pupils or prior bilateral surgery.",
      "mitochondrial_disease_adult_currentclinical_ptosis_opt_6": "5. Bilateral ptosis obscuring >2/3 of pupils or >1/3 of pupils despite prior bilateral surgery.",
      "mitochondrial_disease_adult_currentclinical_cpeo": "Rate current status according to examination performed at the time of assessment. Chronic Progressive External Ophthalmoplegia",
      "mitochondrial_disease_adult_currentclinical_cpeo_opt_1": "0. None.",
      "mitochondrial_disease_adult_currentclinical_cpeo_opt_2": "1. Some restriction of eye movement (any direction). Abduction complete.",
      "mitochondrial_disease_adult_currentclinical_cpeo_opt_3": "2. Abduction of worst eye incomplete.",
      "mitochondrial_disease_adult_currentclinical_cpeo_opt_4": "3. Abduction of worst eye below 60% of normal.",
      "mitochondrial_disease_adult_currentclinical_cpeo_opt_5": "4. Abduction of worst eye below 30% of normal.",
      "mitochondrial_disease_adult_currentclinical_cpeo_opt_6": "5. Abduction of worst eye minimal (flicker).",
      "mitochondrial_disease_adult_currentclinical_dystoniadysarthria": "Rate current status according to examination performed at the time of assessment. Dysphonia/Dysarthria",
      "mitochondrial_disease_adult_currentclinical_dystoniadysarthria_opt_1": "0. None.",
      "mitochondrial_disease_adult_currentclinical_dystoniadysarthria_opt_2": "1. Minimal - noted on examination only.",
      "mitochondrial_disease_adult_currentclinical_dystoniadysarthria_opt_3": "2. Mild - clear impairment but easily understood.",
      "mitochondrial_disease_adult_currentclinical_dystoniadysarthria_opt_4": "3. Moderate - some words poorly understood and infrequent repetition needed.",
      "mitochondrial_disease_adult_currentclinical_dystoniadysarthria_opt_5": "4. Severe - many words poorly understood and frequent repetition needed.",
      "mitochondrial_disease_adult_currentclinical_dystoniadysarthria_opt_6": "5. Not understood. Requires communication aid.",
      "mitochondrial_disease_adult_currentclinical_myopathy": "Rate current status according to examination performed at the time of assessment.  Myopathy",
      "mitochondrial_disease_adult_currentclinical_myopathy_opt_1": "0. Normal.",
      "mitochondrial_disease_adult_currentclinical_myopathy_opt_2": "1. Minimal reduction in hip flexion and/or shoulder abduction only (eg MRC 4+/5).",
      "mitochondrial_disease_adult_currentclinical_myopathy_opt_3": "2. Mild but clear proximal weakness in hip flexion and shoulder abduction (MRC 4/5). Minimal weakness in elbow flexion and knee extension (MRC 4+/5 - both examined with joint at 90 degrees).",
      "mitochondrial_disease_adult_currentclinical_myopathy_opt_4": "3. Moderate proximal weakness including elbow flexion & knee extension (MRC 4/5 or 4 -/5) or difficulty rising from a 90 degree squat.",
      "mitochondrial_disease_adult_currentclinical_myopathy_opt_5": "4. Waddling gait. Unable to rise from a 90 degree squat ,a chair unaided.",
      "mitochondrial_disease_adult_currentclinical_myopathy_opt_6": "5. Wheelchair dependent primarily due to proximal weakness.",
      "mitochondrial_disease_adult_currentclinical_cerebellarataxia": "Rate current status according to examination performed at the time of assessment.  Cerebellar ataxia",
      "mitochondrial_disease_adult_currentclinical_cerebellarataxia_opt_1": "0. None.",
      "mitochondrial_disease_adult_currentclinical_cerebellarataxia_opt_2": "1. Normal gait but hesitant heel-toe.",
      "mitochondrial_disease_adult_currentclinical_cerebellarataxia_opt_3": "2. Gait reasonably steady. Unable to maintain heel-toe walking or mild UL dysmetria.",
      "mitochondrial_disease_adult_currentclinical_cerebellarataxia_opt_4": "3. Ataxic gait (but walks unaided) or UL intention tremor & past-pointing. Unable to walk heel-toe - falls immediately.",
      "mitochondrial_disease_adult_currentclinical_cerebellarataxia_opt_5": "4. Severe - gait grossly unsteady without support or UL ataxia sufficient to affect feeding.",
      "mitochondrial_disease_adult_currentclinical_cerebellarataxia_opt_6": "5. Wheelchair dependent primarily due to ataxia or UL ataxia prevents feeding.",
      "mitochondrial_disease_adult_currentclinical_neuropathy": "Rate current status according to examination performed at the time of assessment. Neuropathy",
      "mitochondrial_disease_adult_currentclinical_neuropathy_opt_1": "0. None.",
      "mitochondrial_disease_adult_currentclinical_neuropathy_opt_2": "1. Subtle sensory symptoms or areflexia.",
      "mitochondrial_disease_adult_currentclinical_neuropathy_opt_3": "2. Sensory impairment only (eg glove & stocking sensory loss).",
      "mitochondrial_disease_adult_currentclinical_neuropathy_opt_4": "3. Motor impairment (distal weakness) or sensory ataxia.",
      "mitochondrial_disease_adult_currentclinical_neuropathy_opt_5": "4. Sensory ataxia or motor effects severely limit ambulation.",
      "mitochondrial_disease_adult_currentclinical_neuropathy_opt_6": "5. Wheelchair bound primarily due to sensory ataxia or neurogenic weakness.",
      "mitochondrial_disease_adult_currentclinical_pyramidal": "Rate current status according to examination performed at the time of assessment. Pyramidal Involvement",
      "mitochondrial_disease_adult_currentclinical_pyramidal_opt_1": "0. None.",
      "mitochondrial_disease_adult_currentclinical_pyramidal_opt_2": "1. Focal or generalised increase in tone or reflexes only.",
      "mitochondrial_disease_adult_currentclinical_pyramidal_opt_3": "2. Mild focal weakness, sensory loss or fine motor impairment (eg cortical hand).",
      "mitochondrial_disease_adult_currentclinical_pyramidal_opt_4": "3. Moderate hemiplegia allowing unaided ambulation or dense UL monoplegia.",
      "mitochondrial_disease_adult_currentclinical_pyramidal_opt_5": "4. Severe hemiplegia allowing ambulation with aids or moderate tetraplegia (ambulant).",
      "mitochondrial_disease_adult_currentclinical_pyramidal_opt_6": "5. Wheelchair dependant primarily due to hemiplegia or tetraplegia.",
      "mitochondrial_disease_adult_currentclinical_extrapyramidal": "Rate current status according to examination performed at the time of assessment. Extrapyramidal",
      "mitochondrial_disease_adult_currentclinical_extrapyramidal_opt_1": "0. Normal.",
      "mitochondrial_disease_adult_currentclinical_extrapyramidal_opt_2": "1. Mild and unilateral. Not disabling (H&Y stage 1).",
      "mitochondrial_disease_adult_currentclinical_extrapyramidal_opt_3": "2. Mild and bilateral. Minimal disability. Gait affected (H&Y stage 2).",
      "mitochondrial_disease_adult_currentclinical_extrapyramidal_opt_4": "3. Moderate. Significant slowing of body movements (H&Y stage 3)",
      "mitochondrial_disease_adult_currentclinical_extrapyramidal_opt_5": "4. Severe. Rigidity and bradykinesia. Unable to live alone. Can walk to limited extent (H&Y stage 4).",
      "mitochondrial_disease_adult_currentclinical_extrapyramidal_opt_6": "5. Cannot walk or stand unaided. Requires constant nursing care (H&Y stage 5).",
      "mitochondrial_disease_adult_currentclinical_cognition": "Rate current status according to examination performed at the time of assessment.  Cognition",
      "mitochondrial_disease_adult_currentclinical_cognition_opt_1": "0. Combined centiles 100 or more.",
      "mitochondrial_disease_adult_currentclinical_cognition_opt_2": "1. Combined centiles 60 - 99",
      "mitochondrial_disease_adult_currentclinical_cognition_opt_3": "2. Combined centiles 30 - 59",
      "mitochondrial_disease_adult_currentclinical_cognition_opt_4": "3. Combined centiles 15 - 29",
      "mitochondrial_disease_adult_currentclinical_cognition_opt_5": "4. Combined centiles 5 - 14",
      "mitochondrial_disease_adult_currentclinical_cognition_opt_6": "5. Combined centiles 4 or below."
    }
  }
}
