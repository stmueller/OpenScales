{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Personal and Family History of Strabismus",
      "code": "PX111001",
      "abbreviation": "PX111001",
      "description": "A series of self-administered questions to assess family and personal history of strabismus, including history of treatments and surgeries.",
      "domain": "Health",
      "citation": "Engle EC. (2007). Oculomotility disorders arising from disruptions in brainstem motor neuron development. Arch Neurol , 64(5):633-7. Engle EC, Andrews C, Law K, Demer JL. (2007). Two pedigrees segregating Duanes retraction syndrome as a dominant trait map to the DURS2 genetic locus. Invest Ophthalmol Vis Sci , 48(1):189-93. [PhenX: https://www.phenxtoolkit.org/protocols/view/111001]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/111001"
    },
    "implementation": {
