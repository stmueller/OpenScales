  "translations": {
    "en": {
      "likert_1": "Almost never true",
      "likert_2": "Rarely true",
      "likert_3": "Sometimes true",
      "likert_4": "Occasionally true",
      "likert_5": "Often true",
      "likert_6": "Usually true",
      "likert_7": "Almost always true",
      "question_head": "Please indicate how true each statement is for you in your workplace.",
      "debrief": "Thank you for completing the Multidimensional Workplace Compassion Scale.",
      "mwcs1": "I experience pain from people's distress in my workplace.",
      "mwcs2": "When I see someone in distress in my workplace, I try to act as quickly as possible.",
      "mwcs3": "I recognize people's feelings of distress without them having to tell me in my workplace.",
      "mwcs4": "I can feel the distress as my own when I see someone in my workplace experiencing it.",
      "mwcs5": "I notice the feeling of discomfort experienced by people in my workplace.",
      "mwcs6": "I try to assess the prior circumstances leading to the person's suffering in my workplace.",
      "mwcs7": "I feel the pain experienced by people in my workplace.",
      "mwcs8": "I try to assess the outcomes of my actions toward the person's distress in my workplace.",
      "mwcs9": "I initiate offering help to people in my workplace, when I hear the story of their pain.",
      "mwcs10": "I notice my co-worker's feelings of distress or pain without them having to tell me.",
      "mwcs11": "I try to understand the context of the person's distress in my workplace.",
      "mwcs12": "When I see someone in my workplace in pain, I try to help them."
    }
  }
}
