  "translations": {
    "en": {
      "general_cannabis_use_tried_marijuana": "Have you ever tried marijuana?",
      "general_cannabis_use_tried_marijuana_opt_1": "Yes",
      "general_cannabis_use_tried_marijuana_opt_2": "No",
      "general_cannabis_use_tried_marijuana_opt_-77": "Don't know",
      "general_cannabis_use_tried_marijuana_opt_-88": "Refuse to answer",
      "general_cannabis_use_last_time": "When was the last time you used marijuana?",
      "general_cannabis_use_last_time_opt_1": "More than 12 months ago",
      "general_cannabis_use_last_time_opt_2": "More than 3 months ago but less than 12 months ago",
      "general_cannabis_use_last_time_opt_3": "More than 30 days ago, but less than 3 months ago",
      "general_cannabis_use_last_time_opt_4": "Within the past 30 days",
      "general_cannabis_use_last_time_opt_-77": "Don't know",
      "general_cannabis_use_last_time_opt_-88": "Refuse to answer",
      "general_cannabis_use_frequency": "How often do you use marijuana?",
      "general_cannabis_use_frequency_opt_1": "Less than once per month",
      "general_cannabis_use_frequency_opt_2": "One or more times per month",
      "general_cannabis_use_frequency_opt_3": "One or more times per week",
      "general_cannabis_use_frequency_opt_4": "Every day or almost every day",
      "general_cannabis_use_frequency_opt_-77": "Don't know",
      "general_cannabis_use_frequency_opt_-88": "Refuse to answer",
      "general_cannabis_use_marijuana_days": "Think specifically about the past 30 days, from [DATEFILL] up to and including today. During the past 30 days, on how many days did you use marijuana? NUMBER OF DAYS:",
      "general_cannabis_use_marijuana_days_other": "Think specifically about the past 30 days, from [DATEFILL] up to and including today. During the past 30 days, on how many days did you use marijuana?",
      "general_cannabis_use_marijuana_days_other_opt_-77": "Don't know",
      "general_cannabis_use_marijuana_days_other_opt_-88": "Refuse to answer",
      "general_cannabis_use_frequency_years": "How long have you used marijuana at least [question 3 = 4: \"daily/almost daily\"; question 3 = 3: \"weekly\"; question 3 = 2: \"monthly\"]?   You can enter in number of years, months, or days. : Enter # years:",
      "general_cannabis_use_frequency_months": "How long have you used marijuana at least [question 3 = 4: \"daily/almost daily\"; question 3 = 3: \"weekly\"; question 3 = 2: \"monthly\"]?   You can enter in number of years, months, or days. : Enter # months:",
      "general_cannabis_use_frequency_days": "How long have you used marijuana at least [question 3 = 4: \"daily/almost daily\"; question 3 = 3: \"weekly\"; question 3 = 2: \"monthly\"]?   You can enter in number of years, months, or days. : Enter # days:",
      "general_cannabis_use_frequency_other": "How long have you used marijuana at least [question 3 = 4: \"daily/almost daily\"; question 3 = 3: \"weekly\"; question 3 = 2: \"monthly\"]?   You can enter in number of years, months, or days.",
      "general_cannabis_use_frequency_other_opt_-77": "Don't know",
      "general_cannabis_use_frequency_other_opt_-88": "Refuse to answer",
      "general_cannabis_use_after_waking": "How soon after waking do you usually use marijuana?  You can answer with minutes or hours, or use both hours and minutes to give a more accurate answer.",
