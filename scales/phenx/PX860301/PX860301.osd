  "translations": {
    "en": {
      "pain_coping_adult_think_enjoy": "I think of things I enjoy doing.",
      "pain_coping_adult_other_sensation": "I just think of it as some other sensation, such as numbness.",
      "pain_coping_adult_never_better": "It is terrible and I think it is never going to get any better.",
      "pain_coping_adult_dont_pay_attention": "I don't pay any attention to it.",
      "pain_coping_adult_pray": "I pray for the pain to stop.",
      "pain_coping_adult_stand_in_way": "I tell myself I can't let the pain stand in the way of what I have to do.",
      "pain_coping_adult_chores_projects": "I do something active, like household chores or projects.",
      "pain_coping_adult_replay_pleasant_experiences": "I replay in my mind pleasant experiences in the past.",
      "pain_coping_adult_pretend": "I pretend it is not a part of me.",
      "pain_coping_adult_cant_stand": "I feel I can't stand it anymore.",
      "pain_coping_adult_ignore": "I ignore it.",
      "pain_coping_adult_years_ahead": "I try to think years ahead, what everything will be like after I've gotten rid of the pain.",
      "pain_coping_adult_challenge": "I see it as a challenge and don't let it bother me.",
      "pain_coping_adult_do_enjoy": "I do something I enjoy, such as watching TV or listening to music.",
      "likert_1": "Never",
      "likert_2": "",
      "likert_3": "",
      "likert_4": "Sometimes do that",
      "likert_5": "",
      "likert_6": "",
      "likert_7": "Always do that"
    }
  }
