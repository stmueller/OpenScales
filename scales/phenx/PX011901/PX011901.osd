  "translations": {
    "en": {
      "race_ethnicity_hispanic": "Is Person 1 of Hispanic, Latino, or Spanish origin?",
      "race_ethnicity_hispanic_opt_1": "No, not of Hispanic, Latino, or Spanish origin",
      "race_ethnicity_hispanic_opt_2": "Yes, Mexican, Mexican Am., Chicano",
      "race_ethnicity_hispanic_opt_3": "Yes, Puerto Rican",
      "race_ethnicity_hispanic_opt_4": "Yes, Cuban",
      "race_ethnicity_hispanic_opt_5": "Yes, another Hispanic, Latino, or Spanish origin - Print, for example, Salvadoran, Dominican, Colombian, Guatemalan, Spaniard, Ecuadorian, etc.",
      "race_ethnicity_hispanic_other": "Is Person 1 of Hispanic, Latino, or Spanish origin? Print, for example, Salvadoran, Dominican, Colombian, Guatemalan, Spaniard, Ecuadorian, etc. (<a href=\"https://www.phenxtoolkit.org/toolkit_content/supplemental_info/demographics/additional_info/Census2020_AllofU_Category_Mapping.doc\">Recommended specific choices</a>)",
      "race_ethnicity_person_race": "What is person 1's race? Mark one or more boxes AND print origins.",
      "race_ethnicity_person_race_opt_1": "White - Print, for example, German, Irish, English, Italian, Lebanese, Egyptian, etc.",
      "race_ethnicity_person_race_opt_2": "Black or African Am. - Print, for example, African American, Jamaican, Haitian, Nigerian, Ethiopian, Somali, etc.",
      "race_ethnicity_person_race_opt_3": "American Indian or Alaska Native - Print name of enrolled or principal tribe(s), for example, Navajo Nation, Blackfeet Tribe, Mayan, Aztec, Native Village of Barrow Inupiat Traditional Government, Nome Eskimo Community, etc.",
      "race_ethnicity_person_race_opt_4": "Chinese",
      "race_ethnicity_person_race_opt_5": "Filipino",
      "race_ethnicity_person_race_opt_6": "Asian Indian",
      "race_ethnicity_person_race_opt_7": "Vietnamese",
      "race_ethnicity_person_race_opt_8": "Korean",
      "race_ethnicity_person_race_opt_9": "Japanese",
      "race_ethnicity_person_race_opt_10": "Other Asian - Print, for example, Pakistani, Cambodian, Hmong, etc.",
      "race_ethnicity_person_race_opt_11": "Native Hawaiian",
      "race_ethnicity_person_race_opt_12": "Samoan",
      "race_ethnicity_person_race_opt_13": "Chamorro",
      "race_ethnicity_person_race_opt_14": "Other Pacific Islander - Print, for example, Tongan, Fijian, Marshallese, etc.",
      "race_ethnicity_person_race_opt_15": "Some other race",
      "race_ethnicity_person_race_origin_white": "What is person 1's race? White - Print, for example, German, Irish, English, Italian, Lebanese, Egyptian, etc. (<a href=\"https://www.phenxtoolkit.org/toolkit_content/supplemental_info/demographics/additional_info/Census2020_AllofU_Category_Mapping.doc\">Recommended specific choices</a>). Please specify origin:",
      "race_ethnicity_person_race_origin_black": "What is person 1's race? Black or African Am. - Print, for example, African American, Jamaican, Haitian, Nigerian, Ethiopian, Somali, etc. (<a href=\"https://www.phenxtoolkit.org/toolkit_content/supplemental_info/demographics/additional_info/Census2020_AllofU_Category_Mapping.doc\">Recommended specific choices</a>). Please specify origin:",
      "race_ethnicity_person_race_origin_american_indian": "What is person 1's race? American Indian or Alaska Native - Print name of enrolled or principal tribe(s), for example, Navajo Nation, Blackfeet Tribe, Mayan, Aztec, Native Village of Barrow Inupiat Traditional Government, Nome Eskimo Community, etc. (<a href=\"https://www.phenxtoolkit.org/toolkit_content/supplemental_info/demographics/additional_info/Census2020_AllofU_Category_Mapping.doc\">Recommended specific choices</a>). Please specify origin:",
      "race_ethnicity_person_race_origin_other_asian": "What is person 1's race? Other Asian - Print, for example, Pakistani, Cambodian, Hmong, etc. (<a href=\"https://www.phenxtoolkit.org/toolkit_content/supplemental_info/demographics/additional_info/Census2020_AllofU_Category_Mapping.doc\">Recommended specific choices</a>). Please specify origin:",
      "race_ethnicity_person_race_origin_other_pacific_islander": "What is person 1's race? Other Pacific Islander - Print, for example, Tongan, Fijian, Marshallese, etc. (<a href=\"https://www.phenxtoolkit.org/toolkit_content/supplemental_info/demographics/additional_info/Census2020_AllofU_Category_Mapping.doc\">Recommended specific choices</a>). Please specify origin:",
      "race_ethnicity_person_race_origin_other": "What is person 1's race? Some other race - Print race of origin. (<a href=\"https://www.phenxtoolkit.org/toolkit_content/supplemental_info/demographics/additional_info/Census2020_AllofU_Category_Mapping.doc\">Recommended specific choices</a>). Please specify origin:"
    }
  }
}
