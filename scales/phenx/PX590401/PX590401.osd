  },
  "translations": {
    "en": {
      "recovery_identification_self_definition": "Which category best describes how you define yourself now, with respect to your prior alcohol or drug use?",
      "recovery_identification_self_definition_opt_1": "in recovery",
      "recovery_identification_self_definition_opt_2": "recovered",
      "recovery_identification_self_definition_opt_3": "used to have an alcohol or drug problem but don't anymore",
      "recovery_identification_self_definition_opt_4": "in medication-assisted recovery"
    }
  }
