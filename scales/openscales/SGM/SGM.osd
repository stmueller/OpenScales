    "en": {
      "likert_1": "Not suitable for me",
      "likert_2": "Slightly suitable for me",
      "likert_3": "Somewhat suitable for me",
      "likert_4": "Suitable for me",
      "likert_5": "Very suitable for me",
      "question_head": "Consider your current or past negative experiences (e.g., COVID-19, traumatic situations), and indicate how well the statement describes your response to the situation.",
      "srgm1": "I am aware of the situation and focus on how I should behave.",
      "srgm2": "I empathize with others and seek how to help them.",
      "srgm3": "I live in the present moment and focus on the future.",
      "srgm4": "I look for an alternative solution to adjust to new changes.",
      "srgm5": "I pursuit for calmness, patience, and social connection.",
