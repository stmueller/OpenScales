          "physical_health_cause_problems"
        ]
      }
    },
    "_scoring_notes": "Scoring Code question 1.a through 1.f 0-4 and sum to convert the K6 to a 0-24 scale. A cut point of 13 or greater is recommended to assess the prevalence of SMI (serious mental illness). Please see Kessler et al. (2002) for further information on scoring the K6.",
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5"
      ]
    }
  },
  "translations": {
    "en": {
      "instr_0121301": "The following questions ask about how you have been feeling during the past 30 days. For each question, please indicate the answer that best describes how often you had this feeling.",
      "nervous": "a During the past 30 days, about how often did you feel...  nervous?",
      "nervous_opt_1": "(1) All of the time",
      "nervous_opt_2": "(2) Most of the time",
      "nervous_opt_3": "(3) Some of the time",
      "nervous_opt_4": "(4) A little of the time",
      "nervous_opt_5": "(5) None of the time",
      "hopeless": "b During the past 30 days, about how often did you feel...  hopeless ?",
      "hopeless_opt_1": "(1) All of the time",
      "hopeless_opt_2": "(2) Most of the time",
      "hopeless_opt_3": "(3) Some of the time",
      "hopeless_opt_4": "(4) A little of the time",
      "hopeless_opt_5": "(5) None of the time",
      "pxt121301_restless": "c During the past 30 days, about how often did you feel...  restless or fidgety?",
      "pxt121301_restless_opt_1": "(1) All of the time",
      "pxt121301_restless_opt_2": "(2) Most of the time",
      "pxt121301_restless_opt_3": "(3) Some of the time",
      "pxt121301_restless_opt_4": "(4) A little of the time",
      "pxt121301_restless_opt_5": "(5) None of the time",
      "pxt121301_depressed": "d During the past 30 days, about how often did you feel...  so depressed that nothing could cheer you up?",
      "pxt121301_depressed_opt_1": "(1) All of the time",
      "pxt121301_depressed_opt_2": "(2) Most of the time",
      "pxt121301_depressed_opt_3": "(3) Some of the time",
      "pxt121301_depressed_opt_4": "(4) A little of the time",
      "pxt121301_depressed_opt_5": "(5) None of the time",
      "everything_an_effort": "e During the past 30 days, about how often did you feel...  that everything was an effort?",
      "everything_an_effort_opt_1": "(1) All of the time",
      "everything_an_effort_opt_2": "(2) Most of the time",
      "everything_an_effort_opt_3": "(3) Some of the time",
      "everything_an_effort_opt_4": "(4) A little of the time",
      "everything_an_effort_opt_5": "(5) None of the time",
      "worthless": "f During the past 30 days, about how often did you feel...  worthless?",
      "worthless_opt_1": "(1) All of the time",
      "worthless_opt_2": "(2) Most of the time",
      "worthless_opt_3": "(3) Some of the time",
      "worthless_opt_4": "(4) A little of the time",
      "worthless_opt_5": "(5) None of the time",
      "frequency_feelings_past_thirty_days": "The last six questions asked about feelings that might have occurred during the past 30 days. Taking them altogether, did these feelings occur more often in the past 30 days than is usual for you, about the same as usual, or less often than usual? (If you never have any of these feelings, circle response option 4.\")\"",
      "frequency_feelings_past_thirty_days_opt_1": "(1) A lot (More often than usual)",
      "frequency_feelings_past_thirty_days_opt_2": "(2) Some (More often than usual)",
      "frequency_feelings_past_thirty_days_opt_3": "(3) A little (More often than usual)",
      "frequency_feelings_past_thirty_days_opt_4": "(4) About the same as usual",
      "frequency_feelings_past_thirty_days_opt_5": "(5) A little (Less often than usual)",
      "frequency_feelings_past_thirty_days_opt_6": "(6) Some (Less often than usual)",
      "frequency_feelings_past_thirty_days_opt_7": "(7) A lot (Less often than usual)",
      "number_days_worked": "During the past 30 days, how many days out of 30 were you totally unable to work or carry out your normal activities because of these feelings?",
      "number_days_do_only_half": "Not counting the days you reported in response to 3, how many days in the past 30 were you able to do only half or less of what you would normally have been able to do, because of these feelings?",
      "number_times_see_doctor": "During the past 30 days, how many times did you see a doctor or other health professional about these feelings?",
      "physical_health_cause_problems": "During the past 30 days, how often have physical health problems been the main cause of these feelings?",
      "physical_health_cause_problems_opt_1": "All of the time",
      "physical_health_cause_problems_opt_2": "Most of the time",
      "physical_health_cause_problems_opt_3": "Some of the time",
      "physical_health_cause_problems_opt_4": "A little of the time",
      "physical_health_cause_problems_opt_5": "None of the time",
      "sec_scoring_title": "Scoring",
      "scoring_0121301": "Code question 1.a through 1.f 0-4 and sum to convert the K6 to a 0-24 scale. A cut point of 13 or greater is recommended to assess the prevalence of SMI (serious mental illness). Please see Kessler et al. (2002) for further information on scoring the K6.",
      "likert_1": "(1) All of the time",
      "likert_2": "(2) Most of the time",
      "likert_3": "(3) Some of the time",
      "likert_4": "(4) A little of the time",
      "likert_5": "(5) None of the time"
    }
  }
}
