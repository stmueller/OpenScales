      "other_chest_illness_ever": "PAST ILLNESSES - Other Chest Illnesses  Have you ever had Any other chest illnesses?",
      "other_chest_illness_specify": "PAST ILLNESSES - Other Chest Illnesses  Please specify chest illnesses you had.",
      "chest_operation_ever": "PAST ILLNESSES - Chest Operations  Have you ever had Any chest operations?",
