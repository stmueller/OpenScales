  "translations": {
    "en": {
      "instructions_060401": "In your work or daily life, are (were) you regularly exposed to any of the following? If \"yes\", indicate the number of years exposed.",
      "exposure_asbestos": "In your work or daily life, are (were) you regularly exposed to Asbestos?",
      "exposure_asbestos_years": "How many years are (were) you regularly exposed to Asbestos?",
      "exposure_solvent": "In your work or daily life, are (were) you regularly exposed to Chemicals/Acids/Solvents?",
      "exposure_solvent_years": "How many years are (were) you regularly exposed to Chemicals/Acids/Solvents?",
      "exposure_coal_dust": "In your work or daily life, are (were) you regularly exposed to Coal or Stone Dusts?",
      "exposure_coal_dust_years": "How many years are (were) you regularly exposed to Coal or Stone Dusts?",
      "exposure_coal_tar": "In your work or daily life, are (were) you regularly exposed to Coal Tar/Pitch/Asphalt?",
      "exposure_coal_tar_years": "How many years are (were) you regularly exposed to Coal Tar/Pitch/Asphalt?",
      "exposure_diesel_engine_exhaust": "In your work or daily life, are (were) you regularly exposed to Diesel Engine Exhaust?",
      "exposure_diesel_engine_exhaust_years": "How many years are (were) you regularly exposed to Diesel Engine Exhaust?",
      "exposure_dye": "In your work or daily life, are (were) you regularly exposed to Dyes?",
      "exposure_dye_years": "How many years are (were) you regularly exposed to Dyes?",
      "exposure_formaldehyde": "In your work or daily life, are (were) you regularly exposed to Formaldehyde?",
      "exposure_formaldehyde_years": "How many years are (were) you regularly exposed to Formaldehyde?",
      "exposure_gasoline_exhaust": "In your work or daily life, are (were) you regularly exposed to Gasoline Exhaust?",
      "exposure_gasoline_exhaust_years": "How many years are (were) you regularly exposed to Gasoline Exhaust?",
      "exposure_pesticides_herbicides": "In your work or daily life, are (were) you regularly exposed to Pesticides/Herbicides?",
      "exposure_pesticides_herbicides_years": "How many years are (were) you regularly exposed to Pesticides/Herbicides?",
      "exposure_textile_fiber_dust": "In your work or daily life, are (were) you regularly exposed to Textile Fibers/Dusts?",
      "exposure_textile_fiber_dust_years": "How many years are (were) you regularly exposed to Textile Fibers/Dusts?",
      "exposure_wood_dust": "In your work or daily life, are (were) you regularly exposed to Wood Dust?",
      "exposure_wood_dust_years": "How many years are (were) you regularly exposed to Wood Dust?",
      "exposure_radioactive_materials": "In your work or daily life, are (were) you regularly exposed to X-rays/Radioactive Materials?",
