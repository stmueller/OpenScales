      },
      "time_criterion": {
        "method": "sum_coded",
        "items": [
          "somedis10"
        ],
        "description": "Time criterion (item 10; range 0–3). Criterion met if value ≥2 (during longer periods or almost daily).",
        "item_coding": {
          "somedis10": 1
        },
        "norms": {
          "thresholds": [
            {
              "min": 0,
              "max": 1,
              "label": "Criterion not met"
            },
            {
              "min": 2,
              "max": 3,
              "label": "Criterion met"
            }
          ]
        }
      }
    }
  },
  "translations": {
    "en": {
      "likert_0": "Strongly disagree",
      "likert_1": "Disagree",
      "likert_2": "Partially agree / partially disagree",
      "likert_3": "Agree",
      "likert_4": "Strongly agree",
      "question_head": "Thinking of the last 12 months, how strongly do you agree with the following statements?",
      "inst": "The following questions ask about your use of social media (e.g., Instagram, TikTok, YouTube — digital services on which texts, photos, animations, or videos can be shared, commented on, or liked). Please indicate how strongly you agree with each statement, thinking of the last 12 months.",
      "somedis1": "I often use social media more frequently and longer than I planned to or agreed upon with my parents.",
      "somedis2": "I often cannot stop using social media even though it would be sensible to do so or for example my parents have told me to stop.",
      "somedis3": "I often do not pursue interests outside the digital world (e.g., meeting friends or partner in real life, attending sports club/societies, reading books, making music) because I prefer using social media.",
      "somedis4": "I neglect daily duties (e.g., grocery shopping, cleaning, tidying up after myself, tidying my room, obligations for school/apprenticeship/job) because I prefer using social media.",
      "somedis5": "I often continue using social media even though it causes me stress with others (e.g., my parents, siblings, friends, partner, teachers).",
      "somedis6": "I continue using social media although it harms my performance at school/apprenticeship/job (e.g., by being late, not participating in class, neglecting homework, worse grades).",
      "somedis7": "Due to my social media use, I neglect my appearance, my personal hygiene, and/or my health (e.g., sleep, nutrition, exercise).",
      "somedis8": "Due to my social media use, I risk losing important relationships (friends, family, partner) or have lost them already.",
      "somedis9": "Due to my social media use, I have disadvantages at school/apprenticeship/job (e.g., bad (final) grades, inability to continue to the next grade/no graduation, no apprenticeship or university spot, poor reference, warning/dismissal).",
      "somedis10": "How often did you experience such problems, conflicts, or difficulties due to your social media use during the past year? Did this only occur on single days, during longer periods of several days to weeks or months, or was it almost daily?",
      "freq_never": "Not at all",
      "freq_rarely": "Only on single days",
      "freq_periods": "During longer periods",
      "freq_daily": "Almost daily",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
