  "translations": {
    "en": {
      "likert_0": "Not at all characteristic of me",
      "likert_1": "Slightly characteristic of me",
      "likert_2": "Moderately characteristic of me",
      "likert_3": "Very characteristic of me",
      "likert_4": "Extremely characteristic of me",
      "question_head": "Read each of the following statements carefully and indicate how characteristic it is of you.",
      "bfnes1": "I worry about what other people will think of me even when I know it doesn't make any difference.",
      "bfnes2": "I am frequently afraid of other people noticing my shortcomings.",
      "bfnes3": "I am afraid that others will not approve of me.",
      "bfnes4": "I am afraid that people will find fault with me.",
      "bfnes5": "When I am talking to someone, I worry about what they may be thinking about me.",
      "bfnes6": "I am usually worried about what kind of impression I make.",
      "bfnes7": "Sometimes I think I am too concerned with what other people think of me.",
      "bfnes8": "I often worry that I will say or do the wrong things.",
      "debrief": "Thank you for completing the Brief Fear of Negative Evaluation Scale."
    }
  }
}