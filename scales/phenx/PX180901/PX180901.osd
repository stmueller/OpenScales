        "id": "wish_have_more_self_respect",
        "text_key": "wish_have_more_self_respect",
        "type": "likert"
      },
      {
        "id": "feel_useless_at_times",
        "text_key": "feel_useless_at_times",
        "type": "likert"
      },
      {
        "id": "times_think_no_good",
        "text_key": "times_think_no_good",
        "type": "likert"
      }
    ],
    "dimensions": [
      {
        "id": "for",
        "name": "For"
      }
    ],
    "scoring": {
      "for": {
        "description": "For: sum_coded of 5 items.",
        "method": "sum_coded",
        "items": [
          "inclined_to_feel_a_failure",
          "not_much_tobe_proud_of",
          "wish_have_more_self_respect",
          "feel_useless_at_times",
          "times_think_no_good"
        ]
      }
    },
    "_scoring_notes": "To score the items, assign a value to each of the 10 items as follows:For items 1, 2, 4, 6, 7: Strongly Agree=3, Agree=2, Disagree=1, and Strongly Disagree=0.For items 3, 5, 8, 9, 10 (which are reversed in valence, and noted with the asterisks**): Strongly Agree=0, Agree=1, Disagree=2, and Strongly Disagree=3.The scale ranges from 0-30, with 30 indicating the highest score possible. Other scoring options are possible. For example, you can assign values 1-4 rather than 0-3; then scores will range from 10-40. Some researchers use 5- or 7-point Likert scales, and again, scale ranges would vary based on the addition of \"middle\" categories of agreement.",
    "likert_options": {
      "points": 4,
      "min": 1,
      "max": 4,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4"
      ]
    }
  },
  "translations": {
    "en": {
      "instructions_180901": "Rosenberg Self-Esteem ScaleBELOW IS A LIST OF STATEMENTS DEALING WITH YOUR GENERAL FEELINGS ABOUT YOURSELF.",
      "person_of_worth": "I feel that I'm a person of worth, at least on an equal plane with others.",
      "person_of_worth_opt_1": "Strongly Agree",
      "person_of_worth_opt_2": "Agree",
      "person_of_worth_opt_3": "Disagree",
      "person_of_worth_opt_4": "Strongly Disagree",
      "number_of_good_qualities": "I feel that I have a number of good qualities.",
      "number_of_good_qualities_opt_1": "Strongly Agree",
      "number_of_good_qualities_opt_2": "Agree",
      "number_of_good_qualities_opt_3": "Disagree",
      "number_of_good_qualities_opt_4": "Strongly Disagree",
      "inclined_to_feel_a_failure": "All in all, I am inclined to feel that I am a failure.",
      "inclined_to_feel_a_failure_opt_1": "Strongly Agree",
      "inclined_to_feel_a_failure_opt_2": "Agree",
      "inclined_to_feel_a_failure_opt_3": "Disagree",
      "inclined_to_feel_a_failure_opt_4": "Strongly Disagree",
      "do_as_well_as_others": "I am able to do things as well as most other people.",
      "do_as_well_as_others_opt_1": "Strongly Agree",
      "do_as_well_as_others_opt_2": "Agree",
      "do_as_well_as_others_opt_3": "Disagree",
      "do_as_well_as_others_opt_4": "Strongly Disagree",
      "not_much_tobe_proud_of": "I feel I do not have much to be proud of.",
      "not_much_tobe_proud_of_opt_1": "Strongly Agree",
      "not_much_tobe_proud_of_opt_2": "Agree",
      "not_much_tobe_proud_of_opt_3": "Disagree",
      "not_much_tobe_proud_of_opt_4": "Strongly Disagree",
      "positive_self_attitude": "I take a positive attitude toward myself.",
      "positive_self_attitude_opt_1": "Strongly Agree",
      "positive_self_attitude_opt_2": "Agree",
      "positive_self_attitude_opt_3": "Disagree",
      "positive_self_attitude_opt_4": "Strongly Disagree",
      "satisfied_with_myself": "On the whole, I am satisfied with myself.",
      "satisfied_with_myself_opt_1": "Strongly Agree",
      "satisfied_with_myself_opt_2": "Agree",
      "satisfied_with_myself_opt_3": "Disagree",
      "satisfied_with_myself_opt_4": "Strongly Disagree",
      "wish_have_more_self_respect": "I wish I could have more respect for myself.",
      "wish_have_more_self_respect_opt_1": "Strongly Agree",
      "wish_have_more_self_respect_opt_2": "Agree",
      "wish_have_more_self_respect_opt_3": "Disagree",
      "wish_have_more_self_respect_opt_4": "Strongly Disagree",
      "feel_useless_at_times": "I certainly feel useless at times.",
      "feel_useless_at_times_opt_1": "Strongly Agree",
      "feel_useless_at_times_opt_2": "Agree",
      "feel_useless_at_times_opt_3": "Disagree",
      "feel_useless_at_times_opt_4": "Strongly Disagree",
      "times_think_no_good": "At times I think I am no good at all.",
      "times_think_no_good_opt_1": "Strongly Agree",
      "times_think_no_good_opt_2": "Agree",
      "times_think_no_good_opt_3": "Disagree",
      "times_think_no_good_opt_4": "Strongly Disagree",
      "scoring_180901": "To score the items, assign a value to each of the 10 items as follows:For items 1, 2, 4, 6, 7: Strongly Agree=3, Agree=2, Disagree=1, and Strongly Disagree=0.For items 3, 5, 8, 9, 10 (which are reversed in valence, and noted with the asterisks**): Strongly Agree=0, Agree=1, Disagree=2, and Strongly Disagree=3.The scale ranges from 0-30, with 30 indicating the highest score possible. Other scoring options are possible. For example, you can assign values 1-4 rather than 0-3; then scores will range from 10-40. Some researchers use 5- or 7-point Likert scales, and again, scale ranges would vary based on the addition of \"middle\" categories of agreement.",
      "likert_1": "Strongly Agree",
      "likert_2": "Agree",
      "likert_3": "Disagree",
      "likert_4": "Strongly Disagree"
    }
  }
