  "translations": {
    "en": {
      "lk_opt_1": "Strongly disagree",
      "lk_opt_2": "Disagree",
      "lk_opt_3": "Neutral",
      "lk_opt_4": "Agree",
      "lk_opt_5": "Strongly agree",
      "px930201_covid_related_social_interactions_desc1": "The next questions ask how you feel about different aspects of your life. For each one, tell me how often you feel that way in a typical week BEFORE and AFTER the COVID-19 outbreak in your region.",
      "px930201_covid_related_social_interactions_before_companionship": "A typical week BEFORE the COVID-19 outbreak, how often do you feel that you lack companionship?",
      "px930201_covid_related_social_interactions_after_companionship": "A typical week AFTER the COVID-19 outbreak, how often do you feel that you lack companionship?",
      "px930201_covid_related_social_interactions_before_feel_left_out": "A typical week BEFORE the COVID-19 outbreak, how often do you feel left out?",
      "px930201_covid_related_social_interactions_after_feel_left_out": "A typical week AFTER the COVID-19 outbreak, how often do you feel left out?",
      "px930201_covid_related_social_interactions_before_feel_isolated": "A typical week BEFORE the COVID-19 outbreak, how often do you feel isolated from others?",
      "px930201_covid_related_social_interactions_after_feel_isolated": "A typical week AFTER the COVID-19 outbreak, how often do you feel isolated from others?",
      "px930201_covid_related_social_interactions_before_content": "A typical week BEFORE the COVID-19 outbreak, I am content with my friendships and relationships.",
      "px930201_covid_related_social_interactions_after_content": "A typical week AFTER the COVID-19 outbreak, I am content with my friendships and relationships.",
      "px930201_covid_related_social_interactions_before_ask_help": "A typical week BEFORE the COVID-19 outbreak, I have enough people I feel comfortable asking for help at any time.",
      "px930201_covid_related_social_interactions_after_ask_help": "A typical week AFTER the COVID-19 outbreak, I have enough people I feel comfortable asking for help at any time.",
      "px930201_covid_related_social_interactions_before_satisfying": "A typical week BEFORE the COVID-19 outbreak, My relationships are satisfying as I would want them to be.",
      "px930201_covid_related_social_interactions_after_satisfying": "A typical week AFTER the COVID-19 outbreak, My relationships are satisfying as I would want them to be."
    }
