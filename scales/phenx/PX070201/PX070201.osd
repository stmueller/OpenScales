{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Cumulative Lifetime Physical Activity",
      "code": "PX070201",
      "abbreviation": "PX070201",
      "description": "The selected protocol assesses strenuous and moderate physical activities and exercise at various stages of life. Respondents are asked to estimate the average amount of time each week and the average number of months each year that they spend doing strenuous and moderate exercise.",
      "domain": "Health",
      "citation": "The California Teachers Study, Baseline. As implemented in: PhenX Toolkit. Cumulative Lifetime Physical Activity. https://www.phenxtoolkit.org/protocols/view/70201",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/70201"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
