  "translations": {
    "en": {
      "info_820401": "Sickle Cell Disease Self-Efficacy ScaleThe following questions ask about how sure you are in dealing day-to-day with sickle cell disease. There are no right or wrong answers; we just want to know what you think. So for each question, tell us how sure you are by checking the response that best tells how you feel. Please answer every question.",
      "selfefficacyscd_sure_something_reduce_pain": "How sure are you that you can do something to cut down on most of the pain?",
      "selfefficacyscd_sure_something_reduce_pain_opt_1": "Not Sure at All",
      "selfefficacyscd_sure_something_reduce_pain_opt_2": "Not Sure",
      "selfefficacyscd_sure_something_reduce_pain_opt_3": "Neither",
      "selfefficacyscd_sure_something_reduce_pain_opt_4": "Sure",
      "selfefficacyscd_sure_something_reduce_pain_opt_5": "Very Sure",
      "selfefficacyscd_sure_doing_daytoday": "How sure are you that you can keep doing most of the things you do day-to-day?",
      "selfefficacyscd_sure_doing_daytoday_opt_1": "Not Sure at All",
      "selfefficacyscd_sure_doing_daytoday_opt_2": "Not Sure",
      "selfefficacyscd_sure_doing_daytoday_opt_3": "Neither",
      "selfefficacyscd_sure_doing_daytoday_opt_4": "Sure",
      "selfefficacyscd_sure_doing_daytoday_opt_5": "Very Sure",
      "selfefficacyscd_sure_preventpain_interfering_sleep": "How sure are you that you can keep sickle cell disease pain from interfering with your sleep?",
      "selfefficacyscd_sure_preventpain_interfering_sleep_opt_1": "Not Sure at All",
      "selfefficacyscd_sure_preventpain_interfering_sleep_opt_2": "Not Sure",
      "selfefficacyscd_sure_preventpain_interfering_sleep_opt_3": "Neither",
      "selfefficacyscd_sure_preventpain_interfering_sleep_opt_4": "Sure",
      "selfefficacyscd_sure_preventpain_interfering_sleep_opt_5": "Very Sure",
      "selfefficacyscd_sure_reducepain_nonmedication": "How sure are you that you can reduce your sickle cell disease pain by using methods other than taking medications?",
      "selfefficacyscd_sure_reducepain_nonmedication_opt_1": "Not Sure at All",
      "selfefficacyscd_sure_reducepain_nonmedication_opt_2": "Not Sure",
      "selfefficacyscd_sure_reducepain_nonmedication_opt_3": "Neither",
      "selfefficacyscd_sure_reducepain_nonmedication_opt_4": "Sure",
      "selfefficacyscd_sure_reducepain_nonmedication_opt_5": "Very Sure",
      "selfefficacyscd_sure_control_frequency_gettired": "How sure are you that you can control how often or when you get tired?",
      "selfefficacyscd_sure_control_frequency_gettired_opt_1": "Not Sure at All",
      "selfefficacyscd_sure_control_frequency_gettired_opt_2": "Not Sure",
      "selfefficacyscd_sure_control_frequency_gettired_opt_3": "Neither",
      "selfefficacyscd_sure_control_frequency_gettired_opt_4": "Sure",
      "selfefficacyscd_sure_control_frequency_gettired_opt_5": "Very Sure",
      "selfefficacyscd_sure_dosomething_feelbetter": "How sure are you that you can do something to help yourself feel better if you are feeling sad or blue?",
      "selfefficacyscd_sure_dosomething_feelbetter_opt_1": "Not Sure at All",
      "selfefficacyscd_sure_dosomething_feelbetter_opt_2": "Not Sure",
      "selfefficacyscd_sure_dosomething_feelbetter_opt_3": "Neither",
      "selfefficacyscd_sure_dosomething_feelbetter_opt_4": "Sure",
      "selfefficacyscd_sure_dosomething_feelbetter_opt_5": "Very Sure",
      "selfefficacyscd_life_management_daytodayy": "As compared with other people with sickle cell disease, how sure are you that you can manage your life from day-to-day?",
      "selfefficacyscd_life_management_daytodayy_opt_1": "Not Sure at All",
      "selfefficacyscd_life_management_daytodayy_opt_2": "Not Sure",
      "selfefficacyscd_life_management_daytodayy_opt_3": "Neither",
      "selfefficacyscd_life_management_daytodayy_opt_4": "Sure",
      "selfefficacyscd_life_management_daytodayy_opt_5": "Very Sure",
      "selfefficacyscd_sure_managediseasesymptoms": "How sure are you that you can manage your sickle cell disease symptoms so that you can do the things you enjoy doing?",
      "selfefficacyscd_sure_managediseasesymptoms_opt_1": "Not Sure at All",
      "selfefficacyscd_sure_managediseasesymptoms_opt_2": "Not Sure",
      "selfefficacyscd_sure_managediseasesymptoms_opt_3": "Neither",
      "selfefficacyscd_sure_managediseasesymptoms_opt_4": "Sure",
      "selfefficacyscd_sure_managediseasesymptoms_opt_5": "Very Sure",
      "selfefficacyscd_sure_dealfrustration_havingdisease": "How sure are you that you can deal with the frustration of having sickle cell disease?",
      "selfefficacyscd_sure_dealfrustration_havingdisease_opt_1": "Not Sure at All",
      "selfefficacyscd_sure_dealfrustration_havingdisease_opt_2": "Not Sure",
      "selfefficacyscd_sure_dealfrustration_havingdisease_opt_3": "Neither",
      "selfefficacyscd_sure_dealfrustration_havingdisease_opt_4": "Sure",
      "selfefficacyscd_sure_dealfrustration_havingdisease_opt_5": "Very Sure",
      "scoring_820401": "Scoring:Responses from individual items are summed to give an overall score, with higher scores indicating greater self-efficacy."
    }
  }
}