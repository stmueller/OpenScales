  "translations": {
    "en": {
      "hero_protective_equipment_work_maskrecord_id": "Record ID",
      "hero_protective_equipment_work_mask": "Do you currently wear a mask at work?",
      "hero_protective_equipment_work_mask_opt_1": "No",
      "hero_protective_equipment_work_mask_opt_2": "Yes, during contact with patients with known or suspected COVID-19",
      "hero_protective_equipment_work_mask_opt_3": "Yes, at all times",
      "hero_protective_equipment_work_mask_type": "Please indicate the mask type:",
      "hero_protective_equipment_work_mask_type_opt_1": "Powered air-purifying respirator (PAPR)",
      "hero_protective_equipment_work_mask_type_opt_2": "N95 respirator",
      "hero_protective_equipment_work_mask_type_opt_3": "Surgical mask",
      "hero_protective_equipment_work_mask_type_opt_4": "Surgical mask for low risk followed by N95/PAPR for known or suspected COVID19",
      "hero_protective_equipment_work_mask_type_opt_5": "Another type",
      "desc1": "During the last day you were at work, how much of a problem did you have getting appropriate access to the following types of PPE?",
      "hero_protective_equipment_work_difficulty_respiratory_mask": "Respiratory mask (e.g., N95, KN95, or other)",
      "hero_protective_equipment_work_difficulty_surgical_mask": "Surgical mask",
      "hero_protective_equipment_work_difficulty_powered_air_purifying_respirator": "Powered air purifying respirator (PAPR)",
      "hero_protective_equipment_work_difficulty_face_shield": "Face shield/goggles",
      "hero_protective_equipment_work_difficulty_gloves": "Gloves",
      "hero_protective_equipment_work_difficulty_gowns": "Gowns",
      "hero_protective_equipment_work_difficulty_hand_sanitizer": "Hand sanitizer",
      "hero_protective_equipment_work_difficulty_soap": "Soap",
      "hero_protective_equipment_work_difficulty_cleaning_disinfectant": "Cleaning/disinfecting products",
      "hero_protective_equipment_work_reuse_mask_respirator": "During the last day you were at work, for how many patients did you have to re-use the same N95/KN95 mask respirator or surgical mask when you would have otherwise used a new mask?",
      "hero_protective_equipment_work_reuse_mask_respirator_opt_1": "Did not have patient contact",
      "hero_protective_equipment_work_reuse_mask_respirator_opt_2": "None (1 mask per patient)",
      "hero_protective_equipment_work_reuse_mask_respirator_opt_3": "Some patients",
      "hero_protective_equipment_work_reuse_mask_respirator_opt_4": "Most patients",
