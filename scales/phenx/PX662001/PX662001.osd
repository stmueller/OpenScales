  "translations": {
    "en": {
      "family_questionnaire_neglect": "I tend to neglect myself because of him or her",
      "family_questionnaire_neglect_opt_1": "Never/Very rarely",
      "family_questionnaire_neglect_opt_2": "Rarely",
      "family_questionnaire_neglect_opt_3": "Often",
      "family_questionnaire_neglect_opt_4": "Very often",
      "family_questionnaire_manage": "I have to keep asking him or her to do things",
      "family_questionnaire_manage_opt_1": "Never/Very rarely",
      "family_questionnaire_manage_opt_2": "Rarely",
      "family_questionnaire_manage_opt_3": "Often",
      "family_questionnaire_manage_opt_4": "Very often",
      "family_questionnaire_future": "I often think about what is to become of him or her",
      "family_questionnaire_future_opt_1": "Never/Very rarely",
      "family_questionnaire_future_opt_2": "Rarely",
      "family_questionnaire_future_opt_3": "Often",
      "family_questionnaire_future_opt_4": "Very often",
      "family_questionnaire_irritating": "He or she irritates me",
      "family_questionnaire_irritating_opt_1": "Never/Very rarely",
      "family_questionnaire_irritating_opt_2": "Rarely",
      "family_questionnaire_irritating_opt_3": "Often",
      "family_questionnaire_irritating_opt_4": "Very often",
      "family_questionnaire_reason_illness": "I keep thinking about the reasons for his or her illness",
      "family_questionnaire_reason_illness_opt_1": "Never/Very rarely",
      "family_questionnaire_reason_illness_opt_2": "Rarely",
      "family_questionnaire_reason_illness_opt_3": "Often",
      "family_questionnaire_reason_illness_opt_4": "Very often",
      "family_questionnaire_criticism": "I have to try not to criticize him or her",
      "family_questionnaire_criticism_opt_1": "Never/Very rarely",
      "family_questionnaire_criticism_opt_2": "Rarely",
      "family_questionnaire_criticism_opt_3": "Often",
      "family_questionnaire_criticism_opt_4": "Very often",
      "family_questionnaire_difficulty_sleeping": "I can't sleep because of him or her",
      "family_questionnaire_difficulty_sleeping_opt_1": "Never/Very rarely",
      "family_questionnaire_difficulty_sleeping_opt_2": "Rarely",
      "family_questionnaire_difficulty_sleeping_opt_3": "Often",
      "family_questionnaire_difficulty_sleeping_opt_4": "Very often",
      "family_questionnaire_difficulty_agreeing": "It's hard for us to agree on things",
      "family_questionnaire_difficulty_agreeing_opt_1": "Never/Very rarely",
      "family_questionnaire_difficulty_agreeing_opt_2": "Rarely",
      "family_questionnaire_difficulty_agreeing_opt_3": "Often",
      "family_questionnaire_difficulty_agreeing_opt_4": "Very often",
      "family_questionnaire_internalization": "When something about him or her bothers me, I keep it to myself",
      "family_questionnaire_internalization_opt_1": "Never/Very rarely",
      "family_questionnaire_internalization_opt_2": "Rarely",
      "family_questionnaire_internalization_opt_3": "Often",
      "family_questionnaire_internalization_opt_4": "Very often",
      "family_questionnaire_appreciative": "He or she does not appreciate what I do for him or her",
      "family_questionnaire_appreciative_opt_1": "Never/Very rarely",
      "family_questionnaire_appreciative_opt_2": "Rarely",
      "family_questionnaire_appreciative_opt_3": "Often",
      "family_questionnaire_appreciative_opt_4": "Very often",
      "family_questionnaire_sacrifice_needs": "I regard my own needs as less important",
      "family_questionnaire_sacrifice_needs_opt_1": "Never/Very rarely",
      "family_questionnaire_sacrifice_needs_opt_2": "Rarely",
      "family_questionnaire_sacrifice_needs_opt_3": "Often",
      "family_questionnaire_sacrifice_needs_opt_4": "Very often",
      "family_questionnaire_annoyed": "He or she sometimes gets on my nerves",
      "family_questionnaire_annoyed_opt_1": "Never/Very rarely",
      "family_questionnaire_annoyed_opt_2": "Rarely",
      "family_questionnaire_annoyed_opt_3": "Often",
      "family_questionnaire_annoyed_opt_4": "Very often",
      "family_questionnaire_worried": "I'm very worried about him or her",
      "family_questionnaire_worried_opt_1": "Never/Very rarely",
      "family_questionnaire_worried_opt_2": "Rarely",
      "family_questionnaire_worried_opt_3": "Often",
      "family_questionnaire_worried_opt_4": "Very often",
      "family_questionnaire_spite": "He or she does some things out of spite",
      "family_questionnaire_spite_opt_1": "Never/Very rarely",
      "family_questionnaire_spite_opt_2": "Rarely",
      "family_questionnaire_spite_opt_3": "Often",
      "family_questionnaire_spite_opt_4": "Very often",
      "family_questionnaire_illness": "I thought I would become ill myself",
      "family_questionnaire_illness_opt_1": "Never/Very rarely",
      "family_questionnaire_illness_opt_2": "Rarely",
      "family_questionnaire_illness_opt_3": "Often",
      "family_questionnaire_illness_opt_4": "Very often",
      "family_questionnaire_needy": "When he or she constantly wants something from me, it annoys me",
      "family_questionnaire_needy_opt_1": "Never/Very rarely",
      "family_questionnaire_needy_opt_2": "Rarely",
      "family_questionnaire_needy_opt_3": "Often",
      "family_questionnaire_needy_opt_4": "Very often",
      "family_questionnaire_important": "He or she is an important part of my life",
      "family_questionnaire_important_opt_1": "Never/Very rarely",
      "family_questionnaire_important_opt_2": "Rarely",
      "family_questionnaire_important_opt_3": "Often",
      "family_questionnaire_important_opt_4": "Very often",
      "family_questionnaire_behavior": "I have to insist that he or she behave differently",
      "family_questionnaire_behavior_opt_1": "Never/Very rarely",
      "family_questionnaire_behavior_opt_2": "Rarely",
      "family_questionnaire_behavior_opt_3": "Often",
      "family_questionnaire_behavior_opt_4": "Very often",
      "family_questionnaire_sacrifice": "I have given up important things in order to be able to help him or her",
      "family_questionnaire_sacrifice_opt_1": "Never/Very rarely",
      "family_questionnaire_sacrifice_opt_2": "Rarely",
      "family_questionnaire_sacrifice_opt_3": "Often",
      "family_questionnaire_sacrifice_opt_4": "Very often",
      "family_questionnaire_anger": "I'm often angry with him or her",
      "family_questionnaire_anger_opt_1": "Never/Very rarely",
      "family_questionnaire_anger_opt_2": "Rarely",
      "family_questionnaire_anger_opt_3": "Often",
      "family_questionnaire_anger_opt_4": "Very often"
    }
  }
