{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Perception of Recovery Orientation and Care Quality of Mental Health Services - Administrator",
      "code": "PX661501",
      "abbreviation": "PX661501",
      "description": "The Recovery Self-Assessment (RSA) administrator/manager version is a 36-item, provider-completed rating scale that focuses on perceptions of recovery principles and overall quality of services, including determination, staff helpfulness, and staff responsiveness. The RSA includes six subscales: lif",
      "domain": "Psychiatric Symptoms & Wellbeing",
      "citation": "McLoughlin, K. A., & Fitzpatrick, J. J. (2008). Self-reports of recovery-oriented practices of mental health nurses in state mental health institutes: Development of a measure. Issues in Mental Health Nursing, 29 (10), 1051-1065. McLoughlin, K. A., Du Wick, A., Collazzi, C. M., & Puntil, C. (2013). Recovery-oriented practices of psychiatric-mental health nursing staff in an acute hospital setting. Journal of the American Psychiatric Nurses Association, 19 (3), 152-159. Ye, S., Pan, J. Y., Wong, D. F. K., & Bola, J. R. (2013). Cross-validation of mental health recovery measures in a Hong Kong Chinese sample. Research on Social Work Practice, 23 , 311-325. [PhenX: https://www.phenxtoolkit.org/protocols/view/661501]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/661501"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
