{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Sitting-Sedentary Behavior - Adolescent",
      "code": "PX150602",
      "abbreviation": "PX150602",
      "description": "These questions provide an estimate of how many hours and/or minutes an adolescent spends doing sedentary activities each day before and after school during a typical school week (including the weekend). The adolescent records the time spent doing these activities each day.",
      "domain": "Health",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/150602]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/150602"
    },
    "implementation": {
