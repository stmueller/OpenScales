      "pediatric_qol_physicalfunction_exercise_opt_4": "1 - With a lot of trouble",
      "pediatric_qol_physicalfunction_exercise_opt_5": "0 - Not able to do",
      "pediatric_qol_physicalfunction_getup_floor": "In the past 7 days  I could get up from the floor",
