  "translations": {
    "en": {
      "mode_conception_trying_pregnant": "When you got pregnant with your new baby, were you trying to get pregnant?",
      "mode_conception_fertility_drugs_treatment": "Did you (or your partner) take any fertility drugs or receive any medical procedures from a doctor, nurse or other health care worker to help you get pregnant with (this pregnancy or your new baby or child?s name)? This may include infertility treatments such as fertility-enhancing drugs or assisted reproductive technology. (italics added by MK)",
      "mode_conception_fertility_treatment_month": "Did you (or your partner) use any of the following fertility treatments during the month you got pregnant with (this pregnancy or your new baby or child?s name)?",
      "mode_conception_fertility_treatment_month_opt_1": "Fertility enhancing drugs prescribed by a doctor (fertility drugs include Clomid, Serophene, Pergonal or other drugs to stimulate ovulation)",
      "mode_conception_fertility_treatment_month_opt_2": "Artificial insemination or intrauterine insemination (treatments in which sperm, but NOT eggs, were collected and medically placed inside the woman's body)",
      "mode_conception_fertility_treatment_month_opt_3": "Assisted reproductive technology (treatments in which BOTH a woman's eggs and a man's sperm were handled in the laboratory, such as in vitro fertilization [IVF], gamete intrafallopian transfer [GIFT], zygote intrafallopian transfer [ZIFT], intracytoplasmic sperm injection [ICSI], frozen embryo transfer, or donor embryo transfer)",
      "mode_conception_fertility_treatment_month_opt_4": "Other medical treatment",
      "mode_conception_fertility_treatment_month_opt_5": "I wasn't using fertility treatments during the month that I got pregnant with (this pregnancy or my new baby or child's name)",
      "mode_conception_fertility_treatment_month_other": "Did you (or your partner) use any of the following fertility treatments during the month you got pregnant with (this pregnancy or your new baby or child?s name)? Other medical treatment",
      "mode_conception_months_before_fertility_drugs_treatment": "How long had you been trying to get pregnant before you took any fertility drugs or used any medical procedures to help you get pregnant with (this pregnancy or your new baby or child?s name)? Do not count long periods of time when you and your partner were apart or not having sex.",
      "mode_conception_months_before_fertility_drugs_treatment_opt_1": "0 to 5 months",
      "mode_conception_months_before_fertility_drugs_treatment_opt_2": "6 to 11 months",
      "mode_conception_months_before_fertility_drugs_treatment_opt_3": "1 to 2 years",
      "mode_conception_months_before_fertility_drugs_treatment_opt_4": "3 to 4 years",
      "mode_conception_months_before_fertility_drugs_treatment_opt_5": "5 to 6 years",
      "mode_conception_cycles_fertility_treatment": "How many cycles of fertility treatments (complete or incomplete) did you have before you got pregnant with your new baby?",
      "mode_conception_cycles_fertility_treatment_opt_1": "1 cycle",
      "mode_conception_cycles_fertility_treatment_opt_2": "2 to 3 cycles",
      "mode_conception_cycles_fertility_treatment_opt_3": "4 to 6 cycles",
      "mode_conception_cycles_fertility_treatment_opt_4": "7 or more cycles",
      "mode_conception_months_trying_pregnant": "How many months were you trying to get pregnant? Do not count long periods of time when you and your partner were apart or not having sex.",
      "mode_conception_months_trying_pregnant_opt_1": "0 to 3 months",
      "mode_conception_months_trying_pregnant_opt_2": "4 to 6 months",
      "mode_conception_months_trying_pregnant_opt_3": "7 to 12 months",
      "mode_conception_months_trying_pregnant_opt_4": "13 to 24 months",
      "mode_conception_months_trying_pregnant_opt_5": "More than 24 months",
      "likert_1": "Fertility enhancing drugs prescribed by a doctor (fertility drugs include Clomid, Serophene, Pergonal or other drugs to stimulate ovulation)",
      "likert_2": "Artificial insemination or intrauterine insemination (treatments in which sperm, but NOT eggs, were collected and medically placed inside the woman's body)",
      "likert_3": "Assisted reproductive technology (treatments in which BOTH a woman's eggs and a man's sperm were handled in the laboratory, such as in vitro fertilization [IVF], gamete intrafallopian transfer [GIFT], zygote intrafallopian transfer [ZIFT], intracytoplasmic sperm injection [ICSI], frozen embryo transfer, or donor embryo transfer)",
      "likert_4": "Other medical treatment",
      "likert_5": "I wasn't using fertility treatments during the month that I got pregnant with (this pregnancy or my new baby or child's name)",
      "opt_1": "Yes",
      "opt_2": "No"
    }
  }
}
