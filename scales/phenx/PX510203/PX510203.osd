        ]
      }
    },
    "_scoring_notes": "Scoring Procedure and InterpretationIf an item was answered in the critical direction, add the number of points indicated for that item:Item #;  Critical direction;  Points to add#1; NO;   2#2;  NO;  2#3;  YES;  5#4;  YES;  2#5;  YES:  2#6;  YES;  2#7:  YES:  2#8:  YES;  5#9:  YES:  5#10: YES:  2A score of 6 or more indicates a probable diagnosis of alcoholism, except for questions 3, 8, or 9, which are by themselves diagnostic."
  },
  "translations": {
    "en": {
      "info_510203": "Please select one answer for each of the following YES or NO questions:",
      "normal_drinker": "Do you feel you are a normal drinker?",
      "normal_drinker_opt_1": "Yes",
      "normal_drinker_opt_2": "No",
      "friends_think_you_normal_drinker": "Do friends or relatives think that you are a normal drinker?",
      "friends_think_you_normal_drinker_opt_1": "Yes",
      "friends_think_you_normal_drinker_opt_2": "No",
      "ever_attended_alcoholics_anonymous": "Have you ever attended a meeting of Alcoholics Anonymous (AA)?",
      "ever_attended_alcoholics_anonymous_opt_1": "Yes",
      "ever_attended_alcoholics_anonymous_opt_2": "No",
      "lost_friends_because_of_drinking": "Have you ever lost friends or girlfriends/boyfriends because of drinking?",
      "lost_friends_because_of_drinking_opt_1": "Yes",
      "lost_friends_because_of_drinking_opt_2": "No",
      "drinking_cause_trouble_at_work": "Have you ever gotten into trouble at work because of drinking?",
      "drinking_cause_trouble_at_work_opt_1": "Yes",
      "drinking_cause_trouble_at_work_opt_2": "No",
      "neglected_obligations_because_of_drinking": "Have you ever neglected your obligations, your family, or your work for two or more days in a row because you were drinking?",
      "neglected_obligations_because_of_drinking_opt_1": "Yes",
      "neglected_obligations_because_of_drinking_opt_2": "No",
      "ever_had_delirium_tremens": "Have you ever had delirium tremens (DTs), severe shaking, heard voices, or seen things that weren't there after heavy drinking?",
      "ever_had_delirium_tremens_opt_1": "Yes",
      "ever_had_delirium_tremens_opt_2": "No",
      "gone_for_help_about_drinking": "Have you ever gone to anyone for help about your drinking?",
      "gone_for_help_about_drinking_opt_1": "Yes",
      "gone_for_help_about_drinking_opt_2": "No",
      "been_hospitalized_because_of_drinking": "Have you ever been in the hospital because of drinking?",
      "been_hospitalized_because_of_drinking_opt_1": "Yes",
      "been_hospitalized_because_of_drinking_opt_2": "No",
      "arrested_for_drunk_driving": "Have you ever been arrested for drunk driving or driving after drinking?",
      "arrested_for_drunk_driving_opt_1": "Yes",
      "arrested_for_drunk_driving_opt_2": "No",
      "scoring_510203": "Scoring Procedure and InterpretationIf an item was answered in the critical direction, add the number of points indicated for that item:Item #;  Critical direction;  Points to add#1; NO;   2#2;  NO;  2#3;  YES;  5#4;  YES;  2#5;  YES:  2#6;  YES;  2#7:  YES:  2#8:  YES;  5#9:  YES:  5#10: YES:  2A score of 6 or more indicates a probable diagnosis of alcoholism, except for questions 3, 8, or 9, which are by themselves diagnostic."
    }
  }
