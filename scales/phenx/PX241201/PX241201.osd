{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Mode of Conception - Interview",
      "code": "PX241201",
      "abbreviation": "PX241201",
      "description": "A woman who gave birth is asked several questions about the amount of time she spent trying to become pregnant and if she used fertility drugs or reproductive technologies to help her get pregnant.",
      "domain": "Health",
      "citation": "Core State Preconception Health Indicators-Pregnancy Risk Assessment Monitoring System and Behavioral Risk Factor Surveillance System, 2009. (2014). Morbidity and Mortality Weekly Report, 63(ss03):1-62. [PhenX: https://www.phenxtoolkit.org/protocols/view/241201]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/241201"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "items": [
      {
        "id": "mode_conception_trying_pregnant",
        "text_key": "mode_conception_trying_pregnant",
        "type": "multi",
        "options": [
          {
            "text_key": "opt_1",
            "value": 1
