          "ebq13",
          "ebq14",
          "ebq15",
          "ebq16"
        ],
        "name": "EBQ Total (composite)"
      }
    }
  },
  "translations": {
    "en": {
      "ebq_inst": "Please read each of the following statements and indicate the degree to which you agree or disagree with each statement.",
      "ebq_opt1": "Strongly disagree",
      "ebq_opt2": "Disagree",
      "ebq_opt3": "Somewhat disagree",
      "ebq_opt4": "Neither agree nor disagree",
      "ebq_opt5": "Somewhat agree",
      "ebq_opt6": "Agree",
      "ebq_opt7": "Strongly agree",
      "ebq1": "Once people are experiencing negative emotions, there is nothing they can do about modifying them.",
      "ebq2": "People cannot control their positive emotions.",
      "ebq3": "There is very little use for negative emotions.",
      "ebq4": "Positive emotions are very unhelpful to people.",
      "ebq5": "It doesn't matter how hard people try, they cannot change their negative emotions.",
      "ebq6": "People cannot learn techniques to effectively control their positive emotions.",
      "ebq7": "People don't need their negative emotions.",
      "ebq8": "There is very little use for positive emotions.",
      "ebq9": "People cannot control their negative emotions.",
      "ebq10": "It doesn't matter how hard people try, they cannot change their positive emotions.",
      "ebq11": "Negative emotions are harmful.",
      "ebq12": "People don't need their positive emotions.",
      "ebq13": "People cannot learn techniques to effectively control their negative emotions.",
      "ebq14": "Once people are experiencing positive emotions, there is nothing they can do about modifying them.",
      "ebq15": "The presence of negative emotions is a bad thing for people.",
      "ebq16": "Positive emotions are harmful."
    }
  }
}
