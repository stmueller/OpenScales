          {
            "text_key": "audit1_opt3",
            "value": 3
          },
          {
            "text_key": "audit1_opt4",
            "value": 4
          }
        ]
      },
      {
        "id": "sec_drinking",
        "type": "section",
        "visible_when": {
          "all": [
            {
              "item": "audit1",
              "operator": "is_answered"
            },
            {
              "item": "audit1",
              "operator": "not_equals",
              "value": 0
            }
          ]
        }
