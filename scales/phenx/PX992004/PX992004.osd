  "translations": {
    "en": {
      "long_covid_symptoms_psychological_lack_energyrecord_id": "Record ID",
      "long_covid_symptoms_psychological_lack_energy": "Do you still have the lack of energy or general tired feeling?",
      "long_covid_symptoms_psychological_lack_energy_opt_1": "Yes, I still have this symptom",
      "long_covid_symptoms_psychological_lack_energy_opt_2": "Yes, I still have the symptom but it is less severe",
      "long_covid_symptoms_psychological_lack_energy_opt_3": "Yes, I still have the symptom but it comes and goes",
      "long_covid_symptoms_psychological_lack_energy_opt_4": "No, the symptom has cleared",
      "long_covid_symptoms_psychological_lack_energy_normal_activities": "Does/did the lack of energy or general tired feeling affect your ability to do your normal activities?",
      "long_covid_symptoms_psychological_lack_energy_normal_activities_opt_1": "I have/had the symptom but I can/could still do normal activities.",
      "long_covid_symptoms_psychological_lack_energy_normal_activities_opt_2": "The symptom really bothers/bothered me. It is/was hard to do normal activities.",
      "long_covid_symptoms_psychological_lack_energy_normal_activities_opt_3": "The symptom is/was very bad. I am/was not able to do activities that I usually do.",
      "long_covid_symptoms_psychological_lack_energy_normal_activities_opt_4": "Refuse to answer",
      "long_covid_symptoms_psychological_lack_energy_clear": "When did the lack of energy or general tired feeling clear?",
      "long_covid_symptoms_psychological_loss_appetite": "Do you still have the loss of appetite?",
      "long_covid_symptoms_psychological_loss_appetite_opt_1": "Yes, I still have this symptom",
      "long_covid_symptoms_psychological_loss_appetite_opt_2": "Yes, I still have the symptom but it is less severe",
      "long_covid_symptoms_psychological_loss_appetite_opt_3": "Yes, I still have the symptom but it comes and goes",
      "long_covid_symptoms_psychological_loss_appetite_opt_4": "No, the symptom has cleared",
      "long_covid_symptoms_psychological_loss_appetite_normal_activities": "Does/did the loss of appetite affect your ability to do your normal activities?",
      "long_covid_symptoms_psychological_loss_appetite_normal_activities_opt_1": "I have/had the symptom but I can/could still do normal activities.",
      "long_covid_symptoms_psychological_loss_appetite_normal_activities_opt_2": "The symptom really bothers/bothered me. It is/was hard to do normal activities.",
      "long_covid_symptoms_psychological_loss_appetite_normal_activities_opt_3": "The symptom is/was very bad. I am/was not able to do activities that I usually do.",
      "long_covid_symptoms_psychological_loss_appetite_normal_activities_opt_4": "Refuse to answer",
      "long_covid_symptoms_psychological_loss_appetite_clear": "When did the loss of appetite clear?",
      "likert_1": "Yes, I still have this symptom",
