{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Belief in Science Scale",
      "code": "BISS",
      "abbreviation": "BISS",
      "description": "10-item scale measuring how important science is to individuals and how effective they perceive its methods to be in describing the world and uncovering truth. 6-point Likert scale (1 = Strongly disagree, 6 = Strongly agree). Single factor, alpha = .86.",
      "citation": "Farias, M., Newheiser, A.-K., Kahane, G., & de Toledo, Z. (2013). Scientific faith: Belief in science increases in the face of stress and existential anxiety. Journal of Experimental Social Psychology, 49(6), 1210–1213. https://doi.org/10.1016/j.jesp.2013.05.008",
      "license": "CC BY",
      "license_explanation": "Published under Creative Commons Attribution License.",
      "license_url": "https://pmc.ncbi.nlm.nih.gov/articles/PMC3807800/",
      "version": "1.0",
      "url": "https://doi.org/10.1016/j.jesp.2013.05.008",
      "domain": "Attitudes & Beliefs"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 6,
      "min": 1,
      "max": 6,
      "labels": [
        "biss_r1",
        "biss_r2",
        "biss_r3",
        "biss_r4",
        "biss_r5",
        "biss_r6"
      ],
      "question_head": "biss_head"
    },
    "dimensions": [
      {
        "id": "belief_in_science",
        "name": "Belief in Science",
        "description": "Single factor measuring belief in the value and efficacy of science (10 items, alpha = .86)."
      }
    ],
