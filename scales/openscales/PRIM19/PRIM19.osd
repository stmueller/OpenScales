  "translations": {
    "en": {
      "likert_0": "Does not describe me",
      "likert_1": "Describes me a little",
      "likert_2": "Describes me moderately",
      "likert_3": "Describes me very well",
      "question_head": "Please indicate how well each statement describes you.",
      "debrief": "Thank you for completing this questionnaire.",
      "prs1": "I find it easy to make friends with people I have just met.",
      "prs2": "I am kind and attentive to people close to me (family and friends).",
      "prs3": "I feel that my friends and family spend time with me.",
      "prs4": "I enjoy spending time with my friends and family.",
      "prs5": "I inspire confidence in people I have just met.",
      "prs6": "My relationship with friends and family is characterized by camaraderie and mutual appreciation.",
      "prs7": "I feel that my friends and family care about me.",
      "prs8": "When I am with my friends and family, I feel happy.",
      "prs9": "When I meet new people, we quickly warm up.",
      "prs10": "I am respectful of the way my friends and family think.",
      "prs11": "I can count on my friends and family in times of difficulty.",
      "prs12": "I feel satisfied with my relationship with my family and friends.",
      "prs13": "I am willing to help people I have just met.",
      "prs14": "I am happy for the triumphs of my friends and family.",
      "prs15": "I feel accompanied by my friends and family.",
      "prs16": "I can establish a close bond with people I have just met.",
      "prs17": "My relationship with my friends and family helps me develop and achieve my goals.",
      "prs18": "I feel loved by my friends and family.",
      "prs19": "I get along well with people I have just met."
    }
  }
