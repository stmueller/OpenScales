    "scale_info": {
      "name": "Flourishing Scale",
      "code": "FS",
      "version": "1.0",
      "description": "8-item summary measure of psychological well-being covering social relationships, meaning, purpose, and self-esteem.",
      "citation": "Diener, E., Wirtz, D., Tov, W., Kim-Prieto, C., Choi, D., Oishi, S., & Biswas-Diener, R. (2010). New well-being measures: Short scales to assess flourishing and positive and negative feelings. Social Indicators Research, 97(2), 143–156. https://doi.org/10.1007/s11205-009-9493-y",
      "license": "free to use",
      "abbreviation": "FS",
      "url": "https://www.psytoolkit.org/survey-library/flourishing-scale.html",
      "license_explanation": "The scale is copyrighted but you are free to use it without permission or charge by all professionals (researchers and practitioners) as long as you give credit to the authors of the scale. Copyright Ed Diener and Robert Biswas-Diener.",
      "license_url": "https://labs.psychology.illinois.edu/~ediener/scales.html",
      "domain": "Well-being"
    },
    "implementation": {
