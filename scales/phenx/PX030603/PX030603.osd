  "translations": {
    "en": {
      "cigarettesmoking_adolescent_ever": "Have you ever smoked a cigarette, even one or two puffs?",
      "cigarettesmoking_adolescent_ever_opt_1": "Yes",
      "cigarettesmoking_adolescent_ever_opt_2": "No",
      "cigarettesmoking_adolescent_ever_opt__8": "DON'T KNOW",
      "cigarettesmoking_adolescent_ever_opt__7": "REFUSED",
      "cigarettesmoking_adolescent_last_time": "When was the last time you smoked a cigarette, even one or two puffs?",
      "cigarettesmoking_adolescent_last_time_opt_1": "Earlier today",
      "cigarettesmoking_adolescent_last_time_opt_2": "Not today but sometime in the past 7 days",
      "cigarettesmoking_adolescent_last_time_opt_3": "Not in the past 7 days but sometime in the past 30 days",
      "cigarettesmoking_adolescent_last_time_opt_4": "Not in the past 30 days but sometime in the past 6 months",
      "cigarettesmoking_adolescent_last_time_opt_5": "Not in the past 6 months but sometime in the past year",
      "cigarettesmoking_adolescent_last_time_opt_6": "1 to 4 years ago",
      "cigarettesmoking_adolescent_last_time_opt_7": "5 or more years ago",
      "cigarettesmoking_adolescent_past_month": "In the past 30 days, on how many days did you smoke cigarettes?",
      "cigarettesmoking_adolescent_past_month_coded": "In the past 30 days, on how many days did you smoke cigarettes?"
