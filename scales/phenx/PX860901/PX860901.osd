  "translations": {
    "en": {
      "lk_opt_1": "Without any difficulty",
      "lk_opt_2": "With a little difficulty",
      "lk_opt_3": "With some difficulty",
      "lk_opt_4": "With much difficulty",
      "lk_opt_5": "Unable to do",
      "stand_one_hour": "Are you able to stand for one hour?",
      "stand_armless_chair": "Are you able to stand up from an armless straight chair?",
      "run_two_miles": "Are you able to run or jog for two miles (3 km)?",
      "stairs_normal_pace": "Are you able to go up and down stairs at a normal pace?",
      "walk_fifteen_minutes": "Are you able to go for a walk of at least 15 minutes?",
      "step_up_down_curb": "Are you able to step up and down curbs?",
      "stand_knees_straight": "Are you able to stand with your knees straight?",
      "stand_short_period": "Are you able to stand for short periods of time?",
      "run_fast_two_miles": "Are you able to run at a fast pace for two miles (3 km)?",
      "squat_get_up": "Are you able to squat and get up?",
      "climb_five_steps": "Are you able to climb up five steps?",
      "run_short_distance": "Are you able to run a short distance, such as to catch a bus?",
      "stand_unsupported_ten_minutes": "Are you able to stand unsupported for 10 minutes?",
      "stand_tiptoes": "Are you able to stand up on tiptoes?",
      "stand_unsupported_thirty_minutes": "Are you able to stand unsupported for 30 minutes?",
      "jump_up_down": "Are you able to jump up and down?",
      "run_hundred_yards": "Are you able to run 100 yards (100 m)?",
      "walk_up_down_two_steps": "Are you able to walk up and down two steps?",
      "climb_five_flights_stairs": "Are you able to climb up 5 flights of stairs?",
      "walk_normal_speed": "Are you able to walk at a normal speed?",
      "stand_without_losing_balance_minutes": "Are you able to stand without losing your balance for several minutes?",
      "kneel_floor": "Are you able to kneel on the floor?",
      "walk_block_flat_ground": "Are you able to walk a block (about 100 m) on flat ground?",
      "run_five_miles": "Are you able to run five miles (8 km)?",
      "climb_stairs_ten_stories": "Are you able to climb the stairs of a 10-story building without stopping?",
      "walk_briskly_twenty_minutes": "Are you able to walk briskly for 20 minutes without stopping to rest?",
      "complete_stop_running": "Are you able to come to a complete stop while running?",
      "sharp_turns_running": "Are you able to make sharp turns while running fast?",
      "jump_over_object_one_foot": "Are you able to jump over an object that is 1 foot (30 cm) tall?",
      "jump_two_feet": "Are you able to jump 2 feet (60 cm) high?",
      "walk_across_balance_beam": "Are you able to walk across a balance beam?",
      "walk_straight_line_five_yards": "Are you able to walk in a straight line putting one foot in front of the other (heel to toe) for 5 yards (5 m)?",
      "dance_energetically_hour": "Are you able to dance energetically for an hour?",
      "run_uneven_ground": "Are you able to run on uneven ground?",
      "run_even_ground": "Are you able to run on even ground?",
      "run_ten_miles": "Are you able to run ten miles (16 km)?",
      "stand_one_foot_eyes_closed_thirty_seconds": "Are you able to stand on one foot with your eyes closed for 30 seconds?",
      "health_limit_bending_kneeling_stooping": "Does your health now limit you in bending, kneeling, or stooping?",
      "health_limit_short_walk": "Does your health now limit you in going for a short walk (less than 15 minutes)?",
      "health_limit_hiking_couple_miles": "Does your health now limit you in hiking a couple of miles (3 km) on uneven surfaces, including hills?",
      "health_limit_climbing_several_flights_stairs": "Does your health now limit you in climbing several flights of stairs?",
      "health_limit_walking_more_than_mile": "Does your health now limit you in walking more than a mile (1.6 km)?",
