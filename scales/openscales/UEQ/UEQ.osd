    "hi": {
      "LANGUAGE": "hi",
      "question_head": "कृपया उत्पाद का आकलन हर पंक्ति में घेरे पर चिन्ह लगाकर करें।",
      "ueq_inst_text": "उत्पाद के मूल्यांकन के लिए, निम्न प्रश्नावली भरें। प्रश्नावली में जोड़ों में विषम गुण हैं जो कि उत्पाद पर लागू हो सकते हैं। विशेषताओं के बीच के घेरे सनमुखों के बीच उन्नयन को दर्शाते हैं। आप उन विशेषताओं के घेरों पर चिन्ह लगाकर अपनी सहमति व्यक्त कर सकते हैं जिसने आप पर गहरी छाप छोड़ी हो। लंबे समय तक अपने निर्णय के बारे में मत सोचिये यह निश्चित करने के लिए कि वह आपके मूल्य धारणा को वक्त करता है। कभी कभी आप एक विशेष गुण के साथ अपने समझौते के बारे में पूरी तरह से निश्चित नहीं होंगे या आप पा सकते हैं कि विशेषता विशेष उत्पाद के लिए पूरी तरह से लागू नहीं होता। फिर भी, हर पंक्ति में एक चक्र को टिक करें। वह आपकी राय है जो कि मायने रखती है। कृपया याद रखें: की कोई सही या गलत जवाब नहीं है !",
      "ueq_01_text": "कष्टप्रद                    मनोरंजक",
      "ueq_01_left": "कष्टप्रद",
      "ueq_01_right": "मनोरंजक",
      "ueq_02_text": "समझ में आता है                    समझ में नहीं आता है",
      "ueq_02_left": "समझ में आता है",
      "ueq_02_right": "समझ में नहीं आता है",
