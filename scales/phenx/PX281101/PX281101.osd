  "translations": {
    "en": {
      "healthcare_communications_doctor_instructions_illness_conditionrecord_id": "Record ID",
      "intro_text": "These questions ask about your own health care. Do not include care you got when you stayed overnight in a hospital. Do not include the times you went for dental care visits.",
      "healthcare_communications_doctor_instructions_illness_condition": "In the last 12 months, did a doctor or other health provider give you instructions about what to do about a specific illness or health condition?",
      "healthcare_communications_doctor_instructions_illness_condition_opt_1": "Yes",
      "healthcare_communications_doctor_instructions_illness_condition_opt_2": "No",
      "healthcare_communications_doctor_instructions_illness_condition_understand": "In the last 12 months, how often were these instructions easy to understand?",
      "healthcare_communications_doctor_instructions_illness_condition_understand_opt_1": "Never",
      "healthcare_communications_doctor_instructions_illness_condition_understand_opt_2": "Sometimes",
      "healthcare_communications_doctor_instructions_illness_condition_understand_opt_3": "Usually",
      "healthcare_communications_doctor_instructions_illness_condition_understand_opt_4": "Always",
      "healthcare_communications_doctor_instructions_illness_condition_describe_follow": "In the last 12 months, how often did doctors or other health providers ask you to describe how you were going to follow these instructions?",
      "healthcare_communications_doctor_instructions_illness_condition_describe_follow_opt_1": "Never",
      "healthcare_communications_doctor_instructions_illness_condition_describe_follow_opt_2": "Sometimes",
      "healthcare_communications_doctor_instructions_illness_condition_describe_follow_opt_3": "Usually",
      "healthcare_communications_doctor_instructions_illness_condition_describe_follow_opt_4": "Always",
      "healthcare_communications_sign_forms_doctor_office": "In the last 12 months, did you have to fill out or sign any forms at a doctor's or other health provider's office?",
      "healthcare_communications_sign_forms_doctor_office_opt_1": "Yes",
      "healthcare_communications_sign_forms_doctor_office_opt_2": "No",
      "healthcare_communications_sign_forms_doctor_office_help": "In the last 12 months, how often were you offered help in filling out a form at the doctor's or other health provider's office?",
      "healthcare_communications_sign_forms_doctor_office_help_opt_1": "Never",
      "healthcare_communications_sign_forms_doctor_office_help_opt_2": "Sometimes",
      "healthcare_communications_sign_forms_doctor_office_help_opt_3": "Usually",
      "healthcare_communications_sign_forms_doctor_office_help_opt_4": "Always",
      "healthcare_communications_doctor_explain_easy_understand": "In the last 12 months, how often did doctors or other health professionals explain things in a way that was easy to understand?",
      "healthcare_communications_doctor_explain_easy_understand_opt_1": "Never",
      "healthcare_communications_doctor_explain_easy_understand_opt_2": "Sometimes",
      "healthcare_communications_doctor_explain_easy_understand_opt_3": "Usually",
      "healthcare_communications_doctor_explain_easy_understand_opt_4": "Always",
      "healthcare_communications_doctor_listen_carefully": "In the last 12 months, how often did doctors or other health professionals listen carefully to you?",
      "healthcare_communications_doctor_listen_carefully_opt_1": "Never",
      "healthcare_communications_doctor_listen_carefully_opt_2": "Sometimes",
      "healthcare_communications_doctor_listen_carefully_opt_3": "Usually",
      "healthcare_communications_doctor_listen_carefully_opt_4": "Always",
      "healthcare_communications_doctor_show_respect": "In the last 12 months, how often did doctors or other health professionals show respect for what you had to say?",
      "healthcare_communications_doctor_show_respect_opt_1": "Never",
      "healthcare_communications_doctor_show_respect_opt_2": "Sometimes",
      "healthcare_communications_doctor_show_respect_opt_3": "Usually",
      "healthcare_communications_doctor_show_respect_opt_4": "Always",
      "healthcare_communications_doctor_spend_time": "In the last 12 months, how often did doctors or other health professionals spend enough time with you?",
      "healthcare_communications_doctor_spend_time_opt_1": "Never",
      "healthcare_communications_doctor_spend_time_opt_2": "Sometimes",
      "healthcare_communications_doctor_spend_time_opt_3": "Usually",
      "healthcare_communications_doctor_spend_time_opt_4": "Always",
      "specialist_text": "When you answer the next questions, do not include dental visits or care you got when you stayed overnight in a hospital.",
      "healthcare_communications_specialist_appointment": "Specialists are doctors like surgeons, heart doctors, allergy doctors, skin doctors, and other doctors who specialize in one area of health care. In the last 12 months, did you make any appointments to see a specialist?",
      "healthcare_communications_specialist_appointment_opt_1": "Yes",
      "healthcare_communications_specialist_appointment_opt_2": "No",
      "healthcare_communications_specialist_appointment_needed": "In the last 12 months, how often did you get an appointment to see a specialist as soon as you needed?",
      "healthcare_communications_specialist_appointment_needed_opt_1": "Never",
      "healthcare_communications_specialist_appointment_needed_opt_2": "Sometimes",
      "healthcare_communications_specialist_appointment_needed_opt_3": "Usually",
      "healthcare_communications_specialist_appointment_needed_opt_4": "Always",
      "healthcare_communications_complete_date": "Date Completed",
      "healthcare_communications_complete_date_who": "Who completed this form?",
      "healthcare_communications_complete_date_who_opt_1": "Person named on front of this form",
