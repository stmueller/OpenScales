    "ja": {
      "d1": "緊張をほぐしにくいと感じた",
      "d2": "口の渇きを覚えた",
      "d3": "ポジティブな気持ちに全くなれなかった",
      "d4": "呼吸困難があった（激しく動いたわけでもないのに、過呼吸または息切 れがあった、など）",
      "d5": "物事に積極的に取り組もうという気になれなかった",
      "d6": "状況に過剰に反応しがちだった",
      "d7": "震えを感じることがあった（手の震えなど）",
      "d8": "神経をすり減らしていると感じた",
      "d9": "パニックになるのでは、恥をかくのでは、と不安になることが あった",
      "d10": "楽しみなことは何もないと感じた",
      "d11": "イライラした",
      "d12": "リラックスしにくかった",
      "d13": "気分が落ち込んでいた",
      "d14": "何かをしていて邪魔が入ることに耐えられなかった",
      "d15": "パニックになりそうな気がした",
      "d16": "何に対しても熱中できなかった",
      "d17": "自分は人として価値がないと思った",
      "d18": "かなり神経質になっていると感じた",
      "d19": "激しく動いたわけでもないのに、心臓の動きに変化を感じることがあ った（心拍数が速くなった、動悸がした、など）",
      "d20": "とくに理由もなく怖いと感じた",
      "d21": "人生は無意味だと思った",
      "debrief": ""
    },
    "ko": {
      "d1": "나는 긴장을 풀고 휴식을 취하기가 힘들었다.",
      "d2": "나는 입안이 마르는 것을 느꼈다.",
      "d3": "나는 전혀 긍정적인 감정을 느끼지 못했던 것 같다.",
      "d4": "나는 호흡하는데 어려움(과도하게 빠른 호흡, 운동을 하지 않는 상태에서 숨이",
      "d5": "나는 새로운 일을 시작하기가 어려웠다.",
      "d6": "나는 상황들에서 과잉반응을 하는 경향이 있었다.",
      "d7": "나는 떨림(예. 손떨림)을 경험했다.",
      "d8": "나는 신경을 너무 많이 쓰고 있음을 느꼈다",
      "d9": "나는 내가 심리적으로 공황상태가 되는 상황들과, 바보 짓을 하게 되는",
      "d10": "나는 아무것도 (미래에) 기대할 것이 없다고 느꼈다.",
      "d11": "나는 내 자신이 (마음의 평정을 잃고) 동요되는 것을 느꼈다.",
      "d12": "나는 긴장을 풀기가 어려웠다.",
      "d13": "나는 기분이 가라앉고 우울함을 느꼈다.",
      "d14": "나는 내가 하고 있는 일을 방해 받는 것을 참고 견디기 어려웠다.",
      "d15": "나는 내가 공황상태에 가깝다고 느꼈다.",
      "d16": "나는 어떤 일에도 열정적 (의욕적, 또는 열심을 가지고 임하는 것)이기가",
      "d17": "나는 한 사람의 인간으로서 가치가 없다고 느꼈다.",
      "d18": "나는 내가 다소 예민하다고 느꼈다.",
      "d19": "나는 운동을 하지 않는 상태에서 내 심장활동을 느꼈다 (예. 심장박동의 증가,",
      "d20": "나는 특별한 이유 없이 겁이났다 (무서웠다)",
      "d21": "나는 인생이 무의미하다고 느꼈다.",
      "debrief": ""
    },
    "lt": {
      "likert_1": "Visiškai man netinka arba Niekada",
      "likert_2": "Šiek tiek man tinka arba Kartais",
      "likert_3": "Visai man tinka arba Dažnai",
      "likert_4": "Labai man tinka arba Beveik visada",
      "d1": "Būdavo sunku nurimti.",
      "d2": "Jaučiau, kad džiūsta burna.",
      "d3": "Atrodė, kad visiškai negaliu patirti jokių teigiamų jausmų.",
      "d4": "Būdavo sunku kvėpuoti (pvz., net ir be fizinio aktyvumo pradėdavau dažnai kvėpuoti ar pritrūkdavo oro).",
      "d5": "Buvo sunku atrasti jėgų ką nors veikti.",
      "d6": "Buvau linkęs (-usi) perdėtai reaguoti į situaciją.",
      "d7": "Jaučiau drebulį (pvz., rankų).",
      "d8": "Jaučiausi psichologiškai išsekęs (-usi).",
      "d9": "Jaudinausi dėl situacijų, kuriose galiu supanikuoti ir apsikvailinti.",
      "d10": "Jaučiau, kad neturiu ko laukti ateityje.",
      "d11": "Pastebėdavau, kad pradedu jaudintis.",
      "d12": "Buvo sunku atsipalaiduoti.",
      "d13": "Jaučiausi nusiminęs (-usi).",
      "d14": "Buvo sunku pakęsti, kai kiti mane sutrukdydavo.",
      "d15": "Jaučiausi arti panikos ribos.",
      "d16": "Niekas manęs nedomino.",
      "d17": "Jaučiausi mažai ko vertas (-a).",
      "d18": "Jaučiausi gana lengvai suerzinamas (-a).",
      "d19": "Jaučiau savo širdies plakimą nesant fizinio aktyvumo (pvz., jaučiau padažnėjusį širdies ritmą, ritmo sutrikimą).",
      "d20": "Jaučiau baimę be aiškios priežasties.",
      "d21": "Jaučiau, kad gyvenimas yra beprasmis.",
      "debrief": ""
    },
    "lv": {
      "likert_1": "Neattiecas uz mani vispār",
      "likert_2": "Ir attiecināms uz mani nelielā mērā vai biju tam pakļauts/a īsu laiku",
      "likert_3": "Ir attiecināms uz mani diezgan lielā mērā vai biju tam pakļauts/a diezgan ilgu laiku",
      "likert_4": "Ir attiecināms uz mani ļoti lielā mērā vai biju tam pakļauts/a ļoti ilgu laiku",
      "d1": "Es atklāju, ka man ir grūti norimt",
      "d2": "Es jutu sausumu mutē",
      "d3": "Man šķita, ka nespēju izjust nekādas pozitīvas emocijas",
      "d4": "Man bija elpošanas grūtības (piemēram, pārmērīgi ātra elpošana, elpas trūkums, neesot fiziskai slodzei)",
      "d5": "Es atklāju, ka ir grūti uzņemties iniciatīvu kaut ko darīt",
      "d6": "Man bija tieksme pārspīlēti reaģēt uz dažādām situācijām",
      "d7": "Es piedzīvoju drebēšanu (piemēram, drebēja rokas)",
      "d8": "Es jutu, ka tērēju daudz nervu enerģijas",
      "d9": "Es biju noraizējies/usies par situācijām, kurās es varētu krist panikā un nostādīt sevi neveiklā situācijā",
      "d10": "Es jutu, ka man nav pēc kā ilgoties",
      "d11": "Es atklāju, ka kļūstu nemierīgs/a",
      "d12": "Es atklāju, ka man ir grūti atslābināties",
      "d13": "Es jutos nospiests/a un drūms/a",
      "d14": "Es nespēju paciest neko, kas novērsa manu uzmanību no tā, ko es darīju",
      "d15": "Es jutu, ka biju tuvu panikai",
      "d16": "Es ne ar ko nespēju aizrauties",
      "d17": "Es jutu, ka neesmu pietiekami vērtīgs/a kā cilvēks",
      "d18": "Es jutu, ka esmu diezgan viegli aizskarams/a",
      "d19": "Es jutu savu sirdsdarbību, kaut nebija fiziskas slodzes (piemēram, paātrināta vai neregulāra sirdsdarbība)",
      "d20": "Es jutos nobijies/usies bez kāda pamatota iemesla",
      "d21": "Es jutu, ka dzīvei nav nozīmes",
      "debrief": ""
    },
    "mn": {
      "d1": "Тайвширч чадахгүй байгаагаа олж мэдсэн",
      "d2": "Ам хатахыг мэдэрсэн",
      "d3": "Бүх зүйлээс ямар нэг эерэг мэдрэмж авч чадахгүй буй мэт санагдсан",
      "d4": "Амьсгалахад төвөгтэй болж байсан (Ялангуяа хэт их амьсгаадах, биеийн ачаалал аваагүй байхад амьсгаадах)",
      "d5": "Санаачлага гарган аливаа зүйлийг хийх ажиллахад хэцүү байсан",
      "d6": "Би нөхцөл байдалд хэт хариу урвал үзүүлэх хандлагатай байсан",
      "d7": "Би салгалж чичирч байсан (жишээ нь гар)",
      "d8": "Би их хэмжээний мэдрэлийн хүч зарцуулж байгаагаа мэдэрч байсан",
      "d9": "Өөрийгөө эвгүй байдалд оруулах, сандарч самгардаж магадгүй нөхцөл байдлын тухай санаа зовж байсан",
      "d10": "Надад хүсэн хүлээх зүйл юу ч байхгүй мэт мэдрэгдэж байсан",
      "d11": "Өөрийнхөө хямарсан, түгшсэн байгааг олж мэдэж байсан",
      "d12": "Тайвшрахад хэцүү байгаагаа мэдэрч байсан",
      "d13": "Би уруу царайтай, гутарсан байгаагаа мэдэрч байсан",
      "d14": "Би хийж байсан юмаа дуусгахад саад болсон зүйлийг тэвчиж чадаагүй",
      "d15": "Би учраа олохгүй байдалд ороход ойр байгааг мэдэрч байсан",
      "d16": "Би ямар нэгэн зүйлд урам зоригтой байх боломжгүй байсан",
      "d17": "Би хүн шиг үнэ цэнэтэй биш мэт мэдэрч байсан",
      "d18": "Би хэтэрхий түргэн ууртай болсон",
      "d19": "Биеийн ачаалал аваагүй боловч зүрх дэлсэхийг мэдэрч байсан (зүрхний агшилт түргэссэн эсвэл зүрх зогссон мэт мэдрэгдэх)",
      "d20": "Ямар нэг тодорхой шалтгаангүйгээр айдас хүрч байсан",
      "d21": "Амьдрал утгагүй мэт мэдрэгдсэн",
      "debrief": ""
    },
    "ne": {
      "d1": "मलाई तनावमुक्त हुन गाह्रो लाग्यो ।",
      "d2": "मेिो मुख सुख्खा भएको मलाई थाहा थथयो ।",
      "d3": "मैले कुनै पनन सकािात्मक भावनाको अनुभव गनण साककन ।",
      "d4": "मलाई सास फेनण गाह्रो भएको मैले अनुभव गिे (उदाहिर् दम बढ्ने, सास रोकिने) ।",
      "d5": "मैले कुनै पनन नयाुँ काम आफै सरु ु गनण गाह्रो पिे को अनभ ु व गिे ।",
      "d6": "कनतपय स्थथनतहरूमा मैले र्ादहनेभन्दा बढी प्रनतकाि गिे ।",
      "d7": "मैले आफू काुँपेको अनुभव गिे (उदाहिर् हातहरू)।",
      "d8": "म धेिै अताललएको मलाई अनभ ु व भयो ।",
      "d9": "म डिाउने अनन आफैलाई मूखण ठान्ने परिस्थथनतहरूको त्तवषयमा थर्स्न्तत भएुँ ।",
      "d10": "मैले आशावादी हुनुपने केही कािर् दे खखन ।",
      "d11": "मैले आफैं लाई अशान्त भएको महशुस गिे ।",
      "d12": "मैले आिाम गनण गाह्रो भएको महशुस गिे ।",
      "d13": "म आफू दुःु खी ि उदास भएको महसुस गिे ।",
      "d14": "मैले गदै गिे को कुिामा बाधा पदाण मलाई हतास लाग्ने गर्थ्यो ।",
      "d15": "मैले डिाउन लागेको वा आतंककत भएको महसुस गिे ।",
      "d16": "म कुनै पनन कुिोको त्तवषयमा उत्सादहत बन्न असक्षम भएुँ ।",
      "d17": "म एउटा नालायक व्यस्क्त िहे छु जथतो मलाई लाग्यो ।",
      "d18": "म भावुक भएको जथतो मलाई महसुस भयो ।",
      "d19": "शिीरिक परिश्रमत्तवना नै मेिो मट् ु टूको धड्कन (हृदयगनत) बढे को महसस ु गिे ।",
      "d20": "त्तवना कुनै कािर् मैले डिाएको अनुभव गिे ।",
      "d21": "मलाई जीवन अथणहीन भएको जथतो लाग्यो ।",
      "debrief": ""
    },
    "no": {
      "likert_1": "Passer ikke i det hele tatt",
      "likert_2": "Passer til en viss grad, eller noe av tiden",
      "likert_3": "Passer godt, eller en god del av tiden",
      "likert_4": "Passer best, eller mesteparten av tiden",
      "d1": "Jeg ble opprørt av trivielle ting",
      "d2": "Jeg var oppmerksom på at jeg var tørr i munnen",
      "d3": "Jeg klarte ikke å oppleve noen positive følelser",
      "d4": "Jeg hadde pustevansker (f.eks. pustet altfor fort, andpusten uten fysisk anstrengelse)",
      "d5": "Jeg kom ikke i gang med noe",
      "d6": "Jeg hadde en tendens til å overreagere",
      "d7": "Jeg følte meg skjelven (f.eks. følte at bena kom til å gi etter under meg)",
      "d8": "Jeg hadde vansker med å slappe av",
      "d9": "Jeg opplevde situasjoner som gjorde meg så engstelig at jeg var utrolig lettet når de var over",
      "d10": "Jeg følte at jeg ikke hadde noe å se frem til",
      "d11": "Jeg ble fort opprørt",
      "d12": "Jeg følte at jeg brukte mye nervøs energi",
      "d13": "Jeg var trist og deprimert",
      "d14": "Jeg ble utålmodig hvis jeg ble forsinket på noen som helst måte",
      "d15": "Jeg følte at jeg kom til å besvime",
      "d16": "Jeg følte at jeg hadde mistet interessen for nesten alt",
      "d17": "Jeg følte meg verdiløs som person",
      "d18": "Jeg tok meg lett nær av ting",
      "d19": "Jeg svettet mye (f.eks. i hendene) uten at det var varmt, og uten fysisk anstrengelse",
      "d20": "Jeg følte meg redd uten å ha særlig grunn til det",
      "d21": "Jeg følte at livet ikke var verdt å leve",
      "debrief": ""
    },
    "pt": {
      "likert_1": "Não se aplicou de maneira alguma",
      "likert_2": "Aplicou-se em algum grau, ou por pouco de tempo",
      "likert_3": "Aplicou-se em um grau considerável, ou por uma boa parte do tempo",
      "likert_4": "Aplicou-se muito, ou na maioria do tempo",
      "d1": "Aplicou-se em algum grau, ou por pouco de tempo",
      "d2": "Aplicou-se em um grau considerável, ou por uma boa parte do tempo",
      "d3": "Não consegui vivenciar nenhum sentimento positivo",
      "d4": "Tive dificuldade em respirar em alguns momentos (ex. respiração ofegante, falta de ar, sem ter feito nenhum esforço físico)",
