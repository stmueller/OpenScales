  "translations": {
    "en": {
      "long_covid_symptoms_screener_new_continuing_symptomsrecord_id": "Record ID",
      "long_covid_symptoms_screener_new_continuing_symptoms": "Now I want you to think about symptoms you may have experienced after your initial illness. Have/had you experienced any new or continuing COVID-19 symptoms? Select all that apply",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_1": "Discomfort, tightness, or pressure in chest",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_2": "New or worsening cough",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_3": "Shortness of breath",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_4": "Lack of energy or general tired feeling",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_5": "Muscle weakness",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_6": "Loss of appetite, like you just haven't been hungry",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_7": "Feeling sick to your stomach or vomiting",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_8": "Diarrhea",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_9": "Muscle aches",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_10": "Joint aches",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_11": "Headache",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_12": "Seizure",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_13": "Dizziness",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_14": "Having hallucinations, altered consciousness",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_15": "Loss of ability to smell",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_16": "Altered smell",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_17": "Loss of ability to taste",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_18": "Altered taste",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_19": "Pain in teeth",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_20": "Hair loss (alopecia)",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_21": "Heavy limbs",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_22": "Tremors",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_23": "Rapid heart rate",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_24": "Slow heart rate",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_25": "Chills/Repeated shaking with chills",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_26": "Difficulty sleeping",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_27": "Insomnia (difficulty falling and staying asleep)",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_28": "Hypersomnia (excessive sleepiness or drowsiness)",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_29": "Disturbed sleep (nightmares, night sweats, etc.)",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_30": "Foggy brain",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_31": "Feeling down or depressed",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_32": "Feeling anxious",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_33": "Always feeling hot or cold (temperature dysregulation)",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_34": "Feeling dizzy or lightheaded when standing up after sitting (orthostatic hypotension)",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_35": "Eye problems",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_36": "Prickling, burning, or numb sensation (neuropathy)",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_37": "Ringing or buzzing in ears (tinnitus)",
      "long_covid_symptoms_screener_new_continuing_symptoms_opt_38": "Skin problems",
