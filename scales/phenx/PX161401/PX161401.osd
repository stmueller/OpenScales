  "translations": {
    "en": {
      "intro": "For each of the following conditions, indicate whether you have ever had the condition or if a doctor has told you that you have the condition. Mark only one response for each. If the condition is still present, mark P (Present). If it has been a problem but is no longer a problem, mark Y (Yes). Otherwise, mark N (Never).",
      "prominent_rash_on_cheeks": "Prominent rash on cheeks for more than 1 month",
      "prominent_rash_on_cheeks_opt_1": "Present",
      "prominent_rash_on_cheeks_opt_2": "Yes",
      "prominent_rash_on_cheeks_opt_3": "Never",
      "skin_breaksout_in_sun": "Skin breaks out in the sun (not sunburn)",
      "skin_breaksout_in_sun_opt_1": "Present",
      "skin_breaksout_in_sun_opt_2": "Yes",
      "skin_breaksout_in_sun_opt_3": "Never",
