  "translations": {
    "en": {
      "info_220801": "Autonomic Nervous System Questionnaire (ANSQ):First we are going to draw your family tree. Be sure to include any abortions (spontaneous and elective) and any infant deaths including sudden infant death syndrome (SIDS). (See step by step family tree diagram.)Now that we've drawn your family tree, I'm going to ask you specific questions that you should answer first about the individual with CCHS (might be you or your child) and then about anyone you've described in your family tree.",
      "cchs_ansq_family_height": "Autonomic Nervous System Questionnaire (ANSQ) - Are you or any other adults (18 years of age or older) in your family Over 6'2\"  Or Under 4'8\"?",
      "cchs_ansq_family_weight": "Autonomic Nervous System Questionnaire (ANSQ) - Are you or any other adults (18 years of age or older) in your family  Over 200 lbs or Under 90 lbs?",
      "cchs_ansq_family_atypical_growth": "Autonomic Nervous System Questionnaire (ANSQ) - Have any minors (under 18 years of age) in your family had atypical growth patterns?",
      "cchs_ansq_family_delayed_growth": "Autonomic Nervous System Questionnaire (ANSQ) - Have any minors (under 18 years of age) in your family had delayed growth patterns?",
      "cchs_ansq_family_accelerated_growth": "Autonomic Nervous System Questionnaire (ANSQ) - Have any minors (under 18 years of age) in your family had accelerated growth patterns?",
      "cchs_ansq_family_obesity_diagnosis": "Autonomic Nervous System Questionnaire (ANSQ) - Have you or anyone in your family ever been diagnosed with obesity?",
      "cchs_ansq_family_growth_hormone_problem": "Autonomic Nervous System Questionnaire (ANSQ) - Do you or anyone in your family have growth hormone deficiency or excess?",
      "cchs_ansq_family_significant_medical_problem": "Autonomic Nervous System Questionnaire (ANSQ) - Do you or anyone in your family have any known significant medical problems?",
      "instructions_220801": "Remember when you answer these questions we would like to know if you ever experienced these problems at any time - as an infant, child or adult.",
      "cchs_ansq_bloodsugar": "Have you ever had low blood sugar (hypoglycemia) or high blood sugar?",
      "cchs_ansq_diabetes": "Have you ever had diabetes: childhood onset, pregnancy related, or adult onset?",
      "cchs_ansq_thyroid": "Have you ever had thyroid disease?",
      "cchs_ansq_phenochrom": "Have you ever had phenochromocytoma?",
      "cchs_ansq_parathyroid": "Have you ever had a parathyroid tumor?",
      "cchs_ansq_carcinoid": "Have you ever had a carcinoid?",
      "cchs_ansq_tumors": "Have you ever had tumors of neural crest origin such as neuroblastoma, ganglioneuroma, ganglioneuroblastoma?",
      "cchs_ansq_hypertension": "Have you ever had hypertension?",
      "cchs_ansq_pacemaker": "Have you ever had a cardiac pacemaker?",
      "cchs_ansq_bypass": "Have you ever had bypass surgery?",
      "cchs_ansq_heartattack": "Have you ever had a heart attack?",
      "cchs_ansq_mitralvalve": "Have you ever had a mitral valve prolapse?",
      "cchs_ansq_gicancer": "Have you ever had GI cancer? If so, which type?",
      "cchs_ansq_chestcancer": "Have you ever had cancers of/in the chest? If so, which type?",
      "cchs_ansq_braintumor": "Have you ever had a brain tumor?",
      "cchs_ansq_othercancers": "Have you ever had other cancers?",
      "cchs_ansq_waardenberg2_df1": "Have you ever had Waardenberg syndrome - a white forelock of hair?",
      "cchs_ansq_hirschsprung": "Have you ever had Hirschsprung disease?",
      "cchs_ansq_colic": "Have you ever had colic as an infant?",
      "cchs_ansq_family_unusual_skin_pigmentation": "Autonomic Nervous System Questionnaire (ANSQ) - Any unusual skin color - increase or decrease in pigmentation?",
      "cchs_ansq_family_genetic_disease": "Autonomic Nervous System Questionnaire (ANSQ) - Are there any genetic disease that run in your family?            Inborn errors?",
      "cchs_ansq_family_parkinson_disease": "Autonomic Nervous System Questionnaire (ANSQ) - Any history of Parkinson's disease?",
      "cchs_ansq_family_strabismus": "Autonomic Nervous System Questionnaire (ANSQ) - Have you ever had a wandering eye/told you have strabismus?",
      "cchs_ansq_family_other_problem": "Autonomic Nervous System Questionnaire (ANSQ) - Other",
      "cchs_csq_dizziness": "Cardiovascular System Questions - Have you experienced episodes of dizziness in the past?",
      "cchs_csq_dizziness_severity": "Cardiovascular System Questions - How severe is this problem?",
