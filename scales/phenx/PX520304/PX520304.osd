  "translations": {
    "en": {
      "instructions_520304": "Indicate how strongly you agree or disagree with each of the following statements by selecting a number between 1 (STRONGLY DISAGREE) and 7 (STRONGLY AGREE). The closer your selection to one end or the other indicates the strength of your agreement or disagreement If you don't agree or disagree with a statement, select the mid-point number 4. Please complete every item. We are interested in how you are thinking or feeling right now as you are filling out the questionnaire.",
      "marijuana_pleasant_right_now": "Smoking marijuana would be pleasant right now.",
      "marijuana_pleasant_right_now_opt_1": "STRONGLY DISAGREE",
      "marijuana_pleasant_right_now_opt_2": "2",
      "marijuana_pleasant_right_now_opt_3": "3",
      "marijuana_pleasant_right_now_opt_4": "4",
      "marijuana_pleasant_right_now_opt_5": "5",
      "marijuana_pleasant_right_now_opt_6": "6",
      "marijuana_pleasant_right_now_opt_7": "STRONGLY AGREE",
      "could_not_limit_marijuana": "I could not easily limit how much marijuana I smoked right now.",
      "could_not_limit_marijuana_opt_1": "STRONGLY DISAGREE",
      "could_not_limit_marijuana_opt_2": "2",
      "could_not_limit_marijuana_opt_3": "3",
      "could_not_limit_marijuana_opt_4": "4",
      "could_not_limit_marijuana_opt_5": "5",
      "could_not_limit_marijuana_opt_6": "6",
      "could_not_limit_marijuana_opt_7": "STRONGLY AGREE",
