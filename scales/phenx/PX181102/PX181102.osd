  "translations": {
    "en": {
      "temperament_early_childhood_clinging": "When approached by an unfamiliar person in a public place (for example, the grocery store), how often did your child cling to a parent?",
      "temperament_early_childhood_clinging_opt_1": "never",
      "temperament_early_childhood_clinging_opt_2": "very rarely",
      "temperament_early_childhood_clinging_opt_3": "less than half the time",
      "temperament_early_childhood_clinging_opt_4": "about half the time",
      "temperament_early_childhood_clinging_opt_5": "more than half the time",
      "temperament_early_childhood_clinging_opt_6": "almost always",
      "temperament_early_childhood_clinging_opt_7": "always",
      "temperament_early_childhood_clinging_opt_NA": "does not apply",
      "temperament_early_childhood_irritated": "While having trouble completing a task (e.g., building, drawing, dressing), how often did your child get easily irritated?",
      "temperament_early_childhood_irritated_opt_1": "never",
      "temperament_early_childhood_irritated_opt_2": "very rarely",
      "temperament_early_childhood_irritated_opt_3": "less than half the time",
      "temperament_early_childhood_irritated_opt_4": "about half the time",
      "temperament_early_childhood_irritated_opt_5": "more than half the time",
