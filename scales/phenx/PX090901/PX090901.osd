      "chronic_bronchitis_start_age_coded": "PAST ILLNESSES - Chronic Bronchitis  At what age did it start?",
      "emphysema_ever": "PAST ILLNESSES - Emphysema  Have you ever had emphysema?",
      "emphysema_still_have": "PAST ILLNESSES - Emphysema  Do you still have it?",
      "emphysema_doctor_confirmed": "PAST ILLNESSES - Emphysema  Was it confirmed by a doctor?",
