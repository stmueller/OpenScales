{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Mental Health Inventory (MHI-38)",
      "code": "MHI38",
      "abbreviation": "MHI-38",
      "description": "38-item measure of psychological distress and well-being developed for the Medical Outcomes Study. Most items use a 6-point frequency scale referring to the past month, but several items use alternate response formats (happiness, frequency, nervousness severity, depression severity, suicidal ideation). Yields 5 subscales: Anxiety (9 items), Depression (4 items), Loss of Behavioral/Emotional Control (10 items), General Positive Affect (10 items), and Emotional Ties (5 items). Two composite scores: Psychological Distress and Psychological Well-Being. Scores are item means transformed to 0–100: (mean − 1) / 5 × 100. Higher scores indicate better mental health.",
      "citation": "Veit, C.T., & Ware, J.E. (1983). The structure of psychological distress and well-being in general populations. Journal of Consulting and Clinical Psychology, 51(5), 730-742. https://doi.org/10.1037/0022-006X.51.5.730",
      "license": "Public Domain",
      "version": "1.0",
      "url": "https://www.rand.org/health/surveys/mos/mental-health.html",
      "license_explanation": "RAND Corporation places their health survey instruments in the public domain. RAND explicitly states these instruments are available for use without permission or fee.",
      "license_url": "https://www.rand.org/health-care/surveys_tools.html",
      "domain": "Mental Health"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 6,
      "min": 1,
      "max": 6,
      "labels": [
        "mhi_freq1",
        "mhi_freq2",
        "mhi_freq3",
        "mhi_freq4",
        "mhi_freq5",
        "mhi_freq6"
      ]
    },
    "dimensions": [
      {
        "id": "anxiety",
        "name": "Anxiety",
        "abbreviation": "ANX",
        "description": "Frequency of anxious symptoms (9 items: mhi2, mhi3, mhi4, mhi9, mhi14, mhi15, mhi22, mhi27, mhi37). Higher transformed scores indicate less anxiety."
      },
      {
        "id": "depression",
        "name": "Depression",
        "abbreviation": "DEP",
        "description": "Frequency of depressive symptoms (4 items: mhi6, mhi11, mhi12, mhi17). Higher transformed scores indicate less depression."
      },
      {
        "id": "loss_of_control",
        "name": "Loss of Behavioral/Emotional Control",
        "abbreviation": "LOC",
        "description": "Frequency of loss of control over behavior, thoughts, and emotions (10 items: mhi5, mhi13, mhi18, mhi20, mhi24, mhi26, mhi28, mhi32, mhi35, mhi38). Higher transformed scores indicate better control."
      },
      {
        "id": "positive_affect",
        "name": "General Positive Affect",
        "abbreviation": "GPA",
        "description": "Frequency of positive emotional states (10 items: mhi1, mhi7, mhi8, mhi19, mhi23, mhi29, mhi30, mhi31, mhi33, mhi34). Higher transformed scores indicate greater positive affect."
      },
      {
        "id": "emotional_ties",
        "name": "Emotional Ties",
        "abbreviation": "ET",
        "description": "Frequency of positive social and emotional connections (5 items: mhi10, mhi16, mhi21, mhi25, mhi36). Higher transformed scores indicate stronger emotional ties."
      },
      {
        "id": "psychological_distress",
        "name": "Psychological Distress",
        "abbreviation": "PD",
        "description": "Composite of Anxiety + Depression + Loss of Control (23 items). Transform: (mean−1)/5×100. Higher = less distress."
      },
      {
        "id": "psychological_wellbeing",
        "name": "Psychological Well-Being",
        "abbreviation": "PWB",
        "description": "Composite of Positive Affect + Emotional Ties (15 items). Transform: (mean−1)/5×100. Higher = greater well-being."
      }
    ],
    "items": [
