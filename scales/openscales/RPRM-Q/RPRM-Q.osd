  "translations": {
    "en": {
      "likert_1": "This does not apply to me at all",
      "likert_2": "This does not really apply to me",
      "likert_3": "Neutral",
      "likert_4": "This applies to me a bit",
      "likert_5": "This applies to me completely",
      "question_head": "Please read each statement carefully and indicate how much it applies to you.",
      "rprm1": "Winning makes me enthusiastic",
      "rprm2": "When I want something I usually go all-out to get it",
      "rprm3": "I go out of my way to get things I want",
      "rprm4": "I do everything in my power to avoid receiving punishment",
      "rprm5": "I am more inclined to work hard to get positive outcomes than others",
      "rprm6": "Positive outcomes motivate me strongly",
      "rprm7": "Obtaining rewards affects me strongly",
      "rprm8": "If I see a chance to get something I want I move on it right away",
      "rprm9": "I work hard for things that are potentially rewarding for me",
      "rprm10": "Criticism or scolding hurts me a lot",
      "rprm11": "I feel lousy after doing something wrong",
      "rprm12": "I go out of my way to avoid unpleasant things happening to me",
      "rprm13": "I do everything I can to avoid receiving criticism",
      "rprm14": "When someone points out I did something wrong I feel miserable",
      "rprm15": "Receiving punishment affects me strongly",
      "rprm16": "I avoid things that might have a negative outcome",
      "rprm17": "I feel really bad when something negative happens to me",
      "rprm18": "When good things happen to me it affects me strongly",
      "debrief": "Thank you for completing the Reward and Punishment Responsivity and Motivation Questionnaire."
    }
  }
}
