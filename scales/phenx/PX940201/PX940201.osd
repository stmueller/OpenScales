  "translations": {
    "en": {
      "medical_condition_prior_outbreak": "Prior to the COVID-19 outbreak, did you have a medical condition that could cause you to get very sick if you were to get COVID-19? (e.g., asthma, a breathing or lung problem, suppressed immune system, diabetes, high blood pressure, obesity, or some other significant health problem)",
      "medical_condition_prior_outbreak_specify": "If yes, what was that?",
      "smoker_vaper_prior_outbreak": "During or in the few months prior to the COVID-19 outbreak, were you a smoker or vaper? [check all that apply]",
      "smoker_vaper_prior_outbreak_opt_1": "No",
      "smoker_vaper_prior_outbreak_opt_2": "Yes, smoker",
      "smoker_vaper_prior_outbreak_opt_3": "Yes, vaper",
      "smoker_vaper_prior_outbreak_smoke_amount": "How much [do/did] you smoke?",
      "smoker_vaper_prior_outbreak_smoke_amount_opt_1": "A pack or more a day (a pack is 20 cigarettes)",
      "smoker_vaper_prior_outbreak_smoke_amount_opt_2": "Daily, 10-19 cigarettes",
      "smoker_vaper_prior_outbreak_smoke_amount_opt_3": "Daily, 4-9 cigarettes",
      "smoker_vaper_prior_outbreak_smoke_amount_opt_4": "Daily 1-3 cigarettes",
      "smoker_vaper_prior_outbreak_smoke_amount_opt_5": "Less than one cigarette per day",
      "smoker_vaper_prior_outbreak_vape_amount": "How often did you vape?",
      "smoker_vaper_prior_outbreak_vape_amount_opt_1": "More than once a day",
      "smoker_vaper_prior_outbreak_vape_amount_opt_2": "Daily or almost every day",
      "smoker_vaper_prior_outbreak_vape_amount_opt_3": "3-4 days a week",
      "smoker_vaper_prior_outbreak_vape_amount_opt_4": "1-2 days a week",
      "smoker_vaper_prior_outbreak_vape_amount_opt_5": "Less than that",
      "pregnant_during_after_outbreak": "During or after the COVID-19 outbreak started, were you pregnant?",
      "outbreak_live_with_someone_sick": "During the COVID-19 outbreak, did you ever live with someone that was sick with COVID19?",
      "outbreak_live_with_someone_sick_opt_3": "Not sure, I think someone I lived with might have had COVID-19",
      "outbreak_live_with_someone_sick_who": "Who was this? [check all that apply]",
      "outbreak_live_with_someone_sick_who_other": "If other, please specify",
      "outbreak_live_with_someone_sick_hospitalization": "Were they (any of them) hospitalized for COVID-19?",
      "outbreak_live_with_someone_sick_death": "Did they (any of them) die because of COVID-19?",
      "outbreak_live_with_someone_sick_death_who": "Who died? [check all that apply]",
      "family_friends_sick_coronavirus": "Has anyone in your family who you did not live with or any of your close friends been diagnosed or been sick with COVID-19?",
      "family_friends_sick_coronavirus_opt_3": "Not sure, I think someone in my family or a close friend might have had COVID-19",
      "family_friends_sick_coronavirus_who": "Who was this? [check all that apply]",
      "family_friends_sick_coronavirus_near_two_weeks_before": "Were you around (any of) them when they were sick or just before, in the 2 weeks before they got sick?",
      "family_friends_sick_coronavirus_hospitalization": "Were they (any of them) hospitalized for COVID-19?",
      "family_friends_sick_coronavirus_death": "Did they (any of them) die because of COVID-19?",
      "family_friends_sick_coronavirus_death_who": "Who died? [check all that apply]",
      "interaction_other_regular_sick": "Has anyone (else) that you interact with regularly, by this we mean at least twice a week, been diagnosed or been sick with COVID-19?",
      "interaction_other_regular_sick_opt_2": "Yes",
      "interaction_other_regular_sick_opt_3": "Not sure, I think someone I interacted with might have had COVID-19",
      "interaction_other_regular_sick_near_two_weeks_before": "Were you around (any of) them when they were sick or just before, in the 2 weeks before they got sick?",
      "opt_1": "Partner",
      "opt_2": "Parent",
      "opt_3": "Child",
      "opt_4": "Sibling",
      "opt_5": "Grandparent",
      "opt_6": "Other family members (e.g. aunt, uncle, cousin)",
      "opt_7": "Roommate",
      "opt_8": "Other",
      "grp2_opt_1": "Partner",
      "grp2_opt_2": "Parent",
      "grp2_opt_3": "Child",
      "grp2_opt_4": "Sibling",
      "grp2_opt_5": "Grandparent",
      "grp2_opt_6": "Other family members (e.g. aunt, uncle, cousin)",
      "grp2_opt_7": "Close friend",
      "grp2_opt_8": "Other"
    }
  }
