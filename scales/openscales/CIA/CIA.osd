              "min": 6,
              "max": 15,
              "label": "Above Average"
            }
          ]
        }
      },
      "cognitive_impairment": {
        "description": "Sum of 5 cognitive impairment items (range 0–15). Mean in clinical sample: 4.51.",
        "method": "sum_coded",
        "items": [
