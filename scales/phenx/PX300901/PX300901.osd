      "peer_relationships_proxy_my_child_friends_helped_each_other": "My child and his/her friends helped each other out",
      "peer_relationships_proxy_other_kids_wanted_my_child_friend": "Other kids wanted to be my child",
      "peer_relationships_proxy_my_child_liked_being_around_other_kids": "My child liked being around other kids his/her age",
      "peer_relationships_proxy_my_child_able_talk_everything_friends": "My child was able to talk about everything with his/her friends",
      "peer_relationships_proxy_my_child_was_good_friend": "My child was a good friend",
      "peer_relationships_proxy_my_child_spent_time_with_friends": "My child spent time with his/her friends",
