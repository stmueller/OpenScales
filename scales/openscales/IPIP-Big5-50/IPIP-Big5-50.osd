{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "IPIP Big Five 50-Item Personality Markers",
      "code": "IPIP-Big5-50",
      "abbreviation": "IPIP-50",
      "description": "50-item IPIP measure of the Big Five personality domains (10 items per domain). Mean-scored, range 1-5 per domain.",
      "citation": "Goldberg, L. R. (1992). The development of markers for the Big-Five factor structure. Psychological Assessment, 4(1), 26-42. https://doi.org/10.1037/1040-3590.4.1.26",
      "license": "Public Domain",
      "version": "1.0",
      "url": "https://ipip.ori.org/new_ipip-50-item-scale.htm",
      "domain": "Personality"
    },
