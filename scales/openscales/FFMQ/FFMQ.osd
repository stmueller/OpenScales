  "translations": {
    "en": {
      "ffmq_inst": "Please rate each of the following statements using the scale provided. Write the number in the blank that best describes your own opinion of what is generally true for you.",
      "ffmq_head": "Rate each statement:",
      "ffmq_r1": "Never or very rarely true",
      "ffmq_r2": "Rarely true",
      "ffmq_r3": "Sometimes true",
      "ffmq_r4": "Often true",
      "ffmq_r5": "Very often or always true",
      "debrief": "Thank you for completing this questionnaire.",
      "ffmq1": "When I'm walking, I deliberately notice the sensations of my body moving.",
      "ffmq2": "I'm good at finding words to describe my feelings.",
      "ffmq3": "I criticize myself for having irrational or inappropriate emotions.",
      "ffmq4": "I perceive my feelings and emotions without having to react to them.",
      "ffmq5": "When I do things, my mind wanders off and I'm easily distracted.",
      "ffmq6": "When I take a shower or bath, I stay alert to the sensations of water on my body.",
      "ffmq7": "I can easily put my beliefs, opinions, and expectations into words.",
      "ffmq8": "I don't pay attention to what I'm doing because I'm daydreaming, worrying, or otherwise distracted.",
      "ffmq9": "I watch my feelings without getting lost in them.",
      "ffmq10": "I tell myself I shouldn't be feeling the way I'm feeling.",
      "ffmq11": "I notice how foods and drinks affect my thoughts, bodily sensations, and emotions.",
      "ffmq12": "It's hard for me to find the words to describe what I'm thinking.",
      "ffmq13": "I am easily distracted.",
      "ffmq14": "I believe some of my thoughts are abnormal or bad and I shouldn't think that way.",
      "ffmq15": "I pay attention to sensations, such as the wind in my hair or sun on my face.",
      "ffmq16": "I have trouble thinking of the right words to express how I feel about things.",
      "ffmq17": "I make judgments about whether my thoughts are good or bad.",
      "ffmq18": "I find it difficult to stay focused on what's happening in the present.",
      "ffmq19": "When I have distressing thoughts or images, I \"step back\" and am aware of the thought or image without getting taken over by it.",
      "ffmq20": "I pay attention to sounds, such as clocks ticking, birds chirping, or cars passing.",
      "ffmq21": "In difficult situations, I can pause without immediately reacting.",
      "ffmq22": "When I have a sensation in my body, it's difficult for me to describe it because I can't find the right words.",
      "ffmq23": "It seems I am \"running on automatic\" without much awareness of what I'm doing.",
      "ffmq24": "When I have distressing thoughts or images, I feel calm soon after.",
      "ffmq25": "I tell myself that I shouldn't be thinking the way I'm thinking.",
      "ffmq26": "I notice the smells and aromas of things.",
      "ffmq27": "Even when I'm feeling terribly upset, I can find a way to put it into words.",
      "ffmq28": "I rush through activities without being really attentive to them.",
      "ffmq29": "When I have distressing thoughts or images I am able just to notice them without reacting.",
      "ffmq30": "I think some of my emotions are bad or inappropriate and I shouldn't feel them.",
      "ffmq31": "I notice visual elements in art or nature, such as colors, shapes, textures, or patterns of light and shadow.",
      "ffmq32": "My natural tendency is to put my experiences into words.",
      "ffmq33": "When I have distressing thoughts or images, I just notice them and let them go.",
      "ffmq34": "I do jobs or tasks automatically without being aware of what I'm doing.",
      "ffmq35": "When I have distressing thoughts or images, I judge myself as good or bad, depending what the thought/image is about.",
      "ffmq36": "I pay attention to how my emotions affect my thoughts and behavior.",
      "ffmq37": "I can usually describe how I feel at the moment in considerable detail.",
      "ffmq38": "I find myself doing things without paying attention.",
      "ffmq39": "I disapprove of myself when I have irrational ideas."
    }
  }
}
