      "smoking_make_you_more_awake": "Did smoking make you feel more awake?",
      "make_you_less_irritable": "Did smoking make you feel less irritable?",
      "smoking_help_you_concentrate": "Did smoking help you concentrate?",
      "reduce_your_hunger": "Did smoking reduce your hunger for food?",
      "smoking_make_you_dizzy": "Did smoking make you dizzy?",
      "smoking_make_you_nauseous": "Did smoking make you nauseous?",
      "smoking_relieve_your_craving": "Did smoking immediately relieve your craving for a cigarette?",
      "did_you_enjoy_smoking": "Did you enjoy smoking?",
      "likert_1": "Not at all",
