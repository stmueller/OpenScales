  "translations": {
    "en": {
      "decaf_coffee_frequency": "HOW OFTEN DID YOU DRINK Decaffeinated coffee (Instant & brewed)?",
      "decaf_coffee_quantity": "What is your serving size for Decaffeinated coffee (Instant & brewed)? Medium serving size is 1 Cup (8 oz)",
      "instant_coffee_frequency": "HOW OFTEN DID YOU DRINK Instant coffee, not decaffeinated (Including flavored types)?",
      "instant_coffee_quantity": "What is your serving size for Instant coffee, not decaffeinated (Including flavored types)? Medium serving size is 1 Cup (8 oz)",
      "brewed_coffee_frequency": "HOW OFTEN DID YOU DRINK Brewed coffee, not decaffeinated?",
      "brewed_coffee_quantity": "What is your serving size for Brewed coffee, not decaffeinated? Medium serving size is 1 Cup (8 oz)",
      "decaf_espresso_frequency": "HOW OFTEN DID YOU DRINK Decaffeinated espresso and espresso drinks (Latte, Mocha, Americano)?",
      "decaf_espresso_quantity": "What is your serving size for Decaffeinated espresso and espresso drinks (Latte, Mocha, Americano)? Medium serving size is 1 Shot of espresso",
      "espresso_frequency": "HOW OFTEN DID YOU DRINK Espresso and espresso drinks, not decaffeinated (Latte, Mocha, Americano)? (MARK ONE)",
      "espresso_quantity": "What is your serving size for Espresso and espresso drinks, not decaffeinated (Latte, Mocha, Americano)? Medium serving size is 1 Shot of espresso",
      "decaf_tea_frequency": "HOW OFTEN DID YOU DRINK Herbal or decaffeinated tea (Instant, bottled, and brewed)? (MARK ONE)",
      "decaf_tea_quantity": "What is your serving size for Herbal or decaffeinated tea (Instant, bottled, and brewed)? Medium serving size is 1 Cup (8 oz)",
      "green_tea_frequency": "HOW OFTEN DID YOU DRINK Green tea (Not decaffeinated-instant, bottled, and brewed)? (MARK ONE)",
      "green_tea_quantity": "What is your serving size for Green tea (Not decaffeinated-instant, bottled, and brewed)? Medium serving size is 1 Cup (8 oz)",
      "black_tea_frequency": "HOW OFTEN DID YOU DRINK Black tea such as Lipton �, or Earl Grey (Not decaffeinated-instant, bottled, and brewed)? (MARK ONE)",
      "black_tea_quantity": "What is your serving size for Black tea such as Lipton�, or Earl Grey (Not decaffeinated-instant, bottled, and brewed)? Medium serving size is 1 Cup (8 oz)",
      "high_caffeine_soda_frequency": "HOW OFTEN DID YOU DRINK Jolt�, Surge�, Mountain Dew�, Red Bull�, and other highly caffeinated sodas? (MARK ONE)",
      "high_caffeine_soda_quantity": "What is your serving size for Jolt�, Surge�, Mountain Dew�, Red Bull�, and other highly caffeinated sodas? Medium serving size is 1 Can (12 oz)",
      "regular_cola_frequency": "HOW OFTEN DID YOU DRINK Regular colas and root beer (With caffeine, not diet)? (MARK ONE)",
      "regular_cola_quantity": "What is your serving size for Regular colas and root beer (With caffeine, not diet)? Medium serving size is 1 Can (12 oz)",
      "diet_cola_frequency": "HOW OFTEN DID YOU DRINK Diet colas and diet root beer (With caffeine)? (MARK ONE)",
      "diet_cola_quantity": "What is your serving size for Diet colas and diet root beer (With caffeine)? Medium serving size is 1 Can (12 oz)",
      "regular_cola_caffeine_free_frequency": "HOW OFTEN DID YOU DRINK Regular colas and root beer (Caffeine free, not diet)? (MARK ONE)",
      "regular_cola_caffeine_free_quantity": "What is your serving size for Regular colas and root beer (Caffeine free, not diet)? Medium serving size is 1 Can (12 oz)",
      "diet_cola_caffeine_free_frequency": "HOW OFTEN DID YOU DRINK Diet colas and diet root beer (Caffeine free)? (MARK ONE)",
      "diet_cola_caffeine_free_quantity": "What is your serving size for Diet colas and diet root beer (Caffeine free)? Medium serving size is 1 Can (12 oz)",
      "likert_1": "Never or less than once per month",
      "likert_2": "1-3 times per month",
      "likert_3": "1 time per week",
      "likert_4": "2-4 times per week",
