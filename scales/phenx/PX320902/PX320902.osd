  "translations": {
    "en": {
      "section1a": "<div class=\"rich-text-field-label\"><p><span style=\"font-weight: normal;\">We are interested in knowing how your experience of having cancer affects your quality of life. Please answer all of the following questions based on your life at this time. Please circle the number from 0 to 10 that best describes your experiences:</span></p>",
      "sec_physical_well_being_title": "Physical Well Being",
      "section1b": "<div class='header'>To what extent are the following a problem for you:</div>",
      "fatigue": "Fatigue",
      "appetite_changes": "Appetite changes",
      "aches_pains": "Aches or pain",
      "sleep_changes": "Sleep changes",
      "constipation": "Constipation",
      "nausea": "Nausea",
      "menstrual_changes_fertility": "Menstrual changes or fertility",
      "overall_physical_health": "Rate your overall physical health",
      "sec_psychological_well_being_items_title": "Psychological Well Being Items",
      "difficulty_cope": "How difficult is it for you to cope as a result of your disease and treatment?",
      "quality_life": "How good is your quality of life?",
      "happiness": "How much happiness do you feel?",
      "control": "Do you feel like you are in control of things in your life?",
      "satisfaction": "How satisfying is your life?",
      "concentration": "How is your present ability to concentrate or to remember things?",
      "usefulness": "How useful do you feel?",
      "changes_appearance": "Has your illness or treatment caused changes in your appearance?",
      "changes_self_concept": "Has your illness or treatment caused changes in your self concept (the way you see your self?)",
      "section2a": "<div class='header'>How distressing were the following aspects of your illness and treatment?</div>",
      "distressing_initial_diagnosis": "Initial diagnosis",
      "distressing_cancer_treatments": "Cancer treatments (i.e., chemotherapy, radiation, or surgery)",
      "distressing_treatment_completion": "Time since my treatment was completed",
      "distressing_anxiety": "How much anxiety do you have?",
      "distressing_depression": "How much depression do you have?",
      "section2b": "<div class='header'>To what extent are you fearful of:</div>",
      "fearful_diagnostic_test": "Future diagnostic test",
      "fearful_second_cancer": "A second cancer",
      "fearful_recurrence_cancer": "Recurrence of your cancer",
      "fearful_metastasis_spreading": "Spreading (metastasis) of your cancer",
      "sec_social_concerns_title": "Social Concerns",
      "distressing_family": "How distressing has your illness been for your family?",
      "support_from_others": "Is the amount of support you receive from others sufficient to meet your needs?",
      "interfere_personal_relationships": "To what degree has your illness or treatment interfered with your personal relationships?",
      "sexuality_impact": "Is your sexuality impacted by your illness?",
      "interfere_employment": "To what degree has your illness or treatment interfered with your employment?",
      "interfere_activities_home": "To what degree has your illness or treatment interfered with your activities at home?",
      "isolation": "How much isolation do you feel is caused by your illness or treatment?",
      "financial_burden": "How much financial burden have you incurred as a result of your illness and treatment?",
      "sec_spiritual_well_being_title": "Spiritual Well Being",
      "participation_religious_activities": "How important to you is your participation in religious activities such as praying, going to church?",
      "other_spiritual_activities": "How important to you are other spiritual activities such as mediation?",
      "changes_spiritual_life": "How much has your spiritual life changed as a result of your cancer diagnosis?",
      "uncertainty_future": "How much uncertainty do you feel about your future?",
      "positive_changes": "To what extent has your illness made positive changes in your life?",
      "sense_purpose_mission": "Do you sense a purpose/mission for your life or a reason for being alive?",
      "hopeful": "How hopeful do you feel?",
      "likert_1": "0 (no problem)",
      "likert_2": "1",
      "likert_3": "2",
      "likert_4": "3",
      "likert_5": "4",
      "likert_6": "5",
      "likert_7": "6",
      "likert_8": "7",
      "likert_9": "8",
      "likert_10": "9",
      "likert_11": "10 (severe problem)"
    }
  }
}
