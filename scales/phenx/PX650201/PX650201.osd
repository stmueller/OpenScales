    "scoring": {
      "withdrawal": {
        "description": "Withdrawal: sum of 3 items.",
        "method": "sum_coded",
        "items": [
          "exercise_avoid_feeling_irritable",
          "exercise_avoid_feeling_anxious",
          "exercise_avoid_feeling_tense"
        ]
      },
      "continuance": {
        "description": "Continuance: sum of 3 items.",
        "method": "sum_coded",
        "items": [
          "exercise_despite_recurring_physical_problems",
          "exercise_when_injured",
          "exercise_despite_persistent_physical_problems"
        ]
      },
      "tolerance": {
        "description": "Tolerance: sum of 3 items.",
        "method": "sum_coded",
        "items": [
          "exercise_increase_intensity_forresults",
          "exercise_increase_frequency_forresults",
          "exercise_increase_duration_forresults"
        ]
      },
      "lack_of_control": {
        "description": "Lack of Control: sum of 3 items.",
        "method": "sum_coded",
        "items": [
          "exercise_unableto_reduce_length",
          "exercise_unableto_reduce_frequency",
          "exercise_unable_reduce_intensity"
        ]
      },
      "reduction": {
        "description": "Reduction in Other Activities: sum of 2 items.",
        "method": "sum_coded",
        "items": [
          "exercise_insteadof_social_activity",
          "exercise_thoughts_insteadof_school_work"
        ]
      },
      "time": {
        "description": "Time: sum of 3 items.",
        "method": "sum_coded",
        "items": [
          "exercise_time_spent",
          "exercise_majorityof_free_time",
          "exercise_excusefrom_social_activity"
        ]
      },
      "intention": {
        "description": "Intention Effects: sum of 3 items.",
        "method": "sum_coded",
        "items": [
          "exercise_longerthan_intended",
          "exercise_longerthan_expected",
          "exercise_longerthan_planned"
        ]
      },
      "total": {
        "description": "EDS Total: sum of all items. Higher = greater exercise dependence.",
        "method": "sum_coded",
        "items": [
          "exercise_avoid_feeling_irritable",
          "exercise_despite_recurring_physical_problems",
          "exercise_increase_intensity_forresults",
          "exercise_unableto_reduce_length",
          "exercise_insteadof_social_activity",
          "exercise_time_spent",
          "exercise_longerthan_intended",
          "exercise_avoid_feeling_anxious",
          "exercise_when_injured",
          "exercise_increase_frequency_forresults",
          "exercise_unableto_reduce_frequency",
          "exercise_thoughts_insteadof_school_work",
          "exercise_majorityof_free_time",
          "exercise_longerthan_expected",
          "exercise_avoid_feeling_tense",
          "exercise_despite_persistent_physical_problems",
          "exercise_increase_duration_forresults",
          "exercise_unable_reduce_intensity",
          "exercise_excusefrom_social_activity",
          "exercise_longerthan_planned"
        ]
      }
    },
    "_scoring_notes": "Scoring:The proposed scoring procedure for the Exercise Dependence Scale is computer based, which allows for immediate and accurate scoring. The computer scoring of the Exercise Dependence Scale is based on the SPSS (Statistic Package for the Social Sciences). A syntax file (see https://www.phenxtoolkit.org/index.php?pageLink=browse.si.all&nimh=true) has been developed by the authors that enables immediate feedback to the Exercise Dependence Scale responses once the items are entered into SPSS. The syntax enables:1. Computing a total and subscale mean scores for Exercise Dependence Scale-21. A higher score indicates more exercise-dependent symptoms.2. Categorizing participants into either at-risk for exercise dependent, nondependent-symptomatic, or nondependent-asymptomatic groups. The categorization into one of the three groups is generated by a scoring manual that consists of flowchart decision rules in which items or combinations or items determine if an individual would be classified in the dependent, symptomatic, or asymptomatic range on each of the 7 DSM IV criteria. Individuals who are classified into the dependent range on 3 or more of the DSM criteria are classified as exercise dependence. The dependent range is operationalized as indicating a score of 5 or 6 for that item. Individuals who scored in the 3 to 4 range are classified as symptomatic. These individuals may theoretically be considered at-risk for exercise dependence. Finally, individuals who score in the 1-2 range are classified as asymptomatic."
  },
  "translations": {
    "en": {
      "instructions_650201": "Exercise Dependence Scale-21Instructions. Using the scale provided below, please complete the following questions as honestly as possible. The questions refer to current exercise beliefs and behaviors that have occurred in the past 3 months. Please select your answer to the right of the question.1= never23456= always",
      "exercise_avoid_feeling_irritable": "I exercise to avoid feeling irritable.",
      "exercise_avoid_feeling_irritable_opt_1": "Never",
      "exercise_avoid_feeling_irritable_opt_2": "2",
      "exercise_avoid_feeling_irritable_opt_3": "3",
      "exercise_avoid_feeling_irritable_opt_4": "4",
      "exercise_avoid_feeling_irritable_opt_5": "5",
      "exercise_avoid_feeling_irritable_opt_6": "Always",
