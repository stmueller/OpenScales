  "translations": {
    "en": {
      "yn_head": "Please indicate whether or not you have experienced this issue during the past four weeks by selecting Yes or No.",
      "distress_head": "Indicate how much distress this issue has caused you during the <u>past four weeks</u>.",
      "yn_yes": "Yes",
      "yn_no": "No",
      "d0": "No distress",
      "d1": "Slight distress",
      "d2": "Moderate distress",
      "d3": "Severe distress",
      "cdisf1": "Thinking I will never be the same again",
      "cdisf2": "Not knowing what the future holds for me",
      "cdisf3": "Feeling lonely",
      "cdisf4": "Withdrawing from people",
      "cdisf5": "Having changes in my usual roles",
      "cdisf6": "Lacking purpose or meaning in life",
      "cdisf7": "Being unable to deal with stress",
      "cdisf8": "Being emotionally exhausted",
      "cdisf9": "Having difficulty concentrating",
      "cdisf10": "Being physically restricted",
      "cdisf11": "Not getting clear directions from my health practitioner on how to manage my heart condition",
      "cdisf12": "Thinking about dying",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
