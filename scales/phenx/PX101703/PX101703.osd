      "sexual_risk_behavior_male_women_anal_opt_99": "Refused",
      "sexual_risk_behavior_male_women_anal_opt_77": "Don't Know",
      "sexual_risk_behavior_male_women_age": "How old were you the first time you had any kind of sex, including {vaginal, anal, or oral/vaginal or anal/vaginal or oral/anal or oral/vaginal/anal/oral}?",
