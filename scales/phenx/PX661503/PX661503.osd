  "translations": {
    "en": {
      "recovery_selfassessment_patient_welcoming_staff": "Staff welcome me and help me feel comfortable in this program. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_facilities": "The physical space of this program (e.g., the lobby, waiting rooms, etc.) feels inviting and dignified. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_encouragement": "Staff encourage me to have hope and high expectations for myself and my recovery. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_flexibility": "I can change my clinician or case manager if I want to. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_treatment_records": "I can easily access my treatment records if I want to. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_threats_bribes": "Staff do not use threats, bribes, or other forms of pressure to get me to do what they want. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_staff_hopeful": "Staff believe that I can recover. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_symptoms": "Staff believe that I have the ability to manage my own symptoms. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_independence": "Staff believe that I can make my own life choices regarding things such as where to live, when to work,whom to be friends with, etc. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_decisions": "Staff listen to me and respect my decisions about my treatment and care. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_interests": "Staff regularly ask me about my interests and the things I would like to do in the community. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_risks": "Staff encourage me to take risks and try new things. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_cultural_acceptance": "This program offers specific services that fit my unique culture and life experiences. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_spiritual_needs": "I am given opportunities to discuss my spiritual needs and interests when I wish. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_sexual_needs": "I am given opportunities to discuss my sexual needs and interests when I wish. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_life_goals": "Staff help me to develop and plan for life goals beyond managing symptoms or staying stable (e.g., employment, education, physical fitness, connecting with family and friends, hobbies). Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_job_search": "Staff help me to find jobs. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_other_activities": "Staff help me to get involved in non-mental health/addiction related activities, such as church groups, adult education, sports, or hobbies. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_support_network": "Staff help me to include people who are important to me in my recovery/treatment planning (such as family, friends, clergy, or an employer). Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_role_models": "Staff introduce me to people in recovery who can serve as role models or mentors. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_network": "Staff offer to help me connect with self-help, peer support, or consumer advocacy groups and programs. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_volunteering": "Staff help me to find ways to give back to my community (i.e., volunteering, community services, neighborhood watch/cleanup). Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_new_development": "I am encouraged to help staff with the development of new groups, programs, or services. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_evaluation": "I am encouraged to be involved in the evaluation of this program�s services and service providers. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_attend_meetings": "I am encouraged to attend agency advisory boards and/or management meetings if I want. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_complete_program": "Staff talk with me about what it would take to complete or exit this program. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_personal_goals": "Staff help me keep track of the progress I am making towards my personal goals. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_assist": "Staff work hard to help me fulfill my personal goals. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_help_train": "I am/can be involved with staff trainings and education programs this agency. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_staff_training": "Staff listen, and respond, to my cultural experiences, interests, and concerns. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_specialinterest_groups": "Staff are knowledgeable about special interest groups and activities in the community. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_diversity": "Agency staff are diverse in terms of culture, ethnicity, lifestyle, and interests. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "likert_1": "1",
      "likert_2": "2",
      "likert_3": "3",
      "likert_4": "4",
      "likert_5": "5",
      "likert_6": "Not applicable",
      "likert_7": "Don't know"
    }
  }
}
