      "adults_attitude_kid_using_alcohol_opt_2": "Wrong",
      "adults_attitude_kid_using_alcohol_opt_3": "A little bit wrong",
      "adults_attitude_kid_using_alcohol_opt_4": "Not wrong at all",
      "adults_attitude_kid_using_cigarettes": "How wrong would most adults (over 21) in your neighborhood think it is for kids your age: to smoke cigarettes?",
