  "translations": {
    "en": {
      "sf12_inst": "This survey asks for your views about your health. This information will help keep track of how you feel and how well you are able to do your usual activities.",
      "sf_pf_head": "The following items are about activities you might do during a typical day. Does your health now limit you in these activities? If so, how much?",
      "sf_rp_head": "During the <b>past 4 weeks</b>, have you had any of the following problems with your work or other regular daily activities <b>as a result of your physical health</b>?",
      "sf_re_head": "During the <b>past 4 weeks</b>, have you had any of the following problems with your work or other regular daily activities <b>as a result of any emotional problems</b> (such as feeling depressed or anxious)?",
      "sf_freq_head": "These questions are about how you feel and how things have been with you during the <b>past 4 weeks</b>. How much of the time during the past 4 weeks...",
      "sf_freq1": "All of the time",
      "sf_freq2": "Most of the time",
      "sf_freq3": "A good bit of the time",
      "sf_freq4": "Some of the time",
      "sf_freq5": "A little of the time",
      "sf_freq6": "None of the time",
      "gh_1": "Excellent",
      "gh_2": "Very good",
      "gh_3": "Good",
      "gh_4": "Fair",
      "gh_5": "Poor",
      "pf_1": "Yes, limited a lot",
      "pf_2": "Yes, limited a little",
      "pf_3": "No, not limited at all",
      "yn_yes": "Yes",
      "yn_no": "No",
      "soc_1": "Not at all",
      "soc_2": "Slightly",
      "soc_3": "Moderately",
      "soc_4": "Quite a bit",
      "soc_5": "Extremely",
      "pain_1": "None",
      "pain_2": "Very mild",
      "pain_3": "Mild",
      "pain_4": "Moderate",
      "pain_5": "Severe",
      "pain_6": "Very severe",
      "sf12_1": "In general, would you say your health is:",
      "sf12_2": "Moderate activities, such as moving a table, pushing a vacuum cleaner, bowling, or playing golf",
      "sf12_3": "Climbing several flights of stairs",
      "sf12_4": "Accomplished less than you would like",
      "sf12_5": "Were limited in the kind of work or other activities",
      "sf12_6": "Accomplished less than you would like",
      "sf12_7": "Didn't do work or other activities as carefully as usual",
      "sf12_8": "During the past 4 weeks, to what extent has your physical health or emotional problems interfered with your normal social activities with family, friends, neighbors, or groups?",
      "sf12_9": "How much bodily pain have you had during the past 4 weeks?",
      "sf12_10": "...have you felt calm and peaceful?",
      "sf12_11": "...did you have a lot of energy?",
      "sf12_12": "...have you felt downhearted and blue?",
      "debrief": "Thank you for completing this survey."
    }
  }
}
