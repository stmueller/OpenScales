  "translations": {
    "en": {
      "likert_1": "Does not look like me",
      "likert_2": "",
      "likert_3": "",
      "likert_4": "",
      "likert_5": "",
      "likert_6": "",
      "likert_7": "Looks like me",
      "question_head": "Please rate how well each statement describes you.",
      "tcpq1": "I have broken rules or regulations in order to implement my ideas or proposals.",
      "tcpq2": "I think I dare more than the average person.",
      "tcpq3": "I like to explore what is around me, in my environment.",
      "tcpq4": "I skip procedures or rules because of the excitement of doing some work.",
      "tcpq5": "I have created original and positive things that are recognized by many people.",
      "tcpq6": "I tend to see things from different perspectives.",
      "tcpq7": "I have developed ideas that involve violation of certain rules.",
      "tcpq8": "In my projects I am definitely riskier than others.",
      "tcpq9": "Just for pleasure, I strive to find out how things work.",
      "tcpq10": "I don't mind breaking the rules to get a better job.",
      "tcpq11": "I get my ideas to have an impact on others.",
      "tcpq12": "Faced with a difficult choice, I follow my intuition.",
      "debrief": "Thank you for completing the Traits of Creative Potential Questionnaire."
    },
    "es": {
      "likert_1": "No se parece a mí",
      "likert_2": "",
      "likert_3": "",
      "likert_4": "",
      "likert_5": "",
      "likert_6": "",
      "likert_7": "Se parece a mí",
      "question_head": "Por favor, califique qué tan bien le describe cada afirmación.",
      "tcpq1": "Me he saltado normas o reglas para lograr implementar ideas o propuestas mías.",
      "tcpq2": "Creo que me atrevo más que el común de las personas.",
      "tcpq3": "Me gusta explorar lo que hay alrededor, en mi entorno.",
      "tcpq4": "Me salto procedimientos o normas por la emoción de realizar algún trabajo.",
      "tcpq5": "He creado cosas originales y positivas que son reconocidas por bastantes personas.",
      "tcpq6": "Tiendo a ver las cosas desde distintas perspectivas.",
      "tcpq7": "He desarrollado ideas que involucran violación de ciertas normas.",
      "tcpq8": "En mis proyectos definitivamente soy más arriesgado/a que los demás.",
      "tcpq9": "Sólo por gusto, me esfuerzo en descubrir cómo funcionan las cosas.",
      "tcpq10": "No me importa romper las reglas para lograr un mejor trabajo.",
      "tcpq11": "Logro que mis ideas tengan un impacto en los demás.",
      "tcpq12": "Ante una elección difícil, sigo mi intuición.",
      "debrief": "Gracias por completar el Cuestionario de Rasgos de Potencial Creativo."
    }
  }
}
