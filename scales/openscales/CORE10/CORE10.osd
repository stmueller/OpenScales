  "translations": {
    "en": {
      "question_head": "Over the last week...",
      "r0": "Not at all",
      "r1": "Only occasionally",
      "r2": "Sometimes",
      "r3": "Often",
      "r4": "Most or all of the time",
      "q1": "I have felt tense, anxious or nervous",
      "q2": "I have felt I have someone to turn to for support when needed",
      "q3": "I have felt able to cope when things go wrong",
      "q4": "Talking to people has felt too much for me",
      "q5": "I have felt panic or terror",
      "q6": "I made plans to end my life",
      "q7": "I have had difficulty getting to sleep or staying asleep",
      "q8": "I have felt despairing or hopeless",
      "q9": "I have felt unhappy",
      "q10": "Unwanted images or memories have been distressing me",
      "debrief": "Thank you for completing this questionnaire."
    }
