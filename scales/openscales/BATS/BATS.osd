  "translations": {
    "en": {
      "bat_r1": "Never",
      "bat_r2": "Rarely",
      "bat_r3": "Sometimes",
      "bat_r4": "Often",
      "bat_r5": "Always",
      "bat_inst": "The following statements are about how you experience your studies. Please indicate how often each statement applies to you.",
      "bat1": "Due to my studies, I feel mentally exhausted.",
      "bat2": "Everything I do for my studies requires a great deal of effort.",
      "bat3": "After a day working on my study, I find it hard to recover my energy.",
      "bat4": "While working on my studies, I feel physically exhausted.",
      "bat5": "When I get up in the morning, I lack the energy to get started with my studies.",
      "bat6": "I want to be active when I am working on my studies but somehow, I am unable to manage.",
      "bat7": "When I exert myself for my studies, I quickly get tired.",
      "bat8": "At the end of a day of working on my studies, I feel mentally exhausted and drained.",
      "bat9": "I struggle to find any enthusiasm for my studies.",
      "bat10": "When I am working on my studies, I do not think much about what I am doing, and I function on autopilot.",
      "bat11": "I feel a strong aversion towards my studies.",
      "bat12": "I feel indifferent about my studies.",
      "bat13": "I'm cynical about the importance of my studies.",
      "bat14": "When I am working on my studies, I have trouble staying focused.",
      "bat15": "When I am working on my studies, I struggle to think clearly.",
      "bat16": "I am forgetful and distracted when I am working on my studies.",
      "bat17": "When I am working on my studies, I have trouble concentrating.",
      "bat18": "I make mistakes while working on my studies because I have my mind on other things.",
      "bat19": "I feel unable to control my emotions.",
      "bat20": "I do not recognize myself in the way I react emotionally.",
      "bat21": "I become irritable when things don't go my way.",
      "bat22": "I get upset or sad without knowing why.",
      "bat23": "I may overreact unintentionally.",
      "debrief": "Thank you for completing this questionnaire.",
      "bat24": "I have trouble falling or staying asleep.",
      "bat25": "I tend to worry.",
      "bat26": "I feel tense and stressed.",
      "bat27": "I feel anxious and/or suffer from panic attacks.",
      "bat28": "Noise and crowds disturb me.",
      "bat29": "I suffer from palpitations or chest pain.",
      "bat30": "I suffer from stomach and/or intestinal complaints.",
      "bat31": "I suffer from headaches.",
      "bat32": "I suffer from muscle pain, for example in the neck, shoulder or back.",
      "bat33": "I often get sick."
    },
    "nl": {
      "bat_r1": "Nooit",
      "bat_r2": "Zelden",
      "bat_r3": "Soms",
      "bat_r4": "Vaak",
      "bat_r5": "Altijd",
      "bat_inst": "De volgende uitspraken hebben betrekking op hoe u uw werk beleeft en hoe u zich daarbij voelt. Wilt u aangeven hoe vaak iedere uitspraak op u van toepassing is door steeds het best passende antwoord aan te kruisen.",
      "bat1": "Op het werk voel ik me geestelijk uitgeput.",
      "bat2": "Alles wat ik doe op mijn werk, kost mij moeite.",
      "bat3": "Ik raak maar niet uitgerust nadat ik gewerkt heb.",
      "bat4": "Op het werk voel ik me lichamelijk uitgeput.",
      "bat5": "Als ik 's morgens opsta, mis ik de energie om aan de werkdag te beginnen.",
      "bat6": "Ik wil wel actief zijn op het werk, maar het lukt mij niet.",
      "bat7": "Als ik me inspan op het werk, dan word ik snel moe.",
      "bat8": "Op het einde van de werkdag voel ik me mentaal uitgeput en leeg.",
      "bat9": "Ik kan geen belangstelling en enthousiasme opbrengen voor mijn werk.",
      "bat10": "Op mijn werk denk ik niet veel na en functioneer ik op de automatische piloot.",
      "bat11": "Ik voel een sterke weerzin tegen mijn werk.",
      "bat12": "Mijn werk laat mij onverschillig.",
      "bat13": "Ik ben cynisch over wat mijn werk voor anderen betekent.",
      "bat14": "Op het werk kan ik er mijn aandacht moeilijk bijhouden.",
      "bat15": "Tijdens mijn werk heb ik moeite om helder na te denken.",
      "bat16": "Ik ben vergeetachtig en verstrooid tijdens mijn werk.",
      "bat17": "Als ik aan het werk ben, kan ik me moeilijk concentreren.",
      "bat18": "Ik maak fouten in mijn werk omdat ik er met mijn hoofd 'niet goed bij ben'.",
      "bat19": "Op mijn werk heb ik het gevoel geen controle te hebben over mijn emoties.",
      "bat20": "Ik herken mezelf niet in de wijze waarop ik emotioneel reageer op mijn werk.",
      "bat21": "Tijdens mijn werk raak ik snel geïrriteerd als de dingen niet lopen zoals ik dat wil.",
      "bat22": "Ik word kwaad of verdrietig op mijn werk zonder goed te weten waarom.",
      "bat23": "Op mijn werk kan ik onbedoeld te sterk emotioneel reageren.",
      "debrief": "Thank you for completing this questionnaire.",
      "bat24": "I have trouble falling or staying asleep.",
      "bat25": "I tend to worry.",
      "bat26": "I feel tense and stressed.",
      "bat27": "I feel anxious and/or suffer from panic attacks.",
      "bat28": "Noise and crowds disturb me.",
      "bat29": "I suffer from palpitations or chest pain.",
      "bat30": "I suffer from stomach and/or intestinal complaints.",
      "bat31": "I suffer from headaches.",
      "bat32": "I suffer from muscle pain, for example in the neck, shoulder or back.",
      "bat33": "I often get sick."
    },
    "de": {
      "bat_r1": "Nie",
      "bat_r2": "Selten",
      "bat_r3": "Manchmal",
      "bat_r4": "Oft",
      "bat_r5": "Immer",
      "bat_inst": "Die nachfolgenden Aussagen beziehen sich auf Ihre Arbeitssituation und wie Sie diese erleben. Bitte kreuzen Sie an, wie häufig dies für Sie zutrifft.",
      "bat1": "Bei der Arbeit fühle ich mich psychisch erschöpft.",
      "bat2": "Alles was ich bei der Arbeit tue, kostet mich große Mühe.",
      "bat3": "Nach einem Arbeitstag fällt es mir schwer mich zu erholen.",
      "bat4": "Bei der Arbeit fühle ich mich körperlich erschöpft.",
      "bat5": "Wenn ich morgens aufstehe, fehlt mir die Energie einen neuen Arbeitstag zu beginnen.",
      "bat6": "Ich will bei der Arbeit aktiv sein, aber irgendwie schaffe ich es nicht.",
      "bat7": "Wenn ich mich bei der Arbeit anstrenge, werde ich schneller müde als gewöhnlich.",
      "bat8": "Am Ende meines Arbeitstages fühle ich mich psychisch erschöpft und ausgelaugt.",
      "bat9": "Ich kann keine Begeisterung für meine Arbeit aufbringen.",
      "bat10": "Bei der Arbeit denke ich nicht darüber nach was ich tue und funktioniere wie auf „Autopilot“.",
      "bat11": "Ich fühle eine starke Abneigung gegen meine Arbeit.",
      "bat12": "Meine Arbeit ist mir gleichgültig.",
      "bat13": "Ich bezweifle, dass meine Arbeit anderen überhaupt etwas bedeutet.",
      "bat14": "Bei der Arbeit habe ich Mühe, aufmerksam zu bleiben.",
      "bat15": "Bei der Arbeit fällt es mir schwer, klar zu denken.",
      "bat16": "Bei der Arbeit bin ich vergesslich und leicht ablenkbar.",
      "bat17": "Bei der Arbeit habe ich Mühe, mich zu konzentrieren.",
      "bat18": "Ich mache Fehler in meiner Arbeit, weil ich in Gedanken bei anderen Dingen bin.",
      "bat19": "Bei meiner Arbeit habe ich das Gefühl, keine Kontrolle über meine Emotionen zu haben.",
      "bat20": "Ich erkenne mich selbst nicht wieder in der Art, wie ich bei der Arbeit emotional reagiere.",
      "bat21": "Während meiner Arbeit werde ich schnell gereizt, wenn Dinge nicht so laufen wie ich will.",
      "bat22": "Ich werde wütend oder traurig bei der Arbeit, ohne zu wissen warum.",
      "bat23": "Bei meiner Arbeit kommt es vor, dass ich emotional überreagiere, ohne es zu wollen.",
      "debrief": "Thank you for completing this questionnaire.",
      "bat24": "I have trouble falling or staying asleep.",
      "bat25": "I tend to worry.",
      "bat26": "I feel tense and stressed.",
      "bat27": "I feel anxious and/or suffer from panic attacks.",
      "bat28": "Noise and crowds disturb me.",
      "bat29": "I suffer from palpitations or chest pain.",
      "bat30": "I suffer from stomach and/or intestinal complaints.",
      "bat31": "I suffer from headaches.",
      "bat32": "I suffer from muscle pain, for example in the neck, shoulder or back.",
      "bat33": "I often get sick."
    },
    "fr": {
      "bat_r1": "Jamais",
      "bat_r2": "Rarement",
      "bat_r3": "Parfois",
      "bat_r4": "Souvent",
      "bat_r5": "Toujours",
      "bat_inst": "Les énoncés suivants sont liés à votre situation de travail et à la manière dont vous la vivez. Veuillez indiquer la fréquence à laquelle chaque déclaration s'applique à vous.",
      "bat1": "Au travail, je me sens mentalement épuisé/e.",
      "bat2": "Tout ce que je fais au travail me demande de l'effort.",
      "bat3": "Je n'arrive pas à trouver le repos après le travail.",
      "bat4": "Au travail, je me sens physiquement épuisé/e.",
      "bat5": "Quand je me lève le matin, je manque d'énergie pour commencer la journée.",
      "bat6": "Je veux être actif/ve au travail, mais je n'y arrive pas.",
      "bat7": "Lorsque je fais des efforts au travail, je me sens rapidement fatigué/e.",
      "bat8": "A la fin de la journée de travail, je me sens mentalement épuisé/e et vide.",
      "bat9": "Je n'arrive pas à faire preuve d'intérêt et d'enthousiasme pour mon travail.",
      "bat10": "Au travail, je ne réfléchis pas beaucoup et je fonctionne au pilote automatique.",
      "bat11": "Je ressens une forte aversion pour mon travail.",
      "bat12": "Mon travail me laisse indifférent/e.",
      "bat13": "Je suis cynique à propos de ce que mon travail représente pour d'autres.",
      "bat14": "Au travail, j'ai du mal à rester concentré/e.",
      "bat15": "Il m'est difficile de réfléchir clairement au travail.",
      "bat16": "J'oublie des choses et je suis distrait/e au travail.",
      "bat17": "Lorsque je suis au travail, je parviens difficilement à me concentrer.",
      "bat18": "Je commets des erreurs au travail parce que j'ai la tête ailleurs.",
      "bat19": "Au travail, j'ai la sensation de ne pas maîtriser mes émotions.",
      "bat20": "Je ne me reconnais pas dans la manière dont je réagis émotionnellement au travail.",
      "bat21": "Au travail, je m'irrite rapidement lorsque les choses ne se passent pas comme je le veux.",
      "bat22": "Je me fâche ou deviens triste au travail sans vraiment savoir pourquoi.",
      "bat23": "Il m'arrive de réagir de façon trop émotionnelle au travail sans le vouloir.",
      "debrief": "Thank you for completing this questionnaire.",
      "bat24": "I have trouble falling or staying asleep.",
      "bat25": "I tend to worry.",
      "bat26": "I feel tense and stressed.",
      "bat27": "I feel anxious and/or suffer from panic attacks.",
      "bat28": "Noise and crowds disturb me.",
      "bat29": "I suffer from palpitations or chest pain.",
      "bat30": "I suffer from stomach and/or intestinal complaints.",
      "bat31": "I suffer from headaches.",
      "bat32": "I suffer from muscle pain, for example in the neck, shoulder or back.",
      "bat33": "I often get sick."
