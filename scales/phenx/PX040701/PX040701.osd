{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Sudden Cardiac Arrest",
      "code": "PX040701",
      "abbreviation": "PX040701",
      "description": "This measure assesses if a patient died of sudden cardiac arrest by reviewing symptoms prior to death, timing of death, possible cardiac origin via autopsy evidence, and/or demonstration of a history of cardiac disease via physician questionnaire and medical records review.",
      "domain": "Health",
      "citation": "For the Multi-Ethnic Study of Atherosclerosis (MESA) hospital record abstraction diagnosis criteria, see MESA Clinical Events Manual of Procedures, Section 4.2: Criteria for Deaths. http://www.mesa-nhlbi.org/PublicDocs/MesaMOO/Appendix11_MESA_ClinicalEvents_MOP.pdf [PhenX: https://www.phenxtoolkit.org/protocols/view/40701]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/40701"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
