    "dimensions": [
      {
        "id": "total",
        "name": "Total Score"
      }
    ],
    "scoring": {
      "total": {
        "description": "Total: mean_coded of all 5 items.",
        "method": "mean_coded",
        "items": [
          "post_acute_withdrawal_signs_and_symptoms_craving_past_week_thought",
          "post_acute_withdrawal_signs_and_symptoms_craving_strength_of_craving",
          "post_acute_withdrawal_signs_and_symptoms_craving_amount_time_thinking",
          "post_acute_withdrawal_signs_and_symptoms_craving_difficulty_resisting_in_house",
          "post_acute_withdrawal_signs_and_symptoms_craving_overall_craving"
        ]
      }
    },
    "_scoring_notes": "Scoring InstructionsEach response is scored from 0 to 6. Items are added together to yield a total score ranging from 0 to 30, with higher scores indicating greater levels of alcohol craving. Craving and other alcohol use disorder symptoms were scored categorically as absent, subclinical, or present. An average item score below 3 (total < 15) indicates mild craving and was categorized as symptom absent. An average item score below 4 (total 15-20) indicates moderate craving and was categorized as subclinical. An average item score above 4 (total > 20) indicates strong craving and was categorized as symptom present."
  },
  "translations": {
    "en": {
      "post_acute_withdrawal_signs_and_symptoms_craving_past_week_thought": "During the past week how often have you thought about drinking or about how good a drink would make you feel?",
      "post_acute_withdrawal_signs_and_symptoms_craving_past_week_thought_opt_0": "Never (0 times during the past week)",
      "post_acute_withdrawal_signs_and_symptoms_craving_past_week_thought_opt_1": "Rarely (1 to 2 times during the past week)",
      "post_acute_withdrawal_signs_and_symptoms_craving_past_week_thought_opt_2": "Occasionally (3 to 4 times during the past week)",
      "post_acute_withdrawal_signs_and_symptoms_craving_past_week_thought_opt_3": "Sometimes (5 to 10 times during the past week or 1 to 2 times per day)",
      "post_acute_withdrawal_signs_and_symptoms_craving_past_week_thought_opt_4": "Often (11 to 20 times during the past week or 2 to 3 times per day)",
      "post_acute_withdrawal_signs_and_symptoms_craving_past_week_thought_opt_5": "Most of the time (20 to 40 times during the past week or 3 to 6 times per day)",
      "post_acute_withdrawal_signs_and_symptoms_craving_past_week_thought_opt_6": "Nearly all the time (more than 40 times during the past week or more than 6 times per day)",
      "post_acute_withdrawal_signs_and_symptoms_craving_strength_of_craving": "At its most severe point, how strong was your craving during the past week?",
      "post_acute_withdrawal_signs_and_symptoms_craving_strength_of_craving_opt_0": "None at all",
      "post_acute_withdrawal_signs_and_symptoms_craving_strength_of_craving_opt_1": "Slight, that is a very mild urge",
      "post_acute_withdrawal_signs_and_symptoms_craving_strength_of_craving_opt_2": "Mild urge",
      "post_acute_withdrawal_signs_and_symptoms_craving_strength_of_craving_opt_3": "Moderate urge",
      "post_acute_withdrawal_signs_and_symptoms_craving_strength_of_craving_opt_4": "Strong urge, but easily controlled",
      "post_acute_withdrawal_signs_and_symptoms_craving_strength_of_craving_opt_5": "Strong urge and difficult to control",
      "post_acute_withdrawal_signs_and_symptoms_craving_strength_of_craving_opt_6": "Strong urge and would have drunk alcohol if it were available",
      "post_acute_withdrawal_signs_and_symptoms_craving_amount_time_thinking": "During the past week how much time have you spent thinking about drinking or about how good a drink would make you feel?",
      "post_acute_withdrawal_signs_and_symptoms_craving_amount_time_thinking_opt_0": "None at all",
      "post_acute_withdrawal_signs_and_symptoms_craving_amount_time_thinking_opt_1": "Less than 20 minutes",
      "post_acute_withdrawal_signs_and_symptoms_craving_amount_time_thinking_opt_2": "21 to 45 minutes",
      "post_acute_withdrawal_signs_and_symptoms_craving_amount_time_thinking_opt_3": "46 to 90 minutes",
      "post_acute_withdrawal_signs_and_symptoms_craving_amount_time_thinking_opt_4": "90 minutes to 3 hours",
      "post_acute_withdrawal_signs_and_symptoms_craving_amount_time_thinking_opt_5": "Between 3 to 6 hours",
      "post_acute_withdrawal_signs_and_symptoms_craving_amount_time_thinking_opt_6": "More than 6 hours",
      "post_acute_withdrawal_signs_and_symptoms_craving_difficulty_resisting_in_house": "During the past week how difficult would it have been to resist taking a drink if you had known a bottle were in your house?",
      "post_acute_withdrawal_signs_and_symptoms_craving_difficulty_resisting_in_house_opt_0": "Not difficult at all",
      "post_acute_withdrawal_signs_and_symptoms_craving_difficulty_resisting_in_house_opt_1": "Very mildly difficult",
      "post_acute_withdrawal_signs_and_symptoms_craving_difficulty_resisting_in_house_opt_2": "Mildly difficult",
      "post_acute_withdrawal_signs_and_symptoms_craving_difficulty_resisting_in_house_opt_3": "Moderately difficult",
      "post_acute_withdrawal_signs_and_symptoms_craving_difficulty_resisting_in_house_opt_4": "Very difficult",
      "post_acute_withdrawal_signs_and_symptoms_craving_difficulty_resisting_in_house_opt_5": "Extremely difficult",
      "post_acute_withdrawal_signs_and_symptoms_craving_difficulty_resisting_in_house_opt_6": "Would not be able to resist",
      "post_acute_withdrawal_signs_and_symptoms_craving_overall_craving": "Keeping in mind your responses to the previous questions, please rate your overall average alcohol craving for the past week.",
      "post_acute_withdrawal_signs_and_symptoms_craving_overall_craving_opt_0": "Never thought about drinking and never had the urge to drink",
      "post_acute_withdrawal_signs_and_symptoms_craving_overall_craving_opt_1": "Rarely thought about drinking and rarely had the urge to drink",
      "post_acute_withdrawal_signs_and_symptoms_craving_overall_craving_opt_2": "Occasionally thought about drinking and occasionally had the urge to drink",
      "post_acute_withdrawal_signs_and_symptoms_craving_overall_craving_opt_3": "Sometimes thought about drinking and sometimes had the urge to drink",
      "post_acute_withdrawal_signs_and_symptoms_craving_overall_craving_opt_4": "Often thought about drinking and often had the urge to drink",
      "post_acute_withdrawal_signs_and_symptoms_craving_overall_craving_opt_5": "Thought about drinking most of the time and had the urge to drink most of the time",
      "post_acute_withdrawal_signs_and_symptoms_craving_overall_craving_opt_6": "Thought about drinking nearly all of the time and had the urge to drink nearly all of the time",
      "px511702_scoring_instructions": "Scoring InstructionsEach response is scored from 0 to 6. Items are added together to yield a total score ranging from 0 to 30, with higher scores indicating greater levels of alcohol craving. Craving and other alcohol use disorder symptoms were scored categorically as absent, subclinical, or present. An average item score below 3 (total < 15) indicates mild craving and was categorized as symptom absent. An average item score below 4 (total 15-20) indicates moderate craving and was categorized as subclinical. An average item score above 4 (total > 20) indicates strong craving and was categorized as symptom present."
    }
  }
