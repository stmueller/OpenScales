{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Physical Activity Readiness",
      "code": "PX150402",
      "abbreviation": "PX150402",
      "description": "A brief set of self-administered physical and medical questions used to determine if the person needs to visit a doctor or fitness expert prior to an increase in physical activity.",
      "domain": "Health",
      "citation": "Jamnik VJ, Warburton DER, Makarski J, McKenzie DC, Shephard RJ, Stone J, and Gledhill N. (2011). Enhancing the effectiveness of clearance for physical activity participation; background and overall process. Appl Physiol Nutr Metab , 36(S1):S3-S13. Warburton DER, Gledhill N, Jamnik VK, Bredin SSD, McKenzie DC, Stone J, Charlesworth S, and Shephard RJ. (2011). Evidence-based risk assessment and recommendations for physical activity clearance; Consensus Document. Appl Physiol Nutr Metab 36(S1):S266-s298 [PhenX: https://www.phenxtoolkit.org/protocols/view/150402]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/150402"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
