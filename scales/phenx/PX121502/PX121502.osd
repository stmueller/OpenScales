  "translations": {
    "en": {
      "instr_0121502": "For each item listed below, how does this child compare to other children of the same age? Please select the best rating based on your observations over the past month.Compared to other children, how does this child do the following:",
      "close_attention_to_detail": "Give close attention to detail and avoid careless mistakes",
      "close_attention_to_detail_opt_1": "far below",
      "close_attention_to_detail_opt_2": "below",
      "close_attention_to_detail_opt_3": "slightly below",
      "close_attention_to_detail_opt_4": "average",
      "close_attention_to_detail_opt_5": "slightly above",
      "close_attention_to_detail_opt_6": "above",
      "close_attention_to_detail_opt_7": "far above",
