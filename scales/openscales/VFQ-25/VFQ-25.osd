    "scoring": {
      "general_health": {
        "method": "sum_coded",
        "items": [
          "vfq1"
        ],
        "description": "Single item (0–4; higher = better health). Multiply by 25 for 0–100 score.",
        "item_coding": {
          "vfq1": 1
        },
        "transform": [
          {
            "op": "multiply",
            "value": 25
          }
        ]
      },
      "general_vision": {
        "method": "sum_coded",
        "items": [
          "vfq2"
        ],
        "description": "Single item (0–5; higher = better vision). Multiply by 20 for 0–100 score.",
        "item_coding": {
          "vfq2": 1
        },
        "transform": [
          {
            "op": "multiply",
            "value": 20
          }
        ]
      },
      "ocular_pain": {
        "method": "mean_coded",
        "items": [
          "vfq4",
          "vfq19"
        ],
        "description": "Mean of 2 items (0–4 each; higher = less pain/discomfort). Multiply mean by 25 for 0–100 score.",
        "item_coding": {
          "vfq4": 1,
          "vfq19": 1
        },
        "transform": [
          {
            "op": "multiply",
            "value": 25
          }
        ]
      },
      "near_activities": {
        "method": "mean_coded",
        "items": [
          "vfq5",
          "vfq6",
          "vfq7"
        ],
        "description": "Mean of 3 items (0–4 each; higher = less difficulty). Multiply mean by 25 for 0–100 score.",
        "item_coding": {
          "vfq5": 1,
          "vfq6": 1,
          "vfq7": 1
        },
        "transform": [
          {
            "op": "multiply",
            "value": 25
          }
        ]
      },
      "distance_activities": {
        "method": "mean_coded",
        "items": [
          "vfq8",
          "vfq9",
          "vfq14"
        ],
        "description": "Mean of 3 items (0–4 each; higher = less difficulty). Multiply mean by 25 for 0–100 score.",
        "item_coding": {
          "vfq8": 1,
          "vfq9": 1,
          "vfq14": 1
        },
        "transform": [
          {
            "op": "multiply",
            "value": 25
          }
        ]
      },
      "social_functioning": {
        "method": "mean_coded",
        "items": [
          "vfq11",
          "vfq13"
        ],
        "description": "Mean of 2 items (0–4 each; higher = less limitation). Multiply mean by 25 for 0–100 score.",
        "item_coding": {
          "vfq11": 1,
          "vfq13": 1
        },
        "transform": [
          {
            "op": "multiply",
            "value": 25
          }
        ]
      },
      "mental_health": {
        "method": "mean_coded",
        "items": [
          "vfq3",
          "vfq21",
