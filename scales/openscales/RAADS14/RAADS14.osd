    "scoring": {
      "autism_spectrum": {
        "method": "sum_coded",
        "items": [
          "raads1",
          "raads2",
          "raads3",
          "raads4",
          "raads5",
          "raads6",
          "raads7",
          "raads8",
          "raads9",
          "raads10",
          "raads11",
          "raads12",
          "raads13",
          "raads14"
        ],
        "description": "Sum of all items (0-42). Cutoff ≥14 is recommended for autism spectrum screening in adults. Items 1–5 and 7–14 score 0–3 in the autistic direction; item 6 is reverse-scored (Never true = 3, True only when younger = 2, True only now = 1, True now and when young = 0).",
        "norms": {
          "thresholds": [
            {
              "min": 0,
              "max": 13,
              "label": "Screen Negative"
            },
            {
              "min": 14,
              "max": 42,
              "label": "Screen Positive — consider further evaluation"
            }
          ]
        },
        "item_coding": {
          "raads1": 1,
          "raads2": 1,
          "raads3": 1,
          "raads4": 1,
          "raads5": 1,
          "raads6": 1,
          "raads7": 1,
          "raads8": 1,
          "raads9": 1,
          "raads10": 1,
          "raads11": 1,
          "raads12": 1,
          "raads13": 1,
          "raads14": 1
        }
      }
    }
  },
  "translations": {
    "en": {
      "raads14_inst": "How well does each statement describe you?",
      "raads_both": "True now and when I was young",
      "raads_now": "True only now",
      "raads_younger": "True only when I was younger than 16",
      "raads_never": "Never true",
      "raads1": "It is difficult for me to understand how other people are feeling when we are talking.",
      "raads2": "Some ordinary textures that do not bother others feel very offensive when they touch my skin.",
      "raads3": "It is very difficult for me to work and function in groups.",
      "raads4": "It is difficult to figure out what other people expect of me.",
      "raads5": "I often don't know how to act in social situations.",
      "raads6": "I can chat and make small talk with people.",
      "raads7": "When I feel overwhelmed by my senses, I have to isolate myself to shut them down.",
      "raads8": "How to make friends and socialize is a mystery to me.",
      "raads9": "When talking to someone, I have a hard time telling when it is my turn to talk or to listen.",
      "raads10": "Sometimes I have to cover my ears to block out painful noises (like vacuum cleaners or people talking too much or too loudly).",
      "raads11": "It can be very hard to read someone's face, hand, and body movements when we are talking.",
      "raads12": "I focus on details rather than the overall idea.",
      "raads13": "I take things too literally, so I often miss what people are trying to say.",
      "raads14": "I get extremely upset when the way I like to do things is suddenly changed.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}