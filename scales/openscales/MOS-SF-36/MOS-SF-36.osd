{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "MOS 36-Item Short Form Health Survey (RAND-36)",
      "code": "MOS-SF-36",
      "abbreviation": "MOS-SF-36",
      "description": "36-item health survey measuring 8 dimensions of health. Items use multiple response formats; standard RAND 0–100 subscale scoring requires post-hoc recoding in R/Python. The framework sum_coded scores are relative indicators only (higher = better health). See RAND SF-36 scoring manual for official 0–100 transformation.",
      "citation": "Hays, R. D., Sherbourne, C. D., & Mazel, R. M. (1993). The RAND 36-Item Health Survey 1.0. Health Economics, 2(3), 217–227. https://doi.org/10.1002/hec.4730020305",
      "license": "Public Domain",
      "version": "1.0",
      "url": "https://www.rand.org/health/surveys_tools/mos/36-item-short-form.html",
      "license_explanation": "RAND Corporation places their health survey instruments in the public domain. RAND explicitly states these instruments are available for use without permission or fee.",
      "license_url": "https://www.rand.org/health-care/surveys_tools/mos/36-item-short-form.html",
      "domain": "Health"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 6,
      "min": 1,
      "max": 6,
      "labels": [
        "sf36_freq1",
        "sf36_freq2",
        "sf36_freq3",
        "sf36_freq4",
        "sf36_freq5",
        "sf36_freq6"
      ],
      "question_head": "sf36_q9_head"
    },
    "dimensions": [
      {
        "id": "pf",
        "name": "Physical Functioning",
        "abbreviation": "PF",
        "description": "Extent to which health limits physical activities. Range: 10–30 (higher = less limitation).",
        "enabled_param": null
      },
      {
        "id": "rp",
        "name": "Role Limitations – Physical",
        "abbreviation": "RP",
        "description": "Extent to which physical health limits work/daily activities. Range: 0–4 (higher = fewer limitations).",
        "enabled_param": null
      },
      {
        "id": "re",
        "name": "Role Limitations – Emotional",
        "abbreviation": "RE",
        "description": "Extent to which emotional problems limit work/daily activities. Range: 0–3 (higher = fewer limitations).",
        "enabled_param": null
      },
      {
        "id": "ef",
        "name": "Energy/Fatigue",
        "abbreviation": "EF",
        "description": "Level of energy and fatigue (Vitality). Range: 4–24 (higher = more vitality).",
        "enabled_param": null
      },
      {
        "id": "ewb",
        "name": "Emotional Well-Being",
        "abbreviation": "EWB",
        "description": "Extent of anxiety and depression. Range: 5–30 (higher = better mental health).",
        "enabled_param": null
      },
      {
        "id": "sf",
        "name": "Social Functioning",
        "abbreviation": "SF",
        "description": "Extent to which health problems interfere with social activities. Range: 2–10 (higher = less interference).",
        "enabled_param": null
      },
      {
        "id": "pain",
        "name": "Pain",
        "abbreviation": "PAIN",
        "description": "Intensity of pain and its interference with normal activities. Range: 2–11 (higher = less pain).",
        "enabled_param": null
      },
      {
        "id": "gh",
        "name": "General Health",
        "abbreviation": "GH",
        "description": "Personal evaluation of health, including current health, health outlook, and resistance to illness. Range: 5–25 (higher = better perceived health).",
        "enabled_param": null
      }
    ],
