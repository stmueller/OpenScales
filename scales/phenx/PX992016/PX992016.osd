  "translations": {
    "en": {
      "long_covid_symptoms_ocular_short_eye_problemrecord_id": "Record ID",
      "long_covid_symptoms_ocular_short_eye_problem": "Do you still have the eye problems?",
      "long_covid_symptoms_ocular_short_eye_problem_opt_1": "Yes, I still have this symptom",
      "long_covid_symptoms_ocular_short_eye_problem_opt_2": "Yes, I still have the symptom but it is less severe",
      "long_covid_symptoms_ocular_short_eye_problem_opt_3": "Yes, I still have the symptom but it comes and goes",
      "long_covid_symptoms_ocular_short_eye_problem_opt_4": "No, the symptom has cleared",
      "long_covid_symptoms_ocular_short_eye_problem_normal_activites": "Does/did the eye problems affect your ability to do your normal activities?",
      "long_covid_symptoms_ocular_short_eye_problem_normal_activites_opt_1": "I have/had the symptom but I can/could still do normal activities.",
      "long_covid_symptoms_ocular_short_eye_problem_normal_activites_opt_2": "The symptom really bothers/bothered me. It is/was hard to do normal activities.",
      "long_covid_symptoms_ocular_short_eye_problem_normal_activites_opt_3": "The symptom is/was very bad. I am/was not able to do activities that I usually do.",
      "long_covid_symptoms_ocular_short_eye_problem_normal_activites_opt_4": "Refuse to answer",
      "long_covid_symptoms_ocular_short_eye_problem_clear": "When did the eye problems clear?",
      "long_covid_symptoms_ocular_short_eye_problem_clear_opt_1": "Less than 3 months after symptom started",
      "long_covid_symptoms_ocular_short_eye_problem_clear_opt_2": "Between 3 to 6 months after symptom started",
      "long_covid_symptoms_ocular_short_eye_problem_clear_opt_3": "Between 6 to 9 months after symptom started",
      "long_covid_symptoms_ocular_short_eye_problem_clear_opt_4": "Greater than 9 months after symptom started",
      "long_covid_symptoms_ocular_short_eye_problem_clear_opt_5": "Don't know",
      "long_covid_symptoms_ocular_short_eye_problem_clear_opt_6": "Refuse to answer"
    }
  }
