  "translations": {
    "en": {
      "lk_opt_1": "Strongly disagree",
      "lk_opt_2": "Disagree somewhat",
      "lk_opt_3": "Uncertain",
      "lk_opt_4": "Agree somewhat",
      "lk_opt_5": "Agree strongly",
      "genetic_counseling_stresses": "My genetic counselor seemed to understand the stresses I was facing.",
      "genetic_counseling_decisions": "My genetic counselor helped me to identify what I needed to know to make decisions about what could happen to me.",
      "genetic_counseling_health": "I felt better about my health after meeting with my genetic counselor.",
      "genetic_counseling_time": "The genetic counseling session was about the right length of time I needed.",
      "genetic_counseling_well_being": "My genetic counselor was truly concerned about my well-being.",
      "genetic_counseling_valuable": "The genetic counseling session was valuable to me."
    }
