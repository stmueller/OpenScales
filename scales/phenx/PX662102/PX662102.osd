  "translations": {
    "en": {
      "score_family_functioning_discussion": "In my family we talk to each other about things which matter to us",
      "score_family_functioning_discussion_opt_1": "Describes us: Very well",
      "score_family_functioning_discussion_opt_2": "Describes us: Well",
      "score_family_functioning_discussion_opt_3": "Describes us: Partly",
      "score_family_functioning_discussion_opt_4": "Describes us: Not well",
      "score_family_functioning_discussion_opt_5": "Describes us: Not at all",
      "score_family_functioning_truthfulness": "People often don't tell each other the truth in my family",
      "score_family_functioning_truthfulness_opt_1": "Describes us: Very well",
      "score_family_functioning_truthfulness_opt_2": "Describes us: Well",
      "score_family_functioning_truthfulness_opt_3": "Describes us: Partly",
      "score_family_functioning_truthfulness_opt_4": "Describes us: Not well",
      "score_family_functioning_truthfulness_opt_5": "Describes us: Not at all",
      "score_family_functioning_respect": "Each of us gets listened to in our family",
      "score_family_functioning_respect_opt_1": "Describes us: Very well",
      "score_family_functioning_respect_opt_2": "Describes us: Well",
      "score_family_functioning_respect_opt_3": "Describes us: Partly",
      "score_family_functioning_respect_opt_4": "Describes us: Not well",
      "score_family_functioning_respect_opt_5": "Describes us: Not at all",
      "score_family_functioning_disagreement": "It feels risky to disagree in our family",
      "score_family_functioning_disagreement_opt_1": "Describes us: Very well",
      "score_family_functioning_disagreement_opt_2": "Describes us: Well",
      "score_family_functioning_disagreement_opt_3": "Describes us: Partly",
      "score_family_functioning_disagreement_opt_4": "Describes us: Not well",
      "score_family_functioning_disagreement_opt_5": "Describes us: Not at all",
      "score_family_functioning_everyday_problems": "We find it hard to deal with everyday problems",
      "score_family_functioning_everyday_problems_opt_1": "Describes us: Very well",
      "score_family_functioning_everyday_problems_opt_2": "Describes us: Well",
      "score_family_functioning_everyday_problems_opt_3": "Describes us: Partly",
      "score_family_functioning_everyday_problems_opt_4": "Describes us: Not well",
      "score_family_functioning_everyday_problems_opt_5": "Describes us: Not at all",
      "score_family_functioning_trust": "We trust each other",
      "score_family_functioning_trust_opt_1": "Describes us: Very well",
      "score_family_functioning_trust_opt_2": "Describes us: Well",
      "score_family_functioning_trust_opt_3": "Describes us: Partly",
      "score_family_functioning_trust_opt_4": "Describes us: Not well",
      "score_family_functioning_trust_opt_5": "Describes us: Not at all",
      "score_family_functioning_miserable": "It feels miserable in our family",
      "score_family_functioning_miserable_opt_1": "Describes us: Very well",
      "score_family_functioning_miserable_opt_2": "Describes us: Well",
      "score_family_functioning_miserable_opt_3": "Describes us: Partly",
      "score_family_functioning_miserable_opt_4": "Describes us: Not well",
      "score_family_functioning_miserable_opt_5": "Describes us: Not at all",
      "score_family_functioning_anger": "When people in my family get angry they ignore each other on purpose",
      "score_family_functioning_anger_opt_1": "Describes us: Very well",
      "score_family_functioning_anger_opt_2": "Describes us: Well",
      "score_family_functioning_anger_opt_3": "Describes us: Partly",
      "score_family_functioning_anger_opt_4": "Describes us: Not well",
      "score_family_functioning_anger_opt_5": "Describes us: Not at all",
      "score_family_functioning_crisis": "We seem to go from one crisis to another in my family",
      "score_family_functioning_crisis_opt_1": "Describes us: Very well",
      "score_family_functioning_crisis_opt_2": "Describes us: Well",
      "score_family_functioning_crisis_opt_3": "Describes us: Partly",
      "score_family_functioning_crisis_opt_4": "Describes us: Not well",
      "score_family_functioning_crisis_opt_5": "Describes us: Not at all",
      "score_family_functioning_upset": "When one of us is upset they get looked after within the family",
      "score_family_functioning_upset_opt_1": "Describes us: Very well",
      "score_family_functioning_upset_opt_2": "Describes us: Well",
      "score_family_functioning_upset_opt_3": "Describes us: Partly",
      "score_family_functioning_upset_opt_4": "Describes us: Not well",
      "score_family_functioning_upset_opt_5": "Describes us: Not at all",
      "score_family_functioning_chaos": "Things always seem to go wrong for my family",
      "score_family_functioning_chaos_opt_1": "Describes us: Very well",
      "score_family_functioning_chaos_opt_2": "Describes us: Well",
      "score_family_functioning_chaos_opt_3": "Describes us: Partly",
      "score_family_functioning_chaos_opt_4": "Describes us: Not well",
      "score_family_functioning_chaos_opt_5": "Describes us: Not at all",
      "score_family_functioning_nasty": "People in the family are nasty to each other",
      "score_family_functioning_nasty_opt_1": "Describes us: Very well",
      "score_family_functioning_nasty_opt_2": "Describes us: Well",
      "score_family_functioning_nasty_opt_3": "Describes us: Partly",
      "score_family_functioning_nasty_opt_4": "Describes us: Not well",
      "score_family_functioning_nasty_opt_5": "Describes us: Not at all",
      "score_family_functioning_interference": "People in my family interfere too much in each other's lives",
      "score_family_functioning_interference_opt_1": "Describes us: Very well",
      "score_family_functioning_interference_opt_2": "Describes us: Well",
      "score_family_functioning_interference_opt_3": "Describes us: Partly",
      "score_family_functioning_interference_opt_4": "Describes us: Not well",
      "score_family_functioning_interference_opt_5": "Describes us: Not at all",
      "score_family_functioning_blame": "In my family we blame each other when things go wrong",
      "score_family_functioning_blame_opt_1": "Describes us: Very well",
      "score_family_functioning_blame_opt_2": "Describes us: Well",
      "score_family_functioning_blame_opt_3": "Describes us: Partly",
      "score_family_functioning_blame_opt_4": "Describes us: Not well",
      "score_family_functioning_blame_opt_5": "Describes us: Not at all",
      "score_family_functioning_difficult_situations": "We are good at finding new ways to deal with things that are difficult",
      "score_family_functioning_difficult_situations_opt_1": "Describes us: Very well",
      "score_family_functioning_difficult_situations_opt_2": "Describes us: Well",
      "score_family_functioning_difficult_situations_opt_3": "Describes us: Partly",
      "score_family_functioning_difficult_situations_opt_4": "Describes us: Not well",
      "score_family_functioning_difficult_situations_opt_5": "Describes us: Not at all"
    }
