  "translations": {
    "en": {
      "comorbidities_covid_impact_description": "DescriptionThis protocol helps better describe and understand the patient experience and recovery of those with confirmed or suspected COVID-19, with a specific emphasis on Long COVID experience especially with pre-existing conditions.",
      "comorbidities_covid_impact_pre_existing_condition": "Did you have any of these pre-existing conditions/diagnoses or did you experience any of the following pre-COVID?",
      "comorbidities_covid_impact_pre_existing_condition_opt_1": "Food Allergies",
      "comorbidities_covid_impact_pre_existing_condition_opt_2": "Environmental Allergies (dust, mold)",
      "comorbidities_covid_impact_pre_existing_condition_opt_3": "Chemical Allergies",
      "comorbidities_covid_impact_pre_existing_condition_opt_4": "Seasonal Allergies",
      "comorbidities_covid_impact_pre_existing_condition_opt_5": "Allergies of unknown origin",
      "comorbidities_covid_impact_pre_existing_condition_opt_6": "Other allergies",
      "comorbidities_covid_impact_pre_existing_condition_opt_7": "Insomnia",
      "comorbidities_covid_impact_pre_existing_condition_opt_8": "Lucid dreams (dreams where you are aware you are dreaming or have some control over what you dream)",
      "comorbidities_covid_impact_pre_existing_condition_opt_9": "Nightmares",
      "comorbidities_covid_impact_pre_existing_condition_opt_10": "Vivid dreams",
      "comorbidities_covid_impact_pre_existing_condition_opt_11": "Night Sweats",
      "comorbidities_covid_impact_pre_existing_condition_opt_12": "Sleep apnea",
      "comorbidities_covid_impact_pre_existing_condition_opt_13": "Acid Reflux Disease",
      "comorbidities_covid_impact_pre_existing_condition_opt_14": "Celiac Disease",
      "comorbidities_covid_impact_pre_existing_condition_opt_15": "Chron's Disease",
      "comorbidities_covid_impact_pre_existing_condition_opt_16": "Ulcerative Colitis",
