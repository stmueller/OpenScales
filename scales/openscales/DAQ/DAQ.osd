  "translations": {
    "en": {
      "likert_1": "Strongly disagree",
      "likert_2": "Disagree",
      "likert_3": "Slightly disagree",
      "likert_4": "Neither agree nor disagree",
      "likert_5": "Slightly agree",
      "likert_6": "Agree",
      "likert_7": "Strongly agree",
      "question_head": "This questionnaire will assess how people cope with situations or activities that can elicit disgust. For each of the statements presented below, please indicate the extent to which you agree or disagree with the statements.",
      "daq1": "I try to avoid activities that could make me feel disgusted.",
      "daq2": "When I think about something gross, I push those thoughts out of my mind.",
      "daq3": "When I feel disgusted, I try to do things to make the feeling go away.",
      "daq4": "I find it hard to let go of my feelings of disgust.",
      "daq5": "I tell myself I shouldn't feel disgusted when I do.",
      "daq6": "I make plans to avoid coming into contact with disgusting things.",
      "daq7": "When I feel disgusted, I try to distract myself from it.",
      "daq8": "I find it difficult to stop thinking about something that disgusts me.",
      "daq9": "I try to control my reactions when I feel disgusted.",
      "daq10": "I go out of my way to avoid encountering disgusting things.",
      "daq11": "When I experience disgust, I try to find a positive side.",
      "daq12": "When I feel disgusted, I keep replaying the experience in my mind.",
      "daq13": "I avoid certain situations that make me pay attention to disgusting things.",
      "daq14": "I distract myself to avoid thinking about things that disgust me.",
      "daq15": "I am quick to leave any situation that makes me feel disgusted.",
      "daq16": "I avoid objects that can trigger feelings of disgust.",
      "daq17": "To avoid thinking about things that revolt me, I force myself to think about something else.",
      "debrief": "Thank you for completing the Disgust Avoidance Questionnaire."
    }
  }
