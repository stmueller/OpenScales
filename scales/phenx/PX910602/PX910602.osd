      "school_work_attendance_adult_past_week_health_productivity_opt_8": "7",
      "school_work_attendance_adult_past_week_health_productivity_opt_9": "8",
      "school_work_attendance_adult_past_week_health_productivity_opt_10": "9",
      "school_work_attendance_adult_past_week_health_productivity_opt_11": "10 = Health problems completely prevented me from working",
      "school_work_attendance_adult_past_week_health_daily_activity": "During the past seven days, how much did your health problems affect your ability to do your regular daily activities, other than work at a job?",
      "school_work_attendance_adult_past_week_health_daily_activity_opt_1": "0 = Health problems had no effect on my work",
      "school_work_attendance_adult_past_week_health_daily_activity_opt_2": "1",
