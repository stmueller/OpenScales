        "dimension": "emotional_impairment"
      },
      {
        "id": "bat11",
        "text_key": "bat11",
        "type": "likert",
        "dimension": "cognitive_impairment"
      },
      {
        "id": "bat12",
        "text_key": "bat12",
        "type": "likert",
        "dimension": "cognitive_impairment"
      }
    ],
    "scoring": {
      "exhaustion": {
        "description": "Mean of items 1–4 (range 1–5). Scores ≥3.00 indicate high exhaustion.",
        "method": "mean_coded",
        "items": [
          "bat1",
          "bat2",
          "bat3",
          "bat4"
        ],
        "norms": {
          "thresholds": [
            {
              "min": 1.0,
              "max": 1.99,
              "label": "Very Low"
            },
            {
              "min": 2.0,
              "max": 2.99,
              "label": "Low"
            },
            {
              "min": 3.0,
              "max": 3.99,
              "label": "High"
            },
            {
              "min": 4.0,
              "max": 5.0,
              "label": "Very High"
            }
          ]
        }
      },
      "mental_distance": {
        "description": "Mean of items 5–7 (range 1–5). Scores ≥2.00 indicate problematic mental distancing.",
        "method": "mean_coded",
        "items": [
          "bat5",
          "bat6",
          "bat7"
        ],
        "norms": {
          "thresholds": [
            {
              "min": 1.0,
              "max": 1.99,
              "label": "Low"
            },
            {
              "min": 2.0,
              "max": 2.99,
              "label": "Moderate"
            },
            {
              "min": 3.0,
              "max": 3.99,
              "label": "High"
            },
            {
              "min": 4.0,
              "max": 5.0,
              "label": "Very High"
            }
          ]
        }
      },
      "emotional_impairment": {
        "description": "Mean of items 8–10 (range 1–5). Higher scores indicate greater difficulty regulating emotions at work.",
        "method": "mean_coded",
        "items": [
          "bat8",
          "bat9",
          "bat10"
        ]
      },
      "cognitive_impairment": {
        "description": "Mean of items 11–12 (range 1–5). Higher scores indicate greater difficulty with concentration and decision-making at work.",
        "method": "mean_coded",
        "items": [
          "bat11",
          "bat12"
        ]
      }
    }
  },
  "translations": {
    "en": {
      "bat_r1": "Never",
      "bat_r2": "Rarely",
      "bat_r3": "Sometimes",
      "bat_r4": "Often",
      "bat_r5": "Always",
      "bat_inst": "The following statements are about how you experience your work. Please indicate how often each statement applies to you.",
      "bat1": "I feel mentally exhausted at my work.",
      "bat2": "Everything I do for my work feels like a great effort.",
      "bat3": "After a working day I feel empty.",
      "bat4": "At my work I feel that I have reached the end of my tether.",
      "bat5": "I struggle to find enthusiasm for my work.",
      "bat6": "I feel a strong aversion to my work.",
      "bat7": "I feel an aversion to carrying out my tasks.",
      "bat8": "At work, I am unable to control my emotions.",
      "bat9": "I do not recognize myself in the way I react emotionally at work.",
      "bat10": "I react to people or things at work in a way that is not typical of me.",
      "bat11": "At work, I have difficulty concentrating.",
      "bat12": "I make more mistakes at work because I have my mind on other things.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
