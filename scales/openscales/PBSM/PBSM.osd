  "translations": {
    "en": {
      "pbsm_r1": "Never",
      "pbsm_r2": "Rarely",
      "pbsm_r3": "Occasionally",
      "pbsm_r4": "Sometimes",
      "pbsm_r5": "Usually",
      "pbsm_r6": "Always",
      "pbsm_question_head": "Please indicate the degree to which you engage in the following behaviors when using marijuana/cannabis.",
      "pbsm_inst": "The following questions ask about strategies you may use when using marijuana or cannabis. Please indicate how often you engage in each behavior.",
      "pbsm1": "Use marijuana only among trusted peers",
      "pbsm2": "Avoid use while spending time with family",
      "pbsm3": "Avoid using marijuana before work or school",
      "pbsm4": "Avoid using marijuana to cope with emotions such as sadness or depression",
      "pbsm5": "Limit use to weekends",
      "pbsm6": "Only purchase marijuana from a trusted source",
      "pbsm7": "Avoid using marijuana habitually (that is, every day or multiple times a week)",
      "pbsm8": "Use a little and then wait to see how you feel before using more",
      "pbsm9": "Avoid mixing marijuana with other drugs",
      "pbsm10": "Avoid using marijuana in public places",
      "pbsm11": "Take periodic breaks if it feels like you are using marijuana too frequently",
      "pbsm12": "Buy less marijuana at a time so you smoke less",
      "pbsm13": "Have a set amount of \"times\" you take a hit (e.g., passing on a shared joint if you have already hit that limit)",
      "pbsm14": "Avoid methods of using marijuana that can make you more intoxicated than you would like (e.g., using large bongs, volcano, 'edibles,' etc.)",
      "pbsm15": "Only use one time during a day/night",
      "pbsm16": "Limit the amount of marijuana you smoke in one sitting",
      "pbsm17": "Avoid using marijuana before engaging in physical activity (i.e., exercise, hiking)",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
