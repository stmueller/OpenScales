    ],
    "scoring": {
      "aote": {
        "description": "Mean of 8 items after reverse-scoring items 3, 4, 5, 7, and 8. Range 1–6. Higher scores indicate greater willingness to revise beliefs in response to evidence.",
        "method": "mean_coded",
        "items": {
          "aote3": -1,
          "aote4": -1,
          "aote5": -1,
          "aote7": -1,
          "aote8": -1,
          "aote1": 1,
