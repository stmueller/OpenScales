{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Emotional Vulnerability Scale",
      "code": "EVS",
      "abbreviation": "EVS",
      "description": "16-item self-report measure of emotional vulnerability in university students. Assesses vulnerability in relation to everyday situations across four factors: vulnerability toward criticism or denial, worsening relationships, interpersonal discord, and procrastination and emotional avoidance.",
      "citation": "Takahashi, F., Ishizu, K., Matsubara, K., Ohtsuki, T., & Shimoda, Y. (2022). The development and validation of an emotional vulnerability scale for university students. Frontiers in Psychology, 13, 941250. https://doi.org/10.3389/fpsyg.2022.941250",
      "license": "CC BY 4.0",
      "license_explanation": "Published in Frontiers in Psychology under Creative Commons Attribution 4.0 International License.",
      "license_url": "https://creativecommons.org/licenses/by/4.0/",
      "version": "1.0",
      "url": "https://doi.org/10.3389/fpsyg.2022.941250",
      "domain": "Mental Health"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 4,
      "min": 1,
      "max": 4,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "criticism",
        "name": "Vulnerability toward Criticism or Denial",
        "description": "Emotional vulnerability when facing criticism or having thoughts denied."
      },
      {
        "id": "relationships",
        "name": "Vulnerability toward Worsening Relationships",
        "description": "Emotional vulnerability related to fear of being hated and inability to refuse requests."
      },
      {
        "id": "discord",
        "name": "Vulnerability toward Interpersonal Discord",
        "description": "Emotional vulnerability in the face of interpersonal conflict and negative feedback."
      },
      {
        "id": "avoidance",
        "name": "Vulnerability toward Procrastination and Emotional Avoidance",
        "description": "Emotional vulnerability arising from avoidance and procrastination behaviors."
      }
    ],
    "items": [
