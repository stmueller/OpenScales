        ],
        "norms": {
          "thresholds": [
            {
              "min": 0,
              "max": 32,
              "label": "Below Probable PTSD Threshold"
            },
            {
              "min": 33,
              "max": 80,
              "label": "Probable PTSD — clinical follow-up recommended"
            }
          ]
        }
      }
    }
