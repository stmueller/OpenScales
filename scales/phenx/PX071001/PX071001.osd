    "scale_info": {
      "name": "Smoking Quit Attempts",
      "code": "PX071001",
      "abbreviation": "PX071001",
      "description": "These self-administered questions ask current and former smokers about their intention to quit smoking, details of past attempts to quit, and whether a health care professional advised the respondent to quit smoking.",
      "domain": "Health",
      "citation": "Prorok, P. C. (2000). Design of the PLCO Cancer Screening Trial. Control Clinical Trials, 21, 273S–309S. [PhenX: https://www.phenxtoolkit.org/protocols/view/71001]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/71001"
    },
    "implementation": {
