  "translations": {
    "en": {
      "Depression_Symptoms_Geriatric_ Satisfied": "During the past week have you felt satisfied with your life?",
      "Depression_Symptoms_Geriatric_ Satisfied_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_ Satisfied_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_ Dropped_Activities": "During the past week have you dropped many of your activities and interests?",
      "Depression_Symptoms_Geriatric_ Dropped_Activities_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_ Dropped_Activities_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_Empty": "During the past week have you felt that your life is empty??",
      "Depression_Symptoms_Geriatric_Empty_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_Empty_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_ Bored": "During the past week have you felt often bored?",
      "Depression_Symptoms_Geriatric_ Bored_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_ Bored_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_ Good_Spirits": "During the past week have you felt in good spirits most of the time?",
      "Depression_Symptoms_Geriatric_ Good_Spirits_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_ Good_Spirits_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_ Afraid": "During the past week have you felt afraid that something bad is going to happen to you?",
      "Depression_Symptoms_Geriatric_ Afraid_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_ Afraid_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_ Happy": "During the past week have you felt happy most of the time?",
      "Depression_Symptoms_Geriatric_ Happy_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_ Happy_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_ Helpless": "During the past week have you often felt helpless?",
      "Depression_Symptoms_Geriatric_ Helpless_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_ Helpless_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_ Stay_Home": "During the past week have you felt that you prefer to stay at home, rather than going out and doing new things?",
      "Depression_Symptoms_Geriatric_ Stay_Home_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_ Stay_Home_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_ Memory": "During the past week have you felt you have more problems with memory than most?",
      "Depression_Symptoms_Geriatric_ Memory_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_ Memory_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_ Alive": "During the past week have you felt you think it is wonderful to be alive now?",
      "Depression_Symptoms_Geriatric_ Alive_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_ Alive_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_ Worthless": "During the past week have you felt pretty worthless the way you are now?",
      "Depression_Symptoms_Geriatric_ Worthless_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_ Worthless_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_ Energy": "During the past week have you felt full of energy?",
      "Depression_Symptoms_Geriatric_ Energy_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_ Energy_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_Hopeless": "During the past week have you felt that your situation is hopeless?",
      "Depression_Symptoms_Geriatric_Hopeless_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_Hopeless_opt_UNDEFINED_2": "No",
      "Depression_Symptoms_Geriatric_ Better_Off": "During the past week have you felt you think that most people are better off than you are?",
      "Depression_Symptoms_Geriatric_ Better_Off_opt_UNDEFINED_1": "Yes",
      "Depression_Symptoms_Geriatric_ Better_Off_opt_UNDEFINED_2": "No"
    }
  }
