  "translations": {
    "en": {
      "LANGUAGE": "en",
      "likert_1": "Strongly disagree",
      "likert_2": "Disagree",
      "likert_3": "Somewhat disagree",
      "likert_4": "Somewhat agree",
      "likert_5": "Agree",
      "likert_6": "Strongly agree",
      "question_head": "Please indicate how much you agree or disagree with each of the following statements, using the scale from 1 (Strongly disagree) to 6 (Strongly agree).",
      "aote1": "A person should always consider new possibilities.",
      "aote2": "People should always take into consideration evidence that goes against their beliefs.",
      "aote3": "It is important to persevere in your beliefs even when evidence is brought to bear against them.",
      "aote4": "Certain beliefs are just too important to abandon no matter how good a case can be made against them.",
      "aote5": "One should disregard evidence that conflicts with your established beliefs.",
      "aote6": "Beliefs should always be revised in response to new information or evidence.",
      "aote7": "No one can talk me out of something I know is right.",
      "aote8": "I believe that loyalty to one's ideals and principles is more important than “open-mindedness”.",
      "debrief": "Thank you — your responses have been recorded."
    }
  }
