    "en": {
      "likert_1": "Did not apply to me at all",
      "likert_2": "Applied to me to some degree, or some of the time",
      "likert_3": "Applied to me to a considerable degree, or a good part of time",
      "likert_4": "Applied to me very much, or most of the time",
      "question_head": "Please read each statement and indicate how much the statement applied to you <b>over the past week</b>. There are no right or wrong answers. Do not spend too much time on any statement.",
      "response_footer": "0 = Never | 1 = Sometimes | 2 = Often | 3 = Almost Always",
      "d1": "I found myself getting upset by quite trivial things",
      "d2": "I was aware of dryness of my mouth",
      "d3": "I couldn't seem to experience any positive feeling at all",
      "d4": "I experienced breathing difficulty (eg, excessively rapid breathing, breathlessness in the absence of physical exertion)",
      "d5": "I just couldn't seem to get going",
      "d6": "I tended to over-react to situations",
      "d7": "I had a feeling of shakiness (eg, legs going to give way)",
      "d8": "I found it difficult to relax",
      "d9": "I found myself in situations that made me so anxious I was most relieved when they ended",
      "d10": "I felt that I had nothing to look forward to",
      "d11": "I found myself getting upset rather easily",
      "d12": "I felt that I was using a lot of nervous energy",
      "d13": "I felt sad and depressed",
      "d14": "I found myself getting impatient when I was delayed in any way (eg, lifts, traffic lights, being kept waiting)",
      "d15": "I had a feeling of faintness",
      "d16": "I felt that I had lost interest in just about everything",
      "d17": "I felt I wasn't worth much as a person",
      "d18": "I felt that I was rather touchy",
      "d19": "I perspired noticeably (eg, hands sweaty) in the absence of high temperatures or physical exertion",
      "d20": "I felt scared without any good reason",
      "d21": "I felt that life wasn't worthwhile",
      "d22": "I found it hard to wind down",
      "d23": "I had difficulty in swallowing",
      "d24": "I couldn't seem to get any enjoyment out of the things I did",
      "d25": "I was aware of the action of my heart in the absence of physical exertion (eg, sense of heart rate increase, heart missing a beat)",
      "d26": "I felt down-hearted and blue",
      "d27": "I found that I was very irritable",
      "d28": "I felt I was close to panic",
      "d29": "I found it hard to calm down after something upset me",
      "d30": "I feared that I would be “thrown” by some trivial but unfamiliar task",
      "d31": "I was unable to become enthusiastic about anything",
      "d32": "I found it difficult to tolerate interruptions to what I was doing",
      "d33": "I was in a state of nervous tension",
      "d34": "I felt I was pretty worthless",
      "d35": "I was intolerant of anything that kept me from getting on with what I was doing",
      "d36": "I felt terrified",
      "d37": "I could see nothing in the future to be hopeful about",
      "d38": "I felt that life was meaningless",
      "d39": "I found myself getting agitated",
      "d40": "I was worried about situations in which I might panic and make a fool of myself",
      "d41": "I experienced trembling (eg, in the hands)",
      "d42": "I found it difficult to work up the initiative to do things",
      "debrief": "Thank you for completing this questionnaire."
    },
    "es": {
      "likert_1": "= Nada aplicable a mí",
      "likert_2": "= Aplicable a mí en algún grado, o una pequeña parte del tiempo",
      "likert_3": "= Aplicable a mí en un grado considerable, o una buena parte del tiempo",
      "likert_4": "= Muy aplicable a mí, o aplicable la mayor parte del tiempo",
      "d1": "Me he alterado por cosas poco o nada importantes",
      "d2": "He notado la boca seca",
      "d3": "No he podido sentir ninguna emoción positiva",
      "d4": "He tenido dificultades para respirar (p.ej., respiración excesivamente rápida, falta de aliento sin haber hecho esfuerzo físico)",
      "d5": "No he podido empezar a hacer nada",
      "d6": "He tendido a reaccionar exageradamente ante las situaciones",
      "d7": "He tenido sensación de inestabilidad (p.ej., como si las piernas fueran a dejar de sostenerme)",
      "d8": "Me ha resultado difícil relajarme",
      "d9": "Me he encontrado en situaciones que me pusieron tan ansioso/a que me sentí muy aliviado/a cuando terminaron",
      "d10": "He sentido que no había nada que me ilusionara",
      "d11": "Me he alterado con bastante facilidad",
      "d12": "He sentido que estaba gastando una gran cantidad de energía",
      "d13": "Me he sentido triste y deprimido/a",
      "d14": "Me he sentido impaciente cuando cualquier cosa me retrasaba (p.ej., ascensores, semáforos, que algo o alguien me hiciera esperar)",
      "d15": "He tenido sensación de desmayo",
      "d16": "He sentido que había perdido el interés por casi todo",
      "d17": "He sentido que no valía mucho como persona",
      "d18": "He tendido a sentirme enfadado/a con facilidad",
      "d19": "He sudado notablemente (p.ej., manos sudorosas) sin que hubiera altas temperaturas o esfuerzo físico",
      "d20": "Me he sentido asustado/a sin una razón de peso",
      "d21": "He sentido que la vida no valía la pena",
      "d22": "Me ha costado mucho descargar la tensión",
      "d23": "He tenido dificultades para tragar",
      "d24": "No he podido disfrutar de las cosas que hacía",
      "d25": "He notado mi corazón sin hacer esfuerzo físico (p.ej., aumento del ritmo cardíaco, ausencia de algún latido)",
      "d26": "Me he sentido desanimado/a y triste",
      "d27": "Me he sentido muy irritable",
      "d28": "He sentido que estaba al borde del pánico",
      "d29": "Me ha resultado difícil calmarme después de que algo me alterara",
      "d30": "He tenido miedo de no poder desenvolverme con alguna tarea sencilla, pero no familiar",
      "d31": "He sido incapaz de entusiasmarme por nada",
      "d32": "Me ha resultado difícil soportar interrupciones en lo que estaba haciendo",
      "d33": "Me he encontrado muy nervioso/a",
      "d34": "Me he sentido bastante inútil",
      "d35": "No he tolerado nada que me impidiera seguir con lo que estaba haciendo",
      "d36": "Me he sentido aterrado/a",
      "d37": "No he podido ver nada en el futuro en lo que tener esperanza",
      "d38": "He sentido que la vida no tenía ningún sentido",
      "d39": "Me he sentido agitado/a",
      "d40": "He estado preocupado/a por situaciones en las que pudiera ser presa del pánico y hacer el ridículo",
      "d41": "He tenido temblores (p.ej., en las manos)",
      "d42": "Me ha resultado difícil tener iniciativa para hacer cosas",
      "debrief": ""
    },
    "eu": {
      "likert_1": "Ez zait egokitzen bat ere",
      "likert_2": "Nolabait edo une batzuetan egokitzen zait",
      "likert_3": "Nahiko edo une askotan egokitzen zait",
      "likert_4": "Asko edo denbora gehienean egokitzen zait",
      "d1": "Funtsik gabeko gauzengatik atsekabetzen nintzela ikusten nuen",
      "d2": "Ahoa lehor nuela konturatu nintzen.",
      "d3": "Bazirudien ezin nuela sentimendu positiborik izan.",
      "d4": "Zailtasunak nituen arnas egiteko (adibidez, arnasketa azkarregia,",
      "d5": "Bazirudien ezin nuela martxan jarri.",
      "d6": "Egoeren aurrean gehiegizko erreakzioak nituen.",
      "d7": "Dardarak sentitzen nituen (adibidez, hankek ez zidatela ondo erantzungo).",
      "d8": "Zaila egiten zitzaidan erlaxatzea.",
      "d9": "Oso larri sentitu nintzen egoera batzuetan eta asko lasaitzen nintzen",
      "d10": "Ezer espero ezin nezakeela sentitzen nuen.",
      "d11": "Nahiko erraz atsekabetzen nintzela nabaritzen nuen.",
      "d12": "Energia nerbioso pila erabiltzen ari nintzela sentitzen nuen.",
      "d13": "Triste eta deprimituta sentitzen nintzen.",
      "d14": "Edonola atzeratzen nindutenean urduritzen nintzela nabaritzen nuen",
      "d15": "Zorabio sentsazioa izan nuen.",
      "d16": "Ia denaren inguruko interesa galdu nuela sentitzen nuen.",
      "d17": "Pertsona gisa asko balio ez nuela sentitzen nuen.",
      "d18": "Nahiko haserrekor nengoela sentitzen nuen.",
      "d19": "Nahiko izerditzen nintzen (adibidez, esku izerditsuak) nahiz eta bero",
      "d20": "Beldur nintzen arrazoi onik gabe.",
      "d21": "Bizitzak merezi ez zuela sentitzen nuen.",
      "d22": "Zaila egiten zitzaidan martxa jaistea.",
      "d23": "Irensteko arazoak nituen.",
      "d24": "Bazirudien ezin nuela ongi pasa egiten nituen gauzekin.",
      "d25": "Nire bihotzaren jarduna sentitzen nuen ahalegin fisikorik egin gabe (adibidez,",
      "d26": "Burumakur eta etsita sentitzen nintzen.",
      "d27": "Oso suminkor nengoela nabaritzen nuen.",
      "d28": "Panikotik gertu nengoela sentitzen nuen.",
      "d29": "Zaila egiten zitzaidan atsekabetu ninduen gertakariren baten ostean lasaitzea.",
      "d30": "Beldur nintzen zeregin erraz baina ezezagun batek ez ote ninduen",
      "d31": "Ezerk ez ninduen gogoberotzen.",
      "d32": "Zaila zitzaidan zer edo zer egiten ari nintzenean etenen bat jasatea.",
      "d33": "Nerbio-tentsioko egoera batean nengoen.",
      "d34": "Baliorik ez nuela sentitzen nuen.",
      "d35": "Ez nintzen gai egiten ari nintzena gelditzen zuen edozer jasateko.",
      "d36": "Oso beldurtuta nengoen.",
      "d37": "Etorkizunean ez nuen itxaropenik ikusten.",
      "d38": "Bizitzak esanahirik ez zuela sentitzen nuen.",
      "d39": "Asaldatuta nengoela nabaritzen nuen.",
      "d40": "Panikora eraman eta barregarri geratzea egin ahal ninduten egoerengatik",
      "d41": "Dardarak nituen (adibidez, eskuetan).",
      "d42": "Zaila zitzaidan gauzak egiteko iniziatiba izatea.",
      "debrief": ""
    },
    "fa": {
      "likert_1": "اصلاً در مورد من صدق نمی‌کرد",
      "likert_2": "تا حدودی یا بعضی وقت‌ها در مورد من صدق می‌کرد",
      "likert_3": "قابل توجهی یا بیشتر وقت‌ها در مورد من صدق می‌کرد",
      "likert_4": "خیلی زیاد یا اکثر مواقع در مورد من صدق می‌کرد",
      "d1": "برای مسائل جزئی کاملاً ناراحت می‌شدم",
      "d2": "احساس می‌کردم دهانم خشک شده بود",
      "d3": "اصلاً احساس مثبتی نداشتم",
      "d4": "نفس کشیدن برایم مشکل بود (برای مثال تنفس خیلی سریع یا احساس خفگی در هنگام عدم فعالیت)",
      "d5": "نمی‌توانستم برخاسته و کاری انجام دهم",
      "d6": "به اتفاقات واکنش شدید نشان می‌دادم",
      "d7": "احساس می‌کردم یک دفعه تکان می‌خورم (بطور مثال تکان خوردن پاها)",
      "d8": "نمی‌توانستم آرامش پیدا کنم",
      "d9": "موقعیت‌هایی وجود داشت که مرا بسیار مضطرب می‌کرد و بعد از رهایی از آن‌ها تسکین می‌یافتم",
      "d10": "احساس می‌کردم چیزی ندارم که به آن امیدوار باشم",
      "d11": "احساس می‌کردم که خیلی زود ناراحت می‌شوم",
      "d12": "احساس می‌کردم که انرژی عصبی زیادی مصرف می‌کنم",
      "d13": "احساس غمگینی و افسردگی می‌کردم",
      "d14": "اگر چیزی به تأخیر می‌افتاد اعصابم خرد می‌شد (بطور مثال برای آسانسور، چراغ قرمز یا مواقعی که منتظرم می‌داشتند)",
      "d15": "احساس ضعف می‌کردم",
      "d16": "احساس می‌کردم که علاقه خود را نسبت به همه چیز از دست داده‌ام",
      "d17": "احساس می‌کردم هیچ ارزشی ندارم",
      "d18": "احساس می‌کردم زود رنجیده می‌شوم",
      "d19": "در مواقعی که دما بالا نبود یا تحرک جسمی نداشتم خیلی عرق می‌کردم (مثل عرق کف دست)",
      "d20": "بدون دلیل احساس ترس می‌کردم",
      "d21": "احساس می‌کردم زندگی ارزشی ندارد",
      "d22": "رفع خستگی بعد از فعالیت برایم سخت بود",
      "d23": "در بلع مشکل داشتم",
      "d24": "از کارهایی که انجام می‌دادم اصلاً لذتی نمی‌بردم",
      "d25": "در مواقعی که حتی فعالیت بدنی نداشتم ضربان قلب خود را احساس می‌کردم (بطور مثال طپش قلب یا احساس نامنظم بودن ضربان)",
      "d26": "احساس دلتنگی و غمگینی می‌کردم",
      "d27": "احساس می‌کردم خیلی زود از کوره در می‌روم (می‌شوم عصبانی)",
      "d28": "احساس می‌کردم که نزدیک است دچار وحشت شوم",
      "d29": "اگر از چیزی ناراحت می‌شدم نمی‌توانستم خونسردی خودم را حفظ کنم",
      "d30": "از انجام کارهای ناآشنا هرچند جزئی می‌ترسیدم",
      "d31": "نمی‌توانستم خودم را به چیزی علاقمند کنم",
      "d32": "تحمل هر چیزی که در کارم تداخل می‌کرد برایم دشوار بود",
      "d33": "در یک حالت تنش عصبی به سر می‌بردم",
      "d34": "احساس می‌کردم خیلی بی‌ارزش هستم",
      "d35": "اگر چیزی مانع ادامه کارم می‌شد نمی‌توانستم آن را تحمل کنم",
      "d36": "احساس وحشت می‌کردم",
      "d37": "در آینده برای خود چیزی نمی‌دیدم که به آن امیدوار باشم",
      "d38": "احساس می‌کردم که زندگی بی‌معنی است",
      "d39": "احساس نگرانی و آشفتگی می‌کردم",
      "d40": "نگران موقعیت‌هایی بودم که ممکن بود هول شده و دست و پا چلفتی به نظر برسم",
      "d41": "لرزش داشتم (بطور مثال در دست‌ها)",
      "d42": "شروع هر کار تازه‌ای برایم سخت بود",
      "debrief": ""
    },
    "fi": {
      "likert_1": "Ei pitänyt paikkaansa lainkaan",
      "likert_2": "Piti paikkansa jonkin verran tai silloin tällöin",
      "likert_3": "Piti paikkansa huomattavassa määrin tai usein",
      "likert_4": "Piti paikkansa hyvin paljon tai melkein koko ajan",
      "d1": "Melko vähäpätöiset asiat saivat minut huolestuneeksi",
      "d2": "Huomasin, että suutani kuivasi",
      "d3": "Minusta tuntui, etten pystynyt kokemaan myönteisiä tunteita lainkaan",
      "d4": "Minulla oli hengitysvaikeuksia (esim. hyvin nopeaa hengittämistä tai hengästymistä ilman fyysistä rasitusta)",
      "d5": "Minusta tuntui siltä, etten saanut mitään aikaiseksi",
      "d6": "Minulla oli taipumusta ylireagoida asioihin",
      "d7": "Minulla oli heikotuksen tunteita (esim. että jalat pettävät alta)",
      "d8": "Minun oli vaikea rentoutua",
      "d9": "Olin niin ahdistunut joissakin tilanteissa, että olin hyvin helpottunut päästessäni niistä pois",
      "d10": "Minusta tuntui, ettei minulla ole mitään odotettavaa tulevaisuudelta",
      "d11": "Jouduin pois tolaltani melko helposti",
      "d12": "Olin hyvin levoton ja hermostunut",
      "d13": "Tunsin itseni surulliseksi ja masentuneeksi",
      "d14": "Tunsin itseni kärsimättömäksi, kun jouduin odotustilanteeseen",
      "d15": "Koin huimauksen tunnetta",
      "d16": "Minusta tuntui, että olen menettänyt kiinnostukseni melkein kaikkeen",
      "d17": "Minusta tuntui, etten ole kovinkaan arvokas ihmisenä",
      "d18": "Loukkaannuin melko herkästi",
      "d19": "Hikoilin huomattavasti (esim. kädet) ilman fyysistä ponnistelua tai ilman, että ympäristön lämpötila oli korkea",
      "d20": "Minua pelotti, vaikkei siihen ollut järkevää syytä",
      "d21": "Minusta tuntui, ettei elämä ole elämisen arvoista",
      "d22": "Minun oli vaikea rentoutua",
      "d23": "Minulla oli nielemisvaikeuksia",
      "d24": "En nauttinut tekemistäni asioista",
      "d25": "Olin tietoinen sydämeni toiminnasta (sydän tykytti tai löi epätahtiin), vaikka ei",
      "d26": "Olin alakuloinen ja surullinen",
      "d27": "Huomasin, että ärsyynnyin helposti",
      "d28": "Tunsin olevani lähellä paniikkia",
      "d29": "Jos jokin sai minut pois tolaltani, minun oli vaikea rauhoittua",
      "d30": "Pelkäsin, että vähäpätöinen, mutta minulle vieras tehtävä saa minut pois",
      "d31": "En pystynyt innostumaan mistään",
      "d32": "Minun oli vaikea sietää keskeytyksiä",
      "d33": "Minulla oli “pinna kireällä”",
      "d34": "Tunsin itseni melko arvottomaksi",
      "d35": "En voinut sietää mitään, mikä esti minua jatkamasta sitä, mitä olin tekemässä",
      "d36": "Tunsin olevani kauhuissani",
      "d37": "Minusta tuntui, ettei tulevaisuudelta ole mitään odotettavaa",
      "d38": "Minusta tuntui, ettei elämällä ole merkitystä",
      "d39": "Vauhkoonnuin helposti",
      "d40": "Murehdin tilanteita, joissa saattaisin joutua paniikkiin ja tehdä itseni",
      "d41": "Minulla oli vapinan tunnetta (esim. käsien vapinaa)",
