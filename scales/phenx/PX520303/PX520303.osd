      "heroin_would_not_satisfying_opt_5": "5",
      "heroin_would_not_satisfying_opt_6": "6",
      "heroin_would_not_satisfying_opt_7": "STRONGLY AGREE",
      "would_not_enjoy_heroin": "I would not enjoy using heroin now.",
      "would_not_enjoy_heroin_opt_1": "STRONGLY DISAGREE",
      "would_not_enjoy_heroin_opt_2": "2",
