    "_scoring_notes": "Scoring Procedure and InterpretationThe Prescription Stimulant Expectancy Questionnaire (PSEQ) score is calculated by averaging the item scores. Half of the items (1, 2, 4, 5, 6, 7, 11, 13, 23, 24, 28, 30, 31, 32, 34, 35, 36, 37, 38, and 39) are scored with 0 = \"Not at all,\" 1= \"Sometimes,\" and 2 = \"Very often or always.\" The other half of the items (3, 8, 9, 10, 12, 14, 15, 16, 17, 18, 19, 20, 21, 22, 25, 26, 27, 29, 33, and 40) are reverse-scored with 2 = \"Not at all,\" 1 = \"Sometimes,\" and 0 = \"Very often or always.\"",
    "likert_options": {
      "points": 3,
      "min": 0,
      "max": 2,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3"
      ]
    }
  },
  "translations": {
    "en": {
      "info_520405": "The following pages contain statements about the effects of prescription stimulants, including Adderall�, Ritalin�, Concerta�, and Dexedrine�.",
      "used_prescription_stimulant": "Have you ever used a prescription stimulant (like Adderall� or Ritalin�) for any reason?",
      "used_prescription_stimulant_opt_1": "YES",
      "used_prescription_stimulant_opt_2": "NO",
      "instructions_520405": "Read each statement carefully and respond according to your own personal thoughts, feelings, and beliefs about prescription stimulants now. We are interested in what you think about prescription stimulants, regardless of what other people might think.Whether or not you have had actual experiences with prescription stimulants yourself, you are to answer in terms of your beliefs about prescription stimulants. It is important that you respond to every question. There are no right or wrong answers.Please fill out the following questions according to your beliefs about the stimulant drug you know best. PLEASE BE HONEST. REMEMBER, YOUR ANSWERS ARE CONFIDENTIAL. RESPOND TO THESE ITEMS ACCORDING TO WHAT YOU PERSONALLY BELIEVE TO BE TRUE ABOUT A MODERATE AMOUNT OF STIMULANTS - HOWEVER YOU DEFINE MODERATE.",
      "distractions_disappear_stimulants": "Distractions disappear.",
      "distractions_disappear_stimulants_opt_0": "Not at all",
      "distractions_disappear_stimulants_opt_1": "Sometimes",
      "distractions_disappear_stimulants_opt_2": "Very often or always",
      "absorb_material_first_time_stimulants": "I absorb new material the first time through.",
      "absorb_material_first_time_stimulants_opt_0": "Not at all",
      "absorb_material_first_time_stimulants_opt_1": "Sometimes",
      "absorb_material_first_time_stimulants_opt_2": "Very often or always",
      "cant_focus_stimulants": "I can't focus on more than one thing at a time.",
      "cant_focus_stimulants_opt_0": "Not at all",
      "cant_focus_stimulants_opt_1": "Sometimes",
      "cant_focus_stimulants_opt_2": "Very often or always",
      "focus_very_wel_stimulants": "I can focus very well.",
      "focus_very_wel_stimulants_opt_0": "Not at all",
      "focus_very_wel_stimulants_opt_1": "Sometimes",
      "focus_very_wel_stimulants_opt_2": "Very often or always",
      "ignore_distractions_stimulants": "I can ignore distractions more easily.",
      "ignore_distractions_stimulants_opt_0": "Not at all",
      "ignore_distractions_stimulants_opt_1": "Sometimes",
      "ignore_distractions_stimulants_opt_2": "Very often or always",
      "pay_attention_stimulants": "I can pay attention really well.",
      "pay_attention_stimulants_opt_0": "Not at all",
      "pay_attention_stimulants_opt_1": "Sometimes",
      "pay_attention_stimulants_opt_2": "Very often or always",
