      "disease_progressionregression_12to18_abnormalities_fetalscan": "abnormalities on fetal anomaly scan",
      "disease_progressionregression_12to18_pregnancy_cardiomyopathy_pregnancyother": "Other",
      "neonatal_info_220703": "Neonatal information:",
      "disease_progressionregression_12to18_neonatal_gestationalage": "gestational age in weeks",
      "disease_progressionregression_12to18_neonatal_deliverymethod": "delivery method (NVD vs instrumental vs C/S)",
      "disease_progressionregression_12to18_neonatal_birthweight": "birth weight in kg",
      "disease_progressionregression_12to18_neonatal_resuscitationventilation": "Resuscitation and ventilation",
      "section_1_220703": "Section I: FunctionRate function during the preceding 4 week period only according to patient and / or caregiver interview. Indicate the score that best fits patient's functional status independently of the nature of the signs.",
      "disease_progressionregression_12to18_currentfunction_vision": "Rate function during the preceding 4 week period only according to patient and / or  caregiver interview.  - Vision",
      "disease_progressionregression_12to18_currentfunction_vision_opt_1": "0. Normal. No parental concerns",
      "disease_progressionregression_12to18_currentfunction_vision_opt_2": "1. Mild. Difficulty with small print or text on the television",
      "disease_progressionregression_12to18_currentfunction_vision_opt_3": "2. Moderate. Difficulty outside the home (e.g. bus numbers, road signs or shopping)",
      "disease_progressionregression_12to18_currentfunction_vision_opt_4": "3. Severe. Difficulty recognising faces or unable to navigate without help or registered blind",
      "disease_progressionregression_12to18_currentfunction_hearing": "Rate function during the preceding 4 week period only according to patient and / or  caregiver interview.  - Hearing",
      "disease_progressionregression_12to18_currentfunction_hearing_opt_1": "0. Normal",
      "disease_progressionregression_12to18_currentfunction_hearing_opt_2": "1.  Mild. Mild deafness (e.g. missing words in presence of background noise)",
      "disease_progressionregression_12to18_currentfunction_hearing_opt_3": "2. Moderate. Hearing impaired but fully corrected with hearing aid",
      "disease_progressionregression_12to18_currentfunction_hearing_opt_4": "3. Severe. Poor hearing even with aid or reliant on non-verbal communication",
      "disease_progressionregression_12to18_currentfunction_communication": "Rate function during the preceding 4 week period only according to patient and / or  caregiver interview.  - communication (assessed with appropriate regard for age)",
      "disease_progressionregression_12to18_currentfunction_communication_opt_1": "0.  Normal.",
      "disease_progressionregression_12to18_currentfunction_communication_opt_2": "1.  Mild. Mild speech difficulties but easily understood and rarely asked to repeat things",
      "disease_progressionregression_12to18_currentfunction_communication_opt_3": "2. Moderate. Speech poorly understood by strangers and frequently asked to repeat things",
      "disease_progressionregression_12to18_currentfunction_communication_opt_4": "3. Severe. Speech not understood by family or friends and / or requires communication aid",
      "disease_progressionregression_12to18_currentfunction_feeding": "Rate function during the preceding 4 week period only according to patient and / or  caregiver interview.  - Feeding",
      "disease_progressionregression_12to18_currentfunction_feeding_opt_1": "0. Normal",
      "disease_progressionregression_12to18_currentfunction_feeding_opt_2": "1. Mild. Choking / vomiting / anorexia resulting in reduced intake or swallowing difficulties requiring dietary adaptations",
      "disease_progressionregression_12to18_currentfunction_feeding_opt_3": "2. Moderate. Supplementary enteral feeding or recurrent aspiration pneumonia",
      "disease_progressionregression_12to18_currentfunction_feeding_opt_4": "3. Severe. Exclusive enteral feeding (gastrostomy / NG tube). Nil by mouth",
      "disease_progressionregression_12to18_currentfunction_selfcare": "Rate function during the preceding 4 week period only according to patient and / or  caregiver interview.  - Self-care (personal hygiene, dressing, utensil use e.g. for feeding)",
      "disease_progressionregression_12to18_currentfunction_selfcare_opt_1": "0. Normal. No concerns. Age appropriately reliant on carers / parents",
      "disease_progressionregression_12to18_currentfunction_selfcare_opt_2": "1. Mild. Slow and / or clumsy self-care requiring extra time or effort. Requires help with some tasks",
      "disease_progressionregression_12to18_currentfunction_selfcare_opt_3": "2. Moderate. Requires help with most tasks but retains some independent selfcare function",
      "disease_progressionregression_12to18_currentfunction_selfcare_opt_4": "3.  Severe. Requires one to one assistance",
      "disease_progressionregression_12to18_currentfunction_mobility": "Rate function during the preceding 4 week period only according to patient and / or  caregiver interview.  - Mobility",
      "disease_progressionregression_12to18_currentfunction_mobility_opt_1": "0. Normal.",
      "disease_progressionregression_12to18_currentfunction_mobility_opt_2": "1. Mild. Difficulty walking up stairs or inclines",
      "disease_progressionregression_12to18_currentfunction_mobility_opt_3": "2. Moderate. Requires support (stick / frame / callipers) to walk on the flat",
      "disease_progressionregression_12to18_currentfunction_mobility_opt_4": "3. Severe. Wheelchair dependent",
      "disease_progressionregression_12to18_currentfunction_education": "Rate function during the preceding 4 week period only according to patient and / or  caregiver interview. - Educational Achievement",
      "disease_progressionregression_12to18_currentfunction_education_opt_1": "0. Normal.",
      "disease_progressionregression_12to18_currentfunction_education_opt_2": "1. Mild. Myoclonic or absence seizures only or < 1 generalised tonic-clonic seizure each month",
      "disease_progressionregression_12to18_currentfunction_education_opt_3": "2. Moderate. > 5 generalized tonic-clonic seizures/month or > 20 absence or myoclonic seizures/month",
      "disease_progressionregression_12to18_currentfunction_education_opt_4": "3. Severe. Status epilepticus",
      "section_ii_220703": "Section II: System Specific InvolvementRate system specific involvement during the preceding 12 month period only according to patient and / or caregiver, clinician's knowledge and clinical notes.",
      "disease_progressionregression_12to18_systeminvolvement_seizures": "Rate system specific involvement during the preceding 12 month period only  according to patient and / or caregiver, clinician's knowledge and clinical notes.    - Seizures",
      "disease_progressionregression_12to18_systeminvolvement_seizures_opt_1": "0. None",
      "disease_progressionregression_12to18_systeminvolvement_seizures_opt_2": "1. Mild. Myoclonic or absence seizures only or < 1 generalised tonic-clonic  seizure/month",
      "disease_progressionregression_12to18_systeminvolvement_seizures_opt_3": "2. Moderate. > 5 generalized tonic-clonic seizures/month or > 20 absence or  myoclonic seizures/month",
      "disease_progressionregression_12to18_systeminvolvement_seizures_opt_4": "3. Severe. Status epilepticus",
      "disease_progressionregression_12to18_systeminvolvement_encephalopathy": "Rate system specific involvement during the preceding 12 month period only  according to patient and / or caregiver, clinician's knowledge and clinical notes.    - Encephalopathy",
      "disease_progressionregression_12to18_systeminvolvement_encephalopathy_opt_1": "0. None",
      "disease_progressionregression_12to18_systeminvolvement_encephalopathy_opt_2": "1. Mild. Single episode of personality change, excessive sleepiness, confusion or disorientation",
      "disease_progressionregression_12to18_systeminvolvement_encephalopathy_opt_3": "2. Moderate. Obtunded or >2 encephalopathic episodes/year",
      "disease_progressionregression_12to18_systeminvolvement_encephalopathy_opt_4": "3. Severe. Life-threatening encephalopathy- requires artificial ventilation",
      "disease_progressionregression_12to18_systeminvolvement_strokelike": "Rate system specific involvement during the preceding 12 month period only  according to patient and / or caregiver, clinician's knowledge and clinical notes.  - Stroke-like Episodes",
      "disease_progressionregression_12to18_systeminvolvement_strokelike_opt_1": "0. None",
      "disease_progressionregression_12to18_systeminvolvement_strokelike_opt_2": "1. Mild. Transient motor symptoms lasting < 24 hours",
      "disease_progressionregression_12to18_systeminvolvement_strokelike_opt_3": "2. Moderate. Single stroke-like episode (> 24 hours)",
      "disease_progressionregression_12to18_systeminvolvement_strokelike_opt_4": "3. Severe. Multiple stroke-like episodes (> 24 hours each)",
      "disease_progressionregression_12to18_systeminvolvement_gastrointestinal": "Rate system specific involvement during the preceding 12 month period only  according to patient and / or caregiver, clinician's knowledge and clinical notes.    - Gastrointestinal",
      "disease_progressionregression_12to18_systeminvolvement_gastrointestinal_opt_1": "0. Normal.",
      "disease_progressionregression_12to18_systeminvolvement_gastrointestinal_opt_2": "1. Mild. Mild constipation or unexplained vomiting / diarrhoea < 1/week",
      "disease_progressionregression_12to18_systeminvolvement_gastrointestinal_opt_3": "2. Moderate. Moderate constipation (some relief with laxative treatment) or unexplained vomiting / diarrhoea > 3/week",
      "disease_progressionregression_12to18_systeminvolvement_gastrointestinal_opt_4": "3. Severe. Severe constipation (no relief with laxative treatment) or unexplained vomiting / diarrhoea every day or surgical intervention for dysmotility",
      "disease_progressionregression_12to18_systeminvolvement_endocrine": "Rate system specific involvement during the preceding 12 month period only  according to patient and / or caregiver, clinician's knowledge and clinical notes.    - Endocrine",
      "disease_progressionregression_12to18_systeminvolvement_endocrine_opt_1": "0. Normal.",
      "disease_progressionregression_12to18_systeminvolvement_endocrine_opt_2": "1. Mild. Biochemical evidence of impaired function",
      "disease_progressionregression_12to18_systeminvolvement_endocrine_opt_3": "2. Moderate. Endocrine failure requiring replacement therapy",
      "disease_progressionregression_12to18_systeminvolvement_endocrine_opt_4": "3. Severe. Endocrine decompensation (e.g. diabetic ketoacidosis, Addisonian  crisis)",
      "disease_progressionregression_12to18_systeminvolvement_respiratory": "Rate system specific involvement during the preceding 12 month period only  according to patient and / or caregiver, clinician's knowledge and clinical notes.    - respiratory",
      "disease_progressionregression_12to18_systeminvolvement_respiratory_opt_1": "0. Normal",
      "disease_progressionregression_12to18_systeminvolvement_respiratory_opt_2": "1. Mild. Abnormal respiration not requiring hospitalization",
      "disease_progressionregression_12to18_systeminvolvement_respiratory_opt_3": "2. Moderate. Abnormal respiration requiring hospitalisation but not ventilation",
      "disease_progressionregression_12to18_systeminvolvement_respiratory_opt_4": "3. Severe. Abnormal respiration requiring artificial ventilation",
      "disease_progressionregression_12to18_systeminvolvement_cardiovascular": "Rate system specific involvement during the preceding 12 month period only  according to patient and / or caregiver, clinician's knowledge and clinical notes.    - cardiovascular",
      "disease_progressionregression_12to18_systeminvolvement_cardiovascular_opt_1": "0. Normal",
      "disease_progressionregression_12to18_systeminvolvement_cardiovascular_opt_2": "1. Mild. Asymptomatic ECG change",
      "disease_progressionregression_12to18_systeminvolvement_cardiovascular_opt_3": "2.  Moderate. Abnormal echocardiogram (e.g. cardiomegaly) or sustained /  symptomatic arrhythmia on ECG",
      "disease_progressionregression_12to18_systeminvolvement_cardiovascular_opt_4": "3. Severe. Decompensated cardiomyopathy or requiring pacing device /  defibrillator / ablation",
      "disease_progressionregression_12to18_systeminvolvement_renal": "Rate system specific involvement during the preceding 12 month period only  according to patient and / or caregiver, clinician's knowledge and clinical notes.    - Renal",
      "disease_progressionregression_12to18_systeminvolvement_renal_opt_1": "0. Normal",
      "disease_progressionregression_12to18_systeminvolvement_renal_opt_2": "1. Mild. Impaired function but no change in diet or therapy required",
      "disease_progressionregression_12to18_systeminvolvement_renal_opt_3": "2. Moderate. Impaired function requiring restricted protein diet",
      "disease_progressionregression_12to18_systeminvolvement_renal_opt_4": "3.  Severe. Failure requiring transplant / dialysis",
      "disease_progressionregression_12to18_systeminvolvement_liver": "Rate system specific involvement during the preceding 12 month period only  according to patient and / or caregiver, clinician's knowledge and clinical notes.    - Liver",
      "disease_progressionregression_12to18_systeminvolvement_liver_opt_1": "0. Normal",
      "disease_progressionregression_12to18_systeminvolvement_liver_opt_2": "1.  Mild. Mildly impaired Liver Function Tests (LFTs). No symptoms of hepatic failure",
      "disease_progressionregression_12to18_systeminvolvement_liver_opt_3": "2. Moderate. Impaired LTFs with symptoms (e.g. jaundice, oedema)",
      "disease_progressionregression_12to18_systeminvolvement_liver_opt_4": "3. Severe. Failure requiring hospitalisation and / or transplantation",
      "disease_progressionregression_12to18_systeminvolvement_blood": "Rate system specific involvement during the preceding 12 month period only  according to patient and / or caregiver, clinician's knowledge and clinical notes.    - blood",
      "disease_progressionregression_12to18_systeminvolvement_blood_opt_1": "0. Normal",
      "disease_progressionregression_12to18_systeminvolvement_blood_opt_2": "1. Mild. Anaemia only",
      "disease_progressionregression_12to18_systeminvolvement_blood_opt_3": "2. Moderate. Asymptomatic pancytopenia",
      "disease_progressionregression_12to18_systeminvolvement_blood_opt_4": "3. Severe. Pancytopenia requiring regular transfusion / transplantation",
      "section_iii_220703": "Section III: Current Clinical AssessmentRate current status according to the clinician's examination performed at the time of assessment unless otherwise stated in the question.",
      "disease_progressionregression_12to18_currentclinical_growthweight": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Growth (ht and weight) over preceding 6 months",
      "disease_progressionregression_12to18_currentclinical_growthweight_opt_1": "0. Normal. Following normal growth trajectory",
      "disease_progressionregression_12to18_currentclinical_growthweight_opt_2": "1. Mild. Weight less than second centile but growing parallel to it",
      "disease_progressionregression_12to18_currentclinical_growthweight_opt_3": "2. Moderate. Weight crossing one centile",
      "disease_progressionregression_12to18_currentclinical_growthweight_opt_4": "3.  Severe. Weight crossing ? 2 centiles or less than 2nd centile with divergent  trajectory",
      "disease_progressionregression_12to18_currentclinical_development": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Development over preceding 12 months __ Score",
      "disease_progressionregression_12to18_currentclinical_development_opt_0": "0. Development is age appropriate",
      "disease_progressionregression_12to18_currentclinical_development_opt_1": "1. Development is not age appropriate, child has not regressed in any area of development, child is not globally delayed in development, AND (1) evidence of delayed speech, language or hearing, or (2) evidence of delayed motor milestones, or (3) evidence of delay in social development, AND there is development progress",
      "disease_progressionregression_12to18_currentclinical_development_opt_2": "2. Development is not age appropriate, child has not regressed in any area of development, child is not globally delayed in development, AND (1) evidence of delayed speech, language or hearing, or (2) evidence of delayed motor milestones, or (3) evidence of delay in social development, AND there is NO development progress",
      "disease_progressionregression_12to18_currentclinical_development_opt_5": "5. Development is not age appropriate, child has not regressed in any area of development, child is globally delayed in development, but there is developmental progress",
      "disease_progressionregression_12to18_currentclinical_development_opt_6": "6. Development is not age appropriate, child has not regressed in any area of development, child is globally delayed in development, and there is no developmental progress",
      "disease_progressionregression_12to18_currentclinical_development_opt_7": "7. Development is not age appropriate and child has regressed in an area of development",
      "disease_progression_and_regression_220703": "disease_progression_and_regression_220703",
      "disease_progressionregression_12to18_currentclinical_vision": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. -Vision",
      "disease_progressionregression_12to18_currentclinical_vision_opt_1": "0. Normal. Visual acuity better than or equal to 6/12 or normal fixation and tracking",
      "disease_progressionregression_12to18_currentclinical_vision_opt_2": "1. Mild. Acuity worse than 6/12 but better than or equal to 6/18 or no fixation on small objects",
      "disease_progressionregression_12to18_currentclinical_vision_opt_3": "2. Moderate. Acuity worse than 6/18 but better than or equal to 6/60 or impaired fixation on large brightly coloured objects",
      "disease_progressionregression_12to18_currentclinical_vision_opt_4": "3.  Severe. Acuity worse than 6/60 or no response to light or visual threat or unable to finger count",
      "disease_progressionregression_12to18_currentclinical_ptosiseyemovement": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Ptosis and Eye Movement",
      "disease_progressionregression_12to18_currentclinical_ptosiseyemovement_opt_1": "0. Normal",
      "disease_progressionregression_12to18_currentclinical_ptosiseyemovement_opt_2": "1. Mild. Gaze evoked nystagmus or unilateral ptosis or impaired eye movement  at extremities",
      "disease_progressionregression_12to18_currentclinical_ptosiseyemovement_opt_3": "2. Moderate. Intermittent nystagmus at rest or bilateral ptosis not obscuring pupils or restriction of >50% eye movement",
      "disease_progressionregression_12to18_currentclinical_ptosiseyemovement_opt_4": "3. Severe. Continuous nystagmus at rest or bilateral ptosis obscuring pupils or  only a flicker of eye movement",
      "disease_progressionregression_12to18_currentclinical_myopathy": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Myopathy",
      "disease_progressionregression_12to18_currentclinical_myopathy_opt_1": "0. Normal",
      "disease_progressionregression_12to18_currentclinical_myopathy_opt_2": "1. Mild. Mild symmetrical weakness of hip and / or shoulder girdle only",
      "disease_progressionregression_12to18_currentclinical_myopathy_opt_3": "2. Moderate. Moderate symmetrical weakness (proximal > distal) limiting mobility",
      "disease_progressionregression_12to18_currentclinical_myopathy_opt_4": "3. Severe. Wheelchair dependent or respiratory compromise due to myopathy",
      "disease_progressionregression_12to18_currentclinical_ataxia": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Ataxia",
      "disease_progressionregression_12to18_currentclinical_ataxia_opt_1": "0. Normal",
      "disease_progressionregression_12to18_currentclinical_ataxia_opt_2": "1. Mild. Ataxic gait but walks unaided or mild upper limb dysmetria",
      "disease_progressionregression_12to18_currentclinical_ataxia_opt_3": "2. Moderate. Gait abnormality requiring assistance or severe upper limb  Dysmetria",
      "disease_progressionregression_12to18_currentclinical_ataxia_opt_4": "3. Severe. Wheelchair dependent or unable to feed due to ataxia",
      "disease_progressionregression_12to18_currentclinical_pyramidal": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Pyramidal",
      "disease_progressionregression_12to18_currentclinical_pyramidal_opt_1": "0. Normal",
      "disease_progressionregression_12to18_currentclinical_pyramidal_opt_2": "1. Mild. Mild hemiplegia allowing unaided ambulation",
      "disease_progressionregression_12to18_currentclinical_pyramidal_opt_3": "2. Moderate. Moderate hemiplegia allowing ambulation with aids",
      "disease_progressionregression_12to18_currentclinical_pyramidal_opt_4": "3.  Severe. Wheelchair dependent due to hemi / tetraplegia",
      "disease_progressionregression_12to18_currentclinical_extrapyramidal": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Extrapyramidal",
      "disease_progressionregression_12to18_currentclinical_extrapyramidal_opt_1": "0. Normal.",
      "disease_progressionregression_12to18_currentclinical_extrapyramidal_opt_2": "1. Mild. Focal dystonia or unilateral extrapyramidal tremor / bradykinesia",
      "disease_progressionregression_12to18_currentclinical_extrapyramidal_opt_3": "2. Moderate. Generalised dystonia or bilateral extrapyramidal tremor / bradykinesia",
      "disease_progressionregression_12to18_currentclinical_extrapyramidal_opt_4": "3.  Severe. Wheelchair dependent due to extrapyramidal disorder",
      "disease_progressionregression_12to18_currentclinical_neuropathy": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Neuropathy",
      "disease_progressionregression_12to18_currentclinical_neuropathy_opt_1": "0. Normal.",
      "disease_progressionregression_12to18_currentclinical_neuropathy_opt_2": "1. Mild. Areflexia only",
      "disease_progressionregression_12to18_currentclinical_neuropathy_opt_3": "2. Moderate. Sensory ataxia or motor impairment (distal weakness) but mobile",
      "disease_progressionregression_12to18_currentclinical_neuropathy_opt_4": "3.  Severe. Reliant on mobility aids primarily due to neuropathy",
      "section_iv_220703": "Section IV: Quality of Life- Parent CompletedThis survey asks for your views about your child's recent health. Please answer every question by marking an 'x' in the box next to the phrase which best describes your answer.",
      "disease_progressionregression_12to18_qol_overallhealth": "During the past 4 weeks, how would you rate your child's overall health?",
      "disease_progressionregression_12to18_qol_phsyicalactivities": "During the past 4 weeks, how much did your child's physical health problems limit their physical activities (such as walking or playing with friends)?",
      "disease_progressionregression_12to18_qol_phsyicalactivities_opt_1": "Very much",
      "disease_progressionregression_12to18_qol_phsyicalactivities_opt_2": "Quite a lot",
      "disease_progressionregression_12to18_qol_phsyicalactivities_opt_3": "Somewhat",
      "disease_progressionregression_12to18_qol_phsyicalactivities_opt_4": "A little",
      "disease_progressionregression_12to18_qol_phsyicalactivities_opt_5": "Not at all",
      "disease_progressionregression_12to18_qol_limits": "During the past 4 weeks, how much did your child's health problems limit their  everyday life (such as attending school, caring for themselves) compared with a  person of the same age in perfect health?",
      "disease_progressionregression_12to18_qol_limits_opt_1": "Very much",
      "disease_progressionregression_12to18_qol_limits_opt_2": "Quite a lot",
      "disease_progressionregression_12to18_qol_limits_opt_3": "Somewhat",
      "disease_progressionregression_12to18_qol_limits_opt_4": "A little",
      "disease_progressionregression_12to18_qol_limits_opt_5": "Not at all",
      "disease_progressionregression_12to18_qol_energy": "During the past 4 weeks, how much energy did your child have?",
      "disease_progressionregression_12to18_qol_energy_opt_1": "None",
      "disease_progressionregression_12to18_qol_energy_opt_2": "A little",
      "disease_progressionregression_12to18_qol_energy_opt_3": "Somewhat",
      "disease_progressionregression_12to18_qol_energy_opt_4": "Quite a lot",
      "disease_progressionregression_12to18_qol_energy_opt_5": "Very much",
      "disease_progressionregression_12to18_qol_pain": "During the past 4 weeks, how much bodily pain / discomfort did your child have?",
      "disease_progressionregression_12to18_qol_pain_opt_1": "Very much",
      "disease_progressionregression_12to18_qol_pain_opt_2": "quite a lot",
      "disease_progressionregression_12to18_qol_pain_opt_3": "Somewhat",
      "disease_progressionregression_12to18_qol_pain_opt_4": "A little",
      "disease_progressionregression_12to18_qol_pain_opt_5": "None",
      "disease_progressionregression_12to18_qol_emotionalproblems": "During the past 4 weeks, how much was your child bothered by emotional  problems?",
      "disease_progressionregression_12to18_qol_emotionalproblems_opt_1": "Very",
      "disease_progressionregression_12to18_qol_emotionalproblems_opt_2": "Quite a lot",
      "disease_progressionregression_12to18_qol_emotionalproblems_opt_3": "Somewhat",
      "disease_progressionregression_12to18_qol_emotionalproblems_opt_4": "A little",
      "disease_progressionregression_12to18_qol_emotionalproblems_opt_5": "Not at all",
      "disease_progressionregression_12to18_qol_abilitieslooks": "During the past 4 weeks, how satisfied did your child feel with their abilities, looks,  relationships with other people and life in general?",
      "disease_progressionregression_12to18_qol_abilitieslooks_opt_1": "Very dissatisfied",
      "disease_progressionregression_12to18_qol_abilitieslooks_opt_2": "Quite dissatisfied",
      "disease_progressionregression_12to18_qol_abilitieslooks_opt_3": "Neither dissatisfied or satisfied",
      "disease_progressionregression_12to18_qol_abilitieslooks_opt_4": "Quite satisfied",
      "disease_progressionregression_12to18_qol_abilitieslooks_opt_5": "Very satisfied",
      "disease_progressionregression_12to18_qol_behavior": "During the past 4 weeks, how would you rate your child's behavior compared with other children his / her age?",
      "disease_progressionregression_12to18_qol_interactions": "During the past 4 weeks, how would you rate your child's ability to interact with other people (e.g. making friends, talking to other children / strangers) compared with other children his / her age?",
      "disease_progressionregression_12to18_qol_parentemotions": "During the past 4 weeks, how much were you (the parent / carer) bothered by emotional problems (e.g. feelings of anxiety, sadness) as a result of your child's illness?",
      "disease_progressionregression_12to18_qol_parentemotions_opt_1": "Very",
      "disease_progressionregression_12to18_qol_parentemotions_opt_2": "Quite a lot",
