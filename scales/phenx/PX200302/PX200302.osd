    "scoring": {
      "assertiveness": {
        "description": "Assertiveness: sum_coded of 3 items.",
        "method": "sum_coded",
        "items": [
          "ability_ask_questions",
          "ability_get_talking",
          "start_convers_other_children"
        ]
      },
      "responsiveness": {
        "description": "Responsiveness: sum_coded of 2 items.",
        "method": "sum_coded",
        "items": [
          "ability_answer_questions",
          "keep_convo_going"
        ]
      },
      "semantics": {
        "description": "Semantics: sum_coded of 3 items.",
        "method": "sum_coded",
        "items": [
          "number_words_known",
          "use_words_correctly",
          "use_proper_words"
        ]
      },
      "syntax": {
        "description": "Syntax: sum_coded of 2 items.",
        "method": "sum_coded",
        "items": [
          "length_of_sentences",
          "make_grownup_sentences"
        ]
      },
      "articulation": {
        "description": "Articulation: sum_coded of 3 items.",
        "method": "sum_coded",
        "items": [
          "say_sentences_clearly",
          "get_message_across",
          "correctly_say_sounds"
        ]
      }
    },
    "_scoring_notes": "Scoring Instructions:Composite scale scores are calculated by adding together the ratings for the items in each subscale and dividing by the total number of items in that scale.Assertiveness subscale: items 1, 11, 12Responsiveness subscale: items 2, 13Semantics subscale: items 5, 6, 10Syntax subscale: items 14, 15Articulation subscale: items 4, 7, 16Assertiveness and responsiveness measure the use of language in social contexts. Semantics measures word learning. Syntax measures grammar. Articulation measures speech sound production and intelligibility.Detailed instructions on scoring and interpretation can be found in Hadley and Rice (1993)."
  },
