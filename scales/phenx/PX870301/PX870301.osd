      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_not_good_as_others": "I feel I am not as good as others because I have SCD.",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_not_good_as_others_opt_1": "completely false",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_not_good_as_others_opt_2": "mostly false",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_not_good_as_others_opt_3": "somewhat false (more false than true)",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_not_good_as_others_opt_4": "somewhat true (more true than false)",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_not_good_as_others_opt_5": "mostly true",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_not_good_as_others_opt_6": "completely true",
      "sec_disclosure_concerns_title": "Disclosure Concerns",
      "internal_stigma_sickle_cell_disease_disclosure_concerns_no_one_knows": "In many areas of my life, no one knows that I have SCD.",
      "internal_stigma_sickle_cell_disease_disclosure_concerns_no_one_knows_opt_1": "completely false",
      "internal_stigma_sickle_cell_disease_disclosure_concerns_no_one_knows_opt_2": "mostly false",
