    "scale_info": {
      "name": "Medications (Current and Past Use of Pain Relievers, Statins, and Steroids)",
      "code": "PX071201",
      "abbreviation": "PX071201",
      "description": "This measure assesses current and past use of prescription and over-the-counter (OTC) medications. Protocol obtains information about pain-relieving medications, statins, steroids, and inhaled bronchodilators.",
      "domain": "Health",
      "citation": "The California Teachers Study, Follow-Up Survey 4, 2005-2006. As implemented in: PhenX Toolkit. Medications (Current and Past Use of Pain Relievers, Statins, and Steroids). https://www.phenxtoolkit.org/protocols/view/71201",
