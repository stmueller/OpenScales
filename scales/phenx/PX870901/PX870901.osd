{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Sickle Cell Disease Transition Readiness Assessment",
      "code": "PX870901",
      "abbreviation": "PX870901",
      "description": "A validated sickle cell disease-specific readiness for transition assessment tool from pediatric to adult care. It is considered to be comprehensive because it includes four skill set scales: Medical, Educational/Vocational, Social Support, and Independent Living.",
      "domain": "Health",
      "citation": "Blum, R. W., Garell, D., Hodgman, C. H., Jorissen, T. W., Okinow, N. A., Orr, D. P., & Slap, G. B. (1993) Transition from child-centered to adult health-care systems for adolescents with chronic conditions. A position paper of the Society for Adolescent Medicine. Journal of Adolescent Health, 14(7), 570-576. doi:10.1016/1054-139x(93)90143-d. Debaun, M. R., & Telfair, J. (2012). Transition and sickle cell disease. Pediatrics, 130(5), 926-935. doi:10.1542/peds.2011-3049 Jordan, L., Swerdlow, P., & Coates, T. D. (2013). Systematic review of transition from adolescent to adult care in patients with sickle cell disease. Journal of Pediatric Hematology/Oncology, 35(3), 165-169. Smith, W. R., Johnson, S., & Treadwell, M. (N.d.). User Manual for the Transition Intervention Program - Readiness for Transition Instrument, the Tier Questionnaires, and Related Survey Batteries. [PhenX: https://www.phenxtoolkit.org/protocols/view/870901]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/870901"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
