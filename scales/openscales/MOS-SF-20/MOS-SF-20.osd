  "translations": {
    "en": {
      "sf20_inst": "Choose one option for each questionnaire item.",
      "sf20_pf_head": "For how long (if at all) has your health limited you in each of the following activities?",
      "sf20_freq_head": "For each of the following questions, please select the one answer that comes closest to the way you have been feeling during the <b>past month</b>.",
      "sf20_12_head": "Please indicate whether each of the following statements is true or false for you.",
      "sf20_freq1": "All of the time",
      "sf20_freq2": "Most of the time",
      "sf20_freq3": "A good bit of the time",
      "sf20_freq4": "Some of the time",
      "sf20_freq5": "A little of the time",
      "sf20_freq6": "None of the time",
      "gh_excellent": "Excellent",
      "gh_verygood": "Very good",
      "gh_good": "Good",
      "gh_fair": "Fair",
      "gh_poor": "Poor",
      "pf_limited3mo": "Limited for more than 3 months",
      "pf_limited_le3mo": "Limited for 3 months or less",
      "pf_notlimited": "Not limited at all",
      "pain_none": "None",
      "pain_verymild": "Very mild",
      "pain_mild": "Mild",
      "pain_moderate": "Moderate",
      "pain_severe": "Severe",
      "pain_verysevere": "Very severe",
      "rf_yes3mo": "Yes, for more than 3 months",
      "rf_yes_le3mo": "Yes, for 3 months or less",
      "rf_no": "No",
      "tf_deftrue": "Definitely true",
      "tf_mostlytrue": "Mostly true",
      "tf_notsure": "Not sure",
      "tf_mostlyfalse": "Mostly false",
      "tf_deffalse": "Definitely false",
      "sf20_1": "In general, would you say your health is:",
      "sf20_2a": "The kinds or amounts of <b>vigorous activities</b> you can do, like lifting heavy objects, running, or participating in strenuous sports",
      "sf20_2b": "The kinds or amounts of <b>moderate activities</b> you can do, like moving a table, carrying groceries, or bowling",
      "sf20_2c": "Walking uphill or climbing <b>a few flights of stairs</b>",
      "sf20_2d": "<b>Bending, lifting, or stooping</b>",
      "sf20_2e": "Walking <b>one block</b>",
      "sf20_2f": "<b>Eating, dressing, bathing</b>, or using the toilet",
      "sf20_3": "How much <b>bodily pain</b> have you had during the <b>past 4 weeks</b>?",
      "sf20_4": "Does your health keep you from <b>working</b> at a job, doing work around the house, or going to school?",
      "sf20_5": "Have you been <b>unable to do certain kinds or amounts</b> of work, housework, or schoolwork because of your health?",
      "sf20_6": "How much of the time, during the <b>past month</b>, has your health <b>limited your social activities</b> (like visiting with friends or close relatives)?",
      "sf20_7": "How much of the time, during the <b>past month</b>, have you been a <b>very nervous person</b>?",
      "sf20_8": "During the <b>past month</b>, how much of the time have you felt <b>calm and peaceful</b>?",
      "sf20_9": "How much of the time, during the <b>past month</b>, have you felt <b>downhearted and blue</b>?",
      "sf20_10": "During the <b>past month</b>, how much of the time have you been a <b>happy person</b>?",
      "sf20_11": "How often, during the <b>past month</b>, have you felt so <b>down in the dumps that nothing could cheer you up</b>?",
      "sf20_12a": "I am somewhat ill.",
      "sf20_12b": "I am as healthy as anybody I know.",
      "sf20_12c": "My health is excellent.",
      "sf20_12d": "I have been feeling bad lately.",
      "debrief": "Thank you for completing this survey."
    }
  }
}
