      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "items": [
      {
        "id": "recovery_identification_self_definition",
        "text_key": "recovery_identification_self_definition",
        "type": "multi",
        "options": [
          {
            "text_key": "recovery_identification_self_definition_opt_1",
            "value": 1
          },
          {
            "text_key": "recovery_identification_self_definition_opt_2",
            "value": 2
