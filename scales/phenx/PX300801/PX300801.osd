  "translations": {
    "en": {
      "parenting_behavior_child_friendly_talk_mom": "Please rate each item as to how often it TYPICALLY occurs in your home.   You have a friendly talk with your mom.",
      "parenting_behavior_child_friendly_talk_mom_opt_1": "Never",
      "parenting_behavior_child_friendly_talk_mom_opt_2": "Almost never",
      "parenting_behavior_child_friendly_talk_mom_opt_3": "Sometimes",
