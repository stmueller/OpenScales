    "he": {
      "LANGUAGE": "he",
      "question_head": "סמן בבקשה עיגול אחד בלבד בכל שורה.",
      "ueq_inst_text": "נא השלם את השאלון הבא לצורך הערכת המוצר. השאלון כולל זוגות מנוגדים של מאפייני המוצר. הציונים בין הניגודים מסומנים באמצעות עיגולים. סמן את אחד מהעיגולים כדי לציין את רמת הסכמתך לכל מאפיין.",
      "ueq_01_text": "מעצבן                    מהנה",
      "ueq_01_left": "מעצבן",
      "ueq_01_right": "מהנה",
      "ueq_02_text": "אינם מובנים                    מובנים",
      "ueq_02_left": "אינם מובנים",
      "ueq_02_right": "מובנים",
      "ueq_03_text": "יצירתיים                    משעממים",
      "ueq_03_left": "יצירתיים",
      "ueq_03_right": "משעממים",
      "ueq_04_text": "קלים ללמידה                    קשים ללמידה",
