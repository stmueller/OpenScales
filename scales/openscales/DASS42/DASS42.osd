    "hi": {
      "d1": "",
      "d2": "मुझे पता है िक मेरा मुँह सू ख जाता था।",
      "d3": "म कोई सकारा क भाव अनु भव नही ं कर सका।",
      "d4": "मने साँस लेने म तकलीफ महसू स की (जै से िक सामा शारी रक म के िबना भी साँ स का फूलना महसूस िकया)।",
      "d5": "मेरा कुछ भी करने का मन नही ं आ।",
      "d6": "मने प र थितयों को ज रत से",
      "d7": "मने लड़खड़ाना अनु भव िकया ( जैसे, पैर कही और जा रहे थे)।",
      "d8": "मने िव ाम करना मु",
      "d9": "कभी कभी म ऐसी प र थित म होता था जो मुझे काफी िचंितत कर दे ती थी, और म उनके ख",
      "d10": "मने अपने आपको",
      "d11": "मने दे खा िक आराम से रहने के बजाय म ब त आसानी से परे शान हो जाता ँ ।",
      "d12": "मने ऐसा महसू स िकया िक म कई बार कुछ",
      "d13": "मने अपने आपको उदास और दु खी महसू स िकया ।",
      "d14": "जब मुझे िकसी वजह से दे र होती थी, म ब त बे चैन हो जाता था ( जैसे िक िल",
      "d15": "मने अपने आपको श",
      "d16": "मने महसू स िकया िक मेरी िदलच गयी थी ।",
      "d17": "मने महसू स िकया िक म",
      "d18": "मने महसू स िकया िक म",
      "d19": "िबना िकसी उ लथपथ हो जाता था।",
      "d20": "मने िबना िकसी कारण के डर महसू स िकया ।",
      "d21": "मने महसू स िकया िक जीवन बे कार है ।",
      "d22": "धीरे धीरे काय मता म ीणता / कमी ने मुझे परे शान िकया था।",
      "d23": "मुझे िनगलने म किठनाई ई थी ।",
      "d24": "मने जो कुछ भी िकया उसका आनं द नही ं उठा सका ।",
      "d25": "शारी रक प र म के िबना भी म अपने िदल की धड़कनों को महसू स करता था (जैसे- तेज गित से धड़कना या कभी क जाना)।",
      "d26": "मने अपने आपको दु खी और हीन महसू स िकया।",
      "d27": "मने महसू स िकया की म ब त िचड़िचड़ा हो गया था।",
      "d28": "मने आतं िकत महसू स िकया था।",
      "d29": "जब कोई चीज मुझे ब त परे शान कर दे ती थी तो मने अपने आपको शांत कर पाना काफी मु",
      "d30": "म सोचता था िक म नए और अनजान काय को म नही ं कर पाउँ गा चाहे वो साधारण ही",
      "d31": "िकसी भी काय को करने के िलए म अपने आपको उ ािहत कर पाने म असमथ पता था।",
      "d32": "जब मेरे िकसी काय म था।",
      "d33": "म घबरा जाने वाली िचं ितत अव था म था।",
      "d34": "मने महसू स िकया िक म ब त बेकार था।",
      "d35": "िकसी िवशेष उप म या मुझे बदा",
      "d36": "म ब त डर गया था।",
      "d37": "मने पाया िक मेरे भिव",
      "d38": "मुझे लगा िक जीवन साथक नही ं था।",
      "d39": "मने अपने आपको ब त घबराया आ महसू स िकया।",
      "d40": "म उस प र थित के बारे म ब त िचं ितत था, िजसमे म ब त बेचैन हो गया था और मने बेवकूफी की।",
      "d41": "मने क न महसू स िकया (जै से- हां थो म)।",
      "d42": "िकसी भी काय की शु आत करने म मुझे िद",
      "debrief": ""
    },
    "hu": {
      "likert_1": "Egyáltalán nem volt rám alkalmazható",
      "likert_2": "Egy kicsit, vagy időnként volt rám alkalmazható",
      "likert_3": "Elég erősen, vagy gyakrabban volt rám alkalmazható",
      "likert_4": "Igen tekintélyes mértékben, vagy nagyon gyakran volt rám alkalmazható",
      "d1": "Észrevettem hogy egész kis dolgok is felzaklatnak.",
      "d2": "Időnként észrevettem hogy kiszáradt a szám.",
      "d3": "Egyáltalan nem voltam képes pozitiv érzelmekre.",
      "d4": "Úgy éreztem mintha valami baj lenne a lélegzetemmel (pl. nagyon gyorsan vettem a levegőt, vagy alig tudtam levegőt kapni, pedig nem voltam fizikailag megterhelve).",
      "d5": "Nehezemre esett hogy bármibe is belekezdjek.",
      "d6": "Nagyon felindulva reagáltam mindenre.",
      "d7": "Remegés és gyöngeség jött rám (pl. úgy éreztem mintha a lábam mindjárt összecsuklana).",
      "d8": "Nehezemre esett a kikapcsolódás.",
      "d9": "Olyan helyzetekben találtam magam amik annyi szorongással töltöttek el hogy csak akkor tudtam megkönnyebbülni amikor befejeződtek.",
      "d10": "Úgy éreztem hogy az életben semmi jó nem vár rám.",
      "d11": "Észrevettem hogy könnyen ideges vagy zaklatott vagyok.",
      "d12": "Úgy éreztem hogy a feszültségből származó energia hajt.",
      "d13": "Szomorúnak és depressziósnak éreztem magam.",
      "d14": "Észrevettem hogy türelmetlenül, nehezen viselem amikor feltartanak (pl lassú liftek, forgalmi jelzőlámpák, általában amikor várni kell).",
      "d15": "Olyan gyengeség érzése jött rám mintha az ájulás környékezne.",
      "d16": "Semmi nem érdekelt többé.",
      "d17": "Nem hittem hogy értékes ember vagyok.",
      "d18": "Túlérzékeny voltam.",
      "d19": "Észrevehetően izzadtam (pl. a tenyerem), pedig a hőmérséklet nem volt meleg és nem is voltam fizikailag megerőltetve.",
      "d20": "Minden ok nélkül a félelem érzése fogott el.",
      "d21": "Úgy éreztem hogy az élet semmit nem ér.",
      "d22": "Nehezemre esett hogy ellazuljak.",
      "d23": "Nehezen tudtam nyelni (mintha gombóc lenne a torkomban).",
      "d24": "Semmiben nem találtam élvezetet.",
      "d25": "Észrevettem a szívműködésemet (pl. gyorsan vagy furcsán vert a szívem), pedig nem voltam fizikailag megterhelve.",
      "d26": "Elcsüggedtnek és lehangoltnak éreztem magam.",
      "d27": "Nagyon ingerlékeny voltam.",
      "d28": "A pánik érzése fogott el.",
      "d29": "Nehezen tudtam megnyugodni miután valami felzaklatott.",
      "d30": "Féltem hogy \"felsülök\" ha valami egyszerű, de újfajta dolgot kell csinálnom.",
      "d31": "Semmi nem tudott fellelkesíteni.",
      "d32": "Nehezemre esett türelmesen elviselni ha félbeszakítottak.",
      "d33": "Feszült lelkiállapotban voltam.",
      "d34": "Hitvány embernek éreztem magam.",
      "d35": "Nem tudtam tolerálni ha feltartottak abban ami éppen elfoglalt.",
      "d36": "A rettegés érzése jött rám.",
      "d37": "Semmi reményt nem láttam a jövőben.",
      "d38": "Értelmetlennek éreztem az életet.",
      "d39": "Észrevettem hogy valamitől zaklatott vagyok.",
      "d40": "Aggódtam hogy egyszer valami olyan helyzetbe kerülök ahol elfog a pánik és bolondot csinálok magamból.",
      "d41": "Észrevettem hogy reszketek (pl. a kezem).",
      "d42": "Semmihez nem találtam magamban kezdeményező erőt.",
      "debrief": ""
    },
    "id": {
      "likert_1": "Tidak sesuai dengan saya sama sekali, atau tidak pernah",
      "likert_2": "Sesuai dengan saya sampai tingkat tertentu, atau kadang kadang",
      "likert_3": "Sesuai dengan saya sampai batas yang dapat dipertimbangkan, atau lumayan sering",
      "likert_4": "Sangat sesuai dengan saya, atau sering sekali",
      "d1": "Saya merasa bahwa diri saya menjadi marah karena hal-hal sepele.",
      "d2": "Saya merasa bibir saya sering kering.",
      "d3": "Saya sama sekali tidak dapat merasakan perasaan positif.",
      "d4": "Saya mengalami kesulitan bernafas (misalnya: seringkali terengah-engah atau tidak dapat bernafas padahal tidak melakukan aktivitas fisik sebelumnya).",
      "d5": "Saya sepertinya tidak kuat lagi untuk melakukan suatu kegiatan.",
      "d6": "Saya cenderung bereaksi berlebihan terhadap suatu situasi.",
      "d7": "Saya merasa goyah (misalnya, kaki terasa mau 'copot').",
      "d8": "Saya merasa sulit untuk bersantai.",
      "d9": "Saya menemukan diri saya berada dalam situasi yang membuat saya merasa sangat cemas dan saya akan merasa sangat lega jika semua ini berakhir.",
      "d10": "Saya merasa tidak ada hal yang dapat diharapkan di masa depan.",
      "d11": "Saya menemukan diri saya mudah merasa kesal.",
      "d12": "Saya merasa telah menghabiskan banyak energi untuk merasa cemas.",
      "d13": "Saya merasa sedih dan tertekan.",
      "d14": "Saya menemukan diri saya menjadi tidak sabar ketika mengalami penundaan (misalnya: kemacetan lalu lintas, menunggu sesuatu).",
      "d15": "Saya merasa lemas seperti mau pingsan.",
      "d16": "Saya merasa saya kehilangan minat akan segala hal.",
      "d17": "Saya merasa bahwa saya tidak berharga sebagai seorang manusia.",
      "d18": "Saya merasa bahwa saya mudah tersinggung.",
      "d19": "Saya berkeringat secara berlebihan (misalnya: tangan berkeringat), padahal temperatur tidak panas atau tidak melakukan aktivitas fisik sebelumnya.",
      "d20": "Saya merasa takut tanpa alasan yang jelas.",
      "d21": "Saya merasa bahwa hidup tidak bermanfaat.",
      "d22": "Saya merasa sulit untuk beristirahat.",
      "d23": "Saya mengalami kesulitan dalam menelan.",
      "d24": "Saya tidak dapat merasakan kenikmatan dari berbagai hal yang saya lakukan.",
      "d25": "Saya menyadari kegiatan jantung, walaupun saya tidak sehabis melakukan aktivitas fisik (misalnya: merasa detak jantung meningkat atau melemah).",
      "d26": "Saya merasa putus asa dan sedih.",
      "d27": "Saya merasa bahwa saya sangat mudah marah.",
      "d28": "Saya merasa saya hampir panik.",
      "d29": "Saya merasa sulit untuk tenang setelah sesuatu membuat saya kesal.",
      "d30": "Saya takut bahwa saya akan 'terhambat' oleh tugas-tugas sepele yang tidak biasa saya lakukan.",
      "d31": "Saya tidak merasa antusias dalam hal apapun.",
      "d32": "Saya sulit untuk sabar dalam menghadapi gangguan terhadap hal yang sedang saya lakukan.",
      "d33": "Saya sedang merasa gelisah.",
      "d34": "Saya merasa bahwa saya tidak berharga.",
      "d35": "Saya tidak dapat memaklumi hal apapun yang menghalangi saya untuk menyelesaikan hal yang sedang saya lakukan.",
      "d36": "Saya merasa sangat ketakutan.",
      "d37": "Saya melihat tidak ada harapan untuk masa depan.",
      "d38": "Saya merasa bahwa hidup tidak berarti.",
      "d39": "Saya menemukan diri saya mudah gelisah.",
      "d40": "Saya merasa khawatir dengan situasi dimana saya mungkin menjadi panik dan mempermalukan diri sendiri.",
      "d41": "Saya merasa gemetar (misalnya: pada tangan).",
      "d42": "Saya merasa sulit untuk meningkatkan inisiatif dalam melakukan sesuatu.",
      "debrief": ""
    },
    "ja": {
      "d1": "些細なことにも腹が立った。",
      "d2": "口の中が乾く感じがすることがあった。",
      "d3": "前向きな気持ちになることは 全くないように思った。",
      "d4": "呼吸困難な感じがした（例えば、 激しく動いたのでもないのに極度に呼吸が 速くなったり、呼吸が停止したりするなど）。",
      "d5": "前に進むことができなかった。",
      "d6": "状況に過剰に反応しやすかった。",
      "d7": "どこかがガクガクすることがあった （例えば、足がグラグラするなど）。",
      "d8": "リラックスするのが難しかった。",
      "d9": "とても心配なことが終わると大変安心した。",
      "d10": "期待できるものは何もないと思った。",
      "d11": "すぐ腹が立った。",
      "d12": "神経のエネルギーをたくさん 使っているように感じた。",
      "d13": "悲しくて落胆した。",
      "d14": "どんな場合も待たされるような状況に我慢が できなかった（例えば、エレベーターや 信号や何かに待たされる場合）。",
      "d15": "フラフラする感じがした。",
      "d16": "すべてのことに対して興味を 失っているように感じた。",
      "d17": "自分は人間としての価値がないと思った。",
      "d18": "自分はかなり神経質で怒りっぽいと思った。",
      "d19": "熱もないし体を激しく動かしたのでもない の目立って汗をかくことがあった （例えば手などに）。",
      "d20": "特に理由もないのに怯えていた。",
      "d21": "人生に価値はないと思った。",
      "d22": "緊張をとくのが難しかった。",
      "d23": "飲み込むのに困難を感じた。",
      "d24": "自分のしていることで楽しいと思うことは なかったように思う。",
      "d25": "体を激しく動かしていないのに心臓の 動きに変化を感じることがあった（例えば、 脈拍が早くなったり脈拍を感じないなど）。",
      "d26": "落ち込んでいて憂鬱だった。",
      "d27": "自分はとても短気だと思った。",
      "d28": "パニックを起こしそうだった。",
      "d29": "何か腹の立つことがあった後で落ち着きを 取り戻すのは難しかった。",
      "d30": "ちょっとした、しかしよく知らない仕事で 失敗してしまうことがないか恐れていた。",
      "d31": "何ごとに対しても熱くなることが できなかった。",
      "d32": "自分がしていることを中断されるのを 許すことができなかった。",
      "d33": "神経が緊張状態にあると思った。",
      "d34": "自分はかなり価値のない人間だと思った。",
      "d35": "うまくいっていることができなくなる 状況を耐えられなかった。",
      "d36": "恐怖を感じていた。",
      "d37": "将来に希望の持てるものは何もなかった。",
      "d38": "人生は無意味だと思った。",
      "d39": "あおられる性格だと思った。",
      "d40": "慌てたり、失敗して人に笑われることに なるのではないかと心配していた。",
      "d41": "震えを感じることがあった （例えば手が震えるなど）。",
      "d42": "何かするのに率先してやるのは難しかった。",
      "debrief": ""
    },
    "ko": {
      "d1": "나는 매우 사소한 일에도 화를 낸다고 느꼈다.",
      "d2": "나는 입안이 마르는 것을 느꼈다.",
      "d3": "나는 긍정적인 감정을 전혀 느끼지 못했던 것 같다.",
      "d4": "나는 호흡하는데 어려움(과도하게 빠른 호흡, 운동을 하지 않는 상황에서 숨이 가쁜 상태)을 경험했다.",
      "d5": "나는 활력이 없고 몸과 마음이 처지는 느낌을 받았다.",
      "d6": "나는 상황들에서 과잉반응을 하는 경향이 있었다.",
      "d7": "나는 주저앉을 것 같이 혼란스러운 느낌을 받았다.",
      "d8": "나는 긴장을 풀기가 어려웠다.",
      "d9": "나를 매우 불안하게 만드는 상황을 경험했으며, 그 상황이 끝나고 대부분 은 안정을 되찾았다.",
      "d10": "나는 아무것도(미래에) 기대할 것이 없다고 느꼈다.",
      "d11": "나는 스스로를 쉽게 화나게 만든다고 느꼈다.",
      "d12": "나는 신경을 너무 많이 쓰고 있음을 느꼈다.",
      "d13": "나는 슬프고 우울하다고 느꼈다.",
      "d14": "나는 길을 가다가 무언가가 지연이 되면 참고 견디기 어려웠다(예, 엘리베 이터, 신호등 또는 누군가를 기다림).",
      "d15": "나는 실신할 것 같은 기분(또는 현기증)을 느꼈다.",
      "d16": "나는 거의 모든 일에서 흥미를 잃었다고 느꼈다.",
      "d17": "나는 한 사람의 인간으로서 가치가 없다고 느꼈다.",
      "d18": "나는 내가 다소 예민하다고 느꼈다.",
      "d19": "온도가 높지 않거나 운동을 하지 않았는데도 손에서 땀이 많이 나는 것을 느꼈다.",
      "d20": "특별한 이유 없이 겁이 났다(무서웠다).",
      "d21": "나는 인생이 살아갈만한 가치가 없다고 느꼈다. 뒷면 계속 ☞",
      "d22": "나는 긴장을 풀고 휴식을 취하기 힘들었다.",
      "d23": "나는 음식을 삼키기 어려웠다.",
      "d24": "나는 내가 하는 일 이외에는 어떠한 즐거움도 찾을 수 없을 것 같았다.",
      "d25": "나는 운동을 하지 않는 상태에서 내 심장활동을 느꼈다(예, 심장박동의",
      "d26": "나는 기분이 가라앉고 우울함을 느꼈다.",
      "d27": "나는 매우 신경질적이었다고 느꼈다.",
      "d28": "나는 내가 공황상태(심한 불안상태)에 가깝다고 느꼈다.",
      "d29": "나는 어떤 일에 몹시 화가 난 후에 진정하기가 어려웠다.",
      "d30": "나는 허드렛일을 하는 업무에 배치될지 모른다고 두려워했다.",
      "d31": "나는 어떤 일에도 열정적(의욕적 또는 열심을 가지고 임하는 것)이기가",
      "d32": "내가 하고 있는 일을 중단시키는 것에 대해서 참기가 어려웠다.",
      "d33": "나는 신경이 곤두서 있는 상태에 있었다.",
      "d34": "나는 내가 매우 가치 없는 존재라고 느꼈다.",
      "d35": "내가 하고 있는 일에 대해 방해 받는 것을 참고 견디기 어려웠다.",
      "d36": "나는 두려움(무서움, 겁이 남)을 느꼈다.",
      "d37": "나는 나의 미래가 희망적이지 않다고 생각했다.",
      "d38": "나는 인생이 무의미하다고 느꼈다.",
      "d39": "나는 내 자신이(마음의 평정을 잃고) 동요되는 것을 느꼈다.",
      "d40": "나는 내가 심리적으로 공황상태가 되는 상황들과, 바보 같은 행동을 하게",
      "d41": "나는 걱정이나 불안으로 떨림(예, 손떨림)을 경험했다.",
      "d42": "나는 새로운 일을 시작하기가 어려웠다.",
      "debrief": ""
    },
    "lv": {
      "likert_1": "Neattiecas uz mani vispār",
      "likert_2": "Ir attiecināms uz mani nelielā mērā vai biju tam pakļauts īsu laiku",
      "likert_3": "Ir attiecināms uz mani diezgan lielā mērā vai biju tam pakļauts diezgan ilgu laiku",
      "likert_4": "Ir attiecināms uz mani ļoti lielā mērā vai biju tam pakļauts ļoti ilgu laiku",
      "d1": "Es uztraucos ikdienas sīkumu dēļ.",
      "d2": "Es sajutu sausuma sajūtu mutē.",
      "d3": "Es neizjutu nekādas pozitīvas emocijas.",
      "d4": "Arī bez fiziskās slodzes man bija grūtības elpot (paātrināta elpošana,elpas trūkums).",
      "d5": "Es nevarēju saņemties darīt to, kas nepieciešams.",
      "d6": "Es pārmērīgi emocionāli reaģēju dažādās situācijās.",
      "d7": "No uztraukuma man trīcēja kājas.",
      "d8": "Man bija grūtības atslābināties.",
      "d9": "Bija situācijas, kurās es tik ļoti uztraucos, ka izjutu milzīgu atvieglojumu, kad tās bija beigušās.",
      "d10": "Es izjūtu bezcerību.",
      "d11": "Es ātri kļuvu bēdīgs.",
      "d12": "Es daudz nervozēju.",
      "d13": "Es jūtos bēdīgs un nomākts.",
      "d14": "Es kļuvu nepacietīgs, ja gadījās kāds kavēklis (piemēram, ilgi bija jāgaida lifts, zaļā gaisma luksoforā).",
      "d15": "Man bija izjūta, ka es noģībšu.",
      "d16": "Es zaudēju interesi par jebko.",
      "d17": "Es jutos nevērtīgs.",
      "d18": "Es biju jūtīgs pret citu cilvēku teikto par mani.",
      "d19": "Man svīda rokas arī tad, ja nebija paaugstināta gaisa temperatūra vai fiziska slodze.",
      "d20": "Es izjutu bailes bez kāda pamatota iemesla.",
      "d21": "Es izjutu, ka dzīve ir bezjēdzīga.",
      "d22": "Man bija grūti nomierināties.",
      "d23": "Man bija grūtības norīt.",
      "d24": "Es nesajutu gandarījumu par to, ko darīju.",
      "d25": "Arī bez fiziskās slodzes es sajutu paātrinātu vai nevienmērīgu sirdsdarbību (sirds klauvēs, aritmiju).",
      "d26": "Es jutos drūms un grūtsirdīgs.",
      "d27": "Es biju ļoti ātri aizkaitināms.",
      "d28": "Es biju tuvu panikai.",
      "d29": "Man bija grūti nomierināties pēc piedzīvotā satraukuma.",
      "d30": "Es baidījos, ka piedzīvošu neveiksmi kādā ikdienišķā, bet man nezināmā uzdevuma veikšanā.",
      "d31": "Mani nekas nespēja aizraut.",
      "d32": "Man bija grūti paciest, ja tiku pārtraukts kaut ko darot.",
      "d33": "Es izjutu nervu spriedzi.",
      "d34": "Es jutos bezvērtīgs.",
      "d35": "Man bija grūti paciest jebkādu kavēkli, kas neļāva man turpināt iesākto darbu.",
      "d36": "Es jutos pārbijies.",
      "d37": "Es izjutu, ka man vairs nav uz ko cerēt.",
      "d38": "Es izjutu, ka nav vērts dzīvot.",
      "d39": "Es izjutu, ka sāku uztraukties.",
      "d40": "Es biju uztraucies par situācijām, kurās es varētu krist panikā un nostādīt sevi neveiklā situācijā.",
      "d41": "No uztraukuma man trīcēja rokas.",
      "d42": "Man bija grūti piespiest sevi, lai kaut ko izdarītu.",
      "debrief": ""
    },
    "ms": {
      "likert_1": "Tidak langsung menggambarkan keadaan saya",
      "likert_2": "Sedikit atau jarang-jarang menggambarkan keadaan saya.",
      "likert_3": "Banyak atau kerapkali menggambarkan keadaan saya.",
      "likert_4": "Sangat banyak atau sangat kerap menggambarkan keadaan saya",
      "d1": "Saya dapati diri saya menjadi kesal/marah disebabkan perkara-perkara yang kecil.",
      "d2": "Banyak atau kerapkali menggambarkan keadaan saya.",
      "d3": "Sangat banyak atau sangat kerap menggambarkan keadaan saya",
      "d4": "Saya mengalami kesukaran bernafas (contohnya pernafasan yang laju, tercungap- cungap walaupun tidak melakukan senaman fizikal)",
      "d5": "Saya rasa diri saya tidak bergerak ke mana-mana",
      "d6": "Saya cenderung untuk bertindak keterlaluan dalam sesuatu keadaan",
      "d7": "Saya mempunyai perasaan gementar (seperti kaki menjadi lemah)",
      "d8": "Saya rasa sukar untuk relaks",
      "d9": "Saya dapati diri saya di dalam keadaan yang menjadikan saya amat risau dan menjadi tenang semula selepas ianya berakhir",
      "d10": "Saya rasa saya tidak mempunyai apa-apa untuk diharapkan",
      "d11": "Saya dapati diri saya mudah merasa kesal",
      "d12": "Saya rasa saya menggunakan banyak tenaga dalam keadaan cemas",
      "d13": "Saya rasa sedih dan murung",
      "d14": "Saya dapati diri saya hilang kesabaran sekiranya saya dilambatkan oleh sesuatu",
      "d15": "Saya rasa macam nak pengsan",
      "d16": "Saya rasa saya hilang minat dalam segala hal",
      "d17": "Saya tidak begitu berharga sebagai seorang individu",
      "d18": "Saya rasa yang saya mudah tersentuh",
      "d19": "Saya banyak berpeluh (contohnya pada tangan) walaupun bukan pada suhu tinggi atau tiada pergerakan fizikal.",
      "d20": "Saya berasa takut tanpa sebab yang munasabah",
      "d21": "Saya rasa hidup ini sudah tidak bermakna lagi",
      "d22": "Saya dapati diri saya sukar ditenteramkan",
      "d23": "Saya rasa sukar menelan",
      "d24": "Saya tidak dapat merasakan keseronokan dalam apa yang saya lakukan",
      "d25": "Saya sedar tindakbalas jantung saya walaupun tidak melakukan aktiviti fizikal",
      "d26": "Saya rasa duka dan tidak keruan",
      "d27": "Saya dapati diri saya mudah marah",
      "d28": "Saya rasa hampir-hampir menjadi panik/cemas",
      "d29": "Saya dapati sukar untuk bertenang setelah sesuatu membuatkan saya kesal",
      "d30": "Saya risau saya akan ‘dihambat’ oleh tugas yang remeh dan tidak biasa dilakukan",
      "d31": "Saya tidak bersemangat dengan apa jua yang saya lakukan",
      "d32": "Saya sukar bersabar pada gangguan terhadap perkara yang sedang saya lakukan",
      "d33": "Saya di dalam keadaan yang terlalu gementar",
      "d34": "Saya rasa diri saya langsung tidak berharga",
      "d35": "Saya hilang pertimbangan pada perkara yang menghalang saya meneruskan apa yang saya lakukan",
      "d36": "Saya rasa amat takut",
      "d37": "Saya melihat tiada masa depan untuk saya menaruh harapan",
      "d38": "Saya rasa hidup ini tidak bermakna",
      "d39": "Saya dapati diri saya semakin gelisah",
      "d40": "Saya bimbang keadaan di mana saya mungkin menjadi panik dan melakukan perkara yang membodohkan diri sendiri",
      "d41": "Saya rasa menggeletar (contohnya pada tangan)",
      "d42": "Saya sukar untuk mendapatkan semangat bagi melakukan sesuatu perkara",
      "debrief": ""
    },
    "nl": {
      "likert_1": "= Helemaal niet of nooit van toepassing",
      "likert_2": "= Een beetje of soms van toepassing",
      "likert_3": "= Behoorlijk of vaak van toepassing",
      "likert_4": "= Zeer zeker of meestal van toepassing",
      "d1": "Ik merkte dat ik overstuur raakte van onbelangrijke zaken",
      "d2": "Ik merkte dat mijn mond droog aanvoelde",
      "d3": "Ik was niet in staat om ook maar enig positief gevoel te ervaren",
      "d4": "Ik had moeite met ademhalen*",
      "d5": "Ik kon maar niet op gang komen",
      "d6": "Ik had de neiging om overdreven te reageren op situaties",
      "d7": "Ik voelde me beverig (bijv. onvast ter been zijn)",
      "d8": "Ik vond het moeilijk me te ontspannen*",
      "d9": "Er waren situaties die me zo angstig maakten dat ik erg opgelucht was",
      "d10": "Ik had het gevoel dat ik niets had om naar uit te kijken*",
      "d11": "Ik merkte dat ik gemakkelijk overstuur raakte*",
      "d12": "Ik was erg opgefokt*",
      "d13": "Ik voelde me verdrietig en depressief",
      "d14": "Ik merkte dat ik erg ongeduldig werd van oponthoud",
      "d15": "Ik had het gevoel flauw te gaan vallen",
      "d16": "Ik had mijn interesse in zo'n beetje alles verloren",
      "d17": "Ik had het gevoel dat ik als persoon niet veel voorstel",
      "d18": "Ik merkte dat ik nogal licht geraakt was*",
      "d19": "Ik transpireerde merkbaar terwijl het niet warm was en ik me niet",
      "d20": "Ik was angstig zonder enige reden",
      "d21": "Ik had het gevoel dat mijn leven niet de moeite waard is",
      "d22": "Ik vond het moeilijk op verhaal te komen*",
      "d23": "Ik had moeite met slikken",
      "d24": "Ik was niet in staat om enig plezier te hebben bij wat ik deed*",
      "d25": "Ik was me bewust van mijn hartslag terwijl ik me niet fysiek inspande*",
      "d26": "Ik voelde me somber en zwaarmoedig*",
      "d27": "Ik merkte dat ik erg snel prikkelbaar was*",
      "d28": "Ik had het gevoel dat ik bijna in paniek raakte*",
      "d29": "Ik vond het moeilijk tot rust te komen nadat iets me overstuur had",
      "d30": "Ik was bang dat ik van mijn stuk zou raken bij een eenvoudige nieuwe",
      "d31": "Ik was niet in staat om over ook maar iets enthousiast te worden*",
      "d32": "Ik merkte dat ik erg onrustig was",
      "d33": "Ik was erg nerveus",
      "d34": "Ik had het gevoel niets waard te zijn*",
      "d35": "Ik had volstrekt geen geduld met dingen die me hinderden bij iets dat ik",
      "d36": "Ik voelde me ontzettend angstig*",
      "d37": "Ik kon niets in de toekomst zien om me op te verheugen",
      "d38": "Ik had het gevoel dat mijn leven geen zin had*",
      "d39": "Ik vond het moeilijk om te dulden dat ik gestoord werd bij wat ik aan",
      "d40": "Ik maakte me zorgen over situaties waarin ik in paniek zou raken en",
      "d41": "Ik merkte dat ik beefde (bijv. met de handen)*",
      "d42": "Ik vond het moeilijk om het initiatief te nemen om iets te gaan doen*",
      "debrief": ""
    },
    "no": {
      "likert_1": "Passer ikke i det hele tatt",
      "likert_2": "Passer til en viss grad, eller noe av tiden",
      "likert_3": "Passer godt, eller en god del av tiden",
      "likert_4": "Passer best, eller mesteparten av tiden",
      "d1": "Jeg ble opprørt av trivielle ting",
      "d2": "Jeg var oppmerksom på at jeg var tørr i munnen",
      "d3": "Jeg klarte ikke å oppleve noen positive følelser",
      "d4": "Jeg hadde pustevansker (f.eks. pustet altfor fort, andpusten uten fysisk anstrengelse)",
      "d5": "Jeg kom ikke i gang med noe",
      "d6": "Jeg hadde en tendens til å overreagere",
      "d7": "Jeg følte meg skjelven (f.eks. følte at bena kom til å gi etter under meg)",
      "d8": "Jeg hadde vansker med å slappe av",
      "d9": "Jeg opplevde situasjoner som gjorde meg så engstelig at jeg var utrolig lettet når de var over",
      "d10": "Jeg følte at jeg ikke hadde noe å se frem til",
      "d11": "Jeg ble fort opprørt",
      "d12": "Jeg følte at jeg brukte mye nervøs energi",
      "d13": "Jeg var trist og deprimert",
      "d14": "Jeg ble utålmodig hvis jeg ble forsinket på noen som helst måte",
      "d15": "Jeg følte at jeg kom til å besvime",
      "d16": "Jeg følte at jeg hadde mistet interessen for nesten alt",
      "d17": "Jeg følte meg verdiløs som person",
      "d18": "Jeg tok meg lett nær av ting",
      "d19": "Jeg svettet mye (f.eks. i hendene) uten at det var varmt, og uten fysisk anstrengelse",
      "d20": "Jeg følte meg redd uten å ha særlig grunn til det",
      "d21": "Jeg følte at livet ikke var verdt å leve",
      "d22": "Jeg hadde vanskelig for å roe meg ned",
      "d23": "Jeg hadde problemer med å svelge",
      "d24": "Jeg fikk ingen glede ut av det jeg gjorde",
      "d25": "Jeg var oppmerksom på hjerterytmen min uten at jeg hadde vært i fysisk aktivitet",
      "d26": "Jeg følte meg nedtrykt og trist",
      "d27": "Jeg var veldig irritabel",
      "d28": "Jeg følte at jeg var nær ved å få panikk",
      "d29": "Jeg hadde vansker med å roe meg ned etter at noe hadde opprørt meg",
      "d30": "Jeg fryktet at en enkel, men ukjent oppgave kom til å bringe meg ut av fatning",
      "d31": "Jeg klarte ikke å føle entusiasme over noe",
      "d32": "Jeg hadde vansker med å tolerere avbrytelser når jeg holdt på med noe",
      "d33": "Jeg var nervøs og anspent",
      "d34": "Jeg følte meg ganske udugelig",
      "d35": "Jeg tolererte ikke å bli avbrutt hvis jeg holdt på med noe",
      "d36": "Jeg var livredd",
      "d37": "Jeg hadde ikke noe håp for fremtiden",
      "d38": "Jeg følte at livet var meningsløst",
      "d39": "Jeg var oppfarende",
      "d40": "Jeg bekymret meg for situasjoner der jeg kunne få panikk og dumme meg ut",
      "d41": "Jeg skalv ofte (f.eks. på hendene)",
      "d42": "Jeg syntes det var vanskelig å ta initiativ til å få ting gjort",
      "debrief": ""
    },
    "sk": {
      "likert_1": "1    2   3",
      "likert_2": "- Platí to pre mňa čiastočne, niekedy",
      "likert_3": "- Platí to pre mňa do značnej miery alebo značnú časť času",
      "likert_4": "- Platí to pre mňa úplne alebo väčšinu času",
      "d1": "Nahnevali ma triviálne veci.",
      "d2": "Pociťoval som sucho v ústach.",
      "d3": "Neprežíval som žiadne pozitívne pocity.",
      "d4": "Mal som problém s dýchaním (napr. dýchal som veľmi rýchlo alebo som lapal po",
      "d5": "Nemal som síl pokračovať.",
      "d6": "V určitých situáciách som reagoval prehnane.",
      "d7": "Mal som pocit, že sa trasiem (napr. nohy, kolená apod.).",
      "d8": "Bolo pre mňa ťažké relaxovať.",
      "d9": "Ocitol som sa v situáciách, v ktorých som cítil takú úzkosť, že mi odľahlo, keď",
      "d10": "Mal som pocit, že neexistuje nič, na čo by som sa tešil.",
      "d11": "Zistil som, že sa dosť rýchlo nahnevám.",
      "d12": "Cítil som sa veľmi nervózne a musel som s tým niečo urobiť.",
      "d13": "Cítil som sa smutný a depresívny.",
      "d14": "Bol som nepokojný, keď som kdekoľvek meškal (kvôli výťahu, premávke, keď som",
      "d15": "Mal som pocit, že omdliem.",
      "d16": "Mal som pocit, že som stratil záujem o všetko.",
      "d17": "Mal som pocit, že ako človek za veľa nestojím.",
      "d18": "Cítil som, že reagujem precitlivelo.",
      "d19": "Potil som sa, aj keď nebolo teplo a nevykonával som fyzickú aktivitu (napr. dlane).",
      "d20": "Bál som sa aj bez zjavného dôvodu.",
      "d21": "Cítil som, že život nemá zmysel.",
      "d22": "Mal som problém sa upokojiť.",
      "d23": "Mal som ťažkosti s prehĺtaním.",
      "d24": "Nenachádzal som žiadne potešenie vo veciach, ktoré som robil.",
      "d25": "Vnímal som tlkot svojho srdca (napr. zrýchlenie činnosti srdca, vynechanie úderu), aj",
      "d26": "Cítil som sa smutne a skľúčene.",
      "d27": "Bol som podráždený.",
      "d28": "Cítil som, že podlieham panike.",
      "d29": "Bolo pre mňa ťažké upokojiť sa potom, ako ma niečo nahnevalo.",
      "d30": "Obával som sa, že ma rozhodí nejaká jednoduchá, ale neznáma úloha.",
      "d31": "Nevedel som sa pre nič nadchnúť.",
      "d32": "Ťažko som znášal, keď ma niečo vyrušilo pri práci.",
      "d33": "Bol som napätý.",
      "d34": "Cítil som sa úplne bezcenný.",
      "d35": "Nezniesol som, keď ma niečo odvádzalo od toho, čo som robil.",
      "d36": "Cítil som sa vydesene/ vystrašene.",
      "d37": "Budúcnosť sa mi zdala beznádejná.",
      "d38": "Cítil som, že život nemá zmysel.",
      "d39": "Cítil som sa rozrušený.",
      "d40": "Obával som sa situácií, v ktorých som mohol podľahnúť panike a strápniť sa.",
      "d41": "Triasol som sa (napr. ruky).",
      "d42": "Bolo pre mňa ťažké prevziať iniciatívu (začať niečo robiť).",
      "debrief": ""
    },
    "sl": {
      "d1": "Opazil sem, da so me vznemirile čisto nepomembne reči.",
      "d2": "Opazil sem, da imam suha usta.",
      "d3": "Zdelo se mi je, da sploh ne morem biti dobro razpoložen.",
      "d4": "Ne da bi se posebej naprezal, sem imel težave z dihanjem (izjemno",
      "d5": "Nisem mogel normalno funkcionirati.",
      "d6": "Pretirano sem reagiral na situacije.",
      "d7": "Imel sem občutek slabotnosti (npr. popustile so mi noge).",
      "d8": "Težko sem se sprostil.",
      "d9": "Znašel sem se v situacijah, ki so bile tako mučne, da sem čutil veliko",
      "d10": "Zdelo se mi je, da se nimam česa veseliti.",
      "d11": "Opazil sem, da se hitro razburim.",
      "d12": "Imel sem občutek da sem precej nervozen.",
      "d13": "Počutil sem se potrto in depresivno.",
      "d14": "Opazil sem, da postanem nepotrpežljiv, ko sem kakorkoli zapravljal",
      "d15": "Imel sem vrtoglavice.",
      "d16": "Zdelo se mi je, da me sploh nobena stvar več ne zanima.",
      "d17": "Počutil sem se, da kot oseba nisem veliko vreden.",
      "d18": "Zdelo se mi je da sem precej občutljiv.",
      "d19": "Opazno sem se potil (npr. potne roke) brez fizičnega napora ali visokih",
      "d20": "Strah me je bilo brez utemeljenega razloga.",
      "d21": "Mislil sem, da ni vredno živeti.",
      "d22": "Opazil sem, da se težko pomirim",
      "d23": "Imel sem težave pri požiranju.",
      "d24": "Zdelo se mi je, da v stvareh, ki jih počnem ne morem najti",
      "d25": "Opazil sem, da moje srce včasih brez fizičnega napora prehitro bije",
      "d26": "Počutil sem se malodušno in potrto.",
      "d27": "Opazil sem, da sem zelo razdražljiv.",
      "d28": "Zdelo se mi je da postajam paničen.",
      "d29": "Težko sem se pomiril, ko me je nekaj razburilo.",
      "d30": "Bal sem se, da bom klonil zaradi sicer neke banalne, a meni",
      "d31": "Nad ničemer se nisem mogel navdušiti.",
      "d32": "Težko sem toleriral, da so me prekinjali med delom.",
      "d33": "Bil sem živčno napet.",
      "d34": "Počutil sem se precej nevrednega.",
      "d35": "Bil sem netoleranten do vsega kar me je oviralo pri delu.",
      "d36": "Strah me je bilo.",
      "d37": "V prihodnosti nisem videl nič obetavnega.",
      "d38": "Čutil sem, da je življenje brez pomena.",
      "d39": "Čutil sem, da postajam vznemirjen.",
      "d40": "Skrbele so me situacije, v katerih bi se me lahko polastila panika",
      "d41": "Doživel sem tresavico (npr. tresenje rok)",
      "d42": "Težko sem začel s pobudami za delo.",
      "debrief": ""
    },
    "sq": {
      "likert_1": "Aspak nuk Pajtohem",
      "likert_2": "Nuk Pajtohem",
      "likert_3": "Pajtohem",
      "likert_4": "Gjithsesi Pajtohem",
      "d1": "Për shkak që nuk ju veje rëndësi gjërave, jam i pamoralshëm",
      "d2": "Goja më thahet",
      "d3": "Nuk kam përjetu ndjenjat pozitive",
      "d4": "Kam vështërsi në frymemarje (p.sh; edhe pse nuk bëjë ushtrime fizike, veshtërsi në frymarje apo ritëm të shpejt në zemer kam)",
      "d5": "Unë nuk mund të fillojë ndonjë pune",
      "d6": "Reagojë shpejt ndaj ngjarjeve",
      "d7": "E dijej vetën të pafuqishëm (p.sh; nuk më mbajnë këmbët)",
      "d8": "Kam vështërsi të relaksohem",
      "d9": "Ndonihere më ndodh që të kem ngushtime dhe kur kalojnë këto ngushtime, ndihem shum i relaksuar",
      "d10": "Nuk pres asgjë dhe nuk shpresojë azgjë",
      "d11": "Shumë shpejt më prishet disponimi",
      "d12": "Ndjej se shum energji hargjoj si skak i nervozës",
      "d13": "Ndihem pesimist dhe i palumtur",
      "d14": "Për ndonjë arsye (p.sh; në ashensor apo në trafik në pritjeve të semaforit) për kët arsye mendojë se po vanohem dhe humbi durimin",
      "d15": "E ndjej vetën të dobët dhe të lodhur",
      "d16": "Pothuaj se kam humbur interesin për çdo gjë",
      "d17": "E ndjej vetën si njeri i pa vlefshëm",
      "d18": "Jam tepër i ndjeshëm dhe prekem shpejt",
      "d19": "Pa punuar asnjë aktivitet fizik the pa qen koha e nxeht unë djersitem (p.sh; djersitja e duarve)",
      "d20": "Friksohem pa ndonjë arsye",
      "d21": "Ndjej se nuk ja vlen të jetohet",
      "d22": "E kam vështir të relaksohem",
      "d23": "E kam të vështir të gëlltitem",
      "d24": "E ndjej se çdo gjë që bëjë nuk më kënaq",
      "d25": "Pa asnjë aktivitet fizik ndjej ritme të shpejta të rrahjes së zemrës (p.sh; rrahjet të forta të zemrës dhe të ndyshueshme)",
      "d26": "Ndjehem i trishtuar dhe i len pas dore",
      "d27": "E ndjeva vetën se shum shpejtë bëhem i ashpër",
      "d28": "Mua më kapë paniku shum leht",
      "d29": "Kur ndjehem në ndonjë rastë i stresuar, pas rastit shum vështir e kam për tu relaksuar",
      "d30": "Edhe për gjërat e thjeshta që nuk mundem ti kalojë ndihem i shqetsuar",
      "d31": "Unë nuk jam entuziast dhe i gëzuar për të bërë diçka",
      "d32": "Kam vërejtur kur më ndalohet puna ndjehem i shqetësuar",
      "d33": "Jam i tensionuar",
      "d34": "E ndjej vetën që jam i pavlefshëm",
      "d35": "Nuk toleroj pengesa në punë",
      "d36": "Ndihem i tmeruar",
      "d37": "Unë nuk shoh asgjë të ardhme premtuese",
      "d38": "Ndjej se jeta nuk ka kuptim, nuk ja vlen të jetohet",
      "d39": "Bie shpejt në provokime",
      "d40": "Shqetësohem për shkak të situatave ku mund të dukem qesharak dhe të më kaplojë paniku",
      "d41": "Ndjej dridhje në trupe (p.sh; dridhja e duarve)",
      "d42": "Punët që dua të bëjë, e kam të vështir tija fillojë",
      "debrief": ""
    },
