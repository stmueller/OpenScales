          "perceieved_compatibility_current_practice_generate_important_information_care": 1,
          "perceieved_compatibility_current_practice_relevant": 1
        },
        "description": "Total score (sum of all items)"
      }
    }
  },
  "translations": {
    "en": {
      "lk_opt_1": "Strongly agree",
      "lk_opt_2": "Agree",
      "lk_opt_3": "Neither agree nor disagree",
      "lk_opt_4": "Disagree",
      "lk_opt_5": "Strongly disagree",
      "perceieved_compatibility_current_practice_care_already_use": "Using [X genomic intervention] fits within the processes that I already use to care for my patients.",
      "perceieved_compatibility_current_practice_generate_important_information_care": "The information generated by [X genomic intervention] is important for patient care.",
      "perceieved_compatibility_current_practice_relevant": "I believe that [X genomic intervention] is relevant to my current clinical practice."
