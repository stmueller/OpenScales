  "translations": {
    "en": {
      "lk_opt_1": "Not at all",
      "lk_opt_2": "A little bit",
      "lk_opt_3": "Somewhat",
      "lk_opt_4": "Quite a bit",
      "lk_opt_5": "Very much",
      "px960301_sleep_covid_before_sleep_quality": "In a normal week, about a month BEFORE the COVID-19 outbreak...My sleep quality was",
      "px960301_sleep_covid_before_sleep_refresh": "In a normal week, about a month BEFORE the COVID-19 outbreak...My sleep quality was refreshing",
      "px960301_sleep_covid_before_sleep_problem": "In a normal week, about a month BEFORE the COVID-19 outbreak...I had a problem with my sleep",
      "px960301_sleep_covid_before_fall_asleep": "In a normal week, about a month BEFORE the COVID-19 outbreak...I had difficulty falling asleep",
