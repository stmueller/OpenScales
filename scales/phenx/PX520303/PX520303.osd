      "would_not_enjoy_heroin_opt_7": "STRONGLY AGREE",
      "do_not_need_heroin_now": "I do not need to use heroin now.",
      "do_not_need_heroin_now_opt_1": "STRONGLY DISAGREE",
      "do_not_need_heroin_now_opt_2": "2",
      "do_not_need_heroin_now_opt_3": "3",
      "do_not_need_heroin_now_opt_4": "4",
      "do_not_need_heroin_now_opt_5": "5",
      "do_not_need_heroin_now_opt_6": "6",
      "do_not_need_heroin_now_opt_7": "STRONGLY AGREE",
      "unable_control_heroin_amount": "I would not be able to control how much heroin I used if I had some here.",
      "unable_control_heroin_amount_opt_1": "STRONGLY DISAGREE",
      "unable_control_heroin_amount_opt_2": "2",
      "unable_control_heroin_amount_opt_3": "3",
      "unable_control_heroin_amount_opt_4": "4",
      "unable_control_heroin_amount_opt_5": "5",
      "unable_control_heroin_amount_opt_6": "6",
      "unable_control_heroin_amount_opt_7": "STRONGLY AGREE",
      "crave_heroin": "I crave heroin right now.",
      "crave_heroin_opt_1": "STRONGLY DISAGREE",
      "crave_heroin_opt_2": "2",
      "crave_heroin_opt_3": "3",
      "crave_heroin_opt_4": "4",
      "crave_heroin_opt_5": "5",
      "crave_heroin_opt_6": "6",
      "crave_heroin_opt_7": "STRONGLY AGREE",
      "urge_for_heroin": "I have an urge for heroin.",
      "urge_for_heroin_opt_1": "STRONGLY DISAGREE",
      "urge_for_heroin_opt_2": "2",
      "urge_for_heroin_opt_3": "3",
      "urge_for_heroin_opt_4": "4",
      "urge_for_heroin_opt_5": "5",
      "urge_for_heroin_opt_6": "6",
      "urge_for_heroin_opt_7": "STRONGLY AGREE",
      "could_resist_heroin_now": "I think that I could resist using heroin now.",
      "could_resist_heroin_now_opt_1": "STRONGLY DISAGREE",
      "could_resist_heroin_now_opt_2": "2",
      "could_resist_heroin_now_opt_3": "3",
      "could_resist_heroin_now_opt_4": "4",
      "could_resist_heroin_now_opt_5": "5",
      "could_resist_heroin_now_opt_6": "6",
      "could_resist_heroin_now_opt_7": "STRONGLY AGREE",
      "scoring_520303": "Scoring Procedure and InterpretationEach item is scored on a scale ranging from 1 for \"Strongly Disagree\" to 7 for \"Strongly Agree.\" The following items are reverse-scored: 1, 5, 8, 9, 10, and 14 (raw score = 8 minus reverse-keyed item score).For total score, sum all 14 items and divide by 14. For the higher-order-factor score, sum all items except item 1 and divide by 13.In a treatment-seeking sample (N = 101), the factor structure of the Heroin Craving Questionnaire-Short Form 14 (HCQ-SF-14) was not consistent with that of the validated 45-item HCQ. The higher-order-factor score can be used as a unidimensional assessment of craving; it correlates with total score on the 45-item HCQ and with visual analog scales for \"crave,\" \"want,\" and \"need\" (Heinz et al., 2006)."
    }
  }
}