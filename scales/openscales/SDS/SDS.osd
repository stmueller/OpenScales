    "scoring": {
      "attention": {
        "description": "Mean of Attention Impulsiveness items (1–5). Higher scores indicate greater distraction from smartphone notifications, apps, and device presence.",
        "method": "mean_coded",
        "items": [
          "sds1",
          "sds2",
          "sds3",
          "sds4"
        ]
      },
      "vigilance": {
        "description": "Mean of Online Vigilance items (1–5). Higher scores indicate greater preoccupation with checking phone content and monitoring social validation.",
        "method": "mean_coded",
        "items": [
          "sds5",
          "sds6",
          "sds7",
          "sds8"
        ]
      },
      "multitasking": {
        "description": "Mean of Multitasking items (1–5). Higher scores indicate more frequent simultaneous smartphone use during other activities.",
        "method": "mean_coded",
        "items": [
          "sds9",
          "sds10",
          "sds11",
          "sds12"
        ]
      },
      "emotion_reg": {
        "description": "Mean of Emotion Regulation items (1–5). Higher scores indicate greater use of the smartphone to avoid unpleasant tasks, negative thoughts, or emotional pressure.",
        "method": "mean_coded",
        "items": [
          "sds13",
          "sds14",
          "sds15",
          "sds16"
        ]
      }
    }
  },
  "translations": {
    "en": {
      "likert_1": "Almost never",
      "likert_2": "Rarely",
      "likert_3": "Sometimes",
      "likert_4": "Often",
      "likert_5": "Almost always",
      "question_head": "Below is a collection of statements about your everyday experience with your smartphone. Using the 1–5 scale below, please indicate how often you currently have each experience. Please answer according to what best reflects your everyday experience.",
      "inst": "Below is a collection of statements about your everyday experience with your smartphone. Using the scale provided, please indicate how often you currently have each experience. Please answer according to what best reflects your everyday experience.",
      "sds1": "I get distracted by my phone notifications.",
      "sds2": "I get distracted by my phone apps.",
      "sds3": "I get distracted by just having my phone next to me.",
      "sds4": "I get distracted by my phone even when my full attention is required on other tasks.",
      "sds5": "I get anxious if I don't check messages immediately on my phone.",
      "sds6": "I think a lot about checking my phone when I can't access it.",
      "sds7": "I get distracted with what I could post while doing other tasks.",
      "sds8": "I get distracted thinking how many likes and comments I will get while doing other tasks.",
      "sds9": "I use several applications on my phone while working.",
      "sds10": "I can easily follow conversations while using my phone.",
      "sds11": "I often walk and use my phone at the same time.",
      "sds12": "I often talk to others while checking what's on my phone.",
      "sds13": "Using my phone distracts me from doing unpleasant things.",
      "sds14": "Using my phone distracts me from negative or unpleasant thoughts.",
      "sds15": "Using my phone distracts me from tasks that are tedious or difficult.",
      "sds16": "Using my phone distracts me when I'm under pressure.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
