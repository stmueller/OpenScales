  "translations": {
    "en": {
      "mossocial_question_head": "How often is each of the following kinds of support available to you if you need it?",
      "mossocial_r1": "None of the time",
      "mossocial_r2": "A little of the time",
      "mossocial_r3": "Some of the time",
      "mossocial_r4": "Most of the time",
      "mossocial_r5": "All of the time",
      "mossocial1": "About how many close friends and close relatives do you have (people you feel at ease with and can talk to about what is on your mind)?",
      "mossocial1_r1": "None",
      "mossocial1_r2": "1",
      "mossocial1_r3": "2",
      "mossocial1_r4": "3–5",
      "mossocial1_r5": "6–9",
      "mossocial1_r6": "10 or more",
      "mossocial2": "Someone you can count on to listen to you when you need to talk",
      "mossocial3": "Someone to give you information to help you understand a situation",
      "mossocial4": "Someone to give you advice about a crisis",
      "mossocial5": "Someone to help you if you were confined to bed",
      "mossocial6": "Someone who shows you love and affection",
      "mossocial7": "Someone to have a good time with",
      "mossocial8": "Someone to confide in or talk to about yourself or your problems",
      "mossocial9": "Someone whose advice you really want",
      "mossocial10": "Someone to take you to the doctor if you needed it",
      "mossocial11": "Someone to prepare your meals if you were unable to do it yourself",
      "mossocial12": "Someone to love and make you feel wanted",
      "mossocial13": "Someone to share your most private worries and fears with",
      "mossocial14": "Someone to turn to for suggestions about how to deal with a personal problem",
      "mossocial15": "Someone who hugs you",
      "mossocial16": "Someone to help with daily chores if you were sick",
      "mossocial17": "Someone to do things with to help you get your mind off things",
      "mossocial18": "Someone who understands your problems",
      "mossocial19": "Someone to get together with for relaxation",
      "mossocial20": "Someone to do something enjoyable with",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
