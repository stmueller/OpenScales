{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Information Sources for Patients after Return of Results",
      "code": "PX310601",
      "abbreviation": "PX310601",
      "description": "After a patient receives genetic test results, the patient is asked which sources were used to find out more about the genetic test results. Then the patient completes a scale of 1–5 based on the perceived usefulness of the information from the source. The patient is also encouraged to list any webs",
      "domain": "Genomics & Genetics",
      "citation": "Read, C. Y., Perry, D. J., & Duffy, M. E. (2005). Design and psychometric evaluation of the Psychological Adaptation to Genetic Information Scale. Journal of Nursing Scholarship, 37(3), 203–208. [PhenX: https://www.phenxtoolkit.org/protocols/view/310601]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/310601"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
