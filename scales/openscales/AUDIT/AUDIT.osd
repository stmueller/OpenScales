{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Alcohol Use Disorders Identification Test",
      "code": "AUDIT",
      "abbreviation": "AUDIT",
      "description": "10-item WHO screening tool for hazardous and harmful alcohol use. Scores range from 0 to 40.",
      "citation": "Saunders, J. B., Aasland, O. G., Babor, T. F., de la Fuente, J. R., & Grant, M. (1993). Development of the Alcohol Use Disorders Identification Test (AUDIT). Addiction, 88(6), 791-804. https://doi.org/10.1111/j.1360-0443.1993.tb02093.x",
      "license": "Public Domain",
      "version": "1.0",
      "url": "https://www.who.int/publications/i/item/WHO-MSD-MSB-01.6a",
      "domain": "Substance Use"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "dimensions": [
      {
        "id": "alcohol_use",
        "name": "Alcohol Use"
      }
    ],
    "items": [
      {
        "id": "audit1",
        "text_key": "audit1",
        "type": "likert"
      },
      {
        "id": "sec_drinking",
        "type": "section",
        "visible_when": {
          "all": [
            {
              "item": "audit1",
              "operator": "is_answered"
            },
            {
              "item": "audit1",
              "operator": "not_equals",
              "value": 0
            }
          ]
        }
      },
      {
        "id": "audit2",
        "text_key": "audit2",
        "type": "likert"
      },
      {
        "id": "audit3",
        "text_key": "audit3",
        "type": "likert"
      },
      {
        "id": "audit4",
        "text_key": "audit4",
        "type": "likert"
      },
      {
        "id": "audit5",
        "text_key": "audit5",
        "type": "likert"
      },
      {
        "id": "audit6",
        "text_key": "audit6",
        "type": "likert"
      },
      {
        "id": "audit7",
        "text_key": "audit7",
        "type": "likert"
      },
      {
        "id": "audit8",
        "text_key": "audit8",
        "type": "likert"
      },
      {
        "id": "sec_consequences",
        "type": "section"
      },
      {
        "id": "audit9",
        "text_key": "audit9",
        "type": "multi",
        "options": [
          {
            "text_key": "opt_1",
            "value": 0
          },
          {
            "text_key": "opt_2",
            "value": 2
          },
          {
            "text_key": "opt_3",
            "value": 4
          }
        ]
      },
      {
        "id": "audit10",
        "text_key": "audit10",
        "type": "multi",
        "options": [
          {
            "text_key": "opt_1",
            "value": 0
          },
          {
            "text_key": "opt_2",
            "value": 2
          },
          {
            "text_key": "opt_3",
            "value": 4
          }
        ]
      }
    ],
    "scoring": {
      "alcohol_use": {
        "description": "Sum of all items (0-40). Score ≥8 = hazardous use; ≥15 = dependence likely.",
        "method": "sum_coded",
        "items": [
          "audit1",
          "audit2",
          "audit3",
          "audit4",
          "audit5",
          "audit6",
          "audit7",
          "audit8",
          "audit9",
          "audit10"
        ],
        "norms": {
          "thresholds": [
            {
              "min": 0,
              "max": 7,
              "label": "Low Risk"
            },
            {
              "min": 8,
              "max": 14,
              "label": "Hazardous Use — simple advice recommended"
            },
            {
              "min": 15,
              "max": 19,
              "label": "Harmful Use — brief counselling recommended"
            },
            {
              "min": 20,
              "max": 40,
              "label": "Dependence Likely — specialist assessment recommended"
            }
          ]
        }
      }
    },
    "likert_options": {
      "points": 5,
      "min": 0,
      "max": 4,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5"
      ]
    }
  },
  "translations": {
    "en": {
      "question_head": "Please answer the following questions about your alcohol use over the <b>past year</b>.",
      "audit1": "How often do you have a drink containing alcohol?",
      "audit2": "How many standard drinks containing alcohol do you have on a typical day when you are drinking?",
      "audit3": "How often do you have 6 or more drinks on one occasion?",
      "audit4": "How often during the last year have you found that you were not able to stop drinking once you had started?",
      "audit5": "How often during the last year have you failed to do what was normally expected of you because of drinking?",
      "audit6": "How often during the last year have you needed a first drink in the morning to get yourself going after a heavy drinking session?",
      "audit7": "How often during the last year have you had a feeling of guilt or remorse after drinking?",
      "audit8": "How often during the last year have you been unable to remember what happened the night before because of your drinking?",
      "audit9": "Have you or someone else been injured as a result of your drinking?",
      "audit10": "Has a relative, friend, doctor, or other health professional expressed concern about your drinking or suggested you cut down?",
      "debrief": "Thank you for completing this questionnaire.",
      "likert_1": "Never",
      "likert_2": "Monthly or less",
      "likert_3": "2 to 4 times a month",
      "likert_4": "2 to 3 times a week",
      "likert_5": "4 or more times a week",
      "opt_1": "No",
      "opt_2": "Yes, but not in the last year",
      "opt_3": "Yes, during the last year"
    }
  }
}
