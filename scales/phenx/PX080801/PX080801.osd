{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Number of Natural Teeth",
      "code": "PX080801",
      "abbreviation": "PX080801",
      "description": "Questions ask for self-reports about the number of natural teeth an adult or child has in his or her mouth. In addition, one question asks a parent or caregiver to record information on the number of teeth in his or her infants mouth at 3–12 months of age.",
      "domain": "Health",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/80801]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/80801"
    },
    "implementation": {
