  "translations": {
    "en": {
      "likert_1": "Not at all like me",
      "likert_2": "Slightly like me",
      "likert_3": "Somewhat like me",
      "likert_4": "Moderately like me",
      "likert_5": "Very much like me",
      "likert_6": "Extremely like me",
      "question_head": "I think a lot about myself because....",
      "scts1": "I am interested in learning about myself.",
      "scts2": "I care too much what people think.",
      "scts3": "I have a lack of confidence.",
      "scts4": "It gives me pleasure to learn about myself.",
      "scts5": "It helps me discover my strength.",
      "scts6": "I am concerned about how others perceive me.",
      "scts7": "I worry that I will do something I regret.",
      "scts8": "I value self-reflection.",
      "scts9": "I do not want to make a bad impression on others.",
      "scts10": "It is important to me what others think of me.",
      "scts11": "I need to grow up.",
      "scts12": "I worry about making mistakes in front of others.",
      "scts13": "It helps me understand myself.",
      "scts14": "I am conscious about what people think of me.",
      "debrief": "Thank you for completing the Self-Consciousness Type Scale."
    }
  }
