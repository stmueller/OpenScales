  "translations": {
    "en": {
      "internet_access_ever_go_online": "Do you ever go on-line to access the Internet or World Wide Web, or to send and receive e-mail?",
      "internet_access_ever_go_online_opt_1": "Yes",
      "internet_access_ever_go_online_opt_2": "No",
      "internet_access_use_dial_up": "When you use the Internet, do you access it through... A regular dial-up telephone line",
      "internet_access_use_dial_up_opt_1": "Yes",
      "internet_access_use_dial_up_opt_2": "No",
      "internet_access_use_broadband": "When you use the Internet, do you access it through... Broadband such as DSL, cable, or FiOS",
      "internet_access_use_broadband_opt_1": "Yes",
      "internet_access_use_broadband_opt_2": "No",
      "internet_access_use_cellular": "When you use the Internet, do you access it through... A cellular network (i.e., phone, 3G/4G)",
      "internet_access_use_cellular_opt_1": "Yes",
      "internet_access_use_cellular_opt_2": "No",
      "internet_access_use_wireless": "When you use the Internet, do you access it through... A wireless network (Wi-Fi)",
      "internet_access_use_wireless_opt_1": "Yes",
      "internet_access_use_wireless_opt_2": "No",
      "internet_access_via_computer_home": "How often do you access the Internet through each of the following? Computer at home",
      "internet_access_via_computer_home_opt_1": "Daily",
      "internet_access_via_computer_home_opt_2": "Sometimes",
      "internet_access_via_computer_home_opt_3": "Never",
      "internet_access_via_computer_home_opt_4": "Not Applicable",
      "internet_access_via_computer_work": "How often do you access the Internet through each of the following? Computer at work",
      "internet_access_via_computer_work_opt_1": "Daily",
      "internet_access_via_computer_work_opt_2": "Sometimes",
      "internet_access_via_computer_work_opt_3": "Never",
      "internet_access_via_computer_work_opt_4": "Not Applicable",
      "internet_access_via_computer_public": "How often do you access the Internet through each of the following? Computer in a public place (library, community center, other)",
      "internet_access_via_computer_public_opt_1": "Daily",
      "internet_access_via_computer_public_opt_2": "Sometimes",
      "internet_access_via_computer_public_opt_3": "Never",
      "internet_access_via_computer_public_opt_4": "Not Applicable",
      "internet_access_via_mobile_device": "How often do you access the Internet through each of the following? On a mobile device (cell phone/smart phone/tablet)",
      "internet_access_via_mobile_device_opt_1": "Daily",
      "internet_access_via_mobile_device_opt_2": "Sometimes",
      "internet_access_via_mobile_device_opt_3": "Never",
      "internet_access_via_mobile_device_opt_4": "Not Applicable",
      "internet_access_satisfied_speed": "To what extent are you satisfied with your internet speed?",
      "internet_access_satisfied_speed_opt_1": "Not at all satisfied",
      "internet_access_satisfied_speed_opt_2": "Not very satisfied",
      "internet_access_satisfied_speed_opt_3": "Somewhat satisfied",
      "internet_access_satisfied_speed_opt_4": "Very satisfied",
      "internet_access_satisfied_speed_opt_5": "Extremely satisfied"
    }
  }
