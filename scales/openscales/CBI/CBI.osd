    "scoring": {
      "personal": {
        "description": "Personal Burnout (items 1–6, mean 0–100).",
        "method": "mean_coded",
        "items": [
          "cbi1",
          "cbi2",
          "cbi3",
          "cbi4",
          "cbi5",
          "cbi6"
        ]
      },
      "work": {
        "description": "Work-Related Burnout (items 7–13, mean 0–100). Item 13 reverse-scored via option values.",
        "method": "mean_coded",
        "items": [
          "cbi7",
          "cbi8",
          "cbi9",
          "cbi10",
          "cbi11",
          "cbi12",
          "cbi13"
        ]
      },
      "client": {
        "description": "Client-Related Burnout (items 14–19, mean 0–100). Only scored when include_client=1.",
        "method": "mean_coded",
        "items": [
          "cbi14",
          "cbi15",
          "cbi16",
          "cbi17",
          "cbi18",
          "cbi19"
        ]
      }
    },
    "report": {
      "template": "standard",
      "include": [
        "timestamp",
        "completion_time",
        "dimension_scores"
      ],
      "header": "Copenhagen Burnout Inventory (CBI) Report",
      "footer_refs": [
        "Kristensen, T. S., et al. (2005). Work & Stress, 19(3), 192–207.",
        "Scores 0–100. Item 13 reverse-scored. Client subscale optional."
      ]
    }
  },
  "translations": {
    "en": {
      "cbi_inst": "The following questions ask about your degree of fatigue and exhaustion. Please indicate how often or to what degree each statement applies to you.",
      "cbi_work_inst": "The following questions are about your <b>work</b> situation.",
      "cbi_client_inst": "The following questions are about working with <b>clients</b> (or patients, students, etc.).",
      "freq_always": "Always",
      "freq_often": "Often",
      "freq_sometimes": "Sometimes",
      "freq_seldom": "Seldom",
      "freq_never": "Never/almost never",
      "deg_veryhigh": "To a very high degree",
      "deg_high": "To a high degree",
      "deg_somewhat": "Somewhat",
      "deg_low": "To a low degree",
      "deg_verylow": "To a very low degree",
      "cbi1": "How often do you feel tired?",
      "cbi2": "How often are you physically exhausted?",
      "cbi3": "How often are you emotionally exhausted?",
      "cbi4": "How often do you think: \"I can't take it anymore\"?",
      "cbi5": "How often do you feel worn out?",
      "cbi6": "How often do you feel weak and susceptible to illness?",
      "cbi7": "Is your work emotionally exhausting?",
      "cbi8": "Do you feel burnt out because of your work?",
      "cbi9": "Does your work frustrate you?",
      "cbi10": "Do you feel worn out at the end of the working day?",
      "cbi11": "Are you exhausted in the morning at the thought of another day at work?",
      "cbi12": "Do you feel that every working hour is tiring for you?",
      "cbi13": "Do you have enough energy for family and friends during leisure time?",
      "cbi14": "Do you find it hard to work with clients?",
      "cbi15": "Does it drain your energy to work with clients?",
      "cbi16": "Do you find it frustrating to work with clients?",
      "cbi17": "Do you feel that you give more than you get back when you work with clients?",
      "cbi18": "Are you tired of working with clients?",
      "cbi19": "Do you sometimes wonder how long you will be able to continue working with clients?",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
