  "translations": {
    "en": {
      "likert_1": "Very Inaccurate",
      "likert_2": "Moderately Inaccurate",
      "likert_3": "Neither Accurate Nor Inaccurate",
      "likert_4": "Moderately Accurate",
      "likert_5": "Very Accurate",
      "question_head": "<h3>How Accurately Can You Describe Yourself?</h3>\nDescribe yourself as you generally are now, not as you wish to be in the future. Describe yourself as you honestly see yourself, in relation to other people you know of the same sex as you are, and roughly your same age. So that you can describe yourself in an honest manner, your responses will be kept in absolute confidence. Indicate how accurately this statement describes you.",
      "debrief": "Thank you for completing this questionnaire.",
      "ipip_16pf_001": "Act wild and crazy.",
      "ipip_16pf_002": "Am the last to laugh at a joke.",
      "ipip_16pf_003": "Am the life of the party.",
      "ipip_16pf_004": "Amuse my friends.",
      "ipip_16pf_005": "Dislike loud music.",
      "ipip_16pf_006": "Don't like crowded events.",
      "ipip_16pf_007": "Enjoy being part of a loud crowd.",
      "ipip_16pf_008": "Joke around a lot.",
      "ipip_16pf_009": "Love large parties.",
      "ipip_16pf_010": "Seldom joke around.",
      "ipip_16pf_011": "Am afraid that I will do the wrong thing.",
      "ipip_16pf_012": "Am easily hurt.",
      "ipip_16pf_013": "Am not easily bothered by things.",
      "ipip_16pf_014": "Don't let others discourage me.",
      "ipip_16pf_015": "Don't worry about things that have already happened.",
      "ipip_16pf_016": "Feel crushed by setbacks.",
      "ipip_16pf_017": "Feel guilty when I say \"no.\"",
      "ipip_16pf_018": "Feel threatened easily.",
      "ipip_16pf_019": "Spend time thinking about past mistakes.",
      "ipip_16pf_020": "Worry about things.",
      "ipip_16pf_021": "Am annoyed by others' mistakes.",
      "ipip_16pf_022": "Am easily put out.",
      "ipip_16pf_023": "Am not easily annoyed.",
      "ipip_16pf_024": "Am quick to judge others.",
      "ipip_16pf_025": "Can't stand being contradicted.",
      "ipip_16pf_026": "Get angry easily.",
      "ipip_16pf_027": "Get irritated easily.",
      "ipip_16pf_028": "Have a good word for everyone.",
      "ipip_16pf_029": "Judge people by their appearance.",
      "ipip_16pf_030": "Try to forgive and forget.",
      "ipip_16pf_031": "Am easily discouraged.",
      "ipip_16pf_032": "Am not easily frustrated.",
      "ipip_16pf_033": "Am relaxed most of the time.",
      "ipip_16pf_034": "Dislike myself.",
      "ipip_16pf_035": "Feel comfortable with myself.",
      "ipip_16pf_036": "Feel desperate.",
      "ipip_16pf_037": "Have frequent mood swings.",
      "ipip_16pf_038": "Often feel blue.",
      "ipip_16pf_039": "Readily overcome setbacks.",
      "ipip_16pf_040": "Seldom feel blue.",
      "ipip_16pf_041": "Am exacting in my work.",
      "ipip_16pf_042": "Am not bothered by disorder.",
      "ipip_16pf_043": "Am not bothered by messy people.",
      "ipip_16pf_044": "Continue until everything is perfect.",
      "ipip_16pf_045": "Get chores done right away.",
      "ipip_16pf_046": "Leave a mess in my room.",
      "ipip_16pf_047": "Leave my belongings around.",
      "ipip_16pf_048": "Like order.",
      "ipip_16pf_049": "Put off unpleasant tasks.",
      "ipip_16pf_050": "Am hard to get to know.",
      "ipip_16pf_051": "Am open about my feelings.",
      "ipip_16pf_052": "Am open about myself to others.",
      "ipip_16pf_053": "Am willing to talk about myself.",
      "ipip_16pf_054": "Bottle up my feelings.",
      "ipip_16pf_055": "Disclose my intimate thoughts.",
      "ipip_16pf_056": "Don't talk a lot.",
