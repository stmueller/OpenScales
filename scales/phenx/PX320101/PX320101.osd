  "translations": {
    "en": {
      "cancer_diagnosis_working_pay_business_job": "At any time from when you were first diagnosed with cancer until now, were you working for pay at a job or business?",
      "cancer_diagnosis_working_pay_business_job_opt_1": "Yes",
      "cancer_diagnosis_working_pay_business_job_opt_2": "No",
      "desc1": "<div class=\"rich-text-field-label\"><p>These next questions ask about different ways cancer, its treatment, or the lasting effects of that treatment may have affected your work - that is, your hours, duties, or employment status.<br /><br />As you answer these questions, please think about the entire time from when you were first diagnosed with cancer to now. <br /><br />If you have had more than one type of cancer please think about your experiences across all of them. If that is not possible, please focus on the most severe, and if they were equally severe, please focus on the most recent.</p></div>",
      "cancer_diagnosis_working_time_off": "At any time since your first cancer diagnosis, did you take extended paid time off from work, unpaid time off, or make a change in your hours, duties or employment status?",
      "cancer_diagnosis_working_time_off_opt_1": "Yes",
      "cancer_diagnosis_working_time_off_opt_2": "No",
      "cancer_diagnosis_extended_time_off": "At any time since your first cancer diagnosis, did you ask for extended paid time off from work, unpaid time off, or a change in your hours, duties or employment status?",
      "cancer_diagnosis_extended_time_off_opt_1": "Yes",
      "cancer_diagnosis_extended_time_off_opt_2": "No",
      "ask_work_changes": "Did you ask for these work changes",
      "ask_work_changes_opt_1": "Because of your cancer, its treatment or its lasting effect",
      "ask_work_changes_opt_2": "Some other reason?",
      "make_work_changes": "Did you make these work changes",
      "make_work_changes_opt_1": "Because of your cancer, its treatment or its lasting effect",
      "make_work_changes_opt_2": "Some other reason?",
      "extended_time_off_ever": "Did you ever take extended time off from work (vacation, sick time and/or disability leave)? By extended time off, we mean more than an occasional day off here and there.",
      "extended_time_off_ever_opt_1": "Yes",
      "extended_time_off_ever_opt_2": "No",
      "extended_time_off_when": "When did you take extended paid time off from work?",
      "extended_time_off_when_opt_1": "At the time of diagnosis",
      "extended_time_off_when_opt_2": "During treatment",
      "extended_time_off_when_opt_3": "Less than on year after treatment was finished",
      "extended_time_off_when_opt_4": "One year or more after treatment was finished",
      "extended_time_off_length": "What do you estimate was the total amount of extended paid time off from work that you took?",
      "extended_time_off_length_opt_1": "Less than 2 months",
      "extended_time_off_length_opt_2": "2 months to less than 6 months",
      "extended_time_off_length_opt_3": "6 months to less than 1 year",
      "extended_time_off_length_opt_4": "1 year to 3 years",
      "extended_time_off_length_opt_5": "More than 3 years",
      "extended_time_off_ongoing": "Is your extended paid time off from work ongoing?",
      "extended_time_off_ongoing_opt_1": "Yes",
      "extended_time_off_ongoing_opt_2": "No",
      "unpaid_time_off_ever": "Did you ever take unpaid time off from work?",
      "unpaid_time_off_ever_opt_1": "Yes",
      "unpaid_time_off_ever_opt_2": "No",
      "unpaid_time_off_when": "When did you take unpaid time off from work?",
      "unpaid_time_off_when_opt_1": "At the time of diagnosis",
      "unpaid_time_off_when_opt_2": "During treatment",
      "unpaid_time_off_when_opt_3": "Less than one year after treatment was finished",
      "unpaid_time_off_when_opt_4": "One year or more after treatment was finished",
      "unpaid_time_off_length": "What do you estimate was the total amount of unpaid time off from work that you took?",
      "unpaid_time_off_length_opt_1": "Less than 2 months",
      "unpaid_time_off_length_opt_2": "2 months to less than 6 months",
      "unpaid_time_off_length_opt_3": "6 months to less than 1 year",
      "unpaid_time_off_length_opt_4": "1 year to 3 years",
      "unpaid_time_off_length_opt_5": "More than 3 years",
      "unpaid_time_off_ongoing": "Is your unpaid time off ongoing?",
      "unpaid_time_off_ongoing_opt_1": "Yes",
      "unpaid_time_off_ongoing_opt_2": "No",
      "part_full_time_change_ever": "Did you ever change from working part-time to working full-time?",
      "part_full_time_change_ever_opt_1": "Yes",
      "part_full_time_change_ever_opt_2": "No",
      "part_full_time_change_when": "When did you change from working part-time to working full-time?",
      "part_full_time_change_when_opt_1": "At the time of diagnosis",
      "part_full_time_change_when_opt_2": "During treatment",
      "part_full_time_change_when_opt_3": "Less than one year after treatment was finished",
      "part_full_time_change_when_opt_4": "One year or more after treatment was finished",
      "part_full_time_change_length": "What do you estimate was the total amount of time you worked full-time?",
      "part_full_time_change_length_opt_1": "Less than 2 months",
      "part_full_time_change_length_opt_2": "2 months to less than 6 months",
      "part_full_time_change_length_opt_3": "6 months to less than 1 year",
      "part_full_time_change_length_opt_4": "1 year to 3 years",
      "part_full_time_change_length_opt_5": "More than 3 years",
