      "comorbidities_covid_impact_pre_existing_condition_opt_63": "Vitamin D deficiency",
      "comorbidities_covid_impact_pre_existing_condition_opt_64": "None of the above",
      "comorbidities_covid_impact_other_pre_existing_condition": "Please indicate other pre-existing conditions/diagnoses not listed here. If multiple, please separate them with a comma. Please only list the conditions, no descriptions or explanations.",
      "comorbidities_covid_impact_pre_existing_condition_change": "Did any of your pre-existing conditions change during the course of COVID-19 symptoms?",
      "comorbidities_covid_impact_pre_existing_condition_change_opt_1": "Yes, they got worse.",
      "comorbidities_covid_impact_pre_existing_condition_change_opt_2": "Yes, they got better.",
      "comorbidities_covid_impact_pre_existing_condition_change_opt_3": "Some got better, some stayed the same, some got worse (please add and explanation in the text boxes in the following page).",
      "comorbidities_covid_impact_pre_existing_condition_change_opt_4": "No, they stayed the same.",
      "comorbidities_covid_impact_pre_existing_condition_change_opt_5": "N/A (I did not have any pre-existing condition)",
      "comorbidities_covid_impact_pre_existing_condition_worse": "If any of your pre-existing conditions got worse, please describe here. (optional)",
      "comorbidities_covid_impact_pre_existing_condition_better": "If any of your pre-existing conditions got better, please describe here. (optional)"
    }
