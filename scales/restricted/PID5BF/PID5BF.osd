  "translations": {
    "en": {
      "pid_inst": "This is a list of things different people might say about themselves. We are interested in how you would describe yourself. There are no right or wrong answers. So you can describe yourself as honestly as possible, we will keep your responses confidential. We'd like you to take your time and read each statement carefully, selecting the response that best describes you.",
      "pid_likert_0": "Very False or Often False",
      "pid_likert_1": "Sometimes or Somewhat False",
      "pid_likert_2": "Sometimes or Somewhat True",
      "pid_likert_3": "Very True or Often True",
      "pid1": "People would describe me as reckless.",
      "pid2": "I feel like I act totally on impulse.",
      "pid3": "Even though I know better, I can't stop making rash decisions.",
      "pid4": "I often feel like nothing I do really matters.",
      "pid5": "Others see me as irresponsible.",
      "pid6": "I'm not good at planning ahead.",
      "pid7": "My thoughts often don't make sense to others.",
      "pid8": "I worry about almost everything.",
      "pid9": "I get emotional easily, often for very little reason.",
      "pid10": "I fear being alone in life more than anything else.",
      "pid11": "I get stuck on one way of doing things, even when it's clear it won't work.",
      "pid12": "I have seen things that weren't really there.",
      "pid13": "I steer clear of romantic relationships.",
      "pid14": "I'm not interested in making friends.",
      "pid15": "I get irritated easily by all sorts of things.",
      "pid16": "I don't like to get too close to people.",
      "pid17": "It's no big deal if I hurt other peoples' feelings.",
      "pid18": "I rarely get enthusiastic about anything.",
      "pid19": "I crave attention.",
      "pid20": "I often have to deal with people who are less important than me.",
      "pid21": "I often have thoughts that make sense to me but that other people say are strange.",
      "pid22": "I use people to get what I want.",
      "pid23": "I often \"zone out\" and then suddenly come to and realize that a lot of time has passed.",
      "pid24": "Things around me often feel unreal, or more real than usual.",
      "pid25": "It is easy for me to take advantage of others.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
