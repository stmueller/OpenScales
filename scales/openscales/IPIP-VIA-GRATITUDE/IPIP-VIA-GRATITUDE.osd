    "scale_info": {
      "name": "IPIP Character Strength: Gratitude",
      "code": "IPIP-VIA-GRATITUDE",
      "abbreviation": "IPIP-VIA-GRATITUDE",
      "description": "IPIP representation of the VIA character strength 'Gratitude'. 8-item subscale from the full IPIP-VIA inventory. Each item is rated on a 5-point accuracy scale. Part of the Values in Action framework (Peterson & Seligman, 2004).",
      "citation": "Peterson, C., & Seligman, M. E. P. (2004). Character Strengths and Virtues: A Handbook and Classification. Oxford University Press. IPIP items: Goldberg et al. (2006). https://ipip.ori.org/newVIAKey.htm",
      "license": "Public Domain",
      "version": "1.0",
      "url": "https://ipip.ori.org/newVIAKey.htm"
    },
    "implementation": {
