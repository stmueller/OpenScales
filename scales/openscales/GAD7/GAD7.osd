      },
      {
        "id": "gad7",
        "text_key": "gad7",
        "type": "likert"
      }
    ],
    "scoring": {
      "anxiety": {
        "method": "sum_coded",
        "items": [
          "gad1",
          "gad2",
          "gad3",
          "gad4",
          "gad5",
          "gad6",
          "gad7"
        ],
        "description": "Sum of all items (0-21). Severity: 0-4 minimal, 5-9 mild, 10-14 moderate, 15-21 severe.",
        "norms": {
          "thresholds": [
            {
              "min": 0,
              "max": 4,
              "label": "Minimal"
            },
            {
              "min": 5,
              "max": 9,
              "label": "Mild"
            },
            {
              "min": 10,
              "max": 14,
              "label": "Moderate"
            },
            {
              "min": 15,
              "max": 21,
              "label": "Severe"
            }
          ]
        },
        "item_coding": {
          "gad1": 1,
          "gad2": 1,
          "gad3": 1,
          "gad4": 1,
          "gad5": 1,
          "gad6": 1,
          "gad7": 1
        }
      }
    }
  },
  "translations": {
    "en": {
      "likert_1": "not at all",
      "likert_2": "several days",
      "likert_3": "more than half the days",
      "likert_4": "nearly every day",
      "question_head": "Over the last 2 weeks, how often have you been bothered by the following problems?",
      "gad1": "Feeling nervous, anxious or on edge",
      "gad2": "Not being able to stop or control worrying",
      "gad3": "Worrying too much about different things",
      "gad4": "Trouble relaxing",
      "gad5": "Being so restless that it is hard to sit still",
      "gad6": "Becoming easily annoyed or irritable",
      "gad7": "Feeling afraid as if something awful might happen",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}