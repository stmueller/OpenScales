  "translations": {
    "en": {
      "sec_how_often_have_you_experienced_the_follo_title": "How often have you experienced the following activities over the last 2 weeks?",
      "px960401_coronavirus_anxiety_scale_experience_dizziness": "I felt dizzy, lightheaded, or faint, when I read or listened to news about the coronavirus",
      "px960401_coronavirus_anxiety_scale_experience_dizziness_opt_0": "Not at all",
      "px960401_coronavirus_anxiety_scale_experience_dizziness_opt_1": "Rare, less than a day or two",
      "px960401_coronavirus_anxiety_scale_experience_dizziness_opt_2": "Several days",
      "px960401_coronavirus_anxiety_scale_experience_dizziness_opt_3": "More than 7 days",
      "px960401_coronavirus_anxiety_scale_experience_dizziness_opt_4": "Nearly every day over the last 2 weeks",
      "px960401_coronavirus_anxiety_scale_trouble_sleeping": "I had trouble falling or staying asleep because I was thinking about the coronavirus.",
      "px960401_coronavirus_anxiety_scale_trouble_sleeping_opt_0": "Not at all",
      "px960401_coronavirus_anxiety_scale_trouble_sleeping_opt_1": "Rare, less than a day or two",
      "px960401_coronavirus_anxiety_scale_trouble_sleeping_opt_2": "Several days",
      "px960401_coronavirus_anxiety_scale_trouble_sleeping_opt_3": "More than 7 days",
      "px960401_coronavirus_anxiety_scale_trouble_sleeping_opt_4": "Nearly every day over the last 2 weeks",
      "px960401_coronavirus_anxiety_scale_paralyzed_frozen": "I felt paralyzed or frozen when I thought about or was exposed to information about the coronavirus.",
      "px960401_coronavirus_anxiety_scale_paralyzed_frozen_opt_0": "Not at all",
      "px960401_coronavirus_anxiety_scale_paralyzed_frozen_opt_1": "Rare, less than a day or two",
      "px960401_coronavirus_anxiety_scale_paralyzed_frozen_opt_2": "Several days",
      "px960401_coronavirus_anxiety_scale_paralyzed_frozen_opt_3": "More than 7 days",
      "px960401_coronavirus_anxiety_scale_paralyzed_frozen_opt_4": "Nearly every day over the last 2 weeks",
      "px960401_coronavirus_anxiety_scale_lost_interest_eating": "I lost interest in eating when I thought about or was exposed to information about the coronavirus.",
      "px960401_coronavirus_anxiety_scale_lost_interest_eating_opt_0": "Not at all",
      "px960401_coronavirus_anxiety_scale_lost_interest_eating_opt_1": "Rare, less than a day or two",
      "px960401_coronavirus_anxiety_scale_lost_interest_eating_opt_2": "Several days",
      "px960401_coronavirus_anxiety_scale_lost_interest_eating_opt_3": "More than 7 days",
      "px960401_coronavirus_anxiety_scale_lost_interest_eating_opt_4": "Nearly every day over the last 2 weeks",
      "px960401_coronavirus_anxiety_scale_nausea": "I felt nauseous or had stomach problems when I thought about or was exposed to information about the coronavirus.",
      "px960401_coronavirus_anxiety_scale_nausea_opt_0": "Not at all",
      "px960401_coronavirus_anxiety_scale_nausea_opt_1": "Rare, less than a day or two",
      "px960401_coronavirus_anxiety_scale_nausea_opt_2": "Several days",
      "px960401_coronavirus_anxiety_scale_nausea_opt_3": "More than 7 days",
      "px960401_coronavirus_anxiety_scale_nausea_opt_4": "Nearly every day over the last 2 weeks",
      "px960401_coronavirus_anxiety_scale_desc": "<div class=\"rich-text-field-label\"><p style=\"text-autospace: none;\">Scoring and interpretation</p> <p style=\"text-autospace: none;\"><span style=\"font-weight: normal;\">Total Score = Question 1 + Question 2 + Question 3 + Question 4 + Question 5</span></p> <p><span style=\"font-weight: normal;\">Each item of the CAS is rated on a 5-point scale, from 0 (not at all) to 4 (nearly every day), based on experiences over the past two weeks. This scaling format is consistent with the DSM-5’s cross-cutting symptom measure. A CAS total score ≥ 9 indicates probable dysfunctional coronavirus-related anxiety. Elevated scores on a particular item or a high total scale score (≥ 9) may indicate problematic symptoms for the individual that might warrant further assessment and/or treatment. Clinical judgement should guide the interpretation of the CAS results.</span></p></div>"
    }
  }
}