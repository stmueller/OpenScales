      "intoleranceofuncertainty_scale_makes_life_tolerable_opt_5": "Entirely characteristic of me",
      "intoleranceofuncertainty_scale_unfair_noguarantees": "It's unfair not having any guarantees in life",
      "intoleranceofuncertainty_scale_unfair_noguarantees_opt_1": "Not all characteristic of me",
      "intoleranceofuncertainty_scale_unfair_noguarantees_opt_2": "Not at all/Somewhat characteristic of me",
