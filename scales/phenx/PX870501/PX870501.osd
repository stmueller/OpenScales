  "translations": {
    "en": {
      "sec_div_class_rich_text_field_label_div_clas_title": "<div class=\"rich-text-field-label\"><div class=\"rich-text-field-label\"> <div class=\"full-instructions\"> <h5><span style=\"font-size: 13px; font-weight: bold;\">Reactions to Loss Scale</span></h5> </div> <div class=\"full-instructions\"><span style=\"font-weight: normal;\"><strong>Following this most significant event or loss, I reacted in the following ways:</strong></span></div> </div></div>",
      "reactions_loss_cried": "Cried about the loss",
      "reactions_loss_listened_music_cope": "Listened to music to cope with the loss",
      "reactions_loss_emotions_out_control": "I felt my emotions were out of control after the loss",
      "reactions_loss_kept_thought_myself": "Kept thoughts and feelings about the loss to myself",
      "reactions_loss_feeling_positive_life_before": "I found myself feeling positive about my life before the loss.",
      "reactions_loss_tried_forget": "I tried to forget the whole thing",
      "reactions_loss_overate": "Overate because of the loss",
      "reactions_loss_more_tolerant": "I became a more tolerant person following the loss",
      "reactions_loss_trouble_eating": "Had trouble eating because of the loss",
      "reactions_loss_took_prescription_medication": "Took prescription medication because of the loss",
      "reactions_loss_physical_activity_after": "Engaged in increased physical activity after the loss",
      "reactions_loss_talked_counselor": "Talked to a counselor about the loss",
      "reactions_loss_worried_ordinary_things": "I worried more about ordinary things",
      "reactions_loss_thought_suicide": "Thought about suicide because of the loss",
      "reactions_loss_wrote_journal": "Wrote in a journal about the loss",
      "reactions_loss_religious_spritual_personally_meaningful_activities": "Engaged in religious, spiritual, or personally meaningful activities to make sense of the loss",
      "reactions_loss_used_alcohol_drugs_cope": "Used alcohol or drugs to cope with the loss",
      "reactions_loss_tried_not_think_about": "I tried hard not to think about the loss",
      "reactions_loss_better_empathize_with_others": "I am better able to empathize with others after the loss",
      "reactions_loss_missed_classes": "Missed classes because of the loss",
      "reactions_loss_engaged_distracting_activities": "Engaged in more distracting activities such as watching T.V. because of the loss",
      "reactions_loss_change_sexual_activities": "Change in amount of sexual activity following the loss",
      "reactions_loss_feeling_self_confident": "I found myself feeling more self-confident",
      "reactions_loss_promise_myself_things_different_next": "I made a promise to myself that things would be different next time",
      "reactions_loss_withdrew_from_friends_family": "Withdrew from friends and family because of the loss",
      "reactions_loss_slept_more": "Slept more or less because of the loss",
      "reactions_loss_engaged_decreased_physical_activity": "Engaged in decreased physical activity after the loss",
      "reactions_loss_control_feelings_not_interfere_with_life": "I was able to control my feelings about the loss so that they did not interfere with my life",
      "reactions_loss_see_positives_life": "I started to see some positives in my life after the loss",
      "reactions_loss_hard_time_trusting_others": "I had a hard time trusting others after this loss",
      "reactions_loss_felt_hopeless_anything_improving": "I felt hopeless about anything improving in my life",
      "reactions_loss_feel_stronger": "I began to feel stronger because of dealing with the loss",
      "reactions_loss_rediscovered_important_life": "I rediscovered what is important in life",
      "reactions_loss_difficult_time_overcoming_feeling_guilt": "I had a very difficult time overcoming my feelings of guilt about the loss",
      "reactions_loss_felt_anger_resentment": "I felt a lot of anger and resentment after the loss",
      "reactions_loss_optimistic_future": "I continued to be optimistic about my future even after the loss",
      "reactions_loss_question_future_bleak": "This loss has made me question my future; it looks bleak",
