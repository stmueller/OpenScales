{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Self-Consciousness Type Scale",
      "code": "SCTS",
      "abbreviation": "SCTS",
      "description": "14-item self-report measure of self-consciousness based on regulatory focus theory. Distinguishes between promotion-focused self-consciousness (growth-oriented) and prevention-focused self-consciousness (defensive). All items begin with the stem 'I think a lot about myself because....' Note: The original preliminary scale had 18 items; after factor analysis, 4 items were removed, yielding 14 final items.",
      "citation": "Author(s). (2024). Development and validation of the self-consciousness type scale. Frontiers in Psychology, 15, 1362324. https://doi.org/10.3389/fpsyg.2024.1362324",
      "license": "CC BY 4.0",
      "license_explanation": "Published in Frontiers in Psychology under Creative Commons Attribution 4.0 International License.",
      "license_url": "https://creativecommons.org/licenses/by/4.0/",
      "version": "1.0",
      "url": "https://doi.org/10.3389/fpsyg.2024.1362324",
      "domain": "Self & Coping"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 6,
      "min": 1,
      "max": 6,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5",
        "likert_6"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "promotion",
        "name": "Promotion-Focused Self-Consciousness",
        "description": "Growth-oriented self-consciousness driven by self-improvement and self-discovery motivation."
      },
      {
        "id": "prevention",
        "name": "Prevention-Focused Self-Consciousness",
        "description": "Defensive self-consciousness driven by concern about others' evaluation and worry about mistakes."
      }
    ],
