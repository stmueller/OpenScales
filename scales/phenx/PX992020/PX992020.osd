    "scale_info": {
      "name": "Long COVID - Symptoms Due to COVID-19 - Pediatric",
      "code": "PX992020",
      "abbreviation": "PX992020",
      "description": "A self-administered questionnaire to better describe and understand the patient experience and recovery of those with confirmed or suspected COVID-19, with a specific emphasis on Long COVID experience in children and young people.",
      "domain": "Health",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/992020]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/992020"
    },
    "implementation": {
