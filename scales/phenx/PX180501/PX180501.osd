    "en": {
      "lk_opt_1": "Very slightly or not at all",
      "lk_opt_2": "A little",
      "lk_opt_3": "Moderately",
      "lk_opt_4": "Quite a bit",
      "lk_opt_5": "Extremely",
      "instructions_180501": "The respondent is asked to read several words and phrases which describe feelings and emotions and enter a number that corresponds to the value on a scale. The 5-item scale ranges from \"very slightly or not at all,\" with a value of 1, to \"extremely,\" with a value of 5.",
