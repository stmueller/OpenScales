  "translations": {
    "en": {
      "income_all": "What is your annual household income from all sources?",
      "income_all_opt_1": "Less than $10,000",
      "income_all_opt_2": "$10,000- $24,999",
      "income_all_opt_3": "$25,000-$34,999",
