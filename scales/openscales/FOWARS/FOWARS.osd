{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Fear of War Scale",
      "code": "FOWARS",
      "abbreviation": "FOWARS",
      "description": "13-item self-report measure assessing fear of war through two dimensions: experiential fear (emotional/cognitive reactions, items 1-7) and physiological fear (somatic reactions, items 8-13). 5-point Likert scale. Higher scores indicate greater fear of war. Originally developed in Hungarian.",
      "citation": "Kalcza-Janosi, K., Kotta, I., Marschalko, E. E., & Szabo, K. (2023). The Fear of War Scale (FOWARS): Development and initial validation. Social Sciences, 12(5), 283. https://doi.org/10.3390/socsci12050283",
      "license": "CC BY 4.0",
      "license_explanation": "Published in MDPI Social Sciences under Creative Commons Attribution 4.0 International License.",
      "license_url": "https://creativecommons.org/licenses/by/4.0/",
      "version": "1.0",
      "url": "https://doi.org/10.3390/socsci12050283",
      "domain": "Mental Health"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "experiential",
        "name": "Experiential Fear",
        "description": "Emotional and cognitive reactions to the threat of war, including worry, dread, and fear about the consequences of war."
      },
      {
        "id": "physiological",
        "name": "Physiological Fear",
        "description": "Somatic reactions associated with fear of war, including trembling, sleep disturbance, and physical tension."
      }
    ],
    "items": [
