    "scale_info": {
      "name": "Coping with COVID-19",
      "code": "PX960501",
      "abbreviation": "PX960501",
      "description": "This protocol is administered either as an interview or a self-report. It includes two questions about how an adult has coped with pandemic-related problems and stress, and a question about how a child has coped with pandemic-related problems and stress.",
      "domain": "Mental Health",
      "citation": "COVID-19 Experiences (COVEX). As implemented in: PhenX Toolkit. Coping with COVID-19. https://www.phenxtoolkit.org/protocols/view/960501",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/960501"
    },
