      "total": {
        "description": "Weighted composite overall QOLIE-89 score. Inputs are the transformed (0–100) subscale scores for each of the 17 subscales, combined using the regression-derived weights from Table 3 of the QOLIE-89 scoring manual (Devinsky et al. 1995). The raw composite is then converted to a T-score: T = 50 + 10 × (composite − 67.9) / 15.55, based on normative data (mean=67.9, SD=15.55) from the development sample. Higher T-score = better quality of life.",
        "method": "weighted_sum",
        "scores": [
          "health_perceptions",
          "overall_qol",
