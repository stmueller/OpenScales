  "translations": {
    "en": {
      "likert_0": "Not at all",
      "likert_1": "Rarely",
      "likert_2": "Somewhat",
      "likert_3": "Often",
      "likert_4": "Totally",
      "question_head": "Think about the <b>last month</b> and indicate the extent of these feelings.",
      "rgpts1": "I spent time thinking about friends gossiping about me.",
      "rgpts2": "I often heard people referring to me.",
      "rgpts3": "I have been upset by friends and colleagues judging me critically.",
      "rgpts4": "People definitely laughed at me behind my back.",
      "rgpts5": "I have been thinking a lot about people avoiding me.",
      "rgpts6": "People have been dropping hints for me.",
      "rgpts7": "I believed that certain people were not what they seemed.",
      "rgpts8": "People talking about me behind my back upset me.",
      "rgpts9": "Certain individuals have had it in for me.",
      "rgpts10": "People wanted me to feel threatened, so they stared at me.",
      "rgpts11": "I was certain people did things in order to annoy me.",
      "rgpts12": "I was convinced there was a conspiracy against me.",
      "rgpts13": "I was sure someone wanted to hurt me.",
      "rgpts14": "I couldn't stop thinking about people wanting to confuse me.",
      "rgpts15": "I was distressed by being persecuted.",
      "rgpts16": "It was difficult to stop thinking about people wanting to make me feel bad.",
      "rgpts17": "People have been hostile towards me on purpose.",
      "rgpts18": "I was angry that someone wanted to hurt me.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}