        "text_key": "fertility_history_ever_pregnant",
        "type": "multi",
        "options": [
          {
            "text_key": "fertility_history_ever_pregnant_opt_1",
            "value": 1
          },
          {
            "text_key": "fertility_history_ever_pregnant_opt_2",
            "value": 2
          }
        ]
