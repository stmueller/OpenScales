  "translations": {
    "en": {
      "info_650601": "Positive and Negative Perfectionism ScalePlease choose the appropriate answer which applies best to each of the following statements. Please answer each statement.5= Strongly Agree4= Agree3= Don't know2= Disagree1= Strongly DisagreeAll replies are strictly confidential.",
      "perfectionismscale_adolescentadult_anxiety_failure": "When I start something I feel anxious that I might fail.",
      "perfectionismscale_adolescentadult_proud_dowell": "My family and friends are proud of me when I do really well.",
      "perfectionismscale_adolescentadult_pride_meticulous": "I take pride in being meticulous when doing things.",
      "perfectionismscale_adolescentadult_impossible_highstandards": "I set impossibly high standards for myself.",
      "perfectionismscale_adolescentadult_avoid_disapproval": "I try to avoid the disapproval of others at all costs.",
      "perfectionismscale_adolescentadult_praise_performance": "I like the acclaim I get for an outstanding performance.",
      "perfectionismscale_adolescentadult_relax_whenperfect": "When I am doing something I cannot relax until it's perfect.",
      "perfectionismscale_adolescentadult_best_notgoodenough": "It feels as though my best is never good enough for other people.",
      "perfectionismscale_adolescentadult_perfectperformance_rewarding": "Producing a perfect performance is a reward in its own right.",
      "perfectionismscale_adolescentadult_problemof_success": "The problem of success is that I must work even harder.",
      "perfectionismscale_adolescentadult_mistake_whole_ruined": "If I make a mistake I feel that the whole thing is ruined.",
      "perfectionismscale_adolescentadult_dissatisfied_higher_standard": "I feel dissatisfied with myself unless I am working towards a higher standard all the time.",
      "perfectionismscale_adolescentadult_fallshort_want_tobe": "I know the kind of person I ought or want to be, but feel I always fall short of this.",
      "perfectionismscale_adolescentadult_others_respect_achievements": "Other people respect me for my achievements.",
      "perfectionismscale_adolescentadult_never_goodenough": "As a child however well I did, it never seemed good enough to please my parents.",
      "perfectionismscale_adolescentadult_everyone_winner": "I think everyone loves a winner.",
      "perfectionismscale_adolescentadult_others_nothingless_perfection": "Other people expect nothing less than perfection of me.",
      "perfectionismscale_adolescentadult_competition_motivatedby": "When I'm competing against others, I'm motivated by wanting to be the best.",
      "perfectionismscale_adolescentadult_feelgood_push_limits": "I feel good when pushing out the limits.",
      "perfectionismscale_adolescentadult_dissatisfied_achieve_goals": "When I achieve my goals I feel dissatisfied.",
      "perfectionismscale_adolescentadult_highstandards_admired_others": "My high standards are admired by others.",
      "perfectionismscale_adolescentadult_failure_cease_respect": "If I fail people, I fear they will cease to respect or care for me.",
      "perfectionismscale_adolescentadult_pleaseothers_bysuccess": "I like to please other people by being successful.",
      "perfectionismscale_adolescentadult_gainapproval_byaccomplishments": "I gain great approval from others by the quality of my accomplishments.",
      "perfectionismscale_adolescentadult_successleadto_achievements": "My successes spur me on to greater achievements.",
      "perfectionismscale_adolescentadult_feelguilty_lessperfect": "I feel guilty or ashamed if I do less than perfectly.",
      "perfectionismscale_adolescentadult_never_satisfied_withperformance": "No matter how well I do I never feel satisfied with my performance.",
      "perfectionismscale_adolescentadult_practice_makes_perfection": "I believe that rigorous practice makes for perfection.",
      "perfectionismscale_adolescentadult_glory_from_success": "I enjoy the glory gained by successes.",
      "perfectionismscale_adolescentadult_satisfaction_fromperfection": "I gain deep satisfaction when I have perfected something.",
      "perfectionismscale_adolescentadult_beperfect_gainapproval": "I feel I have to be perfect to gain people's approval.",
      "perfectionismscale_adolescentadult_parents_encouragement": "My parents encouraged me to excel.",
      "perfectionismscale_adolescentadult_worry_others": "I worry what others think if I make mistakes.",
      "perfectionismscale_adolescentadult_fullfillment_fromdedication": "I get fulfillment from totally dedicating myself to a task.",
      "perfectionismscale_adolescentadult_others_recognize_requiredskills": "I like it when others recognize that what I do requires great skill and effort to perfect.",
      "perfectionismscale_adolescentadult_betterperformance_byothers": "The better I do, the better I am expected to do by others.",
      "perfectionismscale_adolescentadult_enjoy_greaterlevels_precisionaccuracy": "I enjoy working towards greater levels of precision and accuracy.",
      "perfectionismscale_adolescentadult_notstartif_lessthanperfect": "I would rather not start something than risk doing it less than perfectly.",
      "perfectionismscale_adolescentadult_judged_critically": "When I do things I feel others will judge critically the standard of my work.",
      "perfectionismscale_adolescentadult_challenge_highstandards": "I like the challenge of setting very high standards for myself.",
      "likert_1": "Strongly Agree",
      "likert_2": "Agree",
      "likert_3": "Don't know",
      "likert_4": "Disagree",
      "likert_5": "Strongly disagree"
    }
  }
}
