{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Burnout Assessment Tool – Student Version",
      "code": "BATS",
      "abbreviation": "BAT-S",
      "description": "33-item Burnout Assessment Tool — Student Version: 23 core items adapted for students across four subscales (Exhaustion, Mental Distance, Cognitive Impairment, Emotional Impairment) plus 10 secondary symptom items (Psychological Distress, Psychosomatic Complaints). 5-point frequency scale (1=Never to 5=Always). Short 12-item version (BAT-S-12) uses items marked with asterisk: 1,3,4,9,11,13,14,17,18,19,20,23.",
      "citation": "Schaufeli, W. B., De Witte, H., & Desart, S. (2020). Burnout Assessment Tool – Student Version (BAT-S). https://burnoutassessmenttool.be/wp-content/uploads/2024/02/BAT-S_ENG.pdf",
      "license": "CC BY 4.0",
      "version": "1.0",
      "url": "https://burnoutassessmenttool.be/wp-content/uploads/2024/02/BAT-S_ENG.pdf",
      "domain": "Work"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "parameters": {
      "show_header": {
        "type": "boolean",
        "default": 0,
        "description": "Show scale title — default off: title may sensitize respondents to burnout framing"
      }
    },
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "bat_r1",
        "bat_r2",
        "bat_r3",
        "bat_r4",
        "bat_r5"
      ],
      "question_head": "bat_inst"
    },
    "dimensions": [
      {
        "id": "exhaustion",
        "name": "Exhaustion",
        "abbreviation": "EX",
        "description": "Feeling physically and mentally depleted by studies (items 1–8). Mean range 1–5."
      },
      {
        "id": "mental_distance",
        "name": "Mental Distance",
        "abbreviation": "MD",
        "description": "Feeling aversion to and growing distance from studies (items 9–13). Mean range 1–5."
      },
      {
        "id": "cognitive_impairment",
        "name": "Cognitive Impairment",
        "abbreviation": "CI",
        "description": "Difficulty staying focused and thinking clearly while studying (items 14–18). Mean range 1–5."
      },
      {
        "id": "emotional_impairment",
        "name": "Emotional Impairment",
        "abbreviation": "EI",
        "description": "Difficulty controlling emotions (items 19–23). Mean range 1–5."
      },
      {
        "id": "psychological_distress",
        "name": "Psychological Distress",
        "abbreviation": "PD",
        "description": "Secondary symptoms: sleep, worry, tension, anxiety, noise sensitivity (items 24–28). Mean range 1–5."
      },
      {
        "id": "psychosomatic",
        "name": "Psychosomatic Complaints",
        "abbreviation": "PS",
        "description": "Secondary symptoms: physical complaints (items 29–33). Mean range 1–5."
      }
    ],
