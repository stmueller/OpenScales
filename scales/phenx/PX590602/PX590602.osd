  "translations": {
    "en": {
      "mutual_help_group_involvement_and_treatment_attendance_groups_attendedrecord_id": "Record ID",
      "mutual_help_group_involvement_and_treatment_attendance_groups_attended": "Think about your entire lifetime. Please indicate which of the following mutual-help groups you have ever attended for an alcohol/drug problem of your own. (Select all that apply.) *One might add Celebrate Recovery and Recovery Dharma/Refuge Recovery, based on responses to Other.",
      "mutual_help_group_involvement_and_treatment_attendance_groups_attended_opt_1": "Alcoholics Anonymous (AA)",
      "mutual_help_group_involvement_and_treatment_attendance_groups_attended_opt_2": "Narcotics Anonymous (NA)",
      "mutual_help_group_involvement_and_treatment_attendance_groups_attended_opt_3": "Cocaine Anonymous (CA)",
      "mutual_help_group_involvement_and_treatment_attendance_groups_attended_opt_4": "Marijuana Anonymous (MA)",
      "mutual_help_group_involvement_and_treatment_attendance_groups_attended_opt_5": "LifeRing Secular Recovery (LifeRing)",
      "mutual_help_group_involvement_and_treatment_attendance_groups_attended_opt_6": "SMART Recovery (SMART)",
      "mutual_help_group_involvement_and_treatment_attendance_groups_attended_opt_7": "Women for Sobriety (WFS)",
      "mutual_help_group_involvement_and_treatment_attendance_groups_attended_opt_8": "Other (specify)*",
      "mutual_help_group_involvement_and_treatment_attendance_groups_attended_other": "Think about your entire lifetime. Please indicate which of the following mutual-help groups you have ever attended for an alcohol/drug problem of your own. (Select all that apply.) *One might add Celebrate Recovery and Recovery Dharma/Refuge Recovery, based on responses to Other. - Other",
      "mutual_help_group_involvement_and_treatment_attendance_number_meetings_attended_lifetime": "Approximately how many [in-person/online/in-person and online][mutual-help group]* meetings have you attended in your lifetime? Just give us your best guess even if you aren't sure of the exact number. *PAL separately assessed in-person and online meeting attendance for each target group type, then summed, but theoretically these could be tailored to study needs. E.g., one could ask about in-person and online MHG meeting attendance globally.",
      "mutual_help_group_involvement_and_treatment_attendance_number_meetings_attended_past_30_days": "Approximately how many [in-person/online/in-person and online][mutual-help group]* meetings have you attended in the past 30 days? *PAL separately assessed in-person and online meeting attendance for each target group type, then summed, but theoretically these could be tailored to study needs. E.g., one could ask about in-person and online MHG meeting attendance globally.",
      "mutual_help_group_involvement_and_treatment_attendance_past_30_days_meeting_have_regular": "Do you currently have a regular or home group? By this, we mean a meeting that you usually attend weekly and where you know many of the people.  *PAL asked about all mutual-help groups and alcohol problems, so created a summary measure of involvement for alcohol problems. Again, though, these theoretically could be tailored. E.g., one could ask about involvement in a specific group for alcohol or drugs.",
      "mutual_help_group_involvement_and_treatment_attendance_past_30_days_meeting_have_regular_opt_0": "No",
      "mutual_help_group_involvement_and_treatment_attendance_past_30_days_meeting_have_regular_opt_1": "Yes",
      "mutual_help_group_involvement_and_treatment_attendance_past_30_days_meeting_have_sponsor": "Do you currently have at least one close friend or sponsor who you can call on for help when you need it?  *PAL asked about all mutual-help groups and alcohol problems, so created a summary measure of involvement for alcohol problems. Again, though, these theoretically could be tailored. E.g., one could ask about involvement in a specific group for alcohol or drugs.",
      "mutual_help_group_involvement_and_treatment_attendance_past_30_days_meeting_have_sponsor_opt_0": "No",
      "mutual_help_group_involvement_and_treatment_attendance_past_30_days_meeting_have_sponsor_opt_1": "Yes",
      "mutual_help_group_involvement_and_treatment_attendance_past_30_days_meeting_led_meetings": "In the past 30 days, have you convened or led any meetings? *PAL asked about all mutual-help groups and alcohol problems, so created a summary measure of involvement for alcohol problems. Again, though, these theoretically could be tailored. E.g., one could ask about involvement in a specific group for alcohol or drugs.",
      "mutual_help_group_involvement_and_treatment_attendance_past_30_days_meeting_led_meetings_opt_0": "No",
      "mutual_help_group_involvement_and_treatment_attendance_past_30_days_meeting_led_meetings_opt_1": "Yes",
      "mutual_help_group_involvement_and_treatment_attendance_past_30_days_meeting_volunteered": "In the past 30 days, have you done volunteer work or service at a meeting? For example, this might include helping newcomers, setting up chairs, making coffee, or cleaning up after a meeting. Do not include leading meetings. *PAL asked about all mutual-help groups and alcohol problems, so created a summary measure of involvement for alcohol problems. Again, though, these theoretically could be tailored. E.g., one could ask about involvement in a specific group for alcohol or drugs.",
      "mutual_help_group_involvement_and_treatment_attendance_past_30_days_meeting_volunteered_opt_0": "No",
      "mutual_help_group_involvement_and_treatment_attendance_past_30_days_meeting_volunteered_opt_1": "Yes",
      "mutual_help_group_involvement_and_treatment_attendance_treatment_ever_received": "Have you ever received inpatient or outpatient treatment for an alcohol or drug problem?",
      "mutual_help_group_involvement_and_treatment_attendance_treatment_ever_received_opt_1": "No",
      "mutual_help_group_involvement_and_treatment_attendance_treatment_ever_received_opt_2": "Yes",
      "mutual_help_group_involvement_and_treatment_attendance_treatment_past_year_received": "Did you receive any of this treatment in the past 12 months?",
      "mutual_help_group_involvement_and_treatment_attendance_treatment_past_year_received_opt_1": "No",
      "mutual_help_group_involvement_and_treatment_attendance_treatment_past_year_received_opt_2": "Yes"
    }
  }
}
