          },
          {
            "op": "multiply",
            "value": 100
          }
        ]
      },
      "positive_interaction": {
        "description": "Positive Social Interaction: mean of 3 items (range 1–5). Transform to 0–100: ((mean − 1) / 4) × 100.",
        "method": "mean_coded",
        "items": [
          "mossocial7",
          "mossocial19",
          "mossocial20"
        ],
        "transform": [
          {
            "op": "subtract",
            "value": 1
          },
          {
            "op": "divide",
