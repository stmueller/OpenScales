      "support_relax_opt_3": "3- Some of the Time",
      "support_relax_opt_4": "4- Most of the Time",
      "support_relax_opt_5": "5- All of the Time",
      "support_prepare_meals": "Someone to prepare your meals if you were unable to do it yourself.",
