  "translations": {
    "en": {
      "px930101_protective_equiptment_survey_desc": "The following questions ask about your experiences with social distancing. Social distancing means keeping space between yourself and other people outside of your home.",
      "px930101_protective_equiptment_survey_past_month_recommendations_socailly_distancing": "In the past month, have recommendations for socially distancing caused stress for you?",
      "px930101_protective_equiptment_survey_past_month_recommendations_socailly_distancing_opt_1": "A lot",
      "px930101_protective_equiptment_survey_past_month_recommendations_socailly_distancing_opt_2": "Somewhat",
      "px930101_protective_equiptment_survey_past_month_recommendations_socailly_distancing_opt_3": "A little",
      "px930101_protective_equiptment_survey_past_month_recommendations_socailly_distancing_opt_4": "Not at all",
      "px930101_protective_equiptment_survey_last_five_days_stayed_home_all_day": "Thinking about your current social habits, in the last 5 days: I have stayed home all day (aside from time spent outdoors, but never closer than 6 feet from people who are not from my home).",
      "px930101_protective_equiptment_survey_last_five_days_stayed_home_all_day_opt_1": "None of the days (0 days)",
      "px930101_protective_equiptment_survey_last_five_days_stayed_home_all_day_opt_2": "A few days (1-2 days)",
      "px930101_protective_equiptment_survey_last_five_days_stayed_home_all_day_opt_3": "Most days (3-4 days)",
      "px930101_protective_equiptment_survey_last_five_days_stayed_home_all_day_opt_4": "Every day",
      "px930101_protective_equiptment_survey_last_five_days_workplace_outside_home": "Thinking about your current social habits, in the last 5 days: I have gone to my workplace or volunteer site that is outside my home.",
      "px930101_protective_equiptment_survey_last_five_days_workplace_outside_home_opt_1": "None of the days (0 days)",
      "px930101_protective_equiptment_survey_last_five_days_workplace_outside_home_opt_2": "A few days (1-2 days)",
      "px930101_protective_equiptment_survey_last_five_days_workplace_outside_home_opt_3": "Most days (3-4 days)",
      "px930101_protective_equiptment_survey_last_five_days_workplace_outside_home_opt_4": "Every day",
      "px930101_protective_equiptment_survey_last_five_days_attended_social_gatherings_more_ten_people": "Thinking about your current social habits, in the last 5 days: I have attended social gatherings outside my home of MORE than 10 people.",
