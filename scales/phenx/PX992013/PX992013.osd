{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Long COVID - Symptoms Due to COVID-19 - Allergies",
      "code": "PX992013",
      "abbreviation": "PX992013",
      "description": "A self-administered questionnaire to better describe and understand the patient experience and recovery of those with confirmed or suspected COVID-19, with a specific emphasis on Long COVID experience especially with allergies.",
      "domain": "Long COVID",
      "citation": "Neal C. Goldberg, Sabrina Poirier, Allison Kanas, Lisa McCorkell, Carrie Anna McGinn, Yochai Re’em, Kathi Kuehnel, Nina Muirhead, Tahlia Ruschioni, Susan Taylor-Brown & Leonard A. Jason (2022) A new clinical challenge: supporting patients coping with the long-term effects of COVID-19, Fatigue: Biomedicine, Health & Behavior, 10:4, 212-230, DOI: 10.1080/21641846.2022.2128576 [PhenX: https://www.phenxtoolkit.org/protocols/view/992013]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/992013"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
