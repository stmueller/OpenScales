  "translations": {
    "en": {
      "likert_1": "Strongly Disagree",
      "likert_2": "Disagree",
      "likert_3": "Somewhat Disagree",
      "likert_4": "Neither Agree nor Disagree",
      "likert_5": "Somewhat Agree",
      "likert_6": "Agree",
      "likert_7": "Strongly Agree",
      "question_head": "Please indicate your level of agreement with each of the following statements.",
      "soss1": "Science makes me step outside myself to a larger sense of fulfillment.",
      "soss2": "I have had a \"peak\" experience while engaged in science.",
      "soss3": "Thinking about science brings me deep joy.",
      "soss4": "Science helps to show greater meaning in life.",
      "soss5": "There is an order to science that transcends human thinking.",
      "soss6": "I have lost track of time while engaged in science.",
      "soss7": "Science makes me feel deeply connected to everything.",
      "soss8": "Science reveals the beauty of the world we live in.",
      "soss9": "All things are connected through science.",
      "soss10": "Science is a source of spirituality.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
