{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "IPIP Character Strengths (VIA)",
      "code": "IPIP-VIA",
      "abbreviation": "IPIP-VIA",
      "description": "IPIP representation of the Values in Action character strengths inventory measuring 24 character strengths.",
