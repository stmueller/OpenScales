  "translations": {
    "en": {
      "long_covid_physical_function_before_limit_activity_physical_mental_emotional_problemrecord_id": "Record ID",
      "long_covid_physical_function_before_limit_activity_physical_mental_emotional_problem": "Before COVID-19, were you limited in any way in any activities because of physical, mental, or emotional problems?",
      "long_covid_physical_function_before_limit_activity_physical_mental_emotional_problem_opt_1": "Yes (specify)",
      "long_covid_physical_function_before_limit_activity_physical_mental_emotional_problem_opt_2": "No",
      "long_covid_physical_function_before_limit_activity_physical_mental_emotional_problem_opt_3": "Refuse to answer",
      "long_covid_physical_function_before_limit_activity_physical_mental_emotional_problem_specify": "Please specify how you were limited before COVID-19",
      "long_covid_physical_function_before_health_problem_special_equipment": "Before COVID-19, did you have any health problem that required you to use special equipment, such as a cane, a wheelchair, a special bed, or a special telephone? *Include occasional use or use in certain circumstances",
      "long_covid_physical_function_today_difficulty_walk_quarter_mile_any": "Do you have any difficulty walking a quarter of a mile, that is about 2 or 3 blocks, without stopping?",
      "long_covid_physical_function_today_difficulty_walk_quarter_mile_how_much": "How much difficulty do you have walking a quarter of a mile?",
      "long_covid_physical_function_before_difficulty_walk_quarter_mile_any": "Did you have difficulty walking a quarter of a mile before your COVID-19 illness?",
      "long_covid_physical_function_today_ease_walk_quarter_mile": "How easy is it for you to walk a quarter of a mile?",
      "long_covid_physical_function_today_difficulty_walk_one_mile_any": "Do you have any difficulty walking a distance of one mile?",
      "long_covid_physical_function_before_difficulty_walk_one_mile_how_much": "Did you have difficulty walking one mile before your COVID-19 illness?",
      "long_covid_physical_function_today_ease_walk_one_mile": "How easy is it for you to walk one mile?",
      "long_covid_physical_function_today_difficulty_walk_ten_steps_any": "Do you have any difficulty walking up 10 steps, that is about 1 flight, without resting?",
      "long_covid_physical_function_today_difficulty_walk_ten_steps_how_much": "How much difficulty do you have walking up 10 steps?",
      "long_covid_physical_function_before_difficulty_walk_ten_steps_any": "Did you have difficulty walking up 10 steps before your COVID-19 illness?",
      "long_covid_physical_function_today_ease_walk_ten_steps": "How easy is it for you to walk up 10 steps?",
      "long_covid_physical_function_today_difficulty_walk_twenty_steps_any": "Do you have any difficulty walking up 20 steps, that is about 2 flights, without resting?",
      "long_covid_physical_function_before_difficulty_walk_twenty_steps_any": "Did you have difficulty walking up 20 steps before your COVID-19 illness?",
      "long_covid_physical_function_today_ease_walk_twenty_steps": "How easy is it for you to walk up 20 steps?",
      "long_covid_physical_function_today_difficulty_walk_light_housework_any": "Do you have difficulty doing light housework such as doing dishes, straightening up or light cleaning by yourself?",
      "long_covid_physical_function_today_difficulty_walk_light_housework_how_much": "How much difficulty do you have doing light housework?",
      "long_covid_physical_function_before_difficulty_walk_light_housework_any": "Did you have difficulty doing light housework before your COVID-19 illness?",
      "long_covid_physical_function_today_difficulty_walk_heavy_housework_any": "Do you have difficulty doing heavy housework such as vacuuming and washing windows, walls, or floors?",
      "long_covid_physical_function_today_difficulty_walk_heavy_housework_how_much": "How much difficulty do you have doing heavy housework?",
      "long_covid_physical_function_before_difficulty_walk_heavy_housework_any": "Did you have difficulty doing heavy housework before your COVID-19 illness?",
      "long_covid_physical_function_before_strenuous_exercise_times_per_week": "Prior to your initial COVID-19 illness, during a typical 7-day period (a week), how many times on average did you do the following kinds of exercise for more than 15 minutes during your free time? - Strenuous exercise (heart beats rapidly)? (times per week)",
      "long_covid_physical_function_before_strenuous_exercise_times_per_week_desc": "Examples: running, jogging, hockey, football, soccer, squash, basketball, cross country skiing, judo, roller skating, vigorous swimming, vigorous long distance bicycling",
      "long_covid_physical_function_before_moderate_exercise_times_per_week": "Prior to your initial COVID-19 illness, during a typical 7-day period (a week), how many times on average did you do the following kinds of exercise for more than 15 minutes during your free time? - Moderate exercise (not exhausting)? (times per week)",
      "long_covid_physical_function_before_moderate_exercise_times_per_week_desc": "Examples: fast walking, baseball, tennis, easy bicycling, volleyball, badminton, easy swimming, alpine skiing, popular and folk dancing",
      "long_covid_physical_function_before_light_exercise_times_per_week": "Prior to your initial COVID-19 illness, during a typical 7-day period (a week), how many times on average did you do the following kinds of exercise for more than 15 minutes during your free time? - Mild/light exercise (minimal effort)? (times per week)",
      "long_covid_physical_function_before_light_exercise_times_per_week_desc": "Examples: yoga, archery, fishing from river bank, bowling, horseshoes, golf, snow-mobiling, easy walking",
      "long_covid_physical_function_after_strenuous_exercise_times_per_week": "Since your initial COVID-19 illness, during a typical 7-day period (a week), how many times on average do you do the following kinds of exercise for more than 15 minutes during your free time? - Strenuous exercise (heart beats rapidly)? (times per week)",
      "long_covid_physical_function_after_strenuous_exercise_times_per_week_desc": "Examples: running, jogging, hockey, football, soccer, squash, basketball, cross country skiing, judo, roller skating, vigorous swimming, vigorous long distance bicycling",
      "long_covid_physical_function_after_moderate_exercise_times_per_week": "Since your initial COVID-19 illness, during a typical 7-day period (a week), how many times on average do you do the following kinds of exercise for more than 15 minutes during your free time? - Moderate exercise (not exhausting)? (times per week)",
      "long_covid_physical_function_after_moderate_exercise_times_per_week_desc": "Examples: fast walking, baseball, tennis, easy bicycling, volleyball, badminton, easy swimming, alpine skiing, popular and folk dancing",
      "long_covid_physical_function_after_light_exercise_times_per_week": "Since your initial COVID-19 illness, during a typical 7-day period (a week), how many times on average do you do the following kinds of exercise for more than 15 minutes during your free time? - Mild/light exercise (minimal effort)? (times per week)",
      "long_covid_physical_function_after_light_exercise_times_per_week_desc": "Examples: yoga, archery, fishing from river bank, bowling, horseshoes, golf, snow-mobiling, easy walking",
      "opt_1": "A little",
      "opt_2": "Some",
      "opt_3": "A lot",
      "opt_4": "Unable to do",
      "opt_5": "Refuse to answer",
      "grp2_opt_1": "Very easy",
      "grp2_opt_2": "Somewhat easy",
      "grp2_opt_3": "Not so easy",
      "grp2_opt_4": "Refuse to answer"
    }
  }
