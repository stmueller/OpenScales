{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Traits of Creative Potential Questionnaire",
      "code": "TCPQ12",
      "abbreviation": "TCPQ-12",
      "description": "12-item self-report measure assessing three dimensions of creative potential: Transgression (items 1, 4, 7, 10), Challenge (items 2, 5, 8, 11), and Exploration (items 3, 6, 9, 12). 7-point scale.",
      "citation": "Penagos-Corzo, J. C., & Saucedo, A. (2021). Development and validation of a questionnaire to assess creative potential traits. Frontiers in Psychology, 12, 756079. https://doi.org/10.3389/fpsyg.2021.756079",
      "license": "CC BY 4.0",
      "license_explanation": "Published in Frontiers in Psychology under Creative Commons Attribution 4.0 International License.",
      "license_url": "https://creativecommons.org/licenses/by/4.0/",
      "version": "1.0",
      "url": "https://doi.org/10.3389/fpsyg.2021.756079",
      "domain": "Personality"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 7,
      "min": 1,
      "max": 7,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5",
        "likert_6",
        "likert_7"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "transgression",
        "name": "Transgression",
        "description": "Willingness to transgress rules or norms in pursuit of creative ideas (items 1, 4, 7, 10)."
      },
      {
        "id": "challenge",
        "name": "Challenge",
        "description": "Willingness to take on challenges and risks in creative endeavors (items 2, 5, 8, 11)."
      },
      {
        "id": "exploration",
        "name": "Exploration",
        "description": "Willingness to explore the environment and seek new perspectives (items 3, 6, 9, 12)."
      }
    ],
    "items": [
