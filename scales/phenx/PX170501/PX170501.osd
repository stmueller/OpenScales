      "age_arthritis_onset": "Age at which symptoms appeared",
      "age_arthritis_diagnosed": "Age at which arthritis was diagnosed by a physician",
      "arthritis_diagnosed_by_rheumatologist": "Have you been told by a rheumatologist that you have psoriatic arthritis?",
      "crohns_disease": "Have you been diagnosed with Crohn's disease or another inflammatory bowel disorder?",
      "crohns_disease_opt_1": "Yes",
