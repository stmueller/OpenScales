  "translations": {
    "en": {
      "sec_memory_symptoms_title": "Memory Symptoms",
      "long_covid_symptoms_memory_memory_related_symptoms": "<div class=\"rich-text-field-label\"><p>Have you experienced any <span style=\"font-weight: normal;\">MEMORY RELATED SYMPTOMS</span> since the start of your COVID-19 illness?</p></div>",
      "long_covid_symptoms_memory_experienced_memory_symptoms": "Which of the following memory symptoms have you experienced since the start of your COVID-19 illness?",
      "long_covid_symptoms_memory_experienced_memory_symptoms_opt_1": "Short-term memory loss (memory that lasts ~30 seconds, i.e. remembering a phone number before writing it down, or forgetting you're in the middle of a task)",
      "long_covid_symptoms_memory_experienced_memory_symptoms_opt_2": "Long-term memory loss (long-term memory can be anything from remembering yesterday, forgetting you've done a task, forgetting recently learned information, or forgetting your third-grade experience)",
      "long_covid_symptoms_memory_experienced_memory_symptoms_opt_3": "Not being able to make new memories",
      "long_covid_symptoms_memory_experienced_memory_symptoms_opt_4": "Forgetting how to do routine tasks (tying your shoe laces, washing your hands)",
      "long_covid_symptoms_memory_experienced_memory_symptoms_opt_5": "None of the above",
      "long_covid_symptoms_memory_experienced_memory_symptoms_opt_6": "Other",
      "long_covid_symptoms_memory_experienced_memory_symptoms_other": "Which of the following memory symptoms have you experienced since the start of your COVID-19 illness? Other",
      "long_covid_symptoms_memory_when_experienced_symptoms": "When did you experience these symptoms? Please mark symptoms for the first 4 weeks, then months (if applicable). Even if you have only experienced these symptoms for part of a week or month, please select it. Memory Symptoms:",
      "sec_cognitive_function_brain_fog_symptoms_title": "Cognitive Function/Brain Fog Symptoms",
      "long_covid_symptoms_memory_brain_fog": "Have you experienced issues with BRAIN FOG (inability to focus, think clearly, plan, process, understand, and maintain a coherent stream of thought; abnormally slow or fast thoughts) since the start of your COVID-19 illness?",
      "long_covid_symptoms_memory_brain_fog_symptoms": "Which of the following brain fog/cognitive functioning symptoms have you experienced since the start of your COVID-19 illness?",
      "long_covid_symptoms_memory_brain_fog_symptoms_opt_1": "Difficulty with executive functioning (planning, organizing, figuring out the sequence of actions, abstracting)",
      "long_covid_symptoms_memory_brain_fog_symptoms_opt_2": "Agnosia (failure to recognize or identify objects despite intact sensory functioning)",
      "long_covid_symptoms_memory_brain_fog_symptoms_opt_3": "Difficulty problem-solving or decision-making",
      "long_covid_symptoms_memory_brain_fog_symptoms_opt_4": "Difficulty thinking",
      "long_covid_symptoms_memory_brain_fog_symptoms_opt_5": "Thoughts moving too quickly",
      "long_covid_symptoms_memory_brain_fog_symptoms_opt_6": "Slowed thoughts",
      "long_covid_symptoms_memory_brain_fog_symptoms_opt_7": "Poor attention or concentration",
      "long_covid_symptoms_memory_brain_fog_symptoms_opt_8": "I did NOT have any Brain Fog symptoms",
      "long_covid_symptoms_memory_brain_fog_symptoms_opt_9": "Other",
      "long_covid_symptoms_memory_brain_fog_experience_symptoms": "When did you experience these symptoms? Please mark symptoms for the first 4 weeks, then months (if you haven't yet reached a week/month, please leave it blank). Even if you have only experienced these symptoms for part of a week or month, please select it. Brain fog/cognitive functioning symptoms:",
      "sec_have_you_felt_significantly_limited_or_u_title": "Have you felt significantly limited or unable to do any of the following due to MEMORY LOSS OR BRAIN FOG (including issues with attention, cognitive functioning, and awareness) specifically?",
      "long_covid_symptoms_memory_memory_loss_drive": "Drive",
      "long_covid_symptoms_memory_memory_loss_drive_opt_1": "Severely unable",
      "long_covid_symptoms_memory_memory_loss_drive_opt_2": "Moderately unable",
      "long_covid_symptoms_memory_memory_loss_drive_opt_3": "Mildly unable",
      "long_covid_symptoms_memory_memory_loss_drive_opt_4": "Able",
      "long_covid_symptoms_memory_memory_loss_drive_opt_5": "Not applicable",
      "long_covid_symptoms_memory_memory_loss_watch_children": "Watch Children:",
      "long_covid_symptoms_memory_memory_loss_watch_children_opt_1": "Severely unable",
      "long_covid_symptoms_memory_memory_loss_watch_children_opt_2": "Moderately unable",
      "long_covid_symptoms_memory_memory_loss_watch_children_opt_3": "Mildly unable",
      "long_covid_symptoms_memory_memory_loss_watch_children_opt_4": "Able",
      "long_covid_symptoms_memory_memory_loss_watch_children_opt_5": "Not applicable",
      "long_covid_symptoms_memory_memory_loss_cook_hot_items": "Cook or use hot items:",
      "long_covid_symptoms_memory_memory_loss_cook_hot_items_opt_1": "Severely unable",
      "long_covid_symptoms_memory_memory_loss_cook_hot_items_opt_2": "Moderately unable",
