{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Patient Satisfaction with Genetic Counseling",
      "code": "PX311001",
      "abbreviation": "PX311001",
      "description": "The Genetic Counseling Satisfaction Scale (GCSS) is a 6-item, 5-point Likert scale used to assess patient satisfaction with genetic counseling.",
      "domain": "Health",
      "citation": "Buchanan, A. H., Datta, S. K., Skinner, C. S., Hollowell, G. P., Beresford, H. F., Freeland, T., Rogers, B., Boling, J., Marcom, P. K., Adams, M. B. (2015). Randomized trial of telegenetics vs. in-person cancer genetic counseling: Cost, patient satisfaction and attendance. Journal of Genetic Counseling, 24(6), 961–970. Tercyak, K. P., Demarco, T. A., Mars, B. D., & Peshkin, B. N. (2004). Women’s satisfaction with genetic counseling for hereditary breast-ovarian cancer: Psychological aspects. American Journal of Medical Genetics Part A, 131(1), 36–41. [PhenX: https://www.phenxtoolkit.org/protocols/view/311001]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/311001"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "lk_opt_1",
        "lk_opt_2",
        "lk_opt_3",
        "lk_opt_4",
        "lk_opt_5"
      ]
    },
    "items": [
