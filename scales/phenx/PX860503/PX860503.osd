      "lk_opt_5": "Almost Always",
      "pain_interference_parent_proxy_sleeping": "In the past 7 days... My child had trouble sleeping when he/she had pain.",
      "pain_interference_parent_proxy_angry": "In the past 7 days... My child felt angry when he/she had pain.",
      "pain_interference_parent_proxy_schoolwork": "In the past 7 days... My child had trouble doing schoolwork when he/she had pain.",
      "pain_interference_parent_proxy_pay_attention": "In the past 7 days... It was hard for my child to pay attention when he/she had pain.",
      "pain_interference_parent_proxy_run": "In the past 7 days... It was hard for my child to run when he/she had pain.",
      "pain_interference_parent_proxy_walk": "In the past 7 days... It was hard for my child to walk one block when he/she had pain.",
      "pain_interference_parent_proxy_fun": "In the past 7 days... It was hard for my child to have fun when he/she had pain.",
      "pain_interference_parent_proxy_standing": "In the past 7 days... It was hard for my child to stay standing when he/she had pain."
