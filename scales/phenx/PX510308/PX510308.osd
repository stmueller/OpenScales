{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Cannabis Products, Types, and Modes of Use",
      "code": "PX510308",
      "abbreviation": "PX510308",
      "description": "This questionnaire includes up to 135 self-administered items from the International Cannabis Policy Study Survey, Wave 6 (2023). Respondents are first asked to identify which cannabis products they have used in the past 12 months (e.g., dried herb, edibles, concentrates). For each product endorsed,",
      "domain": "Substance Use",
      "citation": "Borodovsky, J. T., Hasin, D. S., Shmulewitz, D., Walsh, C., Livne, O., Aharonovich, E., Struble, C. A., Habib, M. I., & Budney, A. J. (2024). Typical hits, grams, or joints: Evaluating cannabis survey measurement strategies for quantifying consumption. Cannabis and Cannabinoid Research, 9 (2), 646-658. https://doi.org/10.1089/can.2022.0237 Borodovsky, J. T., Struble, C. A., Habib, M. I., Hasin, D. S., Shmulewitz, D., Walsh, C., Livne, O., Aharonovich, E., & Budney, A. J. (2023). Exploring survey methods for measuring consumption quantities of cannabis flower and concentrate products. American Journal of Drug and Alcohol Abuse, 49 (6), 733-745. https://doi.org/10.1080/00952990.2023.2246635 Budney, A. J., Borodovsky, J. T., Struble, C. A., Habib, M. I., Shmulewitz, D., Livne, O., Aharonovich, E., Walsh, C., Cuttler, C., & Hasin, D. S. (2024). Estimating THC consumption from smoked and vaped cannabis products in an online survey of adults who use cannabis. Cannabis and Cannabinoid Research, 9 (2), 688–698. https://doi.org/10.1089/can.2022.0238 Corsetti, D., Fataar, F., Burkalter, R., & Hammond, D. (2023). International Cannabis Policy Study Technical Report – Wave 5 (2022) . University of Waterloo; Waterloo, Ontario, Canada. Hammond, D., Goodman, S., Wadsworth, E., Rynard, V., Boudreau, C., & Hall, W. (2020). Evaluating the impacts of cannabis legalization: The International Cannabis Policy Study. International Journal on Drug Policy, 77 , 102698. https://doi.org/10.1016/j.drugpo.2020.102698 [PhenX: https://www.phenxtoolkit.org/protocols/view/510308]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/510308"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
