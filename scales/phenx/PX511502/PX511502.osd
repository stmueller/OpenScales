  "translations": {
    "en": {
      "lk_opt_1": "Never",
      "lk_opt_2": "Less than monthly",
      "lk_opt_3": "Monthly",
      "lk_opt_4": "Weekly",
      "lk_opt_5": "Daily or almost daily",
      "alcohol_and_cannabis_simultaneous_use_alchohol_and_marijuana": "How often did you use both alcohol and marijuana on the same occasion during the past 12 months, so that the effects of alcohol and marijuana overlapped?",
      "alcohol_and_cannabis_simultaneous_use_alchohol_and_marijuana_opt_0": "Never",
      "alcohol_and_cannabis_simultaneous_use_alchohol_and_marijuana_opt_1": "Monthly or Less",
      "alcohol_and_cannabis_simultaneous_use_alchohol_and_marijuana_opt_2": "2 to 4 times a month",
      "alcohol_and_cannabis_simultaneous_use_alchohol_and_marijuana_opt_3": "2 to 3 times a week",
      "alcohol_and_cannabis_simultaneous_use_alchohol_and_marijuana_opt_4": "4 or more times a week",
      "alcohol_and_cannabis_simultaneous_use_number_of_drinks": "How many drinks containing alcohol did you have on a typical day when you were using both alcohol and marijuana on the same occasion during the past 12 months, so that the effects of alcohol and marijuana overlapped?",
      "alcohol_and_cannabis_simultaneous_use_number_of_drinks_opt_0": "1 or 2",
      "alcohol_and_cannabis_simultaneous_use_number_of_drinks_opt_1": "3 or 4",
      "alcohol_and_cannabis_simultaneous_use_number_of_drinks_opt_2": "5 or 6",
      "alcohol_and_cannabis_simultaneous_use_number_of_drinks_opt_3": "7 to 9",
      "alcohol_and_cannabis_simultaneous_use_number_of_drinks_opt_4": "10 or more",
      "alcohol_and_cannabis_simultaneous_use_grams_of_marijuana": "Please use the image below to refer to various quantities of marijuana. The image is not to scale; the dollar bill is included to help provide size perspective.This is an image showing the scale of a weight in grams of a quantity of marijuana to a U.S. one dollar billNote: 1/8 of a gram = 0.125 grams,1/4 of a gram = 0.25 grams,1/2 of a gram = 0.5 grams,3/4 of a gram = 0.75 grams,1/8 of an ounce = 3.5 grams,1/4 of an ounce = 7 grams,1/2 ounce = 14 grams,1 ounce = 28 gramsHow much marijuana did you use (in grams) on a typical day when you were using both alcohol and marijuana on the same occasion during the past 12?months, so that the effects of alcohol and marijuana overlapped?",
      "alcohol_and_cannabis_simultaneous_use_grams_of_marijuana_opt_0": "0.125 grams or less",
      "alcohol_and_cannabis_simultaneous_use_grams_of_marijuana_opt_1": "0.25 grams",
      "alcohol_and_cannabis_simultaneous_use_grams_of_marijuana_opt_2": "0.50 grams",
      "alcohol_and_cannabis_simultaneous_use_grams_of_marijuana_opt_3": "0.75 grams",
      "alcohol_and_cannabis_simultaneous_use_grams_of_marijuana_opt_4": "1 gram or more",
      "alcohol_and_cannabis_simultaneous_use_frequency_of_use": "How often did you have 4 (for women)/5 (for men) or more drinks on one occasion while also using marijuana on the same occasion during the past 12 months, so that the effects of alcohol and marijuana overlapped?",
      "alcohol_and_cannabis_simultaneous_use_unable_to_stop_alchohol_use": "How often during the past 12 months did you find that you were not able to stop drinking once you started when using both alcohol and marijuana on the same occasion, so that the effects of alcohol and marijuana overlapped?",
      "alcohol_and_cannabis_simultaneous_use_unable_to_stop_marijuana_use": "How often during the past 12 months did you find that you were not able to stop using marijuana once you started when using both alcohol and marijuana on the same occasion, so that the effects of alcohol and marijuana overlapped?",
      "alcohol_and_cannabis_simultaneous_use_fail_to_meet_expectations": "How often during the past 12 months did you fail to do what was normally expected from you because of using both marijuana and alcohol on the same occasion, so that the effects of alcohol and marijuana overlapped?",
      "alcohol_and_cannabis_simultaneous_use_injuries_resulting_from_use": "In the past 12 months, were you or someone else injured as a result of your using both marijuana and alcohol on the same occasion, so that the effects of alcohol and marijuana overlapped?",
      "alcohol_and_cannabis_simultaneous_use_recieved_concern_about_use": "In the past 12 months, was a relative, friend, doctor, or other health worker concerned about you using both marijuana and alcohol on the same occasion, so that the effects of alcohol and marijuana overlapped, or suggested you cut down?",
      "likert_1": "Never",
      "likert_2": "Monthly or Less",
      "likert_3": "2 to 4 times a month",
      "likert_4": "2 to 3 times a week",
      "likert_5": "4 or more times a week",
      "opt_1": "No",
      "opt_2": "Yes, but not in the last 12 months",
      "opt_3": "Yes, during the last 12 months"
