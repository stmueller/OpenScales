  "translations": {
    "en": {
      "kdqol36_health1": "Excellent",
      "kdqol36_health2": "Very good",
      "kdqol36_health3": "Good",
      "kdqol36_health4": "Fair",
      "kdqol36_health5": "Poor",
      "kdqol36_pf1": "Yes, limited a lot",
      "kdqol36_pf2": "Yes, limited a little",
      "kdqol36_pf3": "No, not limited at all",
      "kdqol36_yn1": "Yes",
      "kdqol36_yn2": "No",
      "kdqol36_sf1": "Not at all",
      "kdqol36_sf2": "Slightly",
      "kdqol36_sf3": "Moderately",
      "kdqol36_sf4": "Quite a bit",
      "kdqol36_sf5": "Extremely",
      "kdqol36_freq1": "All of the time",
      "kdqol36_freq2": "Most of the time",
      "kdqol36_freq3": "A good bit of the time",
      "kdqol36_freq4": "Some of the time",
      "kdqol36_freq5": "A little of the time",
      "kdqol36_freq6": "None of the time",
      "kdqol36_effect1": "Not at all",
      "kdqol36_effect2": "Somewhat",
      "kdqol36_effect3": "Moderately",
      "kdqol36_effect4": "Very much",
      "kdqol36_effect5": "Extremely",
      "kdqol36_1": "In general, would you say your health is:",
      "kdqol36_sf12_pf_head": "<b>The following items are about activities you might do during a typical day. <u>Does your health now limit</u> you in these activities? If so, how much?</b>",
      "kdqol36_2": "<u>Moderate activities</u>, such as moving a table, pushing a vacuum cleaner, bowling, or playing golf",
      "kdqol36_3": "Climbing <u>several</u> flights of stairs",
      "kdqol36_rp_head": "<b>During the past 4 weeks, have you had any of the following problems with your work or other regular daily activities as a result of your physical health?</b>",
      "kdqol36_4": "<u>Accomplished less</u> than you would like",
      "kdqol36_5": "Were limited in the <u>kind</u> of work or other activities",
      "kdqol36_re_head": "<b>During the past 4 weeks, have you had any of the following problems with your work or other regular daily activities as a result of any emotional problems (such as feeling depressed or anxious)?</b>",
      "kdqol36_6": "<u>Accomplished less</u> than you would like",
      "kdqol36_7": "Didn't do work or other activities as <u>carefully</u> as usual",
      "kdqol36_8": "<b>During the <u>past 4 weeks</u>, how much did <u>pain</u> interfere with your normal work (including both work outside the home and housework)?",
      "kdqol36_mh_head": "<b>These questions are about how you feel and how things have been with you <u>during the past 4 weeks</u>. For each question, please give the one answer that comes closest to the way you have been feeling. How much of the time <u>during the past 4 weeks…</u></b>",
      "kdqol36_9": "Have you felt calm and peaceful?",
      "kdqol36_10": "Did you have a lot of energy?",
      "kdqol36_11": "Have you felt downhearted and blue?",
      "kdqol36_12": "<b>During the <u>past 4 weeks</u>, how much of the time has your <u>physical health or emotional problems</u> interfered with your social activities (like visiting with friends, relatives, etc.)?</b>",
      "kdqol36_burden_head": "<b>Your Kidney Disease</b><br>How true or false is each of the following statements for you?",
      "kdqol36_13": "Kidney disease interferes too much with my life.",
      "kdqol36_14": "Too much of my time is spent dealing with kidney disease.",
      "kdqol36_15": "I feel frustrated dealing with my kidney disease.",
      "kdqol36_16": "I feel like a burned on my family.",
      "kdqol36_symp_head": "<b>During the past 4 weeks, to what extent were you bothered by each of the following?</b>",
      "kdqol36_17": "Soreness in your muscles?",
      "kdqol36_18": "Chest pain?",
      "kdqol36_19": "Cramps?",
      "kdqol36_20": "Itchy skin?",
      "kdqol36_21": "Dry skin",
      "kdqol36_22": "Shortness of breath?",
      "kdqol36_23": "Faintness or dizziness?",
      "kdqol36_24": "Lack of appetite?",
      "kdqol36_25": "Washed out or drained?",
      "kdqol36_26": "Numbness in hands or feet?",
      "kdqol36_27": "Nausea or upset stomach?",
      "kdqol36_28": "Headaches",
      "kdqol36_28a": "(Hemodialysis patient only) Problems with your access site?",
      "kdqol36_28b": "(Peritoneal dialysis patient only) Problems with your catheter site?",
      "kdqol36_eff_head": "<b>Effects of Kidney Disease on Your Daily Life</b><br>Some people are bothered by the effects of kidney disease on their daily life, while others are not. How much does kidney disease <u>bother</u> you in each of the following areas?",
      "kdqol36_29": "Fluid restriction?",
      "kdqol36_30": "Dietary restriction?",
      "kdqol36_31": "Your ability to work around the house?",
      "kdqol36_32": "Your ability to travel?",
      "kdqol36_33": "Being dependent on doctors and other medical staff?",
      "kdqol36_34": "Stress or worries caused by your kidney disease?",
      "kdqol36_35": "Your sex life?",
      "kdqol36_36": "Your personal appearance?",
      "debrief": "Thank you for completing these questions!",
      "kdqol36_sf_time1": "All of the time",
      "kdqol36_sf_time2": "Most of the time",
      "kdqol36_sf_time3": "Some of the time",
      "kdqol36_sf_time4": "A little of the time",
      "kdqol36_sf_time5": "None of the time",
      "kdqol36_truefalse1": "Definitely true",
      "kdqol36_truefalse2": "Mostly true",
      "kdqol36_truefalse3": "Don't know",
      "kdqol36_truefalse4": "Mostly false",
      "kdqol36_truefalse5": "Definitely false"
    }
  }
}