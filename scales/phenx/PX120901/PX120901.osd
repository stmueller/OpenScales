      "strong_interests_opt_2": "Slightly agree",
      "strong_interests_opt_3": "Slightly disagree",
      "strong_interests_opt_4": "Definitely disagree",
      "enjoy_chit_chat": "I enjoy social chit-chat.",
      "enjoy_chit_chat_opt_1": "Definitely agree",
      "enjoy_chit_chat_opt_2": "Slightly agree",
      "enjoy_chit_chat_opt_3": "Slightly disagree",
      "enjoy_chit_chat_opt_4": "Definitely disagree",
      "dominate_conversation": "When I talk, it isn't always easy for others to get a word in edgeways.",
      "dominate_conversation_opt_1": "Definitely agree",
