    "scoring": {
      "rt_medical": {
        "method": "mean_coded",
        "items": [
          "rt_m1",
          "rt_m2",
          "rt_m3",
          "rt_m4",
          "rt_m5",
          "rt_m6"
        ],
        "description": "Mean of 6 medical risk-taking items (1-7). Cronbach's alpha = 0.57 (Butler et al., 2012).",
        "item_coding": {
          "rt_m1": 1,
          "rt_m2": 1,
          "rt_m3": 1,
          "rt_m4": 1,
          "rt_m5": 1,
          "rt_m6": 1
        }
      },
      "rp_medical": {
        "method": "mean_coded",
        "items": [
          "rp_m1",
          "rp_m2",
          "rp_m3",
          "rp_m4",
          "rp_m5",
          "rp_m6"
        ],
        "description": "Mean of 6 medical risk perception items (1-7).",
        "item_coding": {
          "rp_m1": 1,
          "rp_m2": 1,
          "rp_m3": 1,
          "rp_m4": 1,
          "rp_m5": 1,
          "rp_m6": 1
        }
      },
      "eb_medical": {
        "method": "mean_coded",
        "items": [
          "eb_m1",
          "eb_m2",
          "eb_m3",
          "eb_m4",
          "eb_m5",
          "eb_m6"
        ],
        "description": "Mean of 6 medical expected benefits items (1-7). Only scored when show_expected_benefits is enabled.",
        "item_coding": {
          "eb_m1": 1,
          "eb_m2": 1,
          "eb_m3": 1,
          "eb_m4": 1,
          "eb_m5": 1,
          "eb_m6": 1
        }
      }
    }
  },
  "translations": {
    "en": {
      "sec_blank": "",
      "instructions": "For each situation below, you will answer two or three questions. First, indicate how likely you are to engage in the activity. Then, indicate how risky you perceive the situation to be. Riskiness is a very personal and intuitive notion — we are interested in your gut level assessment.",
      "rt_head": "How likely are you to engage in this activity?",
      "rp_head": "How risky do you perceive this situation?",
      "eb_head": "What benefits would you obtain from this situation?",
      "rt_l1": "Extremely Unlikely",
      "rt_l2": "Moderately Unlikely",
      "rt_l3": "Somewhat Unlikely",
      "rt_l4": "Not Sure",
      "rt_l5": "Somewhat Likely",
      "rt_l6": "Moderately Likely",
      "rt_l7": "Extremely Likely",
      "rp_l1": "Not at all Risky",
      "rp_l2": "Slightly Risky",
      "rp_l3": "Somewhat Risky",
      "rp_l4": "Moderately Risky",
      "rp_l5": "Risky",
      "rp_l6": "Very Risky",
      "rp_l7": "Extremely Risky",
      "eb_l1": "No benefits at all",
      "eb_l2": "",
      "eb_l3": "",
      "eb_l4": "Moderate benefits",
      "eb_l5": "",
      "eb_l6": "",
      "eb_l7": "Great benefits",
      "m1": "Donating one kidney to a patient you do not know.",
      "m2": "Giving blood.",
      "m3": "Participating in a clinical trial to determine whether a new drug is effective.",
      "m4": "Taking daily medication to relieve allergy symptoms.",
      "m5": "Knee replacement surgery to treat arthritis.",
      "m6": "Receiving general rather than local anesthesia when having a wisdom tooth removed."
    }
  }
}
