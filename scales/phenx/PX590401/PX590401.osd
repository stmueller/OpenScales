    "scale_info": {
      "name": "Recovery Identification",
      "code": "PX590401",
      "abbreviation": "PX590401",
      "description": "A single, self-reported Likert-style item inquiring about personal identification in relation to recovery.",
      "domain": "Social Networks & Substance Use",
      "citation": "De Meyer, F., Zerrouk, A., De Ruysscher, C., & Vanderplasschen, W. (2024). Exploring indicators of natural recovery from alcohol and drug use problems: Findings from the life in recovery survey in Flanders. Substance Abuse Treatment, Prevention, and Policy, 19 (1), 22. https://doi.org/10.1186/s13011-024-00604-y [PhenX: https://www.phenxtoolkit.org/protocols/view/590401]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/590401"
    },
    "implementation": {
