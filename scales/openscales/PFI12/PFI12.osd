        "method": "sum_coded",
        "items": [
          "pfi2",
          "pfi4",
          "pfi5",
          "pfi7",
          "pfi9",
          "pfi10"
        ],
        "description": "Sum of positive affect items (0–18). Higher scores indicate greater positive affect.",
        "item_coding": {
          "pfi2": 1,
          "pfi4": 1,
          "pfi5": 1,
          "pfi7": 1,
          "pfi9": 1,
          "pfi10": 1
        }
      },
      "negative_affect": {
        "method": "sum_coded",
        "items": [
          "pfi1",
          "pfi3",
          "pfi6",
          "pfi8",
          "pfi11",
          "pfi12"
        ],
        "description": "Sum of negative affect items (0–18). Higher scores indicate greater negative affect.",
        "item_coding": {
          "pfi1": 1,
          "pfi3": 1,
          "pfi6": 1,
          "pfi8": 1,
          "pfi11": 1,
          "pfi12": 1
        }
      },
      "total_wellbeing": {
        "method": "sum_coded",
        "items": [
          "pfi1",
