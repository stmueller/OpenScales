{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Family Functioning - Systematic Clinical Outcome Routine Evaluation",
      "code": "PX662102",
      "abbreviation": "PX662102",
      "description": "The 15-item Systematic Clinical Outcome Routine Evaluation (SCORE-15) Index of Family Functioning and Change is a 15-item, self-administered instrument that assesses family problems and includes subscales for family strengths, family difficulties, and family communication. Each item is rated on a 5-",
      "domain": "Mental Health",
      "citation": "Cahill, P., O’Reilly, K., Carr, A., Dooley, B., & Stratton, P. (2010). Validation of a 28-item version of the systemic clinical outcome and routine evaluation in an Irish context: The SCORE-28. Journal of Family Therapy , 32, 210-231. Stratton, P., Bland, J., Janes, E., & Lask, J. (2010). Developing a practicable outcome measure for systemic family therapy: The SCORE. Journal of Family Therapy, 32, 232-258. Stratton, P. (2016). SCORE-15 Index of Family Functioning and Change. Warrington, Cheshire, UK: Association for Family Therapy. Available at http://www.aft.org.uk/view/score.html [PhenX: https://www.phenxtoolkit.org/protocols/view/662102]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/662102"
    },
    "implementation": {
