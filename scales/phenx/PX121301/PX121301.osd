    "scoring": {
      "total": {
        "description": "Total: sum_coded of all 11 items.",
        "method": "sum_coded",
        "items": [
          "nervous",
          "hopeless",
          "pxt121301_restless",
          "pxt121301_depressed",
          "everything_an_effort",
          "worthless",
          "frequency_feelings_past_thirty_days",
