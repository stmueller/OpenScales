  "translations": {
    "en": {
      "lk_opt_1": "Never",
      "lk_opt_2": "Rarely",
      "lk_opt_3": "Sometimes",
      "lk_opt_4": "Often",
      "lk_opt_5": "Always",
      "eatingscale_child_loves_food": "My child loves food (EF)",
      "eatingscale_child_eats_more_whenworried": "My child eats more when worried (EOE)",
      "eatingscale_child_big_appetite": "My child has a big appetite (SR*)",
      "eatingscale_child_finishes_meal_quickly": "My child finishes his/her meal quickly (SE*)",
      "eatingscale_child_interested_in_food": "My child is interested in food (EF)",
      "eatingscale_child_alwaysasking_for_drink": "My child is always asking for a drink (DD)",
      "eatingscale_child_refuses_new_food": "My child refuses new foods at first (FF)",
      "eatingscale_child_eats_slowly": "My child eats slowly (SE)",
      "eatingscale_child_eats_less_whenangry": "My child eats less when angry (EUE)",
      "eatingscale_child_enjoys_tasting_newfood": "My child enjoys tasting new foods (FF*)",
      "eatingscale_child_eats_less_whentired": "My child eats less when s/he is tired (EUE)",
      "eatingscale_child_alwaysasking_for_food": "My child is always asking for food (FR)",
      "eatingscale_child_eats_more_whenannoyed": "My child eats more when annoyed (EOE)",
      "eatingscale_child_allowed_eat_toomuch": "If allowed to, my child would eat too much (FR)",
      "eatingscale_child_eats_more_whenanxious": "My child eats more when anxious (EOE)",
      "eatingscale_child_enjoys_wide_variety": "My child enjoys a wide variety of foods (FF*)",
      "eatingscale_child_leaves_food_onplate": "My child leaves food on his/her plate at the end of a meal (SR)",
      "eatingscale_child_morethan_30minute_mealtime": "My child takes more than 30 minutes to finish a meal (SE)",
      "eatingscale_child_allowed_eat_mostoftime": "Given the choice, my child would eat most of the time (FR)",
      "eatingscale_child_looksforward_tomeal": "My child looks forward to mealtimes (EF)",
      "eatingscale_child_getsfull_before_mealfinished": "My child gets full before his/her meal is finished (SR)",
      "eatingscale_child_enjoys_eating": "My child enjoys eating (EF)",
      "eatingscale_child_eats_more_whenhappy": "My child eats more when s/he is happy (EUE)",
      "eatingscale_child_difficult_toplease_meals": "My child is difficult to please with meals (FF)",
      "eatingscale_child_eats_less_whenupset": "My child eats less when upset (EUE)",
      "eatingscale_child_getsfull_up_easily": "My child gets full up easily (SR)",
      "eatingscale_child_eats_more_whenbored": "My child eats more when s/he has nothing else to do (EOE)",
      "eatingscale_child_eats_more_favoritefood": "Even if my child is full up s/he finds room to eat his/her favorite food (FR)",
      "eatingscale_child_drink_continuously": "If given the chance, my child would drink continuously throughout the day (DD)",
      "eatingscale_child_cannoteat_meal_aftersnack": "My child cannot eat a meal if s/he has had a snack just before (SR)",
      "eatingscale_child_always_having_drink": "If given the chance, my child would always be having a drink (DD)",
      "eatingscale_child_interested_tasting_newfood": "My child is interested in tasting food s/he hasn't tasted before (FF)",
      "eatingscale_child_doesntlike_food_withouttasting": "My child decides that s/he doesn't like a food, even without tasting it (FF)",
      "eatingscale_child_alwayshave_food_inmouth": "If given the chance, my child would always have food in his/her mouth (FR)",
      "eatingscale_child_always_havefood_inmouth": "My child eats more and more slowly during the course of a meal (SE)",
      "scoring_650301": "SCORING OF THE CEBQ(Never = 1, Rarely = 2, Sometimes = 3, Often = 4, Always = 5)� Food responsiveness = mean of items labelled FR� Emotional overeating = mean of items labelled EOE� Enjoyment of food = mean of items labelled EF� Desire to drink = mean of items labelled DD� Satiety responsiveness = mean of items labelled SR� Slowness in eating = mean of items labelled SE� Emotional undereating = mean of items labelled EUE� Food fussiness = mean of items labelled FF*Reversed items"
    }
  }
