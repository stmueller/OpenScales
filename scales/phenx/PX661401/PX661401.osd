      "lk_opt_1": "Strongly disagree",
      "lk_opt_2": "Disagree",
      "lk_opt_3": "Undecided",
      "lk_opt_4": "Agree",
      "lk_opt_5": "Strongly agree",
      "mentalhealth_service_survey_overall": "Overall, I am satisfied with the services I received.",
      "mentalhealth_service_survey_choose_service": "I helped to choose my services.",
      "mentalhealth_service_survey_choose_goals": "I helped to choose my treatment goals.",
      "mentalhealth_service_survey_support_system": "The people helping me stuck with me no matter what.",
      "mentalhealth_service_survey_support": "I felt I had someone to talk to when I was troubled.",
      "mentalhealth_service_survey_participation": "I participated in my own treatment.",
      "mentalhealth_service_survey_treatment": "I received services that were right for me.",
      "mentalhealth_service_survey_location": "The location of services was convenient.",
      "mentalhealth_service_survey_convenience": "Services were available at times that were convenient for me.",
      "mentalhealth_service_survey_desired_help": "I got the help I wanted.",
      "mentalhealth_service_survey_limitations": "I got as much help as I needed.",
      "mentalhealth_service_survey_respect": "Staff treated me with respect.",
      "mentalhealth_service_survey_beliefs": "Staff respected my family�s religious/spiritual beliefs.",
      "mentalhealth_service_survey_communication": "Staff spoke with me in a way that I understood.",
      "mentalhealth_service_survey_sensitivity": "Staff were sensitive to my cultural/ethnic background.",
      "mentalhealth_service_survey_daily_life": "As a result of the services I received, I am better at handling daily life.",
      "mentalhealth_service_survey_family": "As a result of the services I received, I get along better with family members.",
      "mentalhealth_service_survey_friends": "As a result of the services I received, I get along better with friends and other people.",
      "mentalhealth_service_survey_work_school": "As a result of the services I received, I am doing better in school and/or work.",
      "mentalhealth_service_survey_coping_skills": "As a result of the services I received, I am better able to cope when things go wrong.",
      "mentalhealth_service_survey_family_life": "As a result of the services I received, I am satisfied with my family life right now."
