{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Neuropathy - Autonomic Assessment - Adult",
      "code": "PX130202",
      "abbreviation": "PX130202",
      "description": "The Survey of Autonomic Symptoms (SAS) is a self-administered 12-item questionnaire that measures autonomic symptoms over the past 6 months in subjects with mild neuropathy. The severity of each item is rated on 5-point Likert scale (1 is least severe; 5 is most severe). The total number of symptoms",
      "domain": "Neurology",
      "citation": "Kim, S. H., Lee, K. A., Jin, H. Y., Baek, H. S., & Park, T. S. (2014). Relationship between the Korean Version Survey of the Autonomic Symptoms Score and cardiac autonomic neuropathy parameters in patients with diabetic peripheral neuropathy. Diabetes and Metabolism Journal , 38(5), 349-355. [PhenX: https://www.phenxtoolkit.org/protocols/view/130202]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/130202"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
