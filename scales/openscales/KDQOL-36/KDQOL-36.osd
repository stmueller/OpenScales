          },
          {
            "op": "divide",
            "value": 4
          },
          {
            "op": "multiply",
            "value": 100
          }
        ]
      },
      "effects_daily_life": {
        "method": "mean_coded",
        "items": [
          "kdqol36_eff_grid_1",
          "kdqol36_eff_grid_2",
