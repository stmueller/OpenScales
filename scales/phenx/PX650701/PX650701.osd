  "translations": {
    "en": {
      "info_650701": "Intolerance of Uncertainty Scale (IUS)You will find below a series of statements which describe how people may react to the uncertainties of life. Please use the scale below to describe to what extent each item is characteristic of you.1= Not at all characteristic of me2=3= Somewhat characteristic of me4=5= Entirely characteristic of mePlease select the option that describes you best.",
      "intoleranceofuncertainty_scale_prevents_firmopinion": "Uncertainty stops me from having a firm opinion",
      "intoleranceofuncertainty_scale_prevents_firmopinion_opt_1": "Not all characteristic of me",
      "intoleranceofuncertainty_scale_prevents_firmopinion_opt_2": "Not at all/Somewhat characteristic of me",
      "intoleranceofuncertainty_scale_prevents_firmopinion_opt_3": "Somewhat characteristic of me",
      "intoleranceofuncertainty_scale_prevents_firmopinion_opt_4": "Somewhat/Entirely characteristic of me",
      "intoleranceofuncertainty_scale_prevents_firmopinion_opt_5": "Entirely characteristic of me",
      "intoleranceofuncertainty_scale_means_disorganization": "Being uncertain means that a person is disorganized",
      "intoleranceofuncertainty_scale_means_disorganization_opt_1": "Not all characteristic of me",
      "intoleranceofuncertainty_scale_means_disorganization_opt_2": "Not at all/Somewhat characteristic of me",
