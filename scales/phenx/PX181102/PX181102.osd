      "temperament_early_childhood_irritated_opt_7": "always",
      "temperament_early_childhood_irritated_opt_NA": "does not apply",
      "temperament_early_childhood_seek_company": "When a familiar child came to your home, how often did your child seek out the company of the child?",
      "temperament_early_childhood_seek_company_opt_1": "never",
      "temperament_early_childhood_seek_company_opt_2": "very rarely",
      "temperament_early_childhood_seek_company_opt_3": "less than half the time",
      "temperament_early_childhood_seek_company_opt_4": "about half the time",
      "temperament_early_childhood_seek_company_opt_5": "more than half the time",
      "temperament_early_childhood_seek_company_opt_6": "almost always",
      "temperament_early_childhood_seek_company_opt_7": "always",
      "temperament_early_childhood_seek_company_opt_NA": "does not apply",
      "temperament_early_childhood_decide_choiecs": "When offered a choice of activities, how often did your child decide what to do very quickly and go after it?",
      "temperament_early_childhood_decide_choiecs_opt_1": "never",
      "temperament_early_childhood_decide_choiecs_opt_2": "very rarely",
      "temperament_early_childhood_decide_choiecs_opt_3": "less than half the time",
