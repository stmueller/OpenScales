  "translations": {
    "en": {
      "lk_opt_1": "not at all",
      "lk_opt_2": "a little",
      "lk_opt_3": "somewhat",
      "lk_opt_4": "a good deal",
      "lk_opt_5": "a great deal",
      "patient_response_genetic_testing_result_upset": "(In the past week) How upset did you feel about your genetic test result?",
      "patient_response_genetic_testing_result_happy": "(In the past week) How happy did you feel about your genetic test result?",
      "patient_response_genetic_testing_result_nervous": "(In the past week) How anxious or nervous did you feel about your genetic test result?",
      "patient_response_genetic_testing_result_relief": "(In the past week) How relieved did you feel about your genetic test result?",
      "patient_response_genetic_testing_result_sad": "(In the past week) How sad did you feel about your genetic test result?",
      "patient_response_genetic_testing_result_recommended_care_frustrated": "(In the past week) How frustrated did you feel about recommendations for your care based on the genetic test result?",
      "patient_response_genetic_testing_result_feel_uncertain": "(In the past week) How uncertain did you feel about what your genetic test result means for you?",
      "patient_response_genetic_testing_result_feel_uncertain_family": "(In the past week) How uncertain did you feel about what your genetic test result means for your child(ren) and/or family's risk of disease?",
      "patient_response_genetic_testing_result_understand_care_choice": "(In the past week) How much did you feel that you understood clearly your choices for care based on the genetic test result?",
      "patient_response_genetic_testing_result_concern_affect_insurance": "(In the past week) How concerned did you feel that your genetic test result would affect your ability to get or keep health insurance?",
      "patient_response_genetic_testing_result_helpful_planning_future": "(In the past week) How helpful was the information you received from your genetic test result in planning for the future?",
      "patient_response_genetic_testing_result_concern_job": "(In the past week) How concerned did you feel that your genetic test result might make it hard for you to get a job or keep a job?"
    }
  }
}