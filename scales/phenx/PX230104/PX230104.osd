      "psychopathologyquestionnaire_dissatisfaction_weight_opt_6": "Markedly",
      "psychopathologyquestionnaire_dissatisfaction_shape": "Over the past 28 days, how dissatisfied have you been with your shape?",
      "psychopathologyquestionnaire_dissatisfaction_shape_opt_0": "Not at all",
      "psychopathologyquestionnaire_dissatisfaction_shape_opt_1": "1",
      "psychopathologyquestionnaire_dissatisfaction_shape_opt_2": "Slightly",
      "psychopathologyquestionnaire_dissatisfaction_shape_opt_3": "3",
