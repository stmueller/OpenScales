      "act_on_immediate_needs_opt_2": "Somewhat true",
      "act_on_immediate_needs_opt_3": "Somewhat false",
      "act_on_immediate_needs_opt_4": "FALSE",
      "parachute": "I have no strong desire to parachute out of an airplane.",
      "parachute_opt_1": "TRUE",
      "parachute_opt_2": "Somewhat true",
      "parachute_opt_3": "Somewhat false",
      "parachute_opt_4": "FALSE",
      "missed_events": "I've often missed things I promised to attend.",
      "missed_events_opt_1": "TRUE",
      "missed_events_opt_2": "Somewhat true",
      "missed_events_opt_3": "Somewhat false",
      "missed_events_opt_4": "FALSE",
      "high_speed_chase": "I would enjoy being in a high-speed chase.",
      "high_speed_chase_opt_1": "TRUE",
      "high_speed_chase_opt_2": "Somewhat true",
      "high_speed_chase_opt_3": "Somewhat false",
      "high_speed_chase_opt_4": "FALSE",
      "deal_with_stress": "I am well-equipped to deal with stress.",
