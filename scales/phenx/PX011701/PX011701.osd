  "translations": {
    "en": {
      "sexual_orientation_identity": "Which of the following best represents how you think of yourself?",
      "sexual_orientation_identity_opt_1": "Gay",
      "sexual_orientation_identity_opt_2": "Lesbian",
      "sexual_orientation_identity_opt_3": "Straight; that is, not gay or lesbian, etc.",
      "sexual_orientation_identity_opt_4": "Bisexual",
      "sexual_orientation_identity_opt_5": "None of these describe me, and Iդ like to see additional options",
      "sexual_orientation_description": "Are any of these a closer description of how you think of yourself?",
      "sexual_orientation_description_opt_1": "Queer",
      "sexual_orientation_description_opt_2": "Polysexual, omnisexual, sapiosexual or pansexual",
      "sexual_orientation_description_opt_3": "Asexual",
      "sexual_orientation_description_opt_4": "Two-spirit",
      "sexual_orientation_description_opt_5": "Have not figured out or are in the process of figuring out your sexuality",
      "sexual_orientation_description_opt_6": "Mostly straight, but sometimes attracted to people of your own sex",
      "sexual_orientation_description_opt_7": "Do not think of yourself as having sexuality",
      "sexual_orientation_description_opt_8": "Do not use labels to identity yourself",
      "sexual_orientation_description_opt_9": "Don't know the answer",
      "sexual_orientation_description_opt_10": "No, I mean something else",
      "sexual_orientation_description_opt_11": "Prefer not to answer",
      "sexual_orientation_description_other": "Are any of these a closer description of how you think of yourself? Other"
    }
  }
}
