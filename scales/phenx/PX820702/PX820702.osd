{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Recovery and Recurrence Questionnaire (RRQ) - Pediatrics",
      "code": "PX820702",
      "abbreviation": "PX820702",
      "description": "The Recovery and Recurrence Questionnaire (RRQ) includes seven questions completed by a parent about their child. Questions 1A to 1D capture problems with strength, coordination, or sensation, problems with expression, problems with understanding, and problems with thoughts or behaviors. Questions 2",
      "domain": "Health",
      "citation": "Lo, W., Zamel, K., Ponnappa, K., Allen, A., Chisolm, D., Tang, M., Kerlin, B., & Yeats, K.O. (2008). The cost of pediatric stroke care and rehabilitation. Stroke, 39 (1), 161-165. Lo, W.D., Hajek, C., Pappa, C., Wang, W., & Zumberge, N. (2013). Outcomes in children with hemorrhagic stroke. JAMA Neurology, 70 (1), 66-71. [PhenX: https://www.phenxtoolkit.org/protocols/view/820702]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/820702"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
