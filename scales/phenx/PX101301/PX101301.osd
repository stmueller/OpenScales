  "translations": {
    "en": {
      "number_pregnancy": "Including live births, stillbirths, miscarriages, abortions, and tubal and other ectopic pregnancies, how many times have you been pregnant? Be sure to count this pregnancy if you are currently pregnant.",
      "pregnancy_1": "Was your 1st pregnancy a live birth, stillbirth, miscarriage, abortion, or ectopic pregnancy?",
      "pregnancy_specify_1": "Specify your 1st pregnancy (Other Specify).",
      "pregnancy_2": "Was your 2nd pregnancy a live birth, stillbirth, miscarriage, abortion, or ectopic pregnancy?",
      "pregnancy_specify_2": "Specify your 2nd pregnancy (Other Specify).",
      "pregnancy_last_weeks_1": "How many weeks did the 1st pregnancy last?",
      "pregnancy_last_months_1": "How many months did the 1st pregnancy last?",
      "pregnancy_last_weeks_2": "How many weeks  did the 2nd pregnancy last?",
      "pregnancy_last_months_2": "How many months did the 2nd pregnancy last?",
      "pregnancy_end_date_1": "On what date did the 1st pregnancy end? (mm/dd/yyyy)",
      "pregnancy_end_date_2": "On what date did the 2nd pregnancy end? (mm/dd/yyyy)",
      "frequent_nausea_vomiting_during_pregnancy_1": "During the 1st pregnancy, did you have frequent nausea or vomiting?",
      "frequent_nausea_vomiting_during_pregnancy_2": "During the 2nd pregnancy, did you have frequent nausea or vomiting?",
      "frequent_nausea_vomiting_months_1": "In which months of the 1st pregnancy did you have frequent nausea or vomiting?",
      "frequent_nausea_vomiting_months_2": "In which months of the 2nd pregnancy did you have frequent nausea or vomiting?",
      "pregnancy_hypertension_high_blood_pressure_1": "During the 1st pregnancy, did you ever develop Hypertension or high blood pressure?",
      "pregnancy_preeclampsia_toxemia_1": "During the 1st pregnancy, did you ever develop Preeclampsia/Toxemia?",
      "pregnancy_diabetes_high_blood_sugar_1": "During  the 1st pregnancy, did you ever develop Diabetes or high blood sugar?",
      "pregnancy_related_complications_1": "During the 1st pregnancy, did you ever develop Any other pregnancy-related complications?",
      "pregnancy_hypertension_high_blood_pressure_2": "During the 2nd pregnancy, did you ever develop Hypertension or high blood pressure?",
      "pregnancy_preeclampsia_toxemia_2": "During the 2nd pregnancy, did you ever develop Preeclampsia/Toxemia?",
      "pregnancy_diabetes_high_blood_sugar_2": "During the 2nd pregnancy, did you ever develop Diabetes or high blood sugar?",
      "pregnancy_related_complications_2": "During the 2nd  pregnancy, did you ever develop Any other pregnancy-related complications?",
      "baby_number_boy_1": "How many boys did you have at your 1st pregnancy?",
      "baby_number_girl_1": "How many girls did you have at your 1st pregnancy?",
      "baby_number_boy_2": "How many boys did you have at your 2nd pregnancy?",
      "baby_number_girl_2": "How many girls did you have at your second pregnancy?",
      "cigarettes_3_months_before_pregnancy": "In the 3 months before you got pregnant, how many cigarettes did you smoke on an average day?",
      "cigarettes_last_3_months_pregnancy": "In the last 3 months of your pregnancy, how many cigarettes did you smoke on an average day?",
      "alcohol_3_months_before_pregnancy": "During the 3 months before you got pregnant, how many alcoholic drinks did you have in an average week?",
      "heavy_alcohol_3_months_before_pregnancy": "During the 3 months before you got pregnant, how many times did you drink 4 alcoholic drinks or more in one sitting?",
      "alcohol_last_3_months_pregnancy": "During the last 3 months of your pregnancy, how many alcoholic drinks did you have in an average week?",
      "heavy_alcohol_last_3_months_pregnancy": "During the last 3 months of your pregnancy, how many times did you drink 4 alcoholic drinks or more in one sitting?",
      "receive_help_alcohol_drug_problem": "During this pregnancy, did you receive help with an alcohol or drug problem?",
      "opt_1": "LIVE BIRTH",
      "opt_2": "STILLBIRTH",
      "opt_3": "MISCARRIAGE",
      "opt_4": "ABORTION",
      "opt_5": "ECTOPIC/TUBAL",
      "opt_6": "CURRENTLY PREGNANT",
      "opt_7": "OTHER",
      "grp2_opt_1": "YES, NAUSEA",
      "grp2_opt_2": "YES, VOMITING",
      "grp2_opt_3": "NO",
      "grp3_opt_1": "MONTHS 1-3 (FIRST TRIMESTER)",
      "grp3_opt_2": "MONTHS 4-6 (SECOND TRIMESTER)",
      "grp3_opt_3": "MONTHS 7-9 (THIRD TRIMESTER)",
