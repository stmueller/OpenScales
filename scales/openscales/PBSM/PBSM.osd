    "scoring": {
      "total": {
        "description": "Sum of all 17 items (range 17–102). Higher scores = more frequent use of protective strategies. Transform converts to IRT-scaled T-scores (M=50, SD=10).",
        "method": "sum_coded",
        "items": [
          "pbsm1",
          "pbsm2",
          "pbsm3",
