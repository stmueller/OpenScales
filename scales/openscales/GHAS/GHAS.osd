{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Gaming Hazard Assessment Scale",
      "code": "GHAS",
      "abbreviation": "GHAS",
      "description": "18-item risk screening tool for gaming disorder based on DSM-5 and ICD-11 criteria. Assesses three dimensions: out-of-control gaming, impairment of social functioning, and cognitive impairment. Total scores range from 0 to 54, with cutoffs for no risk (0-18), moderate risk (19-36), and high risk (37-54).",
      "citation": "Tang, Y., Liao, Z., Huang, S., Hao, J., Huang, Q., Huang, X., Chen, X., Lin, S., Li, Y., Qi, J., & Shen, H. (2022). Development and validation of a risk assessment tool for gaming disorder in China: The Gaming Hazard Assessment Scale. Frontiers in Public Health, 10, 870358. https://doi.org/10.3389/fpubh.2022.870358",
      "license": "CC BY 4.0",
      "license_explanation": "Published in Frontiers in Public Health under Creative Commons Attribution 4.0 International License.",
      "license_url": "https://creativecommons.org/licenses/by/4.0/",
      "version": "1.0",
      "url": "https://doi.org/10.3389/fpubh.2022.870358",
      "domain": "Technology"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 4,
      "min": 0,
      "max": 3,
      "labels": [
        "likert_0",
        "likert_1",
        "likert_2",
        "likert_3"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "out_of_control",
        "name": "Out-of-Control",
        "description": "Loss of control over gaming behavior including inability to stop, playing longer than intended, and failed attempts to reduce gaming."
      },
      {
        "id": "social_impairment",
        "name": "Impairment of Social Functioning",
        "description": "Negative impact of gaming on social relationships, daily activities, sleep, finances, and responsibilities."
      },
      {
        "id": "cognitive_impairment",
        "name": "Cognitive Impairment",
        "description": "Preoccupation with gaming, preference for gaming over other activities, and irritability when asked to stop."
      }
    ],
