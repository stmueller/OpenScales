      "lk_opt_5": "severe",
      "info_721001": "Behavior Rating Scale - Self-ReportPlease rate yourself in the following questions for the period for the last  ___________ (measurement of time, EX day, week, month)",
      "tobacco_use_withdrawal_angry": "Angry, irritable, frustrated",
