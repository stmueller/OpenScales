    "scoring": {
      "alcohol_use": {
        "description": "Sum of all items (0-40). Score ≥8 = hazardous use; ≥15 = dependence likely.",
        "method": "sum_coded",
        "items": [
          "audit1",
          "audit2",
          "audit3",
          "audit4",
          "audit5",
          "audit6",
          "audit7",
          "audit8",
          "audit9",
          "audit10"
        ],
        "norms": {
          "thresholds": [
            {
              "min": 0,
              "max": 7,
              "label": "Low Risk"
            },
            {
              "min": 8,
              "max": 14,
              "label": "Hazardous Use — simple advice recommended"
            },
            {
              "min": 15,
              "max": 19,
              "label": "Harmful Use — brief counselling recommended"
            },
            {
              "min": 20,
              "max": 40,
              "label": "Dependence Likely — specialist assessment recommended"
            }
          ]
        }
      }
    }
  },
  "translations": {
    "en": {
      "question_head": "Please answer the following questions about your alcohol use over the <b>past year</b>.",
      "audit1": "How often do you have a drink containing alcohol?",
      "audit1_opt0": "Never",
      "audit1_opt1": "Monthly or less",
      "audit1_opt2": "2 to 4 times a month",
      "audit1_opt3": "2 to 3 times a week",
      "audit1_opt4": "4 or more times a week",
      "audit2": "How many standard drinks containing alcohol do you have on a typical day when you are drinking?",
      "audit2_opt0": "1 or 2",
      "audit2_opt1": "3 or 4",
      "audit2_opt2": "5 or 6",
      "audit2_opt3": "7 to 9",
      "audit2_opt4": "10 or more",
      "audit3": "How often do you have 6 or more drinks on one occasion?",
      "audit3_opt0": "Never",
      "audit3_opt1": "Less than monthly",
      "audit3_opt2": "Monthly",
      "audit3_opt3": "Weekly",
      "audit3_opt4": "Daily or almost daily",
      "audit4": "How often during the last year have you found that you were not able to stop drinking once you had started?",
      "audit4_opt0": "Never",
      "audit4_opt1": "Less than monthly",
      "audit4_opt2": "Monthly",
      "audit4_opt3": "Weekly",
      "audit4_opt4": "Daily or almost daily",
      "audit5": "How often during the last year have you failed to do what was normally expected of you because of drinking?",
      "audit5_opt0": "Never",
      "audit5_opt1": "Less than monthly",
      "audit5_opt2": "Monthly",
      "audit5_opt3": "Weekly",
      "audit5_opt4": "Daily or almost daily",
      "audit6": "How often during the last year have you needed a first drink in the morning to get yourself going after a heavy drinking session?",
      "audit6_opt0": "Never",
      "audit6_opt1": "Less than monthly",
      "audit6_opt2": "Monthly",
      "audit6_opt3": "Weekly",
      "audit6_opt4": "Daily or almost daily",
      "audit7": "How often during the last year have you had a feeling of guilt or remorse after drinking?",
      "audit7_opt0": "Never",
      "audit7_opt1": "Less than monthly",
      "audit7_opt2": "Monthly",
      "audit7_opt3": "Weekly",
      "audit7_opt4": "Daily or almost daily",
      "audit8": "How often during the last year have you been unable to remember what happened the night before because of your drinking?",
      "audit8_opt0": "Never",
      "audit8_opt1": "Less than monthly",
      "audit8_opt2": "Monthly",
      "audit8_opt3": "Weekly",
      "audit8_opt4": "Daily or almost daily",
      "audit9": "Have you or someone else been injured as a result of your drinking?",
      "audit9_opt0": "No",
      "audit9_opt2": "Yes, but not in the last year",
      "audit9_opt4": "Yes, during the last year",
      "audit10": "Has a relative, friend, doctor, or other health professional expressed concern about your drinking or suggested you cut down?",
      "audit10_opt0": "No",
      "audit10_opt2": "Yes, but not in the last year",
      "audit10_opt4": "Yes, during the last year",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
