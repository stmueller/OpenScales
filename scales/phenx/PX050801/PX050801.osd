  "translations": {
    "en": {
      "pxt50801_cereal_frequency": "Think about your eating habits over the past 12 months. About how often did you eat Cold cereal? Remember breakfast, lunch, dinner, snacks, and eating out. Choose only one answer.",
      "pxt50801_cereal_frequency_opt_1": "Never",
      "pxt50801_cereal_frequency_opt_2": "Less than Once Per Month",
      "pxt50801_cereal_frequency_opt_3": "1-3 Times Per Month",
      "pxt50801_cereal_frequency_opt_4": "1-2 Times Per Week",
      "pxt50801_cereal_frequency_opt_5": "3-4 Times Per Week",
      "pxt50801_cereal_frequency_opt_6": "5-6 Times Per Week",
      "pxt50801_cereal_frequency_opt_7": "1 Time Per Day",
      "pxt50801_cereal_frequency_opt_8": "2 or More Times Per Day",
      "skim_milk_frequency": "Think about your eating habits over the past 12 months. About how often did you drink Skim milk, on cereal or to drink? Remember breakfast, lunch, dinner, snacks, and eating out. Choose only one answer.",
      "skim_milk_frequency_opt_1": "Never",
      "skim_milk_frequency_opt_2": "Less than Once Per Month",
      "skim_milk_frequency_opt_3": "1-3 Times Per Month",
      "skim_milk_frequency_opt_4": "1-2 Times Per Week",
      "skim_milk_frequency_opt_5": "3-4 Times Per Week",
      "skim_milk_frequency_opt_6": "5-6 Times Per Week",
      "skim_milk_frequency_opt_7": "1 Time Per Day",
      "skim_milk_frequency_opt_8": "2 or More Times Per Day",
      "egg_frequency": "Think about your eating habits over the past 12 months. About how often did you eat Eggs, fried or scrambled in margarine, butter, or oil? Remember breakfast, lunch, dinner, snacks, and eating out. Choose only one answer.",
      "egg_frequency_opt_1": "Never",
      "egg_frequency_opt_2": "Less than Once Per Month",
      "egg_frequency_opt_3": "1-3 Times Per Month",
      "egg_frequency_opt_4": "1-2 Times Per Week",
      "egg_frequency_opt_5": "3-4 Times Per Week",
      "egg_frequency_opt_6": "5-6 Times Per Week",
      "egg_frequency_opt_7": "1 Time Per Day",
      "egg_frequency_opt_8": "2 or More Times Per Day",
      "sausage_bacon_frequency": "Think about your eating habits over the past 12 months. About how often did you eat Sausage or bacon, regular-fat? Remember breakfast, lunch, dinner, snacks, and eating out. Choose only one answer.",
      "sausage_bacon_frequency_opt_1": "Never",
      "sausage_bacon_frequency_opt_2": "Less than Once Per Month",
      "sausage_bacon_frequency_opt_3": "1-3 Times Per Month",
      "sausage_bacon_frequency_opt_4": "1-2 Times Per Week",
      "sausage_bacon_frequency_opt_5": "3-4 Times Per Week",
      "sausage_bacon_frequency_opt_6": "5-6 Times Per Week",
      "sausage_bacon_frequency_opt_7": "1 Time Per Day",
      "sausage_bacon_frequency_opt_8": "2 or More Times Per Day",
      "butter_on_bread_frequency": "Think about your eating habits over the past 12 months. About how often did you eat Margarine or butter on bread, rolls, pancakes? Remember breakfast, lunch, dinner, snacks, and eating out. Choose only one answer.",
      "butter_on_bread_frequency_opt_1": "Never",
      "butter_on_bread_frequency_opt_2": "Less than Once Per Month",
      "butter_on_bread_frequency_opt_3": "1-3 Times Per Month",
      "butter_on_bread_frequency_opt_4": "1-2 Times Per Week",
      "butter_on_bread_frequency_opt_5": "3-4 Times Per Week",
