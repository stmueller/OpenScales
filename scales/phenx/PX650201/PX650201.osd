{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Exercise Dependence Scale",
      "code": "PX650201",
      "abbreviation": "PX650201",
      "description": "The Exercise Dependence Scale is a 21-item self-administered scale that can be administered in individual and group settings and has been used with respondents 18 years and older. Participants indicate their responses to each of the 21 items in the blank space provided after each item. They indicate",
      "domain": "Self & Coping",
      "citation": "Cook, B.J., & Hausenblas, H.A. (2011). Eating disorder-specific health-related quality of life and exercise in college females. Quality of Life Research, 55 (8), 1129-1141. Costa, S., Hausenblas, H. A., Oliva, P., Cuzzocrea, F., & Larcan, R. (2013). The role of age, gender, mood states and exercise frequency on exercise dependence. Journal of Behavior Addictions, 2 (4), 216-223. [PhenX: https://www.phenxtoolkit.org/protocols/view/650201]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/650201"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
