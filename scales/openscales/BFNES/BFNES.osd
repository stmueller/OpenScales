          "bfnes4",
          "bfnes5",
          "bfnes6",
          "bfnes7",
          "bfnes8"
        ],
        "description": "Sum of all 8 items (0-32). Higher scores indicate greater fear of negative evaluation.",
        "item_coding": {
          "bfnes1": 1,
          "bfnes2": 1,
          "bfnes3": 1,
