    "scoring": {
      "depression": {
        "method": "sum_coded",
        "items": [
          "gds1",
          "gds2",
          "gds3",
          "gds4",
          "gds5",
          "gds6",
          "gds7",
          "gds8",
          "gds9",
          "gds10",
          "gds11",
          "gds12",
          "gds13",
          "gds14",
          "gds15"
        ],
        "description": "Sum of depressive responses (0-15). Cutoff ≥5 suggests depression (sensitivity 92%, specificity 89%). Score 0-4: normal, 5-8: mild depression, 9-11: moderate, 12-15: severe.",
        "norms": {
          "thresholds": [
            {
              "min": 0,
              "max": 4,
              "label": "Normal"
            },
            {
              "min": 5,
              "max": 8,
              "label": "Mild Depression"
            },
            {
              "min": 9,
              "max": 11,
              "label": "Moderate Depression"
            },
            {
              "min": 12,
              "max": 15,
              "label": "Severe Depression"
            }
          ]
        },
        "item_coding": {
          "gds1": 1,
          "gds2": 1,
