      "recovery_selfassessment_administrator_welcoming_staff_opt_6": "Not applicable",
      "recovery_selfassessment_administrator_welcoming_staff_opt_7": "Don't know",
      "recovery_selfassessment_administrator_facilities": "This program/agency offers an inviting and dignified physical environment (e.g., the lobby, waiting rooms, etc.). Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_administrator_facilities_opt_1": "1",
      "recovery_selfassessment_administrator_facilities_opt_2": "2",
      "recovery_selfassessment_administrator_facilities_opt_3": "3",
