  "translations": {
    "en": {
      "likert_1": "Strongly disagree",
      "likert_2": "Disagree",
      "likert_3": "Neutral",
      "likert_4": "Agree",
      "likert_5": "Strongly agree",
      "question_head": "Please indicate the extent to which each statement is characteristic of you.",
      "fowars1": "I am scared because I know war costs human lives.",
      "fowars2": "I am afraid that the war will drag on for a long time.",
      "fowars3": "I fear that the peace talks will be fruitless.",
      "fowars4": "I am afraid the world will no longer be a safe place.",
      "fowars5": "I feel uncomfortable when I think of the war.",
      "fowars6": "I am concerned about the serious consequences of the war (economic, political, etc.).",
      "fowars7": "I am afraid that a nuclear war will break out.",
      "fowars8": "I start to tremble when I think the war reaches here, as well.",
      "fowars9": "My palms sweat when I think the war will reach us too.",
      "fowars10": "My heart is beating faster (my heart rate is rising) when I think the war will break out in our country too.",
      "fowars11": "I have a sleep disorder because I am worried the war will get to us too.",
      "fowars12": "It gives me the creeps (I get goose bumps) when I think the war will break out here too.",
      "fowars13": "It makes me sick to the stomach (I have nausea, stomach upset) when I think the war will break out here too.",
      "debrief": "Thank you for completing this questionnaire."
    },
    "hu": {
      "likert_1": "Határozottan nem értek egyet",
      "likert_2": "Nem értek egyet",
      "likert_3": "Semleges",
      "likert_4": "Egyetértek",
      "likert_5": "Határozottan egyetértek",
      "question_head": "Kérjük, jelölje meg, mennyire jellemzőek Önre az alábbi állítások.",
      "fowars1": "Félek, mert tudom, hogy a háború emberi életekbe kerül.",
      "fowars2": "Félek, hogy a háború hosszasan elhúzódik.",
      "fowars3": "Attól tartok, hogy a béketárgyalások eredménytelenek lesznek.",
      "fowars4": "Félek attól, hogy a világ már nem lesz biztonságos hely.",
      "fowars5": "Kényelmetlenül érzem magam, ha a háborúra gondolok.",
      "fowars6": "Aggódom a háború súlyos következményei (gazdasági, politikai stb.) miatt.",
      "fowars7": "Félek attól, hogy kitör a nukleáris háború.",
      "fowars8": "Remegni kezdek, amikor arra gondolok, hogy ide is elér a háború.",
      "fowars9": "Izzad a tenyerem, ha arra gondolok, hogy a háború bennünket is elér.",
      "fowars10": "A szívem gyorsabban ver (pulzusom megnő) amikor arra gondolok, hogy nálunk is kitör a háború.",
      "fowars11": "Alvászavarom van, mert aggódom, hogy ide is elér a háború.",
      "fowars12": "Kiráz a hideg (libabőrös leszek), amikor arra gondolok, hogy nálunk is kitör a háború.",
      "fowars13": "Felfordul a gyomrom (hányingerem, gyomoridegem van), amikor arra gondolok, hogy nálunk is kitör a háború.",
      "debrief": "Köszönjük, hogy kitöltötte a kérdőívet."
    }
  }
}
