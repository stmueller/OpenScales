  "translations": {
    "en": {
      "quit_smoking_consider": "Are you considering quitting smoking during the next 6 months?",
      "quit_smoking_consider_opt_1": "Yes, plan to stop within next 30 days",
      "quit_smoking_consider_opt_2": "Yes, plan to stop within next 6 months, but not within next 30 days",
      "quit_smoking_consider_opt_3": "No, not thinking of quitting in next 6 months",
      "quit_smoking_attempt": "In the past, have you ever made a serious attempt to quit smoking? That is, have you stopped smoking for at least one day or longer because you were trying to quit?",
      "quit_smoking_longest_time": "What was the longest length of time you stopped smoking because you were trying to quit?",
      "quit_smoking_longest_time_opt_1": "Less than 1 week",
      "quit_smoking_longest_time_opt_2": "1 to 3 weeks",
      "quit_smoking_longest_time_opt_3": "1 to 2 months",
      "quit_smoking_longest_time_opt_4": "3 to 11 months",
      "quit_smoking_longest_time_opt_5": "1 to 4 years",
      "quit_smoking_longest_time_opt_6": "5 to 9 years",
      "quit_smoking_longest_time_opt_7": "10 years or more",
      "quit_smoking_age": "How old were you when you most recently quit smoking?",
      "quit_smoking_product_nicotine_gum": "Thinking of the most recent time you quit smoking, did you use any of the following products?  Nicotine gum:",
      "quit_smoking_product_nicotine_patch": "Thinking of the most recent time you quit smoking, did you use any of the following products?  Nicotine patch:",
      "quit_smoking_product_nicotine_other": "Thinking of the most recent time you quit smoking, did you use any of the following products?  Nicotine nasal spray, inhaler, lozenge, or tablet:",
      "quit_smoking_product_prescription_pill": "Thinking of the most recent time you quit smoking, did you use any of the following products?  Prescription pill such as Zyban�, Buproprion, or Wellbutrin�:",
      "quit_smoking_product_none": "Thinking of the most recent time you quit smoking, did you use any of the following products?  None of these:",
      "quit_smoking_professional_advise": "During the past 12 months, did any doctor, dentist, nurse, or any other health professional advise you to quit smoking?",
      "quit_smoking_professional_advise_opt_1": "Yes",
      "quit_smoking_professional_advise_opt_2": "No, was not advised to quit",
      "quit_smoking_professional_advise_opt_3": "No, did not see a health professional in past 12 months",
      "quit_smoking_professional_advise_opt_4": "No, did not smoke in past 12 months",
      "opt_1": "Yes",
      "opt_2": "No"
    }
