  "translations": {
    "en": {
      "lk_opt_1": "Never",
      "lk_opt_2": "Rarely",
      "lk_opt_3": "Sometimes",
      "lk_opt_4": "Most of the time",
      "lk_opt_5": "Always",
      "intro_text": "Think of your prior experiences while getting health care when answering these questions.",
      "discrimination_health_care_less_courtesy": "You are treated with less courtesy than other people.",
      "discrimination_health_care_less_respect": "You are treated with less respect than other people.",
      "discrimination_health_care_poorer_service": "You receive poorer service than others.",
      "discrimination_health_care_doctor_nurse_act_thinks_not_smart": "A doctor or nurse acts as if he or she thinks you are not smart.",
      "discrimination_health_care_doctor_nurse_act_afraid": "A doctor or nurse acts as if he or she is afraid of you.",
      "discrimination_health_care_doctor_nurse_act_better": "A doctor or nurse acts as if he or she is better than you.",
      "discrimination_health_care_doctor_nurse_act_not_listen": "You feel like a doctor or nurse is not listening to what you were saying"
