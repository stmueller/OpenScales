  "definition": {
    "scale_info": {
      "name": "Use of Glasses and/or Contact Lenses as a Child",
      "code": "PX111302",
      "abbreviation": "PX111302",
      "description": "The respondent is asked a series of 5 questions to assess their childs current and past use of glasses and contact lenses, duration of use, and reason for use.",
      "domain": "Health",
      "citation": "Ip JM, Saw SM, Rose KA, Morgan IG, Kifley A, Wang JJ, Mitchell P. (2008). Role of Near Work in Myopia: Findings in a Sample of Australian School Children. Invest Ophthalmol Vis Sci , 49(7):2903-10. Ojaimi E, Rose KA, Smith W, Morgan IG, Martin FJ, Mitchell P. (2005). Methods for a population-based study of myopia and other eye conditions in school children: the Sydney Myopia Study. Ophthalmic Epidemiol , 12(1):59-69. [PhenX: https://www.phenxtoolkit.org/protocols/view/111302]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/111302"
    },
