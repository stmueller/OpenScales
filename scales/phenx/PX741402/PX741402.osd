{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Use of Tobacco Products",
      "code": "PX741402",
      "abbreviation": "PX741402",
      "description": "This protocol includes questions from the Wave 7 Adult Population Assessment of Tobacco and Health (PATH) Survey instrument. These specific questions are used to measure a respondent’s use and regularity of use of the following tobacco products: cigarettes, electronic nicotine products, cigars, pipe",
      "domain": "Substance Use",
      "citation": "National Institutes of Health, U.S. Food and Drug Administration. (2023). Population Assessment of Tobacco and Health (PATH) Study: Final Adult Interview, Wave 7 (January 2022 – December 2022), English Data Collection Instrument. Bethesda, MD: National Institutes of Health. [ https://www.icpsr.umich.edu/files/NAHDAP/pathstudy/Final%20PATH%20Wave%207%20English%20Adult%20Questionnaire.pdf ] [PhenX: https://www.phenxtoolkit.org/protocols/view/741402]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/741402"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
