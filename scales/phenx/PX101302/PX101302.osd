{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Reproductive History - Male",
      "code": "PX101302",
      "abbreviation": "PX101302",
      "description": "The male participant is asked whether he has ever fathered a pregnancy. For each pregnancy he reports, he is asked his age at the time, whether the pregnancy was planned, and the birth outcome.",
      "domain": "Puberty & Development",
      "citation": "Eunice Kennedy Shriver National Institute of Child Health and Human Development. (2005). The Longitudinal Investigation of Fertility and the Environment (LIFE) Study. Rockville, MD: Author. https://www.nichd.nih.gov/about/org/diphr/od/research/pages/longitudinal.aspx [PhenX: https://www.phenxtoolkit.org/protocols/view/101302]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/101302"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
