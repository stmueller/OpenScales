{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Offspring and Fertility History",
      "code": "PX880701",
      "abbreviation": "PX880701",
      "description": "The Offspring/Pregnancy History section of the Childhood Cancer Survivor Study includes three self-administered questions for males and females about pregnancy, pregnancy outcomes, and/or the ability to father children.",
      "domain": "Health",
      "citation": "Green, D. M., Whitton, J. A., Stovall, M., Mertens, A. C., Donaldson, S. S., Ruymann, F. B., Pendergrass, T. W., & Robison, L. L. (2003). Pregnancy outcome of partners of male survivors of childhood cancer: A report from the Childhood Cancer Survivor Study. Journal of Clinical Oncology, 21 (4), 716–721. https://doi.org/10.1200/JCO.2003.04.085 [PhenX: https://www.phenxtoolkit.org/protocols/view/880701]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/880701"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "items": [
