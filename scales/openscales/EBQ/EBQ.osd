{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Emotion Beliefs Questionnaire",
      "abbreviation": "EBQ",
      "description": "16-item self-report measure of beliefs about the controllability and usefulness of negative and positive emotions. Four valence-specific subscales (Negative-Controllability, Positive-Controllability, Negative-Usefulness, Positive-Usefulness), two composite scores (General-Controllability, General-Usefulness), and a Total score. Higher scores indicate stronger beliefs that emotions are uncontrollable and useless.",
      "citation": "Becerra, R., Preece, D. A., & Gross, J. J. (2020). Assessing beliefs about emotions: Development and validation of the Emotion Beliefs Questionnaire. PLOS ONE, 15(4), e0231395. https://doi.org/10.1371/journal.pone.0231395",
      "license": "CC BY 4.0",
      "version": "1.0",
      "url": "https://doi.org/10.1371/journal.pone.0231395",
      "domain": "Self & Coping"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 7,
      "min": 1,
      "max": 7,
      "labels": [
        "ebq_opt1",
        "ebq_opt2",
        "ebq_opt3",
        "ebq_opt4",
        "ebq_opt5",
        "ebq_opt6",
        "ebq_opt7"
      ],
      "question_head": "ebq_inst"
    },
    "dimensions": [
      {
        "id": "neg_controllability",
        "name": "Negative-Controllability",
        "abbreviation": "EBQ-NC",
        "description": "Beliefs about the controllability of negative emotions (4 items). Higher scores indicate stronger beliefs that negative emotions are uncontrollable."
      },
      {
        "id": "pos_controllability",
        "name": "Positive-Controllability",
        "abbreviation": "EBQ-PC",
        "description": "Beliefs about the controllability of positive emotions (4 items). Higher scores indicate stronger beliefs that positive emotions are uncontrollable."
      },
      {
        "id": "neg_usefulness",
        "name": "Negative-Usefulness",
        "abbreviation": "EBQ-NU",
        "description": "Beliefs about the usefulness of negative emotions (4 items). Higher scores indicate stronger beliefs that negative emotions are useless."
      },
      {
        "id": "pos_usefulness",
        "name": "Positive-Usefulness",
        "abbreviation": "EBQ-PU",
        "description": "Beliefs about the usefulness of positive emotions (4 items). Higher scores indicate stronger beliefs that positive emotions are useless."
      }
    ],
    "items": [
