{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Copenhagen Burnout Inventory",
      "code": "CBI",
      "abbreviation": "CBI",
      "description": "19-item burnout measure with three subscales: Personal Burnout (6 items), Work-Related Burnout (7 items), and Client-Related Burnout (6 items). Two response formats: frequency (Always→Never) and degree (Very high degree→Very low degree), both scored 0–100 in 25-point increments. Item 13 is reverse-scored. Subscale scores are means (0–100). Public domain.",
      "citation": "Kristensen, T. S., Borritz, M., Villadsen, E., & Christensen, K. B. (2005). The Copenhagen Burnout Inventory: A new tool for the assessment of burnout. Work & Stress, 19(3), 192–207. https://doi.org/10.1080/02678370500297720",
      "license": "Public Domain",
      "license_explanation": "Developed at the Danish National Research Centre for the Working Environment (NFA) with public funds. Freely available.",
      "license_url": "https://nfa.dk/vaerktoejer/spoergeskemaer/spoergeskema-til-maaling-af-udbraendthed-cbi/copenhagen-burnout-inventory-cbi",
      "version": "1.0",
      "url": "https://nfa.dk/vaerktoejer/spoergeskemaer/spoergeskema-til-maaling-af-udbraendthed-cbi/copenhagen-burnout-inventory-cbi",
      "domain": "Work"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "parameters": {
      "include_client": {
        "type": "boolean",
        "default": 1,
        "description": "Include Client-Related Burnout subscale (items 14–19). Set to 0 for respondents who do not work with clients/patients/students."
      }
    },
    "dimensions": [
      {
        "id": "personal",
        "name": "Personal Burnout",
        "description": "General fatigue and exhaustion not attributed to a specific domain (items 1–6). Mean 0–100."
      },
      {
        "id": "work",
        "name": "Work-Related Burnout",
        "description": "Fatigue and exhaustion attributed to work (items 7–13). Mean 0–100. Item 13 reverse-scored."
      },
      {
        "id": "client",
        "name": "Client-Related Burnout",
        "description": "Fatigue and exhaustion attributed to working with clients/patients/students (items 14–19). Mean 0–100."
      }
    ],
