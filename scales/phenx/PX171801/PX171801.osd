  "translations": {
    "en": {
      "psoriatric_arthritis_screening_intro": "Please answer the questions below and score 1 point for each question answered 'Yes'",
      "psoriatic_arthritis_screening_swollen_joint_ever": "Have you ever had a swollen joint (or joints)?",
      "psoriatic_arthritis_screening_doctor_told_arthritis": "Has a doctor ever told you that you have arthritis?",
      "psoriatic_arthritis_screening_finger_toe_nail_pit_hole": "Do your finger nails or toenails have holes or pits?",
      "psoriatic_arthritis_screening_pain_heel": "Have you had pain in your heel?",
      "psoriatic_arthritis_screening_finger_toe_swollen_completely_no_reason": "Have you had a finger or toe that was completely swollen and painful for no apparent reason?",
      "psoriatric_arthritis_screening_outro": "A total score of 3 or more out of 5 is positive and indicates referral to rheumatology should be considered.",
