        },
        "input_type": "number"
      }
    ]
  },
  "translations": {
    "en": {
      "weight_loss_gain_weight_one_year_ago": "How much did {you/SP*} weigh a year ago? [If {you were/she was} pregnant a year ago, how much did {you/she} weigh before your pregnancy?]",
      "weight_loss_gain_weight_one_year_ago_opt_1": "Enter weight in pounds",
      "weight_loss_gain_weight_one_year_ago_opt_2": "Enter weight in kilograms",
      "weight_loss_gain_weight_one_year_ago_opt_7": "Refused",
      "weight_loss_gain_weight_one_year_ago_opt_9": "Don't know",
      "weight_loss_gain_weight_one_year_ago_pounds": "How much did {you/SP*} weigh a year ago? [If {you were/she was} pregnant a year ago, how much did {you/she} weigh before your pregnancy?]. Pounds",
      "weight_loss_gain_weight_one_year_ago_kilograms": "How much did {you/SP*} weigh a year ago? [If {you were/she was} pregnant a year ago, how much did {you/she} weigh before your pregnancy?]. Kilograms"
    }
  }
