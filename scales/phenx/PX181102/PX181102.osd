{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Temperament - Early Childhood",
      "code": "PX181102",
      "abbreviation": "PX181102",
      "description": "The Early Childhood Behavior Questionnaire (ECBQ) is a parent-report questionnaire used to measure the temperament of a young child (18-36 months old). The 36-item instrument (very short form) includes three broad scales. Respondents are asked to read each description of behavior and indicate how ma",
      "domain": "Mental Health & Quality of Life",
      "citation": "Rothbart, M. K., & Bates, J. E. (1998). Temperament. In W. Damon (Series Ed.) & N. Eisenberg (Vol. Ed.), Handbook of child psychology: Vol. 3. Social, emotional and personality development (5th ed., pp. 105-176). New York: Wiley. [PhenX: https://www.phenxtoolkit.org/protocols/view/181102]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/181102"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
