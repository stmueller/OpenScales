  "translations": {
    "en": {
      "temperament_early_childhood_clinging": "When approached by an unfamiliar person in a public place (for example, the grocery store), how often did your child cling to a parent?",
      "temperament_early_childhood_irritated": "While having trouble completing a task (e.g., building, drawing, dressing), how often did your child get easily irritated?",
      "temperament_early_childhood_seek_company": "When a familiar child came to your home, how often did your child seek out the company of the child?",
      "temperament_early_childhood_decide_choiecs": "When offered a choice of activities, how often did your child decide what to do very quickly and go after it?",
      "temperament_early_childhood_singing": "During daily or evening quiet time with you and your child, how often did your child enjoy just being quietly sung to?",
      "temperament_early_childhood_outdoors_excitement": "While playing outdoors, how often did your child choose to take chances for the fun and excitement of it?",
      "temperament_early_childhood_toy_time": "When engaged in play with his/her favorite toy, how often did your child play for more than 10 minutes?",
      "temperament_early_childhood_toy_responding": "When engaged in play with his/her favorite toy, how often did your child continue to play while at the same time responding to your remarks or questions?",
      "temperament_early_childhood_visit_excited": "When told that loved adults would visit, how often did your child get very excited?",
      "temperament_early_childhood_quiet_activities_fiddle": "During quiet activities, such as reading a story, how often did your child fiddle with his/her hair, clothing, etc.?",
      "temperament_early_childhood_indoors_rough_games": "While playing indoors, how often did your child like rough and rowdy games?",
      "temperament_early_childhood_hug": "When being gently rocked or hugged, how often did your child seem eager to get away?",
      "temperament_early_childhood_new_activity": "When encountering a new activity, how often did your child get involved immediately?",
      "temperament_early_childhood_activity_tired": "When engaged in an activity requiring attention, such as building with blocks, how often did your child tire of the activity relatively quickly?",
      "temperament_early_childhood_everyday_activities_attention": "During everyday activities, how often did your child pay attention to you right away when you called to him/her?",
      "temperament_early_childhood_everyday_activities_irritated": "During everyday activities, how often did your child seem to be irritated by tags in his/her clothes?",
      "temperament_early_childhood_everyday_activities_bothered": "During everyday activities, how often did your child become bothered by sounds while in noisy environments?",
      "temperament_early_childhood_everyday_activities_energy": "During everyday activities, how often did your child seem full of energy, even in the evening?",
      "temperament_early_childhood_public_place_noise": "While in a public place, how often did your child seem afraid of large, noisy vehicles?",
      "temperament_early_childhood_outdoors_active": "When playing outdoors with other children, how often did your child seem to be one of the most active children?",
      "temperament_early_childhood_stop_activity": "When told \"no\"  how often did your child stop the forbidden activity?",
      "temperament_early_childhood_stop_tearful": "When told \"no\"  how often did your child become sadly tearful?",
      "temperament_early_childhood_activity_depressed": "Following an exciting activity or event, how often did your child seem to feel down or blue?",
      "temperament_early_childhood_indoors_run": "While playing indoors, how often did your child run through the house?",
      "temperament_early_childhood_excited": "Before an exciting event (such as receiving a new toy), how often did your child get very excited about getting it?",
      "temperament_early_childhood_temper_tantrum": "When s/he asked for something and you said \"no\"  how often did your child have a temper tantrum?",
      "temperament_early_childhood_waiting_patiently": "When asked to wait for a desirable item (such as ice cream), how often did your child wait patiently?",
      "temperament_early_childhood_rock_smile": "When being gently rocked, how often did your child smile?",
      "temperament_early_childhood_lap_mold_body": "While being held on your lap, how often did your child mold to your body?",
      "temperament_early_childhood_adult_interact": "When a familiar adult, such as a relative or friend, visited your home, how often did your child want to interact with the adult?",
      "temperament_early_childhood_careful": "When asked to do so, how often was your child able to be careful with something breakable?",
      "temperament_early_childhood_new_place": "When visiting a new place, how often did your child not want to enter?",
      "temperament_early_childhood_upset_comfort": "When s/he was upset, how often did your child cry for more than 3 minutes, even when being comforted?",
      "temperament_early_childhood_upset_soothe": "When s/he was upset, how often did your child become easily soothed?",
      "temperament_early_childhood_busy_activity": "When you were busy, how often did your child find another activity to do when asked?",
      "temperament_early_childhood_gathering_different_people": "When around large gatherings of familiar adults or children, how often did your child enjoy playing with a number of different people?",
      "likert_1": "never",
      "likert_2": "very rarely",
      "likert_3": "less than half the time",
      "likert_4": "about half the time",
      "likert_5": "more than half the time",
      "likert_6": "almost always",
      "likert_7": "always",
      "likert_8": "does not apply"
    }
  }
}
