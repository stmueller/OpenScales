  "definition": {
    "scale_info": {
      "name": "General Cannabis Use",
      "code": "PX510307",
      "abbreviation": "PX510307",
      "description": "This questionnaire includes six items from the International Cannabis Policy Study Survey, Wave 6 (2023). Respondents are asked if they ever tried marijuana, when they last used marijuana, how often they use marijuana, how often they used marijuana in the last 30 days, length of marijuana use and ho",
      "domain": "Substance Use",
      "citation": "Corsetti, D., Fataar, F., Burkalter, R., & Hammond, D. (2023). International Cannabis Policy Study Technical Report-Wave 5 (2022) . Waterloo, Ontario, Canada: University of Waterloo. Hammond, D., Goodman, S., Wadsworth, E., Rynard, V., Boudreau, C., & Hall, W. (2020). Evaluating the impacts of cannabis legalization: The International Cannabis Policy Study. International Journal on Drug Policy, 77 , 102698. https://doi.org/10.1016/j.drugpo.2020.102698 [PhenX: https://www.phenxtoolkit.org/protocols/view/510307]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/510307"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
