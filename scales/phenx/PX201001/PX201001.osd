{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Tinnitus",
      "code": "PX201001",
      "abbreviation": "PX201001",
      "description": "The Tinnitus Handicap Inventory is a 25-item self-administered questionnaire that assesses the impact of tinnitus on the respondent's general well-being. The Tinnitus Handicap Inventory includes a functional subscale (11 items) that measures limitations of mental, social, and physical functioning; a",
      "domain": "Communication & Hearing",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/201001]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/201001"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
