  "translations": {
    "en": {
      "baby_low_aspirin_regular": "Do you currently take any of the following pain-relieving medications regularly (at least once a week)?  \"Baby\" or low-dose aspirin.",
      "baby_low_aspirin_tablets_quantity": "Total tablets per week?  \"Baby\" or low-dose aspirin.",
      "aspirin_regular": "Do you currently take any of the following pain-relieving medications regularly (at least once a week)?  Aspirin or aspirin-containing product (Bayer�, Bufferin�, Excedrin�).",
      "aspirin_tablets_quantity": "Total tablets per week?  Aspirin or aspirin-containing product (Bayer�, Bufferin�, Excedrin�).",
      "ibuprofen_regular": "Do you currently take any of the following pain-relieving medications regularly (at least once a week)?  Ibuprofen (Advil�, Motrin�).",
      "ibuprofen_tablets_quantity": "Total tablets per week?  Ibuprofen (Advil�, Motrin�).",
      "naproxen_ketoprofen_regular": "Do you currently take any of the following pain-relieving medications regularly (at least once a week)?  Naproxen, ketoprofen or other non-steroidal (Aleve�, Feldene�, Indocin�, Naprosyn�, Orudis�, Relafen�).",
      "naproxen_ketoprofen_tablets_quantity": "Total tablets per week?  Naproxen, ketoprofen or other non-steroidal (Aleve�, Feldene�, Indocin�, Naprosyn�, Orudis�, Relafen�).",
      "cox2_inhibitor_regular": "Do you currently take any of the following pain-relieving medications regularly (at least once a week)? Cox-2 inhibitor (Celebrex�, Vioxx�).",
      "cox2_inhibitor_tablets_quantity": "Total tablets per week? Cox-2 inhibitor (Celebrex�, Vioxx�).",
      "acetaminophen_regular": "Do you currently take any of the following pain-relieving medications regularly (at least once a week)? Acetaminophen (Aspirin-free Excedrin�, Tylenol�, Tempra�).",
      "acetaminophen_tablets_quantity": "Total tablets per week? Acetaminophen (Aspirin-free Excedrin�, Tylenol�, Tempra�).",
      "baby_low_aspirin_stop": "Did you stop the regular use of any of the following medications during the past 3 years? \"Baby\" or low-dose aspirin.",
      "baby_low_aspirin_stop_reason": "Why did you stop regular use? \"Baby\" or low-dose aspirin.",
      "aspirin_stop": "Did you stop the regular use of any of the following medications during the past 3 years? Aspirin or aspirin-containing product.",
      "aspirin_stop_reason": "Why did you stop regular use? Aspirin or aspirin-containing product.",
      "ibuprofen_stop": "Did you stop the regular use of any of the following medications during the past 3 years?  Ibuprofen.",
      "ibuprofen_stop_reason": "Why did you stop regular use?  Ibuprofen.",
      "naproxen_ketoprofen_stop": "Did you stop the regular use of any of the following medications during the past 3 years?  Naproxen, ketoprofen, or other non-steroidal.",
      "naproxen_ketoprofen_stop_reason": "Why did you stop regular use?  Naproxen, ketoprofen, or other non-steroidal.",
      "cox2_inhibitor_stop": "Did you stop the regular use of any of the following medications during the past 3 years?  Cox-2 inhibitor.",
      "cox2_inhibitor_stop_reason": "Why did you stop regular use?  Cox-2 inhibitor.",
      "acetaminophen_stop": "Did you stop the regular use of any of the following medications during the past 3 years?  Acetaminophen.",
      "acetaminophen_stop_reason": "Why did you stop regular use?  Acetaminophen.",
      "statin": "In the past 3 years, please indicate if you have taken either of the following types of medications.  Statin medications such as lovastatin (Mevacor�), atorvastatin (Lipitor�), rosuvastain (Crestor�), pravastatin (Pravachol�), simvastatin (Zocor�), fluvastatin (Lescol�)",
      "steroid_pill": "In the past 3 years, please indicate if you have taken either of the following types of medications.  Steroid medication in pill form such as prednisone, dexamethasone (Decadron�), solumedrol (Medrol dose-pack�)",
      "opt_1": "1-2 per week",
      "opt_2": "3-4 per week",
      "opt_3": "5-6 per week",
      "opt_4": "7-8 per week",
      "opt_5": "9-10 per week",
      "opt_6": "11-12 per week",
      "opt_7": "13-14 per week",
      "opt_8": "15-21 per week",
      "opt_9": "22-28 per week",
      "opt_10": "29+ per week",
      "grp2_opt_1": "Never took regularly or did not stop use",
      "grp2_opt_2": "Yes, I stopped regular use",
      "grp3_opt_1": "Condition improved",
      "grp3_opt_2": "Don't work",
      "grp3_opt_3": "I had side effects",
      "grp3_opt_4": "I heard about side effects",
      "grp3_opt_5": "Drug no longer available",
      "grp3_opt_6": "Other",
      "grp4_opt_1": "Yes, regularly (daily for at least 2 months)",
      "grp4_opt_2": "Yes, but not regularly",
      "grp4_opt_3": "No"
    }
  }
