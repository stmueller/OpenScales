{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "MOS 12-Item Short Form Health Survey",
      "code": "MOS-SF-12",
      "abbreviation": "MOS-SF-12",
      "description": "12-item subset of the RAND 36-Item Health Survey (MOS-SFHF-36) covering physical functioning, role limitations (physical and emotional), bodily pain, general health, vitality, social functioning, and mental health. Items drawn from the public domain RAND-36. Mixed response formats. Higher scores indicate better health.",
      "citation": "Ware, J. E., Kosinski, M., & Keller, S. D. (1996). A 12-Item Short-Form Health Survey: Construction of scales and preliminary tests of reliability and validity. Medical Care, 34(3), 220–233. Items from: Hays, R. D., Sherbourne, C. D., & Mazel, R. M. (1993). The RAND 36-Item Health Survey 1.0. Health Economics, 2(3), 217–227.",
      "license": "Public Domain",
      "version": "1.0",
      "url": "https://www.rand.org/health/surveys/mos/36-item-short-form.html",
      "domain": "Health",
      "license_explanation": "Items are a subset of the RAND 36-Item Health Survey which is in the public domain. RAND explicitly states these instruments are available for use without permission or fee. This is NOT the proprietary SF-12v2 from QualityMetric.",
      "license_url": "https://www.rand.org/health-care/surveys_tools.html"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 6,
      "min": 1,
      "max": 6,
      "labels": [
        "sf_freq1",
        "sf_freq2",
        "sf_freq3",
        "sf_freq4",
        "sf_freq5",
        "sf_freq6"
      ],
      "question_head": "sf_freq_head"
    },
    "dimensions": [
      {
        "id": "physical_functioning",
        "name": "Physical Functioning",
        "abbreviation": "PF",
        "description": "Items 2, 3 (activity limitations). Higher = less limited."
      },
      {
        "id": "role_physical",
        "name": "Role Limitations (Physical)",
        "abbreviation": "RP",
        "description": "Items 4, 5 (role limitations due to physical health). Higher = less limited."
      },
      {
        "id": "bodily_pain",
        "name": "Bodily Pain",
        "abbreviation": "BP",
        "description": "Item 9. Higher = less pain."
      },
      {
        "id": "general_health",
        "name": "General Health",
        "abbreviation": "GH",
        "description": "Item 1. Higher = better health."
      },
      {
        "id": "vitality",
        "name": "Vitality",
        "abbreviation": "VT",
        "description": "Item 11 (energy). Higher = more vitality."
      },
      {
        "id": "social_functioning",
        "name": "Social Functioning",
        "abbreviation": "SF",
        "description": "Item 8. Higher = better social functioning."
      },
      {
        "id": "role_emotional",
        "name": "Role Limitations (Emotional)",
        "abbreviation": "RE",
        "description": "Items 6, 7 (role limitations due to emotional problems). Higher = less limited."
      },
      {
        "id": "mental_health",
        "name": "Mental Health",
        "abbreviation": "MH",
        "description": "Items 10, 12 (calm/peaceful, downhearted). Higher = better mental health."
      }
    ],
