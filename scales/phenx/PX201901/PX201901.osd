{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Phonological Awareness",
      "code": "PX201901",
      "abbreviation": "PX201901",
      "description": "Syllable Repetition Task (SRT) is an 18-item task to assess the ability to repeat nonwords. Administrator presses the down arrow key to progress through the test stimuli in PowerPoint. Each test item (nonword) will appear on the PC screen in the order on the SRT Scoring Form. The screen should not b",
      "domain": "Health",
      "citation": "Dollaghan, C., & Campbell, T. F. (1998). Nonword repetition and child language impairment. Journal of Speech, Language, and Hearing Research, 41, 1136–1146. Shriberg, L. D., Lohmeier, H. L., Campbell, T. F., Dollaghan, C. A., Green, J. R., & Moore, C. A. (2009). A nonword repetition task for speakers with misarticulations: The Syllable Repetition Task (SRT). Journal of Speech, Language, and Hearing Research, 52, 1189–1212. Shriberg, L. D., Lohmeier, H. L., Strand, E. A., & Jakielski, K. J. (2012). Encoding, memory, and transcoding deficits in childhood apraxia of speech. Clinical Linguistics & Phonetics, 26, 445–482. [PhenX: https://www.phenxtoolkit.org/protocols/view/201901]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/201901"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
