  "translations": {
    "en": {
      "lk_opt_1": "Never",
      "lk_opt_2": "Rarely",
      "lk_opt_3": "Sometimes",
      "lk_opt_4": "Often",
      "instr_0121501": "Please answer the questions below, rating yourself on each of the criteria shown.  As you answer each question, select the option that best describes how you have felt and conducted yourself over the past 6 months.",
      "sec_part_a_title": "Part A",
      "trouble_wrapping_up_project": "How often do you have trouble wrapping up the final details of a project, once the challenging parts have been done?",
      "difficulty_getting_orgainized": "How often do you have difficulty getting things in order when you have to do a task that requires organization?",
      "difficulty_remembering_appointments": "How often do you have problems remembering appointments or obligations?",
      "procrastinate_tasks": "When you have a task that requires a lot of thought, how often do you avoid or delay getting started?",
      "fidget_while_sitting": "How often do you fidget or squirm with your hands or feet when you have to sit down for a long time?",
      "feel_driven_by_motor": "How often do you feel overly active and compelled to do things, like you were driven by a motor?",
      "sec_part_b_title": "Part B",
      "careless_mistakes_tedious_tasks": "How often do you make careless mistakes when you have to work on a boring or difficult project?",
      "difficulty_paying_attention_repetitive_tasks": "How often do you have difficulty keeping your attention when you are doing boring or repetitive work?",
      "difficulty_concentrating_on_conversations": "How often do you have difficulty concentrating on what people say to you, even when they are speaking to you directly?",
      "misplace_items_home_work": "How often do you misplace or have difficulty finding things at home or at work?",
      "frequency_distracted_by_noise": "How often are you distracted by activity or noise around you?",
      "frequency_leave_seat_at_meetings": "How often do you leave your seat in meetings or other situations in which you are expected to remain seated?",
      "frequency_restless": "How often do you feel restless or fidgety?",
      "difficulty_unwinding": "How often do you have difficulty unwinding and relaxing when you have time to yourself?",
      "frequency_talk_too_much": "How often do you find yourself talking too much when you are in social situations?",
      "finish_others_sentences": "When you're in a conversation, how often do you find yourself finishing the sentences of the people you are talking to, before they can finish them themselves?",
      "difficulty_waiting_turn": "How often do you have difficulty waiting your turn in situations when turn taking is required?",
      "interrupt_others_when_busy": "How often do you interrupt others when they are busy?",
      "sec_scoring_title": "Scoring",
      "scoring_0121501": "Part A.If four or more marks appear in the darkly shaded boxes within Part A, then the patient has symptoms highly consistent with ADHD in adults, and further investigation is warranted.Part B.The frequency scores on Part B provide additional cues and can serve as further probes into the patient's symptoms. Pay particular attention to marks appearing in the darkly shaded boxes. No total score or diagnostic likelihood is utilized for the twelve questions."
    }
  }
}
