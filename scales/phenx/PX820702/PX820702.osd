  "translations": {
    "en": {
      "info_820702": "International Pediatric Stroke Study (IPSS) Recovery and Recurrence QuestionnaireNote: If child has died since discharge from hospital, please go directly to item 8 (skip items 1-7)",
      "functionalityafterstrokepediatrics_recovered_completely": "Has your child recovered completely from the stroke?",
      "functionalityafterstrokepediatrics_recovered_completely_opt_1": "Yes",
      "functionalityafterstrokepediatrics_recovered_completely_opt_2": "No - If no, please answer the following questions:",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensation": "1A.  Does your child have any problems with strength, coordination, or sensation including vision or hearing, as a result of the stroke? If yes, please choose which of the following are present in your child:",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensation_opt_1": "Developmental delay",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensation_opt_2": "Abnormal tone",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensation_opt_3": "Weakness on one side of the body",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensation_opt_4": "Weakness on one side of the face",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensation_opt_5": "Unsteadiness on one side of the body",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensation_opt_6": "Difficulty with hearing",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensation_opt_7": "Difficulty with speaking clearly (problem with pronouncing words)",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensation_opt_8": "Difficulty with drinking, chewing, or swallowing",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensation_opt_9": "Loss of sensation on one side of the body",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensation_opt_10": "Other sensory problems",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensation_opt_11": "Difficulty with vision",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensation_opt_12": "Other problems with strength or coordination; Describe below in Q 1Aa",
      "functionalityafterstrokepediatrics_problems_strength_coordination_sensationdescribe": "1Aa.  Does your child have any problems with strength, coordination, or sensation including vision or hearing, as a result of the stroke? Please describe",
      "functionalityafterstrokepediatrics_affect_daily_activities": "1a1. Does the problem affect your child's day-to-day activities?",
      "functionalityafterstrokepediatrics_leftside_face_body": "Left side face or body",
      "functionalityafterstrokepediatrics_rightside_face_body": "Right side face or body",
      "functionalityafterstrokepediatrics_difficulty_expressing_verbally": "1B.  Does your child have difficulty expressing him/herself verbally? (Exclude dysarthrias or pronunciation problems)",
      "functionalityafterstrokepediatrics_difficulty_expressing_verbally_describe": "1B1.  Does your child have difficulty expressing him/herself verbally? (Exclude dysarthrias or pronunciation problems): Please describe",
      "functionalityafterstrokepediatrics_difficulty_understanding": "1C.  Does your child have difficulty understanding what is said to her/him?",
      "functionalityafterstrokepediatrics_difficulty_understanding_describe": "1C1.  Does your child have difficulty understanding what is said to her/him? Please describe",
      "functionalityafterstrokepediatrics_difficulty_thinking_behavior": "1D.  Does your child have difficulty with his/her thinking or behavior?",
      "functionalityafterstrokepediatrics_difficulty_thinking_behavior_describe": "1D1.  Does your child have difficulty with his/her thinking or behavior? Please describe",
      "functionalityafterstrokepediatrics_help_dailyactivities_compared_otherchildren": "Does your child need extra help with day-to-day activities compared with other children of the same age?",
      "functionalityafterstrokepediatrics_stroke_tia_bloodclot": "Since the first stroke, has your child had another Stroke or Transient Ischemic Attack (TIA) or blood clot in any other blood vessel (e.g. in the leg, lung, heart, other location) ?",
      "functionalityafterstrokepediatrics_stroke_tia_bloodclottype": "3a.  If yes, which type?",
      "functionalityafterstrokepediatrics_stroke_tia_bloodclottype_opt_2": "Stroke in a brain artery (usual form of ?stroke?)",
      "functionalityafterstrokepediatrics_stroke_tia_bloodclottype_opt_3": "Stroke in a brain vein (?sinus thrombosis?)",
      "functionalityafterstrokepediatrics_stroke_tia_bloodclottype_opt_4": "Other blood clot: describe below",
      "functionalityafterstrokepediatrics_stroke_tia_bloodclottype_other": "3a1.  If yes, which type? Other blood clot: (State location of blood clot :_______________ )",
