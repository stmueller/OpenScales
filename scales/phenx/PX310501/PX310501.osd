  "translations": {
    "en": {
      "lk_opt_1": "Not at all confident",
      "lk_opt_2": "A little confident",
      "lk_opt_3": "Somewhat confident",
      "lk_opt_4": "Very confident",
      "clinician_confidence_genetic_results_encounter_patient_after": "Have you had a medical encounter with your patient since you received the genomic result?",
      "clinician_confidence_genetic_results_encounter_patient_after_opt_1": "Yes",
      "clinician_confidence_genetic_results_encounter_patient_after_opt_2": "No",
      "clinician_confidence_genetic_results_knowledge_condition": "Before looking at resources other than those provided with the result, when you received the genomic result, how confident did you feel in your knowledge about the condition caused by this gene?",
      "clinician_confidence_ability_explain_genetic_results": "Before looking at resources other than those provided with the result, when you received the genomic result, how confident did you feel in your ability to explain the result to your patient?",
      "clinician_confidence_answer_questions_genetic_results": "Before looking at resources other than those provided with the result, when you received the genomic result, how confident did you feel in your ability to answer your patient",
      "clinician_confidence_manage_patient_care_genetic_results": "Before looking at resources other than those provided with the result, when you received the genomic result, how confident did you feel in your ability to personally manage the patient",
      "clinician_confidence_genetic_results_informative": "To what extent do you agree with the following statements about receiving this unsolicited genomic result? The result was informative",
      "clinician_confidence_genetic_results_informative_opt_1": "Strongly disagree",
      "clinician_confidence_genetic_results_informative_opt_2": "Somewhat disagree",
      "clinician_confidence_genetic_results_informative_opt_3": "Somewhat agree",
      "clinician_confidence_genetic_results_informative_opt_4": "Strongly agree",
      "clinician_confidence_genetic_results_confusing": "To what extent do you agree with the following statements about receiving this unsolicited genomic result? The result was confusing",
      "clinician_confidence_genetic_results_confusing_opt_1": "Strongly disagree",
      "clinician_confidence_genetic_results_confusing_opt_2": "Somewhat disagree",
      "clinician_confidence_genetic_results_confusing_opt_3": "Somewhat agree",
      "clinician_confidence_genetic_results_confusing_opt_4": "Strongly agree",
      "clinician_confidence_genetic_results_helpful": "To what extent do you agree with the following statements about receiving this unsolicited genomic result? The result was helpful",
      "clinician_confidence_genetic_results_helpful_opt_1": "Strongly disagree",
      "clinician_confidence_genetic_results_helpful_opt_2": "Somewhat disagree",
      "clinician_confidence_genetic_results_helpful_opt_3": "Somewhat agree",
      "clinician_confidence_genetic_results_helpful_opt_4": "Strongly agree",
      "clinician_confidence_genetic_results_useless": "To what extent do you agree with the following statements about receiving this unsolicited genomic result? The result was useless",
      "clinician_confidence_genetic_results_useless_opt_1": "Strongly disagree",
      "clinician_confidence_genetic_results_useless_opt_2": "Somewhat disagree",
      "clinician_confidence_genetic_results_useless_opt_3": "Somewhat agree",
      "clinician_confidence_genetic_results_useless_opt_4": "Strongly agree",
      "likert_1": "Strongly disagree",
      "likert_2": "Somewhat disagree",
      "likert_3": "Somewhat agree",
      "likert_4": "Strongly agree"
