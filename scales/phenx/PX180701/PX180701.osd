{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Perceived Social Support Conflict",
      "code": "PX180701",
      "abbreviation": "PX180701",
      "description": "The respondent completes three groups of questions about interactions with spouse/partner, family, and friends. Each group includes social support questions about how much they care about you, how much they understand the way you feel, if you can rely on them, and if you can talk to them about your ",
      "domain": "Mental Health",
      "citation": "Schuster, T. L., Kessler, R. C., & Aseltine, R. H., Jr. (1990). Supportive interactions, negative interactions, and depressed mood. American Journal of Community Psychology, 18(3), 423-438. Whalen, H. R., & Lachman, M. E. (2000). Social support and strain from partner, family and friends: Costs and benefits for men and women in adulthood. Journal of Social and Personal Relationships, 17(1), 5-30. [PhenX: https://www.phenxtoolkit.org/protocols/view/180701]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/180701"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
