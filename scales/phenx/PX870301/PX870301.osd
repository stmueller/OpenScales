    },
    "_scoring_notes": "ScoringEach item is assigned a value ranging from 1 to 6. A total stigma scale score is computed by adding the values for each of the 11 items. Subscale scores are computed by adding the values for the items that constitute each subscale: Social Exclusion, Internalized Stigma, Disclosure Concerns, and Expected Discrimination. Higher scores indicate greater levels of stigma."
  },
  "translations": {
    "en": {
      "internal_stigma_sickle_cell_disease_social_exclusion_instructions": "Measure of Sickle Cell Stigma (MoSCS) ScaleInstructionsThe statements below are based on some experiences of people with sickle cell disease (SCD). It is not a test, and there are no \"right\" or \"wrong\" responses. Therefore, please respond to each statement as openly and honestly as you possibly can. There is no need to worry about the privacy of your answers or how they might compare to the answers of others, because we are interested in overall views, not individual points of view. Choose a number using the scale below that best indicates your agreement with each statement and write it in the corresponding space. These numbers mean the following:1 = completely false2 = mostly false3 = somewhat false (more false than true)4 = somewhat true (more true than false)5 = mostly true6 = completely true",
      "sec_social_exclusion_title": "Social Exclusion",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_backed_away": "People have physically backed away from me because I have SCD.",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_backed_away_opt_1": "completely false",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_backed_away_opt_2": "mostly false",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_backed_away_opt_3": "somewhat false (more false than true)",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_backed_away_opt_4": "somewhat true (more true than false)",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_backed_away_opt_5": "mostly true",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_backed_away_opt_6": "completely true",
      "internal_stigma_sickle_cell_disease_social_exclusion_telling_others_mistake": "As a rule, telling others that I have SCD has been a mistake.",
      "internal_stigma_sickle_cell_disease_social_exclusion_telling_others_mistake_opt_1": "completely false",
      "internal_stigma_sickle_cell_disease_social_exclusion_telling_others_mistake_opt_2": "mostly false",
      "internal_stigma_sickle_cell_disease_social_exclusion_telling_others_mistake_opt_3": "somewhat false (more false than true)",
      "internal_stigma_sickle_cell_disease_social_exclusion_telling_others_mistake_opt_4": "somewhat true (more true than false)",
      "internal_stigma_sickle_cell_disease_social_exclusion_telling_others_mistake_opt_5": "mostly true",
      "internal_stigma_sickle_cell_disease_social_exclusion_telling_others_mistake_opt_6": "completely true",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_afraid": "People seem to be afraid of me because I have SCD.",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_afraid_opt_1": "completely false",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_afraid_opt_2": "mostly false",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_afraid_opt_3": "somewhat false (more false than true)",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_afraid_opt_4": "somewhat true (more true than false)",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_afraid_opt_5": "mostly true",
      "internal_stigma_sickle_cell_disease_social_exclusion_people_afraid_opt_6": "completely true",
      "sec_internalized_stigma_title": "Internalized Stigma",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_guilty": "I feel guilty because I have SCD.",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_guilty_opt_1": "completely false",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_guilty_opt_2": "mostly false",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_guilty_opt_3": "somewhat false (more false than true)",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_guilty_opt_4": "somewhat true (more true than false)",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_guilty_opt_5": "mostly true",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_guilty_opt_6": "completely true",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_bad_person": "Having SCD makes me feel that I am a bad person.",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_bad_person_opt_1": "completely false",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_bad_person_opt_2": "mostly false",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_bad_person_opt_3": "somewhat false (more false than true)",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_bad_person_opt_4": "somewhat true (more true than false)",
      "internal_stigma_sickle_cell_disease_internalized_stigma_feel_bad_person_opt_5": "mostly true",
