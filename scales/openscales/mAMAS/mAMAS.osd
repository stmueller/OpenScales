        "dimension": "total"
      }
    ],
    "scoring": {
      "total": {
        "description": "Total score: sum of all 9 items (range 9-45). Higher scores indicate greater math anxiety.",
        "method": "sum_coded",
        "items": [
          "mamas1",
          "mamas2",
          "mamas3",
          "mamas4",
          "mamas5",
          "mamas6",
          "mamas7",
          "mamas8",
          "mamas9"
        ]
      }
    }
  },
  "translations": {
    "en": {
      "likert_1": "Low anxiety",
      "likert_2": "Some anxiety",
      "likert_3": "Moderate anxiety",
      "likert_4": "Quite a lot of anxiety",
      "likert_5": "High anxiety",
      "question_head": "Please give each sentence a score in terms of how anxious you would feel during each situation.",
      "mamas1": "Having to complete a worksheet by yourself.",
      "mamas2": "Thinking about a maths test the day before you take it.",
      "mamas3": "Watching the teacher work out a maths problem on the board.",
      "mamas4": "Taking a maths test.",
      "mamas5": "Being given maths homework with lots of difficult problems that is due the next day.",
      "mamas6": "Listening to the teacher talk for a long time in maths.",
      "mamas7": "Listening to another pupil explain a maths problem.",
      "mamas8": "Being given a surprise maths test.",
      "mamas9": "Starting to learn a new maths topic.",
      "debrief": "Thank you for completing the Modified Abbreviated Math Anxiety Scale."
    }
  }
}
