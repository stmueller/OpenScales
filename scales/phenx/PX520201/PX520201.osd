  "translations": {
    "en": {
      "instructions_520201": "Please rate the extent to which these words describe your feelings the very first time you smoked a cigarette.",
      "first_cigarette_pleasurable_sensations": "While smoking your very first cigarette, did you have pleasurable sensations?",
      "first_cigarette_unpleasant_sensations": "While smoking your very first cigarette, did you have unpleasant sensations?",
      "info_520201": "Please answer yes or no to the following questions about the very first cigarette you smoked",
      "first_cigarette_buzz_or_rush": "While smoking your very first cigarette, did you have a pleasurable buzz or rush?",
      "first_cigarette_feel_relaxed": "While smoking your very first cigarette, did you feel relaxed?",
      "first_cigarette_feel_dizzy": "While smoking your very first cigarette, did you feel dizzy?",
      "first_cigarette_nausea": "While smoking your very first cigarette, did you have nausea?",
      "first_cigarette_cough": "While smoking your very first cigarette, did you cough?",
      "first_cigarette_alone": "Were you alone the first time you experimented with cigarettes?",
      "opt_1": "None",
      "opt_2": "2",
      "opt_3": "3",
      "opt_4": "Intense"
    }
  }
