  "translations": {
    "en": {
      "MigrainePediatrics_Missed_Full_SchoolDays_Past3Months": "How many full school days of school were missed in the last 3 months due to headaches?",
      "MigrainePediatrics_Missed_Partial_SchoolDays_Past3Months": "How many partial days of school were missed in the last 3 months due to headaches (do not include full days counted in the first question)?",
      "MigrainePediatrics_Function_LessThan_Ability_Past3Months": "How many days in the last 3 months did you function at less than half your ability in school because of a headache (do not include days counted in the first two questions)?",
      "MigrainePediatrics_Days_Unable_Function_AtHome": "How many days were you not able to do things at home (i.e., chores, homework, etc.) due to a headache?",
      "MigrainePediatrics_Days_Unable_Participate_InActivities": "How many days did you not participate in other activities due to headaches (i.e., play, go out, sports, etc.)?",
      "MigrainePediatrics_Function_LessThan_Ability_InActivities": "How many days did you participate in these activities, but functioned at less than half your ability (do not include days counted in the 5th question)?",
      "MigrainePediatrics_Headache_Frequency": "Headache Frequency",
      "MigrainePediatrics_Headache_Severity": "Headache Severity"
    }
  }
