{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Clinical Impairment Assessment 3.0",
      "code": "CIA",
      "abbreviation": "CIA 3.0",
      "description": "16-item measure of psychosocial impairment due to eating disorder features over the past 28 days. Three subscales: Personal Impairment (6 items, range 0–18), Social Impairment (5 items, range 0–15), and Cognitive Impairment (5 items, range 0–15). Global score ranges from 0 to 48; a score of 16 or above may indicate clinical significance.",
      "citation": "Bohn, K., Doll, H. A., Cooper, Z., O'Connor, M., Palmer, R. L., & Fairburn, C. G. (2008). The measurement of impairment due to eating disorder psychopathology. Behaviour Research and Therapy, 46(10), 1105-1110. https://doi.org/10.1016/j.brat.2008.06.012",
      "license": "CC BY 3.0",
      "version": "1.0",
      "url": "https://doi.org/10.1016/j.brat.2008.06.012",
      "domain": "Mental Health"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 4,
      "min": 0,
      "max": 3,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4"
      ],
      "question_head": "question_head"
    },
    "parameters": {
      "shuffle_questions": {
        "type": "boolean",
        "default": 1,
        "description": "Randomize item presentation order within the scale."
      }
    },
    "dimensions": [
      {
        "id": "personal_impairment",
        "name": "Personal Impairment",
        "description": "Distress related to self-evaluation (6 items, range 0–18)."
      },
      {
        "id": "social_impairment",
        "name": "Social Impairment",
        "description": "Interference with social functioning (5 items, range 0–15)."
      },
      {
        "id": "cognitive_impairment",
        "name": "Cognitive Impairment",
        "description": "Interference with cognitive functioning (5 items, range 0–15)."
      }
    ],
