  "translations": {
    "en": {
      "medical_cannabis_provider_patient_communication_cancer_discuss": "Have you discussed using cannabis for your cancer symptoms with a healthcare provider?",
      "medical_cannabis_provider_patient_communication_provider_type_talk": "What type of healthcare provider have you talked to about cannabis? Select all that apply.",
      "medical_cannabis_provider_patient_communication_provider_recommend": "At any time since your cancer diagnosis, has your doctor or another healthcare provider recommended that you use cannabis?",
      "medical_cannabis_provider_patient_communication_provider_type_recommend": "What type of healthcare provider recommended you use cannabis? Select all that apply.",
      "opt_1": "Yes",
      "opt_2": "No",
