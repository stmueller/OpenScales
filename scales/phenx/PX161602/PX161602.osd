    "scale_info": {
      "name": "Personal History of Allergies, Infectious Diseases, and Immunizations - Adult",
      "code": "PX161602",
      "abbreviation": "PX161602",
      "description": "This protocol is a self- or proxy-administered personal health record from the American Health Information Management Association (AHIMA). The respondent is asked to provide details on the following categories: Medical History, Infectious Diseases, Immunizations, Allergies/Drug Sensitivities, Health",
      "domain": "Health",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/161602]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/161602"
    },
