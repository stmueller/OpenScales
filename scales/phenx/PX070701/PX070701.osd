  "translations": {
    "en": {
      "lung_cancer_worry": "How often do you worry about getting lung cancer? Would you say:",
      "lung_cancer_worry_opt_1": "Rarely or never",
      "lung_cancer_worry_opt_2": "Sometimes",
      "lung_cancer_worry_opt_3": "Often",
      "lung_cancer_worry_opt_4": "All of the time",
      "lung_cancer_risk_assessment": "Compared to others your age who currently smoke, what do you think are your chances of being diagnosed with lung cancer during your lifetime? Are you:",
      "lung_cancer_risk_assessment_opt_1": "at much less risk",
      "lung_cancer_risk_assessment_opt_2": "at less risk",
      "lung_cancer_risk_assessment_opt_3": "at the same risk",
      "lung_cancer_risk_assessment_opt_4": "at higher risk",
      "lung_cancer_risk_assessment_opt_5": "at much higher risk"
    }
  }
}