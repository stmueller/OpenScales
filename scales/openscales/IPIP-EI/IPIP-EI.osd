  "translations": {
    "en": {
      "likert_1": "Very Inaccurate",
      "likert_2": "Moderately Inaccurate",
      "likert_3": "Neither Accurate Nor Inaccurate",
      "likert_4": "Moderately Accurate",
      "likert_5": "Very Accurate",
      "question_head": "<h3>How Accurately Can You Describe Yourself?</h3>\nDescribe yourself as you generally are now, not as you wish to be in the future. Describe yourself as you honestly see yourself, in relation to other people you know of the same sex as you are, and roughly your same age. So that you can describe yourself in an honest manner, your responses will be kept in absolute confidence. Indicate how accurately this statement describes you.",
      "ipip_ei_001": "Am calm even in tense situations.",
      "ipip_ei_002": "Am deeply moved by others' misfortunes.",
      "ipip_ei_003": "Am easily moved to tears.",
      "ipip_ei_004": "Am not easily disturbed by events.",
      "ipip_ei_005": "Am unaffected by the suffering of others.",
      "ipip_ei_006": "Am upset by the misfortunes of strangers.",
      "ipip_ei_007": "Rarely cry during sad movies.",
      "ipip_ei_008": "Remain calm during emergencies.",
      "ipip_ei_009": "Suffer from others' sorrows.",
      "ipip_ei_010": "Would be upset if I saw an injured animal.",
      "ipip_ei_011": "Am concerned about others.",
      "ipip_ei_012": "Believe that criminals should receive help rather than punishment.",
      "ipip_ei_013": "Believe that the poor deserve our sympathy.",
      "ipip_ei_014": "Don't like to get involved in other people's problems.",
      "ipip_ei_015": "Feel little concern for others.",
      "ipip_ei_016": "Feel sympathy for those who are worse off than myself.",
      "ipip_ei_017": "Have little sympathy for the unemployed.",
      "ipip_ei_018": "Have no sympathy for criminals.",
      "ipip_ei_019": "Look down on any weakness.",
      "ipip_ei_020": "Sympathize with the homeless.",
      "ipip_ei_021": "Am not in touch with my feelings.",
      "ipip_ei_022": "Am usually aware of the way that I'm feeling.",
      "ipip_ei_023": "Notice my emotions.",
      "ipip_ei_024": "Often ignore my feelings.",
      "ipip_ei_025": "Often stop to analyze how I'm feeling.",
      "ipip_ei_026": "Pay a lot of attention to my feelings.",
      "ipip_ei_027": "Rarely analyze my emotions.",
      "ipip_ei_028": "Rarely notice my emotional reactions.",
      "ipip_ei_029": "Rarely think about how I feel.",
      "ipip_ei_030": "Think about the causes of my emotions.",
      "ipip_ei_031": "Am strongly influenced by the good moods of others.",
      "ipip_ei_032": "Am unaffected by other people's happiness.",
      "ipip_ei_033": "Dislike being around happy people when I'm feeling sad.",
      "ipip_ei_034": "Dislike children's birthday parties.",
      "ipip_ei_035": "Feel other people's joy.",
      "ipip_ei_036": "Find it hard to stay in a bad mood if the people around me are happy.",
      "ipip_ei_037": "Get caught up in the excitement when others are celebrating.",
      "ipip_ei_038": "Like to watch children open presents.",
      "ipip_ei_039": "Rarely get caught up in the excitement.",
      "ipip_ei_040": "Usually end up laughing if the people around me are laughing.",
      "ipip_ei_041": "Base my goals in life on inspiration, rather than logic.",
      "ipip_ei_042": "Believe emotions give direction to life.",
      "ipip_ei_043": "Believe important decisions should be based on logical reasoning.",
      "ipip_ei_044": "Listen to my brain rather than my heart.",
      "ipip_ei_045": "Listen to my feelings when making important decisions.",
      "ipip_ei_046": "Listen to my heart rather than my brain.",
      "ipip_ei_047": "Make decisions based on facts, not feelings.",
      "ipip_ei_048": "Plan my life based on how I feel.",
      "ipip_ei_049": "Plan my life logically.",
      "ipip_ei_050": "Can't help but look upset when something bad happens.",
      "ipip_ei_051": "Find it difficult showing people that I'm angry with them.",
      "ipip_ei_052": "Keep my feelings to myself, regardless of how scared I am.",
      "ipip_ei_053": "Keep my feelings to myself, regardless of how unhappy I am.",
      "ipip_ei_054": "Rarely show my anger.",
      "ipip_ei_055": "Shout or scream when I'm angry.",
      "ipip_ei_056": "Show my fear.",
      "ipip_ei_057": "Show my sadness.",
      "ipip_ei_058": "Suspect that my facial expressions give me away when I feel sad.",
      "ipip_ei_059": "Wish I could more easily show my negative feelings.",
      "ipip_ei_060": "Express my affection physically.",
      "ipip_ei_061": "Express my happiness in a childlike manner.",
      "ipip_ei_062": "Find it difficult showing people that I care about them.",
      "ipip_ei_063": "Have difficulty showing affection.",
      "ipip_ei_064": "Hug my close friends.",
      "ipip_ei_065": "Keep my happy feelings to myself.",
      "ipip_ei_066": "Laugh out loud if something is funny.",
      "ipip_ei_067": "Show my feelings when I'm happy.",
