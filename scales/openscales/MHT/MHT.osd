  "translations": {
    "en": {
      "likert_1": "Strongly disagree",
      "likert_2": "Disagree",
      "likert_3": "Slightly disagree",
      "likert_4": "Slightly agree",
      "likert_5": "Agree",
      "likert_6": "Strongly agree",
      "question_head": "Please consider each statement carefully and indicate the response with which you most agree. There are no right or wrong answers.",
      "mht1": "Joy is present more than sorrow in my everyday life.",
      "mht2": "I easily become impatient.",
      "mht3": "It's easy for me to revive the joy from pleasant memories.",
      "mht4": "I tend to bounce back quickly after hard times.",
      "mht5": "I often have ideas that are taken further by others.",
      "mht6": "I have a hard time making it through stressful events.",
      "mht7": "Others describe me as a problem solver.",
      "mht8": "I am impulsive: I act first and think second.",
      "mht9": "I can successfully achieve targets which I set for myself.",
      "mht10": "I like to store memories of fun times that I go through so that I can recall them later.",
      "mht11": "It does not take me long to recover from a stressful event.",
      "mht12": "I can make myself feel good by imagining what a happy time that is about to happen will be like.",
      "mht13": "I tend to take a long time to get over set-backs in my life.",
      "mht14": "My general psychological state is good.",
      "mht15": "I am good at work that needs new and original ideas.",
      "mht16": "I become frustrated when something does not happen the way I planned it.",
      "mht17": "I often know what people are thinking and feeling.",
      "mht18": "How do you feel about your life as a whole?",
      "mht18_1": "Very bad",
      "mht18_2": "Bad",
      "mht18_3": "Somewhat bad",
      "mht18_4": "Somewhat good",
      "mht18_5": "Good",
      "mht18_6": "Very good",
      "debrief": "Thank you for completing the Mental Health Test."
    }
  }
