{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Cancer: Personal and Family History",
      "code": "PX070601",
      "abbreviation": "PX070601",
      "description": "This protocol is used to assess if the respondent and his or her biological parents, siblings, and children have had cancer. This protocol also obtains information about vital status, age, type of cancer, age at first diagnosis, and any additional cancer diagnoses.",
      "domain": "Health",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/70601]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/70601"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
