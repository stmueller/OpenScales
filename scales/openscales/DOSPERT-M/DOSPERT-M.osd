{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "DOSPERT Medical Risk Subscale",
      "code": "DOSPERT-M",
      "abbreviation": "DOSPERT+M",
      "description": "6-item medical risk domain extension for the DOSPERT scale. Adds medical scenarios to the five existing DOSPERT content domains. Administered with the same three response modes as DOSPERT: risk-taking likelihood (RT), risk perception (RP), and optionally expected benefits (EB). Designed to be used alongside the base DOSPERT scale. Subscale scores are means of the 6 medical items within each response mode.",
      "citation": "Butler, S., Rosman, A., Seleski, S., Garcia, M., Lee, S., Barnes, J., & Schwartz, A. (2012). A medical risk attitude subscale for DOSPERT. Judgment and Decision Making, 7(2), 189-195.",
      "license": "CC BY 4.0",
      "version": "1.0",
      "url": "https://doi.org/10.1017/S1930297500003028"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "parameters": {
      "show_expected_benefits": {
        "type": "boolean",
        "default": true,
        "description": "Include the Expected Benefits (EB) response mode for each item"
      }
    },
    "likert_options": {
      "points": 7,
      "min": 1,
      "max": 7,
      "labels": [
        "rt_l1",
        "rt_l2",
        "rt_l3",
        "rt_l4",
        "rt_l5",
        "rt_l6",
        "rt_l7"
      ],
      "question_head": "rt_head"
    },
    "randomize_sections": {
      "method": "shuffle",
      "fixed": [
        "sec_intro"
      ]
    },
    "dimensions": [
      {
        "id": "rt_medical",
        "name": "Risk-Taking: Medical"
      },
      {
        "id": "rp_medical",
        "name": "Risk Perception: Medical"
      },
      {
        "id": "eb_medical",
        "name": "Expected Benefits: Medical"
      }
    ],
    "items": [
      {
        "id": "sec_intro",
        "type": "section",
        "text_key": "sec_blank"
      },
      {
        "id": "inst1",
        "type": "inst",
        "text_key": "instructions"
      },
      {
        "id": "sec1",
        "type": "section",
        "text_key": "sec_blank"
      },
      {
        "id": "rt_m1",
        "type": "likert",
        "text_key": "m1",
        "dimension": "rt_medical",
        "question_head": "rt_head"
      },
      {
        "id": "rp_m1",
        "type": "likert",
        "text_key": "m1",
        "dimension": "rp_medical",
        "question_head": "rp_head",
        "likert_labels": [
          "rp_l1",
          "rp_l2",
          "rp_l3",
          "rp_l4",
          "rp_l5",
          "rp_l6",
          "rp_l7"
        ]
      },
      {
        "id": "eb_m1",
        "type": "likert",
        "text_key": "m1",
        "dimension": "eb_medical",
        "question_head": "eb_head",
        "likert_labels": [
          "eb_l1",
          "eb_l2",
          "eb_l3",
          "eb_l4",
          "eb_l5",
          "eb_l6",
          "eb_l7"
        ],
        "visible_when": {
          "parameter": "show_expected_benefits",
          "operator": "equals",
          "value": true
        }
      },
      {
        "id": "sec2",
        "type": "section",
        "text_key": "sec_blank"
      },
