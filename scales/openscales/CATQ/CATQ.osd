  "translations": {
    "en": {
      "likert_1": "Strongly Disagree",
      "likert_2": "Disagree",
      "likert_3": "Somewhat Disagree",
      "likert_4": "Neither Agree nor Disagree",
      "likert_5": "Somewhat Agree",
      "likert_6": "Agree",
      "likert_7": "Strongly Agree",
      "question_head": "Please indicate how much you agree or disagree with each statement.",
      "catq1": "When I am interacting with someone, I deliberately copy their body language or facial expressions.",
      "catq2": "I learn how people use their bodies and faces to interact by watching television or films, or by reading fiction.",
      "catq3": "I have tried to improve my understanding of social skills by watching other people.",
      "catq4": "I will repeat phrases that I have heard others say in the exact same way that I first heard them.",
      "catq5": "I practice my facial expressions and body language to make sure they look natural.",
      "catq6": "I have spent time learning social skills from television shows and films, and try to use these in my interactions.",
      "catq7": "In my own social interactions, I use behaviours that I have learned from watching other people interacting.",
      "catq8": "I have researched the rules of social interactions (for example, by studying psychology or reading books on human behaviour) to improve my own social skills.",
      "catq9": "I have developed a script to follow in social situations (for example, a list of questions or topics of conversation).",
      "catq10": "I monitor my body language or facial expressions so that I appear relaxed.",
      "catq11": "I adjust my body language or facial expressions so that I appear relaxed.",
      "catq12": "I monitor my body language or facial expressions so that I appear interested by the person I am interacting with.",
      "catq13": "I adjust my body language or facial expressions so that I appear interested by the person I am interacting with.",
      "catq14": "I don't feel the need to make eye contact with other people if I don't want to.",
      "catq15": "In social interactions, I do not pay attention to what my face or body are doing.",
      "catq16": "I always think about the impression I make on other people.",
      "catq17": "I am always aware of the impression I make on other people.",
      "catq18": "I rarely feel the need to put on an act in order to get through a social situation.",
      "catq19": "When talking to other people, I feel like the conversation flows naturally.",
      "catq20": "When in social situations, I try to find ways to avoid interacting with others.",
      "catq21": "In social situations, I feel like I'm 'performing' rather than being myself.",
      "catq22": "I have to force myself to interact with people when I am in social situations.",
      "catq23": "In social situations, I feel like I am pretending to be 'normal'.",
      "catq24": "I need the support of other people in order to socialise.",
      "catq25": "I feel free to be myself when I am with other people.",
      "debrief": "Thank you for completing the Camouflaging Autistic Traits Questionnaire."
    }
  }
}
