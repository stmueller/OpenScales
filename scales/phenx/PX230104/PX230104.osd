      "psychopathologyquestionnaire_thinkingweightshape_distraction_opt_4": "16-22 days",
      "psychopathologyquestionnaire_thinkingweightshape_distraction_opt_5": "23-27 days",
      "psychopathologyquestionnaire_thinkingweightshape_distraction_opt_6": "every day",
      "psychopathologyquestionnaire_fear_losingcontrol_eating": "On how many of the past 28 days, have you had a definite fear of losing control over eating?",
      "psychopathologyquestionnaire_fear_losingcontrol_eating_opt_0": "No days",
      "psychopathologyquestionnaire_fear_losingcontrol_eating_opt_1": "1-5 days",
      "psychopathologyquestionnaire_fear_losingcontrol_eating_opt_2": "6-12 days",
      "psychopathologyquestionnaire_fear_losingcontrol_eating_opt_3": "13-15 days",
      "psychopathologyquestionnaire_fear_losingcontrol_eating_opt_4": "16-22 days",
      "psychopathologyquestionnaire_fear_losingcontrol_eating_opt_5": "23-27 days",
      "psychopathologyquestionnaire_fear_losingcontrol_eating_opt_6": "every day",
      "psychopathologyquestionnaire_fear_gainweight": "On how many of the past 28 days, have you had a definite fear that you might gain weight?",
      "psychopathologyquestionnaire_fear_gainweight_opt_0": "No days",
      "psychopathologyquestionnaire_fear_gainweight_opt_1": "1-5 days",
      "psychopathologyquestionnaire_fear_gainweight_opt_2": "6-12 days",
