  "translations": {
    "en": {
      "dietaryrestraint_smellsteak_difficulty_noteating": "When I smell a sizzling steak or juicy piece of meat, I find it very difficult to keep from eating, even if I have just finished a meal.",
      "dietaryrestraint_deliberately_smallhelpings_controlweight": "I deliberately take small helpings as a means of controlling my weight.",
      "dietaryrestraint_feelanxious_findmyselfeating": "When I feel anxious, I find myself eating.",
      "dietaryrestraint_starteating_cantstop": "Sometimes when I start eating, I just can't seem to stop",
      "dietaryrestraint_beingwitheater_makesmehungry": "Being with someone who is eating often makes me hungry enough to eat also.",
      "dietaryrestraint_feelblue_often_overeat": "When I feel blue, I often overeat.",
      "dietaryrestraint_seedelicacy_sohungry_musteat": "When I see a real delicacy, I often get so hungry that I have to eat right away.",
      "dietaryrestraint_often_sohungry_stomach_bottomlesspit": "I get so hungry that my stomach often seems like a bottomless pit.",
      "dietaryrestraint_alwayshungry_hard_stopeating_beforefinishfood": "I am always hungry so it is hard for me to stop eating before I finish the food on my plate.",
      "dietaryrestraint_feellonely_consolemyself_byeating": "When I feel lonely, I console myself by eating.",
      "dietaryrestraint_holdback_atmeals_weightgain": "I consciously hold back at meals in order not to weight gain.",
      "dietaryrestraint_donoteat_somefoods_makemefat": "I do not eat some foods because they make me fat.",
      "dietaryrestraint_alwayshungry_enough_toeat": "I am always hungry enough to eat at any time.",
      "dietaryrestraint_howoften_hungry": "How often do you feel hungry?",
      "dietaryrestraint_howfrequently_avoid_stocking_temptingfoods": "How frequently do you avoid 'stocking up' on tempting foods?",
      "dietaryrestraint_howlikely_consicous_eatless_thanwant": "How likely are you to consciously eat less than you want?",
      "dietaryrestraint_eatingbinges_nothungry": "Do you go on eating binges though you are not hungry?",
      "dietaryrestraint_rating": "On a scale of 1 to 8, where 1 means no restraint in eating (eating whatever you want, whenever you want it) and 8 means total restraint (constantly limiting food intake and never \"giving in\") what number would you give yourself?",
      "dietaryrestraint_rating_opt_1": "1 no restraint in eating (eating whatever you want, whenever you want it)",
      "dietaryrestraint_rating_opt_2": "2",
      "dietaryrestraint_rating_opt_3": "3",
      "dietaryrestraint_rating_opt_4": "4",
      "dietaryrestraint_rating_opt_5": "5",
      "dietaryrestraint_rating_opt_6": "6",
      "dietaryrestraint_rating_opt_7": "7",
      "dietaryrestraint_rating_opt_8": "8 total restraint (constantly limiting food intake and never giving in)",
      "likert_1": "Only at meal times (1)",
      "likert_2": "Sometimes between meals (2)",
      "likert_3": "Often between meals (3)",
      "likert_4": "Almost always (4)"
    }
  }
