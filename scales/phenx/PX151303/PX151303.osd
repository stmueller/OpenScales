  "translations": {
    "en": {
      "lk_opt_1": "Strongly disagree",
      "lk_opt_2": "Somewhat disagree",
      "lk_opt_3": "Neutral",
      "lk_opt_4": "Somewhat agree",
      "lk_opt_5": "Strongly agree",
      "physicalactivity_selfefficacy_physicalactivity_frequency": "In a typical week, how many days do you do physical activity for 60 minutes or more? Mark the answer that is true for you.",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_1": "0",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_2": "1",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_3": "2",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_4": "3",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_5": "4",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_6": "5",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_7": "6+",
      "physicalactivity_selfefficacy_physicalactivity_highfrequency": "How many months have you been doing 60 minutes of physical activity on 5 or more days per week?",
      "physicalactivity_selfefficacy_physicalactivity_highfrequency_opt_1": "Less than 6 months",
      "physicalactivity_selfefficacy_physicalactivity_highfrequency_opt_2": "6 months or more",
      "physicalactivity_selfefficacy_physicalactivity_future": "Do you think you will start doing 60 minutes of physical activity 5 or more days a week in the next 6 months?",
      "physicalactivity_selfefficacy_physicalactivity_future_opt_1": "No I do not intend to in the next six months",
      "physicalactivity_selfefficacy_physicalactivity_future_opt_2": "Yes I intend to in the next six months",
      "physicalactivity_selfefficacy_physicalactivity_future_opt_3": "Yes I intend to in the next 30 days",
      "physicalactivity_selfefficacy_changestrategies_desc": "The following are activities, thoughts, and feelings people use to help them change their physical activity. Think of any similar experiences you may be having or have had in the past month. Then rate HOW OFTEN you do each of the following:",
      "physicalactivity_selfefficacy_changestrategies_1": "I look for information about physical activity or sports.",
      "physicalactivity_selfefficacy_changestrategies_1_opt_1": "Never",
      "physicalactivity_selfefficacy_changestrategies_1_opt_2": "Almost Never",
      "physicalactivity_selfefficacy_changestrategies_1_opt_3": "Sometimes",
      "physicalactivity_selfefficacy_changestrategies_1_opt_4": "Often",
      "physicalactivity_selfefficacy_changestrategies_1_opt_5": "Many times",
      "physicalactivity_selfefficacy_changestrategies_2": "I keep track of how much physical activity I do.",
      "physicalactivity_selfefficacy_changestrategies_2_opt_1": "Never",
      "physicalactivity_selfefficacy_changestrategies_2_opt_2": "Almost Never",
      "physicalactivity_selfefficacy_changestrategies_2_opt_3": "Sometimes",
      "physicalactivity_selfefficacy_changestrategies_2_opt_4": "Often",
      "physicalactivity_selfefficacy_changestrategies_2_opt_5": "Many times",
      "physicalactivity_selfefficacy_changestrategies_3": "I find ways to get around the things that get in the way of being physically active.",
      "physicalactivity_selfefficacy_changestrategies_3_opt_1": "Never",
      "physicalactivity_selfefficacy_changestrategies_3_opt_2": "Almost Never",
      "physicalactivity_selfefficacy_changestrategies_3_opt_3": "Sometimes",
      "physicalactivity_selfefficacy_changestrategies_3_opt_4": "Often",
      "physicalactivity_selfefficacy_changestrategies_3_opt_5": "Many times",
      "physicalactivity_selfefficacy_changestrategies_4": "I think about how my surroundings affect the amount of physical activity I do. (Surroundings are things like having exercise equipment at home or a park nearby.)",
      "physicalactivity_selfefficacy_changestrategies_4_opt_1": "Never",
      "physicalactivity_selfefficacy_changestrategies_4_opt_2": "Almost Never",
      "physicalactivity_selfefficacy_changestrategies_4_opt_3": "Sometimes",
      "physicalactivity_selfefficacy_changestrategies_4_opt_4": "Often",
      "physicalactivity_selfefficacy_changestrategies_4_opt_5": "Many times",
      "physicalactivity_selfefficacy_changestrategies_5": "I put reminders around my home to be physically active.",
      "physicalactivity_selfefficacy_changestrategies_5_opt_1": "Never",
      "physicalactivity_selfefficacy_changestrategies_5_opt_2": "Almost Never",
      "physicalactivity_selfefficacy_changestrategies_5_opt_3": "Sometimes",
      "physicalactivity_selfefficacy_changestrategies_5_opt_4": "Often",
      "physicalactivity_selfefficacy_changestrategies_5_opt_5": "Many times",
      "physicalactivity_selfefficacy_changestrategies_6": "I reward myself for being physically active.",
      "physicalactivity_selfefficacy_changestrategies_6_opt_1": "Never",
      "physicalactivity_selfefficacy_changestrategies_6_opt_2": "Almost Never",
      "physicalactivity_selfefficacy_changestrategies_6_opt_3": "Sometimes",
      "physicalactivity_selfefficacy_changestrategies_6_opt_4": "Often",
      "physicalactivity_selfefficacy_changestrategies_6_opt_5": "Many times",
      "physicalactivity_selfefficacy_changestrategies_7": "I do things to make physical activity more enjoyable.",
      "physicalactivity_selfefficacy_changestrategies_7_opt_1": "Never",
      "physicalactivity_selfefficacy_changestrategies_7_opt_2": "Almost Never",
      "physicalactivity_selfefficacy_changestrategies_7_opt_3": "Sometimes",
      "physicalactivity_selfefficacy_changestrategies_7_opt_4": "Often",
      "physicalactivity_selfefficacy_changestrategies_7_opt_5": "Many times",
      "physicalactivity_selfefficacy_changestrategies_8": "I think about the benefits I will get from being physically active.",
      "physicalactivity_selfefficacy_changestrategies_8_opt_1": "Never",
      "physicalactivity_selfefficacy_changestrategies_8_opt_2": "Almost Never",
      "physicalactivity_selfefficacy_changestrategies_8_opt_3": "Sometimes",
      "physicalactivity_selfefficacy_changestrategies_8_opt_4": "Often",
      "physicalactivity_selfefficacy_changestrategies_8_opt_5": "Many times",
      "physicalactivity_selfefficacy_changestrategies_9": "I try to think more about the benefits of physical activity and less about the hassles of being active.",
      "physicalactivity_selfefficacy_changestrategies_9_opt_1": "Never",
      "physicalactivity_selfefficacy_changestrategies_9_opt_2": "Almost Never",
      "physicalactivity_selfefficacy_changestrategies_9_opt_3": "Sometimes",
      "physicalactivity_selfefficacy_changestrategies_9_opt_4": "Often",
      "physicalactivity_selfefficacy_changestrategies_9_opt_5": "Many times",
      "physicalactivity_selfefficacy_changestrategies_10": "I say positive things to myself about physical activity.",
      "physicalactivity_selfefficacy_changestrategies_10_opt_1": "Never",
      "physicalactivity_selfefficacy_changestrategies_10_opt_2": "Almost Never",
      "physicalactivity_selfefficacy_changestrategies_10_opt_3": "Sometimes",
      "physicalactivity_selfefficacy_changestrategies_10_opt_4": "Often",
      "physicalactivity_selfefficacy_changestrategies_10_opt_5": "Many times",
