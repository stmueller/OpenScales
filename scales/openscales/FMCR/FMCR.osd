{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Functional Meaning of Cash Rewards Scale",
      "code": "FMCR",
      "abbreviation": "FMCR",
      "description": "7-item measure of the functional meaning employees attribute to cash rewards from their supervisor. Two subscales: Controlling Meaning (items 1-3) and Informative Meaning (items 4-7). 7-point Likert scale (1=Strongly Disagree to 7=Strongly Agree).",
      "citation": "Thibault Landry, A., Papachristopoulos, K., Gradito Dubord, M.-A., & Forest, J. (2022). Frontiers in Psychology. [APA PsycTests: https://doi.org/10.1037/t94383-000]",
      "license": "CC BY 4.0",
      "license_url": "https://doi.org/10.3389/fpsyg.2022.821501",
      "version": "1.0",
      "url": "https://doi.org/10.3389/fpsyg.2022.821501",
      "domain": "Work"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-02",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 7,
      "min": 1,
      "max": 7,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5",
        "likert_6",
        "likert_7"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
