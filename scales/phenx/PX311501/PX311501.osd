  "translations": {
    "en": {
      "genetic_test_result": "Did you receive a genetic test result for yourself or your child?",
      "genetic_test_result_opt_1": "Yes",
      "genetic_test_result_opt_2": "No",
      "genetic_test_result_diagnosis": "If so, did the result provide a genetic diagnosis (was there a positive genetic test result)?",
      "genetic_test_result_diagnosis_opt_1": "Yes",
      "genetic_test_result_diagnosis_opt_2": "No",
      "genetic_test_result_shared_biological_family": "Since receiving your/your child's study results, have you shared the information with any biological family members (blood relatives)?",
      "genetic_test_result_shared_biological_family_opt_1": "Yes",
      "genetic_test_result_shared_biological_family_opt_2": "I didn't share this information with anyone",
      "genetic_test_result_shared_biological_family_opt_3": "I haven't shared this information yet, but plan to in the future",
      "genetic_test_result_shared_other_biological_parent": "Since receiving your/your child's study results, have you shared the information with any of the following blood relatives? My child's other biological parent",
      "genetic_test_result_shared_children": "Since receiving your/your child's study results, have you shared the information with any of the following blood relatives? My child(ren)",
      "genetic_test_result_shared_sibling": "Since receiving your/your child's study results, have you shared the information with any of the following blood relatives? My siblings",
      "genetic_test_result_shared_parent": "Since receiving your/your child's study results, have you shared the information with any of the following blood relatives? My parents",
      "genetic_test_result_shared_other_biological_family": "Since receiving your/your child's study results, have you shared the information with any of the following blood relatives? My other biological family members",
      "genetic_test_result_shared_other_biological_family_detail": "Please specify:",
      "genetic_test_result_share_decision": "Thinking about the family members you DID share your genetic test result with, which of the following were important to your decision to share? Check all that apply.",
      "genetic_test_result_share_decision_opt_a": "I felt obligated to share my genetic test result",
      "genetic_test_result_share_decision_opt_b": "I was encouraged by my health care provider",
      "genetic_test_result_share_decision_opt_c": "I made an agreement to tell them before receiving my genetic test result",
      "genetic_test_result_share_decision_opt_d": "I was encouraged by other family members to share the information",
      "genetic_test_result_share_decision_opt_e": "I felt the information could help my family members in making medical decisions",
      "genetic_test_result_share_decision_opt_f": "I was asked about my genetic test result by a family member",
      "genetic_test_result_share_decision_opt_g": "I wanted to know if a family member had symptoms related to my genetic test result",
      "genetic_test_result_share_decision_opt_h": "I needed emotional support from my family member",
      "genetic_test_result_share_decision_opt_i": "I needed advice from my family member in making medical decisions",
      "genetic_test_result_share_decision_opt_j": "I wanted to provide my family member information about their risk",
      "genetic_test_result_share_decision_opt_k": "I wanted to encourage them to get tested",
      "genetic_test_result_share_decision_opt_l": "Other",
      "genetic_test_result_share_decision_specify": "If Other, specify:",
      "opt_1": "Yes",
      "opt_2": "No",
      "opt_3": "N/A"
    }
  }
}
