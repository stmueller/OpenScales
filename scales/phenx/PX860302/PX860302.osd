  "translations": {
    "en": {
      "pain_coping_child_desc_1": "Name _________________ Age (in years) ___________ Sex (circle): Male Female  Grade ________",
      "sec_pain_coping_questionnaire_short_form_title": "Pain Coping Questionnaire - Short Form",
      "pain_coping_child_desc": "Everyone has had a time when they have been hurt or in pain for a few hours or longer. For example, you might have had a headache, a stomach ache, a bad muscle pull, or pain in your joints (elbow, knee), an earache, or, for women, menstrual pain, etc... Below are some things that people might say, do, or think when they are hurt or in pain. We are interested in the things you do when you are in pain for a few hours or days.   Circle one word for each question to show how often you do each thing listed: 1 = never, 2 = hardly ever, 3 = sometimes, 4 = often or 5 = very often.",
      "sec_when_i_am_hurt_or_in_pain_for_a_few_hour_title": "WHEN I AM HURT OR IN PAIN FOR A FEW HOURS OR DAYS, I ...",
      "pain_coping_child_say_mean_things": "Say mean things to people.",
      "pain_coping_child_ask_questions": "Ask a nurse or doctor questions.",
      "pain_coping_child_think_make_better": "Think about what needs to be done to make the pain better.",
      "pain_coping_child_talk": "Talk to someone about how I am feeling.",
      "pain_coping_child_fun": "Do something fun.",
      "pain_coping_child_stand_in_way": "Find out more information.",
      "pain_coping_child_tell": "Tell someone how I feel.",
      "pain_coping_child_forget": "Try to forget the pain.",
      "pain_coping_child_figure_out": "Figure out what I can do about the pain.",
      "pain_coping_child_say_things_okay": "Say to myself, things will be okay.",
      "pain_coping_child_do_active": "Do something active.",
      "pain_coping_child_put_out_mind": "Put the pain out of my mind.",
      "pain_coping_child_mad": "Get mad and throw or hit something.",
      "pain_coping_child_never_stop": "Think that the pain will never stop.",
      "pain_coping_child_not_bad": "Tell myself it's not so bad.",
      "pain_coping_child_worry": "Worry too much about the pain.",
      "likert_1": "Never",
      "likert_2": "Hardly Ever",
      "likert_3": "Sometimes",
      "likert_4": "Often",
      "likert_5": "Very Often"
    }
  }
