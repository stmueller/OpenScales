  "translations": {
    "en": {
      "instr_0121502": "For each item listed below, how does this child compare to other children of the same age? Please select the best rating based on your observations over the past month.Compared to other children, how does this child do the following:",
      "close_attention_to_detail": "Give close attention to detail and avoid careless mistakes",
      "sustain_attention": "Sustain attention on tasks or play activities",
      "listen_when_spoken_to": "Listen when spoken to directly",
      "follow_through_chores": "Follow through on instructions & finish school work/chores",
      "organize_tasks_activities": "Organize tasks and activities",
      "engage_mental_effort": "Engage in tasks that require sustained mental effort",
      "keep_track_of_activity_items": "Keep track of things necessary for activities",
      "ignore_extraneous_stimuli": "Ignore extraneous stimuli",
      "remember_daily_activities": "Remember daily activities",
      "sit_still": "Sit still (control movement of hands/feet or control squirming)",
      "stay_seated": "Stay seated (when required by class rules/social conventions)",
      "modulate_motor_activity": "Modulate motor activity (inhibit inappropriate running/climbing)",
      "play_quietly": "Play quietly (keep noise level reasonable)",
      "settle_down": "Settle down and rest (control constant activity)",
      "control_excess_talking": "Modulate verbal activity (control excess talking)",
      "control_blurting_out": "Reflect on questions (control blurting out answers)",
      "await_turns": "Await turn (stand in line and take turns)",
      "control_interrupting": "Enter into conversation & games (control interrupting/intruding)",
      "likert_1": "far below",
      "likert_2": "below",
      "likert_3": "slightly below",
      "likert_4": "average",
      "likert_5": "slightly above",
      "likert_6": "above",
      "likert_7": "far above"
    }
  }
}
