  "osd_version": "1.0",
  "translations": {
    "en": {
      "sfive1": "I do not meet with friends as often as I would like because of noises they make.",
      "sfive10": "I can experience distress as the result of some noises",
      "sfive11": "I feel trapped if I cannot get away from certain noises.",
      "sfive12": "I feel like I must be a very angry person inside because of the way I react to certain sounds",
      "sfive13": "People should not make certain sounds, even if they do not know about others' sensitivities.",
      "sfive14": "There are places I would like to go but do not, because I am too worried about how the noises will impact me",
      "sfive15": "I can see future where I cannot do everyday things because of my reactions to noises",
      "sfive16": "I react strongly to certain sounds because I can't stand how selfish, thoughtless, or bad-mannered people can be.",
      "sfive17": "I can get so angry at certain noises that I get physically aggressive towards people to make them stop",
      "sfive18": "The way I react to certain sounds makes me wonder whether deep inside I am just a bad person.",
      "sfive19": "I dislike myself in the moments of my reactions to sounds",
      "sfive2": "If I cannot get away from certain noises, I am afraid I might panic or feel like I will explode",
      "sfive20": "My job opportunities are limited because of my reaction to certain sounds.",
      "sfive21": "Certain sounds are just bad manners, and it is not strange to feel intense anger about that.",
      "sfive22": "Sometimes I get so distressed by noises that I use violence to try and make it stop",
      "sfive23": "Some sounds are so unbearable that I will shout at people to make them stop.",
      "sfive24": "I am afraid of doing something aggressive or violent because I cannot tolerate the noise someone is making.",
      "sfive25": "I get angry at other people because of how disrespectful they are with the noises they make",
      "sfive3": "If I cannot avoid certain sounds, I feel helpless.",
      "sfive4": "If people make certain sounds that I cannot bear, I become verbally aggressive",
      "sfive5": "I respect myself less because of my responses to certain sounds.",
      "sfive6": "People should do everything they can to avoid making noises that might bother others",
      "sfive7": "I feel anxious if I cannot avoid listening to certain sounds",
      "sfive8": "The way I react to certain noises makes me feel like I must be an unlikable person deep down",
      "sfive9": "The way I feel/react to certain sounds will eventually isolate me and prevent me from doing everyday things.",
      "sfive_head": "Please read each statement carefully and base your answer on how true they feel to you based on your current thoughts, experiences, and reactions.",
      "sfive_l0": "Not at all true",
      "sfive_l1": "1",
      "sfive_l10": "Completely true",
      "sfive_l2": "2",
      "sfive_l3": "3",
      "sfive_l4": "4",
      "sfive_l5": "5",
      "sfive_l6": "6",
      "sfive_l7": "7",
      "sfive_l8": "8",
      "sfive_l9": "9"
    }
  }
}