  "translations": {
    "en": {
      "knee_pain_either_knee": "During the past 30 days, have you had any pain, aching or stiffness in or around either knee?",
      "knee_pain_either_knee_opt_1": "Yes",
      "knee_pain_either_knee_opt_0": "No",
      "knee_pain_either_knee_opt_8": "Don't know/Refused",
      "knee_pain_right_knee": "During the past 30 days, have you had pain, aching or stiffness in or around your right knee on most days?",
      "knee_pain_left_knee": "During the past 30 days, have you had pain, aching or stiffness in or around your left knee on most days?",
      "opt_1": "Yes",
      "opt_2": "No",
      "opt_3": "Don't know"
    }
