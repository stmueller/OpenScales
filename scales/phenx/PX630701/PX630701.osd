  "definition": {
    "scale_info": {
      "name": "General Well-being",
      "code": "PX630701",
      "abbreviation": "PX630701",
      "description": "The General Well Being Schedule (GWB) is an 18-item, self-administered questionnaire that was developed for the U.S. Health and Nutrition Examination Survey (HANES I). The GWB includes positive and negative questions across six dimensions: positive well-being, self-control, vitality, depression, anx",
      "domain": "Mental Health",
      "citation": "Dupuy, H. J. (1978). Self-representations of general psychological well-being of American adults. Paper presented at American Public Health Association Meeting, Los Angeles, CA.. Poston, W. S. C. II, Olvera, N. E., Yanez C., et al. (1998). Evacuation of the factor structure and psychometric characteristics of the General Well-Being Schedule (GWB) with Mexican American women. Women Health, 27, 51-64. Taylor, J. E., Poston, W. S. C. II, Haddock, C. K., et al. (2003). Psychometric characteristics of the General Well-Being Schedule (GWB) with African-American women. Quality of Life Research, 12, 31-39. [PhenX: https://www.phenxtoolkit.org/protocols/view/630701]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/630701"
    },
