  "translations": {
    "en": {
      "lk_opt_1": "Strongly disagree",
      "lk_opt_2": "Somewhat disagree",
      "lk_opt_3": "Somewhat agree",
      "lk_opt_4": "Strongly agree",
      "sec_please_answer_the_following_questions_on_title": "Please answer the following questions on your beliefs about how the Coronavirus is affecting people of your race/ethnicity.",
      "cyberbullying_race_more_danger": "I believe the country has become more dangerous for people in my racial/ethnic group because of fear of the Coronavirus.",
      "cyberbullying_race_lose_job": "People of my race/ethnicity are more likely to lose their job because of the Coronavirus.",
      "cyberbullying_race_infection": "I worry about people thinking I have the Coronavirus simply because of my race/ethnicity.",
      "cyberbullying_race_social_mass_media_reports": "Most social and mass media reports about the Coronavirus create bias against people of my racial/ethnic group.",
      "cyberbullying_race_infection_more_likely": "People of my race/ethnicity are more likely to get the Coronavirus.",
      "cyberbullying_race_healthcare": "People of my race/ethnicity will not receive Coronavirus healthcare as good as the care received by other groups.",
      "cyberbullying_race_coronavirus": "Due to the Coronavirus I have been cyberbullied because of my race/ethnicity",
      "cyberbullying_race_coronavirus_increase": "Since the Coronavirus I have seen a lot more cyberbullying of people of my race/ethnicity.",
      "cyberbullying_race_negative_social_media_increase": "Negative social media posts against people of my race/ethnicity have increased because of the Coronavirus.",
      "instructions": "Scoring InstructionsEach item on the CRBS is rated on a 4-point scale, from 1 (strongly disagree) to 4 (strongly agree). The CRBS score is the mean of the 9 items."
    }
  }
