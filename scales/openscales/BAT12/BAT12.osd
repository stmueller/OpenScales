        "type": "likert",
        "dimension": "exhaustion"
      },
      {
        "id": "bat5",
        "text_key": "bat5",
        "type": "likert",
        "dimension": "mental_distance"
      },
      {
        "id": "bat6",
        "text_key": "bat6",
        "type": "likert",
        "dimension": "mental_distance"
      },
      {
        "id": "bat7",
        "text_key": "bat7",
        "type": "likert",
        "dimension": "mental_distance"
      },
      {
        "id": "bat8",
