    "scoring": {
      "total": {
        "description": "Total: sum_coded of all 10 items.",
        "method": "sum_coded",
        "items": [
          "normal_drinker",
          "friends_think_you_normal_drinker",
          "ever_attended_alcoholics_anonymous",
          "lost_friends_because_of_drinking",
