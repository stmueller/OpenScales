        "method": "mean_coded",
        "items": [
          "dsq1",
          "dsq2",
          "dsq3",
          "dsq4",
          "dsq5"
        ],
        "description": "Mean of 5 Avoidant items (1-5). Higher scores indicate greater tendency to avoid or delay decision making. Positively associated with depressive symptoms.",
        "item_coding": {
          "dsq1": 1,
          "dsq2": 1,
          "dsq3": 1,
          "dsq4": 1,
          "dsq5": 1
