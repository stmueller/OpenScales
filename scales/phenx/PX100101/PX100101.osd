  "translations": {
    "en": {
      "female_breast_development_stage": "Select the option that is closest to your current breast stage.",
      "female_breast_development_stage_opt_1": "The nipple is raised a little in this stage. The rest of the breast is still flat.",
      "female_breast_development_stage_opt_2": "This is the breast bud stage. In this stage the nipple is raised more than in stage 1. The breast is a small mound. The dark area around the nipple (areola) is larger than in stage 1.",
      "female_breast_development_stage_opt_3": "The areola and the breast are both larger than in stage 2. The areola does not stick out away from the breast.",
      "female_breast_development_stage_opt_4": "The areola and the nipple make up a mound that sticks up above the shape of the breast. (Note: This stage may not happen at all for some teenagers. Some teenagers develop from stage 3 to stage 5 with no stage 4.).",
      "female_breast_development_stage_opt_5": "This is the mature adult stage. The breasts are fully developed. Only the nipple sticks out in this stage. The areola has moved back in the general shape of the breast.",
      "breast_stage1": "breast stage 1 - image",
      "breast_stage2": "breast stage 2 - image",
      "breast_stage3": "breast stage 3 - image",
      "breast_stage4": "breast stage 4 - image",
      "breast_stage5": "breast stage 5 - image",
      "female_pubic_hair_development_stage": "Select the option that is closest to your current pubic hair stage.",
      "female_pubic_hair_development_stage_opt_1": "There is no pubic hair.",
      "female_pubic_hair_development_stage_opt_2": "There is a little long, lightly coloured hair. This hair may be straight or a little curly.",
      "female_pubic_hair_development_stage_opt_3": "The hair is darker in this stage. It is coarser and more curled. It has spread out and thinly covers a bigger area.",
      "female_pubic_hair_development_stage_opt_4": "The hair is now as dark, curly, and coarse as that of an adult woman. However, the area that the hair covers is not as large as that of an adult woman. The hair has not spread out to the legs.",
      "female_pubic_hair_development_stage_opt_5": "The hair is like that of an adult woman. It also covers the same area as that of an adult woman. The hair usually forms a triangular pattern as it spreads out to the legs.",
      "pubic_fem_stage1": "pubic_fem_stage1 - image",
      "pubic_fem_stage2": "pubic_fem_stage2 - image",
      "pubic_fem_stage3": "pubic_fem_stage3 - image",
      "pubic_fem_stage4": "pubic_fem_stage4 - image",
      "pubic_fem_stage5": "pubic_fem_stage5 - image"
    }
  }
}
