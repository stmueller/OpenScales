  "translations": {
    "en": {
      "scd_pain_menstruation_quality_of_life_title": "<div class=\"rich-text-field-label\"><p>Modified version of the Sickle Cell Disease Pain Burden Interview-Youth (SCPBI-Y)</p></div>",
      "scd_pain_menstruation_quality_of_life_desc": "I want you to think about your sickle cell pain experienced 7 days before or during your last menstrual period:",
      "scd_pain_menstruation_quality_of_life_days_during_period": "How many days have you had any sickle cell pain during this menstrual period?",
      "scd_pain_menstruation_quality_of_life_days_during_period_opt_1": "None",
      "scd_pain_menstruation_quality_of_life_days_during_period_opt_2": "A Few",
      "scd_pain_menstruation_quality_of_life_days_during_period_opt_3": "Some",
      "scd_pain_menstruation_quality_of_life_days_during_period_opt_4": "Many",
      "scd_pain_menstruation_quality_of_life_days_during_period_opt_5": "Every",
      "scd_pain_menstruation_quality_of_life_nights_slept_poorly_period": "How many nights have you slept poorly (trouble falling asleep or waking up during sleep) because of sickle cell pain during this menstrual period?",
      "scd_pain_menstruation_quality_of_life_nights_slept_poorly_period_opt_1": "None",
      "scd_pain_menstruation_quality_of_life_nights_slept_poorly_period_opt_2": "A Few",
      "scd_pain_menstruation_quality_of_life_nights_slept_poorly_period_opt_3": "Some",
      "scd_pain_menstruation_quality_of_life_nights_slept_poorly_period_opt_4": "Many",
      "scd_pain_menstruation_quality_of_life_nights_slept_poorly_period_opt_5": "Every",
      "scd_pain_menstruation_quality_of_life_days_trouble_care_self_period": "How many days have you had trouble taking care of yourself (dressing, going to the bathroom, showering) because of sickle cell pain during this menstrual period?",
      "scd_pain_menstruation_quality_of_life_days_trouble_care_self_period_opt_1": "None",
      "scd_pain_menstruation_quality_of_life_days_trouble_care_self_period_opt_2": "A Few",
      "scd_pain_menstruation_quality_of_life_days_trouble_care_self_period_opt_3": "Some",
      "scd_pain_menstruation_quality_of_life_days_trouble_care_self_period_opt_4": "Many",
      "scd_pain_menstruation_quality_of_life_days_trouble_care_self_period_opt_5": "Every",
      "scd_pain_menstruation_quality_of_life_days_missed_school_work_period": "How many days have you missed from school/work because of sickle cell pain during this menstrual period?",
      "scd_pain_menstruation_quality_of_life_days_missed_school_work_period_opt_1": "None",
      "scd_pain_menstruation_quality_of_life_days_missed_school_work_period_opt_2": "A Few",
      "scd_pain_menstruation_quality_of_life_days_missed_school_work_period_opt_3": "Some",
      "scd_pain_menstruation_quality_of_life_days_missed_school_work_period_opt_4": "Many",
      "scd_pain_menstruation_quality_of_life_days_missed_school_work_period_opt_5": "Every",
      "scd_pain_menstruation_quality_of_life_days_left_school_work_period": "How many days have you left school/work early because of sickle cell pain during this menstrual period?",
      "scd_pain_menstruation_quality_of_life_days_left_school_work_period_opt_1": "None",
      "scd_pain_menstruation_quality_of_life_days_left_school_work_period_opt_2": "A Few",
      "scd_pain_menstruation_quality_of_life_days_left_school_work_period_opt_3": "Some",
      "scd_pain_menstruation_quality_of_life_days_left_school_work_period_opt_4": "Many",
      "scd_pain_menstruation_quality_of_life_days_left_school_work_period_opt_5": "Every",
      "scd_pain_menstruation_quality_of_life_days_unable_do_things_enjoy_period": "How many days have you been unable to do things you enjoy because of sickle cell pain during this menstrual period?",
      "scd_pain_menstruation_quality_of_life_days_unable_do_things_enjoy_period_opt_1": "None",
      "scd_pain_menstruation_quality_of_life_days_unable_do_things_enjoy_period_opt_2": "A Few",
