    "scale_info": {
      "name": "Injection Drug Use",
      "code": "PX161101",
      "abbreviation": "PX161101",
      "description": "This protocol includes seven self-administered questions from the National Health and Nutrition Examination Survey (NHANES). Respondents answer questions regarding the use of a needle to inject drugs not prescribed by a doctor.",
      "domain": "Health",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/161101]",
