{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "MOS Social Support Survey",
      "code": "MOS-SOCIAL",
      "abbreviation": "MOS-Social",
      "description": "20-item multidimensional measure of perceived social support developed for the Medical Outcomes Study. Item 1 is a structural measure (number of close friends and close relatives). Items 2–20 rate the perceived availability of four types of functional support on a 5-point frequency scale (1=None of the time to 5=All of the time). Subscale scores are transformed to a 0–100 metric: Score = ((mean_of_items − 1) / 4) × 100. Higher scores indicate greater perceived social support.",
      "citation": "Sherbourne, C.D., & Stewart, A.L. (1991). The MOS Social Support Survey. Social Science & Medicine, 32(6), 705–714. https://doi.org/10.1016/0277-9536(91)90150-B",
      "license": "Public Domain",
      "version": "1.0",
      "url": "https://www.rand.org/health-care/surveys_tools/mos/social-support.html",
      "domain": "Social",
      "license_explanation": "RAND Corporation places their health survey instruments in the public domain. RAND explicitly states these instruments are available for use without permission or fee.",
      "license_url": "https://www.rand.org/health-care/surveys_tools/mos/social-support-survey.html"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "mossocial_r1",
        "mossocial_r2",
        "mossocial_r3",
        "mossocial_r4",
        "mossocial_r5"
      ],
      "question_head": "mossocial_question_head"
    },
    "dimensions": [
      {
        "id": "emotional_info",
        "name": "Emotional/Informational Support",
        "abbreviation": "EIS",
        "description": "Perceived availability of emotional support (being listened to, confided in, understood) and informational support (advice, guidance). Items: mossocial3, mossocial4, mossocial5, mossocial9, mossocial10, mossocial14, mossocial15, mossocial19.",
        "enabled_param": null
      },
      {
        "id": "tangible",
        "name": "Tangible Support",
        "abbreviation": "TS",
        "description": "Perceived availability of material aid and behavioral assistance (help when confined to bed, transportation, meals, household tasks). Items: mossocial6, mossocial11, mossocial12, mossocial17.",
        "enabled_param": null
      },
      {
        "id": "affectionate",
        "name": "Affectionate Support",
        "abbreviation": "AS",
        "description": "Perceived availability of love, affection, and emotional closeness. Items: mossocial7, mossocial13, mossocial16.",
        "enabled_param": null
      },
      {
        "id": "positive_interaction",
        "name": "Positive Social Interaction",
        "abbreviation": "PSI",
        "description": "Perceived availability of others with whom to have fun and relax. Items: mossocial7, mossocial19, mossocial20.",
        "enabled_param": null
      },
      {
        "id": "overall",
        "name": "Overall Social Support",
        "abbreviation": "OSS",
        "description": "Overall perceived social support across all 19 functional support items (mossocial2–mossocial20). Higher scores indicate greater perceived support.",
        "enabled_param": null
      }
    ],
