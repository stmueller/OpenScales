  "translations": {
    "en": {
      "likert_1": "Very Inaccurate",
      "likert_2": "Moderately Inaccurate",
      "likert_3": "Neither Accurate Nor Inaccurate",
      "likert_4": "Moderately Accurate",
      "likert_5": "Very Accurate",
      "question_head": "<h3>How Accurately Can You Describe Yourself?</h3>\nDescribe yourself as you generally are now, not as you wish to be in the future. Describe yourself as you honestly see yourself, in relation to other people you know of the same sex as you are, and roughly your same age. So that you can describe yourself in an honest manner, your responses will be kept in absolute confidence. Indicate how accurately this statement describes you.",
      "ipip_depression_001": "Could not get going.",
      "ipip_depression_002": "Did not feel like eating, even though I should have been hungry.",
      "ipip_depression_003": "Enjoyed life.",
      "ipip_depression_004": "Felt depressed.",
      "ipip_depression_005": "Felt fearful.",
      "ipip_depression_006": "Felt happy.",
      "ipip_depression_007": "Felt hopeful about the future.",
      "ipip_depression_008": "Felt lonely.",
      "ipip_depression_009": "Felt sad.",
      "ipip_depression_010": "Felt that everything I did was an effort.",
      "ipip_depression_011": "Felt that I could not shake off the blues, even with help from my family or friends.",
      "ipip_depression_012": "Felt that people disliked me.",
      "ipip_depression_013": "Had a poor appetite.",
      "ipip_depression_014": "Had crying spells.",
      "ipip_depression_015": "Had restless sleep.",
      "ipip_depression_016": "Had thoughts about death.",
      "ipip_depression_017": "Had trouble keeping my mind on what I was doing.",
      "ipip_depression_018": "Talked less than usual.",
      "ipip_depression_019": "Thought about killing myself.",
      "ipip_depression_020": "Thought my life had been a failure.",
      "ipip_depression_021": "Was bothered by things that usually don't bother me.",
      "ipip_depression_022": "Was down in the dumps.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
