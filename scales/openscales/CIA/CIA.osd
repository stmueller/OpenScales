  "translations": {
    "en": {
      "likert_1": "not at all",
      "likert_2": "a little",
      "likert_3": "quite a bit",
      "likert_4": "a lot",
      "question_head": "Over the <b>past 28 days</b>, to what extent have your eating habits, exercising, or your feelings about your eating, shape or weight ...",
      "cia1": "made it difficult to concentrate?",
      "cia2": "made you feel critical of yourself?",
      "cia3": "stopped you going out with others?",
      "cia4": "affected your work performance (if applicable)?",
      "cia5": "made you forgetful?",
      "cia6": "affected your ability to make everyday decisions?",
      "cia7": "interfered with meals with family or friends?",
      "cia8": "made you upset?",
      "cia9": "made you feel ashamed of yourself?",
      "cia10": "made it difficult to eat out with others?",
      "cia11": "made you feel guilty?",
      "cia12": "interfered with you doing things you used to enjoy?",
      "cia13": "made you absent-minded?",
      "cia14": "made you feel a failure?",
      "cia15": "interfered with your relationship with others?",
      "cia16": "made you worry?",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
