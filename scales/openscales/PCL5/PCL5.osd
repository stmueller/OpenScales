      },
      {
        "id": "cognition",
        "name": "Negative Alterations in Cognition and Mood (Criterion D)"
      },
      {
        "id": "arousal",
        "name": "Alterations in Arousal and Reactivity (Criterion E)"
      },
      {
        "id": "total",
        "name": "Total PTSD Severity"
      }
    ],
