  "translations": {
    "en": {
      "info_540601": "Each item of this questionnaire is a statement with which a person may either agree or disagree. For each item, indicate how much you agree or disagree with what the item says. Please respond to all the items; do not leave any blank. Choose only one response to each statement. Please be as accurate and honest as you can be. Respond to each item as if it were the only item. That is, don't worry about being \"consistent\" in your responses.",
      "rarely_experience_fear": "Even if something bad is about to happen to me, I rarely experience fear or nervousness.",
      "rarely_experience_fear_opt_1": "Strongly Agree",
      "rarely_experience_fear_opt_2": "Agree",
      "rarely_experience_fear_opt_3": "Disagree",
      "rarely_experience_fear_opt_4": "Strongly Disagree",
      "get_things_i_want": "I go out of my way to get things I want.",
      "get_things_i_want_opt_1": "Strongly Agree",
      "get_things_i_want_opt_2": "Agree",
      "get_things_i_want_opt_3": "Disagree",
      "get_things_i_want_opt_4": "Strongly Disagree",
      "doing_well_at_something": "When I'm doing well at something, I love to keep at it.",
      "doing_well_at_something_opt_1": "Strongly Agree",
      "doing_well_at_something_opt_2": "Agree",
      "doing_well_at_something_opt_3": "Disagree",
      "doing_well_at_something_opt_4": "Strongly Disagree",
      "willing_to_try_something_new": "I'm always willing to try something new if I think it will be fun.",
      "willing_to_try_something_new_opt_1": "Strongly Agree",
      "willing_to_try_something_new_opt_2": "Agree",
      "willing_to_try_something_new_opt_3": "Disagree",
      "willing_to_try_something_new_opt_4": "Strongly Disagree",
      "get_something_i_want_energized": "When I get something I want, I feel excited and energized.",
      "get_something_i_want_energized_opt_1": "Strongly Agree",
      "get_something_i_want_energized_opt_2": "Agree",
      "get_something_i_want_energized_opt_3": "Disagree",
      "get_something_i_want_energized_opt_4": "Strongly Disagree",
      "criticism_or_scolding_hurts_me": "Criticism or scolding hurts me quite a bit.",
      "criticism_or_scolding_hurts_me_opt_1": "Strongly Agree",
      "criticism_or_scolding_hurts_me_opt_2": "Agree",
      "criticism_or_scolding_hurts_me_opt_3": "Disagree",
      "criticism_or_scolding_hurts_me_opt_4": "Strongly Disagree",
      "go_allout": "When I want something, I usually go all-out to get it.",
      "go_allout_opt_1": "Strongly Agree",
      "go_allout_opt_2": "Agree",
      "go_allout_opt_3": "Disagree",
      "go_allout_opt_4": "Strongly Disagree",
      "do_because_might_be_fun": "I will often do things for no other reason than that they might be fun.",
      "do_because_might_be_fun_opt_1": "Strongly Agree",
      "do_because_might_be_fun_opt_2": "Agree",
      "do_because_might_be_fun_opt_3": "Disagree",
      "do_because_might_be_fun_opt_4": "Strongly Disagree",
      "move_on_it_right_away": "If I see a chance to get something I want, I move on it right away.",
      "move_on_it_right_away_opt_1": "Strongly Agree",
      "move_on_it_right_away_opt_2": "Agree",
      "move_on_it_right_away_opt_3": "Disagree",
      "move_on_it_right_away_opt_4": "Strongly Disagree",
      "worried_when_somebody_is_angry": "I feel pretty worried or upset when I think or know somebody is angry at me.",
      "worried_when_somebody_is_angry_opt_1": "Strongly Agree",
      "worried_when_somebody_is_angry_opt_2": "Agree",
      "worried_when_somebody_is_angry_opt_3": "Disagree",
      "worried_when_somebody_is_angry_opt_4": "Strongly Disagree",
      "get_excited_right_away": "When I see an opportunity for something I like, I get excited right away.",
      "get_excited_right_away_opt_1": "Strongly Agree",
      "get_excited_right_away_opt_2": "Agree",
      "get_excited_right_away_opt_3": "Disagree",
      "get_excited_right_away_opt_4": "Strongly Disagree",
      "act_spur_of_moment": "I often act on the spur of the moment.",
      "act_spur_of_moment_opt_1": "Strongly Agree",
      "act_spur_of_moment_opt_2": "Agree",
      "act_spur_of_moment_opt_3": "Disagree",
      "act_spur_of_moment_opt_4": "Strongly Disagree",
      "worked_up_over_unpleasant_things": "If I think something unpleasant is going to happen, I usually get pretty 'worked up'.",
      "worked_up_over_unpleasant_things_opt_1": "Strongly Agree",
      "worked_up_over_unpleasant_things_opt_2": "Agree",
      "worked_up_over_unpleasant_things_opt_3": "Disagree",
      "worked_up_over_unpleasant_things_opt_4": "Strongly Disagree",
      "good_things_affect_me_strongly": "When good things happen to me, it affects me strongly.",
      "good_things_affect_me_strongly_opt_1": "Strongly Agree",
      "good_things_affect_me_strongly_opt_2": "Agree",
      "good_things_affect_me_strongly_opt_3": "Disagree",
      "good_things_affect_me_strongly_opt_4": "Strongly Disagree",
      "worried_when_done_poorly": "I feel worried when I think I have done poorly at something important.",
      "worried_when_done_poorly_opt_1": "Strongly Agree",
      "worried_when_done_poorly_opt_2": "Agree",
      "worried_when_done_poorly_opt_3": "Disagree",
      "worried_when_done_poorly_opt_4": "Strongly Disagree",
      "crave_excitement": "I crave excitement and new sensations.",
      "crave_excitement_opt_1": "Strongly Agree",
      "crave_excitement_opt_2": "Agree",
      "crave_excitement_opt_3": "Disagree",
      "crave_excitement_opt_4": "Strongly Disagree",
      "no_holds_barred_approach": "When I go after something, I use a 'no holds barred' approach.",
      "no_holds_barred_approach_opt_1": "Strongly Agree",
      "no_holds_barred_approach_opt_2": "Agree",
      "no_holds_barred_approach_opt_3": "Disagree",
      "no_holds_barred_approach_opt_4": "Strongly Disagree",
      "few_fears_compared_to_friends": "I have very few fears compared to my friends.",
      "few_fears_compared_to_friends_opt_1": "Strongly Agree",
      "few_fears_compared_to_friends_opt_2": "Agree",
      "few_fears_compared_to_friends_opt_3": "Disagree",
      "few_fears_compared_to_friends_opt_4": "Strongly Disagree",
      "excite_me_to_win_contest": "It would excite me to win a contest.",
      "excite_me_to_win_contest_opt_1": "Strongly Agree",
      "excite_me_to_win_contest_opt_2": "Agree",
      "excite_me_to_win_contest_opt_3": "Disagree",
      "excite_me_to_win_contest_opt_4": "Strongly Disagree",
      "worry_about_making_mistakes": "I worry about making mistakes.",
      "worry_about_making_mistakes_opt_1": "Strongly Agree",
      "worry_about_making_mistakes_opt_2": "Agree",
      "worry_about_making_mistakes_opt_3": "Disagree",
      "worry_about_making_mistakes_opt_4": "Strongly Disagree",
      "scoring_540601": "ScoringItems 1 and 18 are reverse-scored.Add up the scores associated with each answer response to obtain scores for the individual subscales listed below.1= strongly agree2= agree3= disagree4= strongly disagreeBAS Drive: 2, 7, 9, 17BAS Fun Seeking: 4, 8, 12, 16BAS Reward Responsiveness: 3, 5, 11, 14, 19BIS: 1, 6, 10, 13, 15, 18, 20"
    }
  }
}
