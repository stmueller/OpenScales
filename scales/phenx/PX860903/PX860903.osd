  "definition": {
    "scale_info": {
      "name": "Physical Mobility - Hospitalized Individuals",
      "code": "PX860903",
      "abbreviation": "PX860903",
      "description": "The Youth Acute Pain Functional Ability Questionnaire (YAPFAQ) is a 12-item self-administered questionnaire, with items prompting responses on a five-point rating scale (from \"Not Difficult\" to \"Extremely Difficult\") regarding how difficult a specified task is for a hospitalized patient. This protoc",
      "domain": "Health",
      "citation": "Bernier, K. M., Strobel, M., & Lucas, R. (2018). Assessing the Effect of an Educational Intervention on Nurses and Patient Care Assistants Comprehension and documentation of functional ability in pediatric patients with sickle cell disease. Journal of Pediatric Nursing, 41, 117-122. Rabbitts, J. A., Aaron, R. V., Zempsky, W. T., & Palermo, T. M. (2017). Validation of the Youth Acute Pain Functional Ability Questionnaire in children and adolescents undergoing inpatient surgery. Journal of Pain, 18(10), 1209-1215. [PhenX: https://www.phenxtoolkit.org/protocols/view/860903]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/860903"
    },
