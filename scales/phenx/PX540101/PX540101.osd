  "translations": {
    "en": {
      "get_beer_wine_liquor": "If you wanted to get some beer, wine, or hard liquor (for example, vodka, whiskey, or gin), how easy would it be for you to get some?",
      "get_beer_wine_liquor_opt_1": "Very hard",
      "get_beer_wine_liquor_opt_2": "Sort of hard",
      "get_beer_wine_liquor_opt_3": "Sort of easy",
      "get_beer_wine_liquor_opt_4": "Very easy",
      "get_cigarettes": "If you wanted to get some cigarettes, how easy would it be for you to get some?",
      "get_cigarettes_opt_1": "Very hard",
      "get_cigarettes_opt_2": "Sort of hard",
      "get_cigarettes_opt_3": "Sort of easy",
      "get_cigarettes_opt_4": "Very easy",
      "kid_smoked_marijuana_get_caught": "If a kid smoked marijuana in your neighborhood, would he or she be caught by the police?",
      "kid_smoked_marijuana_get_caught_opt_4": "NO!",
      "kid_smoked_marijuana_get_caught_opt_3": "no",
      "kid_smoked_marijuana_get_caught_opt_2": "yes",
      "kid_smoked_marijuana_get_caught_opt_1": "YES!",
      "get_cocaine_lsd_amphetamines": "If you wanted to get a drug like cocaine, LSD, or amphetamines, how easy would it be for you to get some?",
      "get_cocaine_lsd_amphetamines_opt_1": "Very hard",
      "get_cocaine_lsd_amphetamines_opt_2": "Sort of hard",
      "get_cocaine_lsd_amphetamines_opt_3": "Sort of easy",
      "get_cocaine_lsd_amphetamines_opt_4": "Very easy",
      "kid_drank_get_caught": "If a kid drank some beer, wine, or hard liquor (for example, vodka, whiskey, or gin) in your neighborhood, would he or she be caught by the police?",
      "kid_drank_get_caught_opt_4": "NO!",
      "kid_drank_get_caught_opt_3": "no",
      "kid_drank_get_caught_opt_2": "yes",
      "kid_drank_get_caught_opt_1": "YES!",
      "get_handgun": "If you wanted to get a handgun, how easy would it be for you to get one?",
      "get_handgun_opt_1": "Very hard",
      "get_handgun_opt_2": "Sort of hard",
      "get_handgun_opt_3": "Sort of easy",
      "get_handgun_opt_4": "Very easy",
      "kid_carried_handgun_get_caught": "If a kid carried a handgun in your neighborhood would he or she be caught by the police?",
      "kid_carried_handgun_get_caught_opt_4": "NO!",
      "kid_carried_handgun_get_caught_opt_3": "no",
      "kid_carried_handgun_get_caught_opt_2": "yes",
      "kid_carried_handgun_get_caught_opt_1": "YES!",
      "marijuana_how_easy_for_you": "If you wanted to get some marijuana, how easy would it be for you to get some?",
      "marijuana_how_easy_for_you_opt_1": "Very hard",
      "marijuana_how_easy_for_you_opt_2": "Sort of hard",
      "marijuana_how_easy_for_you_opt_3": "Sort of easy",
      "marijuana_how_easy_for_you_opt_4": "Very easy",
      "kid_smoked_cigarette_get_caught": "If a kid smoked a cigarette in your neighborhood would he or she be caught by the police?",
      "kid_smoked_cigarette_get_caught_opt_4": "NO!",
      "kid_smoked_cigarette_get_caught_opt_3": "no",
      "kid_smoked_cigarette_get_caught_opt_2": "yes",
      "kid_smoked_cigarette_get_caught_opt_1": "YES!",
      "adults_attitude_kid_using_marijuana": "How wrong would most adults (over 21) in your neighborhood think it is for kids your age: to use marijuana?",
      "adults_attitude_kid_using_marijuana_opt_1": "Very wrong",
      "adults_attitude_kid_using_marijuana_opt_2": "Wrong",
      "adults_attitude_kid_using_marijuana_opt_3": "A little bit wrong",
      "adults_attitude_kid_using_marijuana_opt_4": "Not wrong at all",
      "adults_attitude_kid_using_alcohol": "How wrong would most adults (over 21) in your neighborhood think it is for kids your age: to drink alcohol?",
