  "translations": {
    "en": {
      "wchs_inst": "Please read the following statements, and indicate your level of agreement with each one using the slider (1 = Strongly disagree, 100 = Strongly agree).",
      "vas_0": "Strongly disagree",
      "vas_25": "Somewhat disagree",
      "vas_50": "Neither agree nor disagree",
      "vas_75": "Somewhat agree",
      "vas_100": "Strongly agree",
      "wchs1": "I could be left emotionally scarred by something I read.",
      "wchs2": "I could be traumatized without ever being touched, just through someone's hurtful words.",
      "wchs3": "Reading a book can be emotionally damaging, depending on who is reading it.",
      "wchs4": "A person might develop posttraumatic stress disorder or at least some of its symptoms from something they read.",
      "wchs5": "I should be careful about what I say, as it could permanently damage someone's emotional health.",
      "wchs6": "Vulnerable people should not be exposed to certain kinds of speech, as this might harm them.",
      "wchs7": "Even if I try to think about them in a different way, hurtful words could be damaging nonetheless.",
      "wchs8": "Exposing someone to a triggering idea can seriously damage their mental health.",
      "wchs9": "There is great power in the words we choose, either to heal others or to permanently harm them.",
      "wchs10": "Even a simple phrase can be emotionally traumatizing for someone vulnerable.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}