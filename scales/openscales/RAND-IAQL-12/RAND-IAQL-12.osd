  "translations": {
    "en": {
      "iaql12_inst": "The following statements are about how asthma affects the quality of your life. For each statement, please mark the one box below that comes closest to the way asthma has affected your life.",
      "iaql_head_a": "In the past 4 weeks, <b>because of my asthma</b>…",
      "iaql_head_b": "In the past 4 weeks…",
      "iaql_r0": "Not at all",
      "iaql_r1": "A little bit",
      "iaql_r2": "Somewhat",
      "iaql_r3": "Quite a bit",
      "iaql_r4": "Very much",
      "iaql12_1": "I felt frustrated that I have to do things differently than people who don't have asthma.",
      "iaql12_2": "Everyday activities were a struggle.",
      "iaql12_3": "I had to do a lot of planning to make sure I always had an inhaler ready.",
      "iaql12_4": "Asthma placed stress on my relationships with family, friends, significant others, or co-workers.",
      "iaql12_5": "I felt like I missed out on doing things with others because of my asthma.",
      "iaql12_6": "I had to worry about asthma triggers.",
      "iaql12_7": "My asthma was on my mind.",
      "iaql12_8": "I felt that asthma was controlling my life.",
      "iaql12_9": "I felt like I couldn't enjoy life because of my asthma.",
      "iaql12_10": "I worried about the long-term effects of asthma on my health.",
      "iaql12_11": "I felt frustrated that I couldn't make plans in advance because of my asthma.",
      "iaql12_12": "It was hard to get a good night's sleep because of my asthma.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}