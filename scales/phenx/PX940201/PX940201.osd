    "scale_info": {
      "name": "Vulnerability and Exposure to COVID-19",
      "code": "PX940201",
      "abbreviation": "PX940201",
      "description": "The COVID-19 Experiences (COVEX) questionnaire was developed by investigators from the Division of Child and Adolescent Psychiatry at Columbia University/New York State Psychiatric Institute for use in ongoing and new research studies and by affiliated clinical settings to document the experiences o",
      "domain": "Health",
      "citation": "COVID-19 Experiences (COVEX). As implemented in: PhenX Toolkit. Vulnerability and Exposure to COVID-19. https://www.phenxtoolkit.org/protocols/view/940201",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/940201"
    },
