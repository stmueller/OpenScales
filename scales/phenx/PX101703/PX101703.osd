{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Sexual Risk Behavior - Male",
      "code": "PX101703",
      "abbreviation": "PX101703",
      "description": "The purpose of this measure is to quantify sexual risk behavior in women or men. The measure quantifies both same-sex and opposite-sex interactions.",
      "domain": "Education",
      "citation": "Chaturvedi, A. K., Graubard, B. I., Broutian, T., Pickard, R. K., Tong, Z. Y., Xiao, W., Kahle, L., Gillison, M. L. (2015). NHANES 2009-2012 Findings: Association of Sexual Behaviors with Higher Prevalence of Oral Oncogenic Human Papillomavirus Infections in U.S. Men. Cancer Res, 75(12): 2468-2477. Liu, G., Hariri, S., Bradley, H., Gottlieb, S. L., Leichliter, J. S., Markowitz, L. E. (2015). Trends and Patterns of Sexual Behaviors Among Adolescents and Adults Aged 14 to 59 Years, United States. Sexually Transmitted Diseases, 42(1): 20-26. Mirzaei, M., Ahmadi, K., Saadat, S.-H., & Ramezani, M. A. (2016). Instruments of high risk sexual behavior assessment: A systematic review. Materia Socio-Medica, 28(1), 46-50. [PhenX: https://www.phenxtoolkit.org/protocols/view/101703]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/101703"
    },
    "implementation": {
