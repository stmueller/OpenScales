  "translations": {
    "en": {
      "pxt160802_sick_today": "Is the child sick today?",
      "pxt160802_sick_today_opt_1": "Yes",
      "pxt160802_sick_today_opt_2": "No",
      "pxt160802_sick_today_opt_3": "Don't Know",
      "pxt160802_allergies": "Does the child have allergies to medications, food, or any vaccine?",
      "pxt160802_allergies_opt_1": "Yes",
      "pxt160802_allergies_opt_2": "No",
      "pxt160802_allergies_opt_3": "Don't Know",
      "vaccine_reaction": "Has the child had a serious reaction to a vaccine in the past?",
      "vaccine_reaction_opt_1": "Yes",
      "vaccine_reaction_opt_2": "No",
      "vaccine_reaction_opt_3": "Don't Know",
      "seizure_brain_problem": "Has the child had a seizure or a brain problem?",
      "seizure_brain_problem_opt_1": "Yes",
      "seizure_brain_problem_opt_2": "No",
      "seizure_brain_problem_opt_3": "Don't Know",
      "pxt160802_immune_system_problem": "Does the child have cancer, leukemia, AIDS, or any other immune system problem?",
      "pxt160802_immune_system_problem_opt_1": "Yes",
      "pxt160802_immune_system_problem_opt_2": "No",
      "pxt160802_immune_system_problem_opt_3": "Don't Know",
      "pxt160802_steroids_anticancerdrugs_radiation": "Has the child take cortisone, prednisone, other steroids, or anticancer drugs or had x-ray treatments in the past 3 months?",
      "pxt160802_steroids_anticancerdrugs_radiation_opt_1": "Yes",
      "pxt160802_steroids_anticancerdrugs_radiation_opt_2": "No",
      "pxt160802_steroids_anticancerdrugs_radiation_opt_3": "Don't Know",
      "transfusion_immuneglobulin": "Has the child received a transfusion of blood or blood products or been given a medicine called immune (gamma) globulin in the past year?",
      "transfusion_immuneglobulin_opt_1": "Yes",
      "transfusion_immuneglobulin_opt_2": "No",
      "transfusion_immuneglobulin_opt_3": "Don't Know",
      "pxt160802_pregnant": "Is the child/teen pregnant, or is there a chance she could become pregnant during the next month?",
      "pxt160802_pregnant_opt_1": "Yes",
      "pxt160802_pregnant_opt_2": "No",
      "pxt160802_pregnant_opt_3": "Don't Know",
      "vaccination": "Has the child received vaccinations in the past 4 weeks?",
      "vaccination_opt_1": "Yes",
      "vaccination_opt_2": "No",
      "vaccination_opt_3": "Don't Know"
    }
  }
