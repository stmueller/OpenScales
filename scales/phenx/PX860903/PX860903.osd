  "translations": {
    "en": {
      "lk_opt_1": "Not Difficult",
      "lk_opt_2": "A Little Difficult",
      "lk_opt_3": "Somewhat Difficult",
      "lk_opt_4": "Very Difficult",
      "lk_opt_5": "Extremely Difficult",
      "yapfaq_intro_text": "When people are in the hospital they sometimes are too sick or uncomfortable to do all of their normal activities. We want you to think about how difficult it would be to do these things today-not whether or not you like to do these things, or whether you did them today.",
      "sec_today_how_difficult_are_these_things_for_title": "Today how difficult are these things for you to do?",
      "take_bath_shower": "Take a bath or shower?",
      "change_hospital_gown_clothes": "Put on or change your hospital gown or clothes?",
      "wash_body": "Wash your body?",
      "get_up_bed": "Get up from the bed?",
      "walk_around_room": "Walk around in the room?",
      "wash_shampoo_hair": "Wash or shampoo your hair?",
      "go_outside_room": "Go outside your room?",
      "up_without_need_rest": "Be up without needing to rest?",
      "change_pants": "Put on or change pants?",
      "homework_schoolwork": "Do homework or schoolwork?",
      "turn_roll_over_bed": "Turn over or roll over in bed?",
      "change_shirt": "Put on or change your shirt?"
    }
