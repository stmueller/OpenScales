    "scale_info": {
      "name": "Exposure at Work and in Daily Life",
      "code": "PX060401",
      "abbreviation": "PX060401",
      "description": "The respondent is asked to complete a table of questions about exposures at work or during daily life. If the respondent answers \"yes\" to any of the exposures the number of years exposed to the substance is also requested.",
      "domain": "Health",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/60401]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
