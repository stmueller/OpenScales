      "want_to_use_heroin_opt_6": "6",
      "want_to_use_heroin_opt_7": "STRONGLY AGREE",
      "heroin_would_not_satisfying": "Using heroin would not be very satisfying now.",
      "heroin_would_not_satisfying_opt_1": "STRONGLY DISAGREE",
      "heroin_would_not_satisfying_opt_2": "2",
