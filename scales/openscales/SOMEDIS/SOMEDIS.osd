    "scoring": {
      "cognitive_behavioral": {
        "method": "sum_coded",
        "items": [
          "somedis1",
          "somedis2",
          "somedis4",
          "somedis5"
        ],
        "description": "Cognitive Behavioral Symptoms (items 1, 2, 4, 5; range 0–16). Cutoff >8.",
        "item_coding": {
          "somedis1": 1,
          "somedis2": 1,
          "somedis4": 1,
