      "qolie89_supp3": "Yes, some",
      "qolie89_supp4": "Yes, a little",
      "qolie89_supp5": "No, not at all",
      "qolie89_iso_head": "During the <b>past 4 weeks</b>...",
      "qolie89_iso_al": "Always",
