{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Early Childhood Speech and Language Assessment - Speech and Language Assessment Scale",
      "code": "PX200302",
      "abbreviation": "PX200302",
      "description": "The Speech and Language Assessment Scale (SLAS) is a 19-item, parent-report questionnaire designed to identify children with delayed speech and language skills. The SLAS uses seven-point Likert-style questions to assess six subscales: assertiveness, responsiveness, semantics, syntax, articulation, a",
      "domain": "Health",
      "citation": "Junge, C., & Cutler, A. (2014). Early word recognition and later language skills. Brain sciences, 4(4), 532-559. [PhenX: https://www.phenxtoolkit.org/protocols/view/200302]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/200302"
    },
    "implementation": {
      "author": "Shane T. Mueller",
