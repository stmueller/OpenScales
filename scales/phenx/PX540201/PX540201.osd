  "translations": {
    "en": {
      "run_away_from_home_overnight": "Has run away from home overnight at least twice while living in parental or parental surrogate home (or once without returning for a lengthy period)",
      "often_argues_with_adults": "Often argues with adults",
      "often_lies": "Often lies to obtain goods or favors or to avoid obligations (i.e., \"cons\" others)",
      "physically_cruel_to_people": "Has been physically cruel to people",
      "stolen_items_without_confronting_victim": "Has stolen items of nontrivial value without confronting a victim (e.g., shoplifting, but without breaking and entering; forgery)",
      "often_truant_from_school": "Often truant from school, beginning before age 13 years",
      "often_spiteful_or_vindictive": "Is often spiteful or vindictive",
      "blames_others_for_mistakes": "Often blames others for his or her mistakes or misbehavior",
      "deliberately_destroyed_property": "Has deliberately destroyed others' property (other than by fire setting)",
      "defies_adults_requests_rules": "Often actively defies or refuses to comply with adults' requests or rules",
      "initiates_physical_fights": "Often initiates physical fights with others who do not live in his or her household (e.g., peers at school or in the neighborhood)",
      "often_angry_and_resentful": "Is often angry and resentful",
      "touchy_or_annoyed_by_others": "Is often touchy or easily annoyed by others",
      "often_loses_temper": "Often loses temper",
      "forced_someone_into_sexual_activity": "Has forced someone into sexual activity",
      "often_bullies_threatens_or_intimidates": "Often bullies, threatens, or intimidates others",
      "physically_cruel_to_animals": "Has been physically cruel to animals",
      "stays_out_at_night": "Often stays out at night despite parental prohibitions, beginning before age 13 years",
      "often_deliberately_annoys_people": "Often deliberately annoys people",
      "stolen_confronting_victim": "Has stolen while confronting a victim (e.g., mugging, purse snatching, extortion, armed robbery)",
      "engaged_in_fire_setting": "Has deliberately engaged in fire setting with the intention of causing serious damage",
      "broken_into_house_building_car": "Has broken into someone else's house, building, or car",
      "used_weapon": "Has used a weapon that can cause serious physical harm to others (e.g., a bat, brick, broken bottle, knife, gun)",
      "likert_1": "Not at all",
      "likert_2": "Just a little",
      "likert_3": "Pretty much",
      "likert_4": "Very much",
      "likert_5": "Don't Know"
    }
  }
}
