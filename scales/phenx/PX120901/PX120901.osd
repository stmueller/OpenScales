  "translations": {
    "en": {
      "prefer_do_things_with_others": "I prefer to do things with others rather than on my own.",
      "prefer_do_things_with_others_opt_1": "Definitely agree",
      "prefer_do_things_with_others_opt_2": "Slightly agree",
      "prefer_do_things_with_others_opt_3": "Slightly disagree",
      "prefer_do_things_with_others_opt_4": "Definitely disagree",
      "prefer_do_things_same_way": "I prefer to do things the same way over and over again.",
      "prefer_do_things_same_way_opt_1": "Definitely agree",
      "prefer_do_things_same_way_opt_2": "Slightly agree",
      "prefer_do_things_same_way_opt_3": "Slightly disagree",
      "prefer_do_things_same_way_opt_4": "Definitely disagree",
      "easy_create_picture_imagination": "If I try to imagine something, I find it very easy to create a picture in my mind.",
      "easy_create_picture_imagination_opt_1": "Definitely agree",
      "easy_create_picture_imagination_opt_2": "Slightly agree",
      "easy_create_picture_imagination_opt_3": "Slightly disagree",
      "easy_create_picture_imagination_opt_4": "Definitely disagree",
      "strongly_absorbed": "I frequently get so strongly absorbed in one thing that I lose sight of other things.",
      "strongly_absorbed_opt_1": "Definitely agree",
      "strongly_absorbed_opt_2": "Slightly agree",
      "strongly_absorbed_opt_3": "Slightly disagree",
      "strongly_absorbed_opt_4": "Definitely disagree",
      "notice_small_sounds": "I often notice small sounds when others do not.",
      "notice_small_sounds_opt_1": "Definitely agree",
      "notice_small_sounds_opt_2": "Slightly agree",
      "notice_small_sounds_opt_3": "Slightly disagree",
      "notice_small_sounds_opt_4": "Definitely disagree",
      "notice_license_plates": "I usually notice car number plates or similar strings of information.",
      "notice_license_plates_opt_1": "Definitely agree",
      "notice_license_plates_opt_2": "Slightly agree",
      "notice_license_plates_opt_3": "Slightly disagree",
      "notice_license_plates_opt_4": "Definitely disagree",
      "people_call_me_impolite": "Other people frequently tell me that what I've said is impolite, even though I think it is polite.",
      "people_call_me_impolite_opt_1": "Definitely agree",
      "people_call_me_impolite_opt_2": "Slightly agree",
      "people_call_me_impolite_opt_3": "Slightly disagree",
      "people_call_me_impolite_opt_4": "Definitely disagree",
      "easily_imagine_story_characters": "When I'm reading a story, I can easily imagine what the characters might look like.",
      "easily_imagine_story_characters_opt_1": "Definitely agree",
      "easily_imagine_story_characters_opt_2": "Slightly agree",
      "easily_imagine_story_characters_opt_3": "Slightly disagree",
      "easily_imagine_story_characters_opt_4": "Definitely disagree",
      "fascinated_dates": "I am fascinated by dates.",
      "fascinated_dates_opt_1": "Definitely agree",
      "fascinated_dates_opt_2": "Slightly agree",
      "fascinated_dates_opt_3": "Slightly disagree",
      "fascinated_dates_opt_4": "Definitely disagree",
      "keep_track_different_conversations": "In a social group, I can easily keep track of several different people's conversations.",
      "keep_track_different_conversations_opt_1": "Definitely agree",
      "keep_track_different_conversations_opt_2": "Slightly agree",
      "keep_track_different_conversations_opt_3": "Slightly disagree",
      "keep_track_different_conversations_opt_4": "Definitely disagree",
      "social_situations_easy": "I find social situations easy.",
      "social_situations_easy_opt_1": "Definitely agree",
      "social_situations_easy_opt_2": "Slightly agree",
      "social_situations_easy_opt_3": "Slightly disagree",
      "social_situations_easy_opt_4": "Definitely disagree",
      "notice_details": "I tend to notice details that others do not.",
      "notice_details_opt_1": "Definitely agree",
      "notice_details_opt_2": "Slightly agree",
      "notice_details_opt_3": "Slightly disagree",
      "notice_details_opt_4": "Definitely disagree",
      "library_over_party": "I would rather go to a library than a party.",
      "library_over_party_opt_1": "Definitely agree",
      "library_over_party_opt_2": "Slightly agree",
      "library_over_party_opt_3": "Slightly disagree",
      "library_over_party_opt_4": "Definitely disagree",
      "make_up_stories_easily": "I find making up stories easy.",
      "make_up_stories_easily_opt_1": "Definitely agree",
      "make_up_stories_easily_opt_2": "Slightly agree",
      "make_up_stories_easily_opt_3": "Slightly disagree",
      "make_up_stories_easily_opt_4": "Definitely disagree",
      "drawn_to_people": "I find myself drawn more strongly to people than to things.",
      "drawn_to_people_opt_1": "Definitely agree",
      "drawn_to_people_opt_2": "Slightly agree",
      "drawn_to_people_opt_3": "Slightly disagree",
      "drawn_to_people_opt_4": "Definitely disagree",
      "strong_interests": "I tend to have very strong interests which I get upset about if I can't pursue.",
