    "scoring": {
      "satisfaction": {
        "description": "Smoking Satisfaction: mean_coded of 3 items.",
        "method": "mean_coded",
        "items": [
          "was_smoking_satisfying",
          "did_cigarettes_taste_good",
          "did_you_enjoy_smoking"
        ]
      },
      "psychological_reward": {
        "description": "Psychological Reward: mean_coded of 5 items.",
        "method": "mean_coded",
        "items": [
          "smoking_calm_you_down",
          "smoking_make_you_more_awake",
          "make_you_less_irritable",
          "smoking_help_you_concentrate",
          "reduce_your_hunger"
        ]
      },
      "aversion": {
        "description": "Aversion: mean_coded of 2 items.",
        "method": "mean_coded",
        "items": [
          "smoking_make_you_dizzy",
          "smoking_make_you_nauseous"
        ]
      }
    },
    "_scoring_notes": "Scoring Procedure and InterpretationThe modified Cigarette Evaluation Questionnaire (mCEQ) uses three multi-item subscales and two single items: \"Smoking Satisfaction\" (items 1, 2, and 12); \"Psychological Reward\" (items 4 through 8); \"Aversion\" (items 9 and 10); \"Enjoyment of Respiratory Tract Sensations\" (item 3); and \"Craving Reduction\" (item 11). Scores for each subscale are calculated as the mean of the individual item responses or the single item. Higher scores indicate greater intensity on that scale.1= not at all2= very little3= a little4= moderately5= a lot6= quite a lot7= extremely",
    "likert_options": {
      "points": 7,
      "min": 1,
      "max": 7,
      "labels": [
