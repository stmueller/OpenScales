    "scale_info": {
      "name": "Motives - Alcohol, Tobacco and Other Substances - Specific - Drugs",
      "code": "PX520506",
      "abbreviation": "PX520506",
      "description": "Respondents complete self-administered questions from the Monitoring the Future (MTF) 2015 questionnaire regarding their reason(s) for using marijuana or hasish, amphetamines or other stimulant drugs, tranquilizers, cocaine and/or narcotics other than heroin (e.g., feel good, fit in, anger, tastes g",
      "domain": "Substance Use",
      "citation": "Miech, R. A., Johnston, L. D., O’Malley, P. M., Bachman, J. G., & Schulenberg, J. E. (2015). Monitoring the Future national survey results on drug use, 1975-2014: Volume I, Secondary school students . Ann Arbor: Institute for Social Research, The University of Michigan, 599 pp. [PhenX: https://www.phenxtoolkit.org/protocols/view/520506]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/520506"
    },
