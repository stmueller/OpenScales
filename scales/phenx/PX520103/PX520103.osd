    "scale_info": {
      "name": "Acute Subjective Response to Substances - Current - General",
      "code": "PX520103",
      "abbreviation": "PX520103",
      "description": "The Drug Effects Questionnaire (DEQ) consists of simple, face-valid, visual analog scale (VAS) questions on which people report their subjective states after ingesting a substance. The analog scale of responses ranges from \"not at all\" to \"extremely.\"",
      "domain": "Substance Use",
      "citation": "Meghan E. Morean , Harriet de Wit , Andrea C. King , Mehmet Sofuoglu , Sandra Y. Rueger , and Stephanie S. O’Malley (2013). The Drug Effects Questionnaire: Psychometric Support across Three Drug Types Psychopharmacology (Berl), 227 (1), 177-192. PMCID: PMC3624068 [PhenX: https://www.phenxtoolkit.org/protocols/view/520103]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/520103"
    },
