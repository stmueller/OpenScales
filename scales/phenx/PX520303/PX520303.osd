      "dont_want_heroin_now_opt_6": "6",
      "dont_want_heroin_now_opt_7": "STRONGLY AGREE",
      "less_irritable_heroin": "I would be less irritable now if I could use heroin.",
      "less_irritable_heroin_opt_1": "STRONGLY DISAGREE",
      "less_irritable_heroin_opt_2": "2",
      "less_irritable_heroin_opt_3": "3",
