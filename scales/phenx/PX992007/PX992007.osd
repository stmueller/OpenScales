  "translations": {
    "en": {
      "long_covid_symptoms_psychiatric_long_hallucinations_altered_consciousness": "Do you still have the hallucinations, altered consciousness?",
      "long_covid_symptoms_psychiatric_long_hallucinations_altered_consciousness_opt_1": "Yes, I still have this symptom",
      "long_covid_symptoms_psychiatric_long_hallucinations_altered_consciousness_opt_2": "Yes, I still have the symptom but it is less severe",
      "long_covid_symptoms_psychiatric_long_hallucinations_altered_consciousness_opt_3": "Yes, I still have the symptom but it comes and goes",
      "long_covid_symptoms_psychiatric_long_hallucinations_altered_consciousness_opt_4": "No, the symptom has cleared",
      "long_covid_symptoms_psychiatric_long_hallucinations_normal_activities": "Does/did the hallucinations, altered consciousness affect your ability to do your normal activities?",
      "long_covid_symptoms_psychiatric_long_hallucinations_normal_activities_opt_1": "I have/had the symptom but I can/could still do normal activities.",
      "long_covid_symptoms_psychiatric_long_hallucinations_normal_activities_opt_2": "The symptom really bothers/bothered me. It is/was hard to do normal activities.",
      "long_covid_symptoms_psychiatric_long_hallucinations_normal_activities_opt_3": "The symptom is/was very bad. I am/was not able to do activities that I usually do.",
      "long_covid_symptoms_psychiatric_long_hallucinations_normal_activities_opt_4": "Refuse to answer",
      "long_covid_symptoms_psychiatric_long_hallucinations_clear": "When did the hallucinations, altered consciousness clear?",
      "long_covid_symptoms_psychiatric_long_hallucinations_clear_opt_1": "Less than 3 months after symptom started",
      "long_covid_symptoms_psychiatric_long_hallucinations_clear_opt_2": "Between 3 to 6 months after symptom started",
      "long_covid_symptoms_psychiatric_long_hallucinations_clear_opt_3": "Between 6 to 9 months after symptom started",
      "long_covid_symptoms_psychiatric_long_hallucinations_clear_opt_4": "Greater than 9 months after symptom started",
      "long_covid_symptoms_psychiatric_long_hallucinations_clear_opt_5": "Don't know",
      "long_covid_symptoms_psychiatric_long_hallucinations_clear_opt_6": "Refuse to answer",
      "long_covid_symptoms_psychiatric_long_difficulty_sleeping": "Do you still have difficulty sleeping?",
      "long_covid_symptoms_psychiatric_long_difficulty_sleeping_opt_1": "Yes, I still have this symptom",
      "long_covid_symptoms_psychiatric_long_difficulty_sleeping_opt_2": "Yes, I still have the symptom but it is less severe",
      "long_covid_symptoms_psychiatric_long_difficulty_sleeping_opt_3": "Yes, I still have the symptom but it comes and goes",
      "long_covid_symptoms_psychiatric_long_difficulty_sleeping_opt_4": "No, the symptom has cleared",
      "long_covid_symptoms_psychiatric_long_difficulty_sleeping_normal_activities": "Does/did the difficulty sleeping affect your ability to do your normal activities?",
      "long_covid_symptoms_psychiatric_long_difficulty_sleeping_normal_activities_opt_1": "I have/had the symptom but I can/could still do normal activities.",
      "long_covid_symptoms_psychiatric_long_difficulty_sleeping_normal_activities_opt_2": "The symptom really bothers/bothered me. It is/was hard to do normal activities.",
      "long_covid_symptoms_psychiatric_long_difficulty_sleeping_normal_activities_opt_3": "The symptom is/was very bad. I am/was not able to do activities that I usually do.",
      "long_covid_symptoms_psychiatric_long_difficulty_sleeping_normal_activities_opt_4": "Refuse to answer",
