    "scoring": {
      "gate": {
        "method": "sum_coded",
        "items": [
          "phqpd1",
          "phqpd2",
          "phqpd3",
          "phqpd4"
        ],
        "description": "Gate questions (0–4). All 4 must be YES (sum=4) for panic syndrome.",
        "item_coding": {
          "phqpd1": 1,
          "phqpd2": 1,
          "phqpd3": 1,
          "phqpd4": 1
        }
      },
      "symptoms": {
        "method": "sum_coded",
        "items": [
          "phqpd5",
          "phqpd6",
          "phqpd7",
          "phqpd8",
          "phqpd9",
          "phqpd10",
          "phqpd11",
          "phqpd12",
          "phqpd13",
          "phqpd14",
          "phqpd15"
        ],
        "description": "Somatic symptoms (0–11). 4 or more YES (with all gate YES) = panic syndrome.",
        "item_coding": {
          "phqpd5": 1,
          "phqpd6": 1,
          "phqpd7": 1,
          "phqpd8": 1,
          "phqpd9": 1,
          "phqpd10": 1,
          "phqpd11": 1,
          "phqpd12": 1,
          "phqpd13": 1,
          "phqpd14": 1,
          "phqpd15": 1
        },
        "norms": {
          "thresholds": [
            {
              "min": 0,
              "max": 3,
              "label": "Below symptom threshold"
            },
            {
              "min": 4,
              "max": 11,
              "label": "Meets symptom criterion (if all gate items YES)"
            }
          ]
        }
      }
    },
    "report": {
      "template": "standard",
      "include": [
        "timestamp",
        "completion_time",
        "dimension_scores"
      ],
      "header": "PHQ Panic Disorder Module Report",
      "footer_refs": [
        "Spitzer, R. L., Kroenke, K., & Williams, J. B. W. (1999). JAMA, 282(18), 1737–1744.",
        "Panic Syndrome: all 4 gate items YES AND 4+ of 11 symptom items YES."
      ]
    }
  },
  "translations": {
    "en": {
      "yes": "Yes",
      "no": "No",
      "phqpd_inst": "The following questions ask about anxiety and panic attacks. An anxiety attack is a sudden rush of intense fear or anxiety that comes on quickly and may include physical symptoms like a racing heart, shortness of breath, or dizziness. Please answer based on your experience in the <b>last 4 weeks</b>.",
      "phqpd_symptom_head": "<b>Think about your last bad anxiety attack.</b>",
      "phqpd1": "In the <b>last 4 weeks</b>, have you had an anxiety attack — suddenly feeling fear or panic?",
      "phqpd2": "Has this ever happened before?",
      "phqpd3": "Do some of these attacks come <u>suddenly out of the blue</u> — that is, in situations where you don't expect to be nervous or uncomfortable?",
      "phqpd4": "Do these attacks bother you a lot or are you worried about having another attack?",
      "phqpd5": "Were you short of breath?",
      "phqpd6": "Did your heart race, pound, or skip?",
      "phqpd7": "Did you have chest pain or pressure?",
      "phqpd8": "Did you sweat?",
      "phqpd9": "Did you feel as if you were choking?",
      "phqpd10": "Did you have hot flashes or chills?",
      "phqpd11": "Did you have nausea or an upset stomach, or the feeling that you were going to have diarrhea?",
      "phqpd12": "Did you feel dizzy, unsteady, or faint?",
      "phqpd13": "Did you have tingling or numbness in parts of your body?",
      "phqpd14": "Did you tremble or shake?",
      "phqpd15": "Were you afraid you were dying?",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
