  "translations": {
    "en": {
      "likert_0": "0 - Not at all",
      "likert_1": "1",
      "likert_2": "2",
      "likert_3": "3",
      "likert_4": "4",
      "likert_5": "5",
      "likert_6": "6",
      "likert_7": "7",
      "likert_8": "8",
      "likert_9": "9",
      "likert_10": "10 - More than ever",
      "question_head": "Indicate how much you WANT or DESIRE to perform the following activities. Do NOT think about how much you 'should' desire each activity. Think about how you actually want/desire to behave at this very moment.",
      "crve1": "At this very moment (right now) I want/desire to... move my body",
      "crve2": "At this very moment (right now) I want/desire to... be physically active",
      "crve3": "At this very moment (right now) I want/desire to... do nothing active",
      "crve4": "At this very moment (right now) I want/desire to... just sit down",
      "crve5": "At this very moment (right now) I want/desire to... take a nap",
      "crve6": "At this very moment (right now) I want/desire to... rest",
      "crve7": "At this very moment (right now) I want/desire to... be still",
      "crve8": "At this very moment (right now) I want/desire to... exercise",
      "crve9": "At this very moment (right now) I want/desire to... play a sport or game that is physically active",
      "crve10": "At this very moment (right now) I want/desire to... go for a walk",
      "crve11": "At this very moment (right now) I want/desire to... go for a run or jog",
      "crve12": "At this very moment (right now) I want/desire to... participate in physical activities with others",
      "crve13": "At this very moment (right now) I want/desire to... stretch",
      "debrief": "Thank you for completing the Cravings for Rest and Volitional Energy Expenditure Scale."
    }
  }
