      "support_prepare_meals_opt_2": "2- A little of the time",
      "support_prepare_meals_opt_3": "3- Some of the Time",
      "support_prepare_meals_opt_4": "4- Most of the Time",
      "support_prepare_meals_opt_5": "5- All of the Time",
