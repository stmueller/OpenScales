  "translations": {
    "en": {
      "heaviness_smoking_index_wake_wait_first_cigarette": "At present, how long after waking do you wait before having your first cigarette?",
      "heaviness_smoking_index_wake_wait_first_cigarette_opt_1": "Within 5 minutes [3 points]",
      "heaviness_smoking_index_wake_wait_first_cigarette_opt_2": "6-30 minutes [2 points]",
      "heaviness_smoking_index_wake_wait_first_cigarette_opt_3": "31-60 minutes [1 point]",
      "heaviness_smoking_index_wake_wait_first_cigarette_opt_4": "over 60 minutes [0 points]",
      "heaviness_smoking_index_cigarettes_daily": "How many cigarettes per day do/did you smoke?",
      "heaviness_smoking_index_cigarettes_daily_opt_1": "10 or less [0 points]",
      "heaviness_smoking_index_cigarettes_daily_opt_2": "11-20 [1 point]",
      "heaviness_smoking_index_cigarettes_daily_opt_3": "21-30 [2 points]",
      "heaviness_smoking_index_cigarettes_daily_opt_4": "31 or more [3 points]",
      "scoring_instructions": "<div class=\"rich-text-field-label\"><p>Note on how to score the results:</p> <ul> <li><span style=\"font-weight: normal;\">A six-point scale is calculated from the time to first cigarette after waking (3, 2, 1, or 0 points) and number of cigarettes smoked per day (0, 1, 2, or 3 points).</span></li> <li><span style=\"font-weight: normal;\">Sum the points for each round of 2 questions asked.</span></li> <li><span style=\"font-weight: normal;\">Nicotine dependence is categorized into a three-category variable: low (0-1), medium (2-4), and high (5-6).</span></li> </ul></div>"
    }
  }
}