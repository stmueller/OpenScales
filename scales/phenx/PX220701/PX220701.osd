  "translations": {
    "en": {
      "lk_opt_1": "Very poor",
      "lk_opt_2": "Poor",
      "lk_opt_3": "Fair",
      "lk_opt_4": "Good",
      "lk_opt_5": "Very good",
      "intro_220701": "The Newcastle Paediatric Mitochondrial Disease Scale (NPMDS)0 - 24 months",
      "disease_progressionregression_024mo_date": "Date of assessment:",
      "disease_progressionregression_024mo_age": "Age at assessment:",
      "disease_progressionregression_024mo_parental_consanguinity": "Parental consanguinity:",
      "disease_progressionregression_024mo_parental_agepresentation": "Age at presentation:",
      "disease_progressionregression_024mo_parentalage_agedx": "Age at clinical diagnosis:",
      "disease_progressionregression_024mo_genotype": "Genotype if known:",
      "disease_progressionregression_024mo_biochemical_phenotype": "Biochemical phenotype if known:",
      "disease_progressionregression_024mo_basis_diagnosis": "Basis of clinical diagnosis e.g. MRI, blood / CSF lactate",
      "disease_progressionregression_024mo_reduced_fetalmovement": "Information regarding pregnancy:reduced fetal movements",
      "disease_progressionregression_024mo_pregnancy_cardiomyopathy_antenatal": "Information regarding pregnancy:cardiomyopathy on antenatal scans",
      "disease_progressionregression_024mo_abnormalities_fetalscan": "Information regarding pregnancy:abnormalities on fetal anomaly scan",
      "disease_progressionregression_024mo_abnormalities_specify": "Please specify",
      "disease_progressionregression_024mo_pregnancy_cardiomyopathy_pregnancyother": "Other",
      "disease_progressionregression_024mo_neonatal_gestationalage": "Neonatal information:gestational age ____weeks",
      "disease_progressionregression_024mo_neonatal_deliverymethod": "Neonatal information:delivery method (NVD vs instrumental vs C/S)",
      "disease_progressionregression_024mo_neonatal_birthweight": "Neonatal information:birth weight in kg",
      "disease_progressionregression_024mo_neonatal_resuscitationventilation": "Neonatal information:Resuscitation and ventilation",
      "disease_progressionregression_024mo_neonatal_specify": "Specify",
      "instructions_220701": "Section I: Current FunctionRate function during the preceding 2 week period only according to caregiver interview. Indicate the score that best fits patient's functional status independently of the nature of the signs.",
      "disease_progressionregression_024mo_currentfunction_vision": "Rate function during the preceding 2 week period only according to caregiver - Vision",
      "disease_progressionregression_024mo_currentfunction_hearing": "Rate function during the preceding 2 week period only according to caregiver - Hearing",
      "disease_progressionregression_024mo_currentfunction_communication": "Rate function during the preceding 2 week period only according to caregiver - communication (assessed with appropriate regard for age)",
      "disease_progressionregression_024mo_currentfunction_feeding": "Rate function during the preceding 2 week period only according to caregiver - Feeding",
      "disease_progressionregression_024mo_currentfunction_mobility": "Rate function during the preceding 2 week period only according to caregiver - Mobility",
      "section_ii_220701": "Section II: System Specific InvolvementRate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question. Scores should be assigned according to caregiver interview, clinician's knowledge of the patient and clinical notes.",
      "disease_progressionregression_024mo_systeminvolvement_seizures": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - Seizures",
      "disease_progressionregression_024mo_systeminvolvement_encephalopathy": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - Encephalopathy",
      "disease_progressionregression_024mo_systeminvolvement_gastrointestinal": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - Gastrointestinal",
      "disease_progressionregression_024mo_systeminvolvement_endocrine": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - Endocrine",
      "disease_progressionregression_024mo_systeminvolvement_respiratory": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - respiratory",
      "disease_progressionregression_024mo_systeminvolvement_cardiovascular": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - cardiovascular",
      "disease_progressionregression_024mo_systeminvolvement_renal": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - Renal",
      "disease_progressionregression_024mo_systeminvolvement_liver": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - Liver",
      "disease_progressionregression_024mo_systeminvolvement_blood": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - blood",
      "section_iii_220701": "Section III: Current Clinical AssessmentRate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question.",
      "disease_progressionregression_024mo_currentclinical_growthweight": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Growth (weight) over preceding 6 months",
      "disease_progression_and_regression": "IMAGE - disease_progression_and_regression",
      "disease_progressionregression_024mo_currentclinical_development": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Development over preceding 4 months __ Score",
      "disease_progressionregression_024mo_currentclinical_development_opt_0": "Development is age appropriate",
      "disease_progressionregression_024mo_currentclinical_development_opt_1": "Development is not age appropriate, child has not regressed in any area of development, child is not globally delayed in development, AND (1) evidence of delayed speech, language or hearing, or (2) evidence of delayed motor milestones, or (3) evidence of delay in social development, AND there is development progress",
      "disease_progressionregression_024mo_currentclinical_development_opt_2": "Development is not age appropriate, child has not regressed in any area of development, child is not globally delayed in development, AND (1) evidence of delayed speech, language or hearing, or (2) evidence of delayed motor milestones, or (3) evidence of delay in social development, AND there is NO development progress",
      "disease_progressionregression_024mo_currentclinical_development_opt_5": "Development is not age appropriate, child has not regressed in any area of development, child is globally delayed in development, but there is developmental progress",
      "disease_progressionregression_024mo_currentclinical_development_opt_6": "Development is not age appropriate, child has not regressed in any area of development, child is globally delayed in development, and there is no developmental progress",
      "disease_progressionregression_024mo_currentclinical_development_opt_7": "Development is not age appropriate and child has regressed in an area of development",
      "disease_progressionregression_024mo_currentclinical_vision": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. -Vision",
      "disease_progressionregression_024mo_currentclinical_ptosiseyemovement": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Ptosis and Eye Movement",
      "disease_progressionregression_024mo_currentclinical_myopathy": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Myopathy",
      "disease_progressionregression_024mo_currentclinical_pyramidal": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Pyramidal",
      "disease_progressionregression_024mo_currentclinical_extrapyramidal": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Extrapyramidal",
      "disease_progressionregression_024mo_currentclinical_neuropathy": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Neuropathy",
      "section_iv_220701": "Section IV: Quality of LifeThis survey asks for your views about your child's recent health. Please answer every question by selecting the phrase which best describes your answer.",
      "disease_progressionregression_024mo_qol_overallhealth": "During the past 4 weeks, how would you rate your child's overall health?",
      "disease_progressionregression_024mo_qol_phsyicalactivities": "During the past 4 weeks, how much did your child's physical health problems limit their physical activities (such as moving or playing)?",
      "disease_progressionregression_024mo_qol_energy": "During the past 4 weeks, how much energy did your child have?",
      "disease_progressionregression_024mo_qol_pain": "During the past 4 weeks, how much bodily pain / discomfort did your child have?",
      "disease_progressionregression_024mo_qol_behavior": "During the past 4 weeks, how would you rate your child's behavior compared with other children his / her age?",
      "disease_progressionregression_024mo_qol_interactions": "During the past 4 weeks, how would you rate your child's ability to interact with other people (e.g. with you, siblings or other children his / her age) compared with other children his / her age?",
      "disease_progressionregression_024mo_qol_emotionalproblems": "During the past 4 weeks, how much were you (the parent / carer) bothered by emotional problems (e.g. feelings of anxiety, sadness) as a result of your child's illness?",
      "disease_progressionregression_024mo_qol_timelimited": "During the past 4 weeks, how much was your time limited as a result of your child's illness?",
