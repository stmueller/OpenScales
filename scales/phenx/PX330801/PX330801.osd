    "scoring": {
      "internal_stimuli": {
        "description": "Internal Stimuli: mean self-efficacy for resisting smoking during internal states (6 items).",
        "method": "mean_coded",
        "items": [
          "self_efficacy_smoking_refrain_internal_stimuli_nervous",
          "self_efficacy_smoking_refrain_internal_stimuli_depressed",
          "self_efficacy_smoking_refrain_internal_stimuli_angry",
