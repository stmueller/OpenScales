  "translations": {
    "en": {
      "likert_1": "Very Inaccurate",
      "likert_2": "Moderately Inaccurate",
      "likert_3": "Neither Accurate Nor Inaccurate",
      "likert_4": "Moderately Accurate",
      "likert_5": "Very Accurate",
      "question_head": "<h3>How Accurately Can You Describe Yourself?</h3>\nDescribe yourself as you generally are now, not as you wish to be in the future. Describe yourself as you honestly see yourself, in relation to other people you know of the same sex as you are, and roughly your same age. So that you can describe yourself in an honest manner, your responses will be kept in absolute confidence. Indicate how accurately this statement describes you.",
      "debrief": "Thank you for completing this questionnaire.",
      "ipip_bisbas_001": "Am afraid that I will do the wrong thing.",
      "ipip_bisbas_002": "Am always worried about something.",
      "ipip_bisbas_003": "Am easily hurt.",
      "ipip_bisbas_004": "Am not embarrassed easily.",
      "ipip_bisbas_005": "Become overwhelmed by events.",
      "ipip_bisbas_006": "Begin to panic when there is danger.",
      "ipip_bisbas_007": "Get stressed out easily.",
      "ipip_bisbas_008": "Often worry about things that turn out to be unimportant.",
      "ipip_bisbas_009": "Rarely worry.",
      "ipip_bisbas_010": "Worry about what people think of me.",
      "ipip_bisbas_011": "Am eager to soothe hurt feelings.",
      "ipip_bisbas_012": "Don't get excited about things.",
      "ipip_bisbas_013": "Feel excited or happy for no apparent reason.",
      "ipip_bisbas_014": "Get caught up in the excitement when others are celebrating.",
      "ipip_bisbas_015": "Get so happy or energetic that I am almost giddy.",
      "ipip_bisbas_016": "Rarely get caught up in the excitement.",
      "ipip_bisbas_017": "Am not an extraordinary person.",
      "ipip_bisbas_018": "Am not highly motivated to succeed.",
      "ipip_bisbas_019": "Hate being the center of attention.",
      "ipip_bisbas_020": "Have a strong need for power.",
      "ipip_bisbas_021": "Know how to get around the rules.",
      "ipip_bisbas_022": "Like to show off my body.",
      "ipip_bisbas_023": "Push myself very hard to succeed.",
      "ipip_bisbas_024": "Take charge.",
      "ipip_bisbas_025": "Try to surpass others' accomplishments.",
      "ipip_bisbas_026": "Want to be in charge.",
      "ipip_bisbas_027": "Am willing to try anything once.",
      "ipip_bisbas_028": "Avoid dangerous situations.",
      "ipip_bisbas_029": "Do crazy things.",
      "ipip_bisbas_030": "Enjoy being reckless.",
      "ipip_bisbas_031": "Have persuaded others to do something really adventurous or crazy.",
      "ipip_bisbas_032": "Like to act on a whim.",
      "ipip_bisbas_033": "Like to behave spontaneously.",
      "ipip_bisbas_034": "Prefer friends who are excitingly unpredictable.",
      "ipip_bisbas_035": "Rarely enjoy behaving in a silly manner.",
      "ipip_bisbas_036": "Would never go hang gliding or bungee jumping."
    }
  }
