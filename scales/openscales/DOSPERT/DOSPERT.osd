  "translations": {
    "en": {
      "sec_blank": "",
      "instructions": "For each situation below, you will answer two or three questions. First, indicate how likely you are to engage in the activity. Then, indicate how risky you perceive the situation to be. Riskiness is a very personal and intuitive notion — we are interested in your gut level assessment.",
      "rt_head": "How likely are you to engage in this activity?",
      "rp_head": "How risky do you perceive this situation?",
      "eb_head": "What benefits would you obtain from this situation?",
      "rt_l1": "Extremely Unlikely",
      "rt_l2": "Moderately Unlikely",
      "rt_l3": "Somewhat Unlikely",
      "rt_l4": "Not Sure",
      "rt_l5": "Somewhat Likely",
      "rt_l6": "Moderately Likely",
      "rt_l7": "Extremely Likely",
      "rp_l1": "Not at all Risky",
      "rp_l2": "Slightly Risky",
      "rp_l3": "Somewhat Risky",
      "rp_l4": "Moderately Risky",
      "rp_l5": "Risky",
      "rp_l6": "Very Risky",
      "rp_l7": "Extremely Risky",
      "eb_l1": "No benefits at all",
      "eb_l2": "",
      "eb_l3": "",
      "eb_l4": "Moderate benefits",
      "eb_l5": "",
      "eb_l6": "",
      "eb_l7": "Great benefits",
      "q1": "Admitting that your tastes are different from those of a friend.",
      "q2": "Going camping in the wilderness.",
      "q3": "Betting a day's income at the horse races.",
      "q4": "Investing 10% of your annual income in a moderate growth mutual fund.",
      "q5": "Drinking heavily at a social function.",
      "q6": "Taking some questionable deductions on your income tax return.",
      "q7": "Disagreeing with an authority figure on a major issue.",
      "q8": "Betting a day's income at a high-stake poker game.",
      "q9": "Having an affair with a married man/woman.",
      "q10": "Passing off somebody else's work as your own.",
      "q11": "Going down a ski run that is beyond your ability.",
      "q12": "Investing 5% of your annual income in a very speculative stock.",
      "q13": "Going whitewater rafting at high water in the spring.",
      "q14": "Betting a day's income on the outcome of a sporting event.",
      "q15": "Engaging in unprotected sex.",
      "q16": "Revealing a friend's secret to someone else.",
      "q17": "Driving a car without wearing a seat belt.",
      "q18": "Investing 10% of your annual income in a new business venture.",
      "q19": "Taking a skydiving class.",
      "q20": "Riding a motorcycle without a helmet.",
      "q21": "Choosing a career that you truly enjoy over a more secure one.",
      "q22": "Speaking your mind about an unpopular issue in a meeting at work.",
      "q23": "Sunbathing without sunscreen.",
      "q24": "Bungee jumping off a tall bridge.",
      "q25": "Piloting a small plane.",
      "q26": "Walking home alone at night in an unsafe area of town.",
      "q27": "Moving to a city far away from your extended family.",
      "q28": "Starting a new career in your mid-thirties.",
      "q29": "Leaving your young children alone at home while running an errand.",
      "q30": "Not returning a wallet you found that contains $200."
    },
    "fr": {
      "sec_blank": "",
      "instructions": "Pour chaque situation ci-dessous, vous répondrez à deux ou trois questions. D'abord, indiquez la probabilité que vous preniez part à l'activité. Ensuite, indiquez le niveau de risque que vous percevez pour cette situation. Le degré de risque est un concept très personnel et intuitif — nous sommes intéressés par votre évaluation intuitive.",
      "rt_head": "Quelle est la probabilité que vous preniez part à cette activité?",
      "rp_head": "Quel niveau de risque percevez-vous pour cette situation?",
      "eb_head": "Quels bénéfices obtiendriez-vous de cette situation?",
      "rt_l1": "Extrêmement peu probable",
      "rt_l2": "Modérément peu probable",
      "rt_l3": "Quelque peu improbable",
      "rt_l4": "Pas certain(e)",
      "rt_l5": "Quelque peu probable",
      "rt_l6": "Modérément probable",
      "rt_l7": "Extrêmement probable",
      "rp_l1": "Pas du tout risqué",
      "rp_l2": "Légèrement risqué",
      "rp_l3": "Quelque peu risqué",
      "rp_l4": "Modérément risqué",
      "rp_l5": "Risqué",
      "rp_l6": "Très risqué",
      "rp_l7": "Extrêmement risqué",
      "eb_l1": "Aucun bénéfice",
      "eb_l2": "",
      "eb_l3": "",
      "eb_l4": "Bénéfices modérés",
      "eb_l5": "",
      "eb_l6": "",
      "eb_l7": "Grands bénéfices",
      "q1": "Avouer que vos goûts sont différents de ceux d'un ami.",
      "q2": "Aller camper en pleine nature.",
      "q3": "Parier une journée de salaire aux courses de chevaux.",
      "q4": "Investir 10% de vos revenus annuels dans un fonds mutuel à croissance modérée.",
      "q5": "Boire abondamment lors d'une activité sociale.",
      "q6": "Tricher par un montant important dans votre déclaration d'impôt.",
      "q7": "Être en désaccord avec un symbole d'autorité sur une question importante.",
      "q8": "Parier une journée de salaire lors d'une partie de poker à enjeu important.",
      "q9": "Avoir une aventure avec un homme ou une femme marié(e).",
      "q10": "Présenter le travail de quelqu'un d'autre comme étant le vôtre.",
      "q11": "Descendre une pente de ski exigeant une habileté plus grande que la vôtre.",
      "q12": "Investir 5% de vos revenus annuels dans des titres très spéculatifs.",
      "q13": "Faire de la descente en eau vive au printemps, quand le niveau de l'eau est élevé.",
      "q14": "Parier une journée de salaire sur le résultat d'un événement sportif.",
      "q15": "Avoir des relations sexuelles sans protection.",
      "q16": "Révéler le secret d'un ami à un autre ami.",
      "q17": "Conduire une voiture sans porter de ceinture de sécurité.",
      "q18": "Investir 10% de vos revenus annuels dans une nouvelle entreprise.",
      "q19": "Suivre un cours de parachutisme.",
      "q20": "Conduire une motocyclette sans casque protecteur.",
      "q21": "Choisir une carrière qui vous plaît vraiment plutôt qu'une carrière sécuritaire.",
      "q22": "Dire votre opinion sur une question controversée lors d'une réunion au travail.",
      "q23": "Vous faire bronzer sans écran solaire.",
      "q24": "Effectuer un saut à l'élastique à partir d'un pont élevé.",
      "q25": "Piloter un petit avion.",
      "q26": "Rentrer chez vous à pied le soir dans un quartier peu sécuritaire.",
      "q27": "Déménager dans une ville éloignée de votre famille.",
      "q28": "Entreprendre une nouvelle carrière au cours de la mi-trentaine.",
      "q29": "Laisser vos enfants seuls à la maison pendant que vous faites une course.",
      "q30": "Ne pas retourner un portefeuille trouvé contenant 200$."
    }
  }
