  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Discrimination in Health Care",
      "code": "PX280901",
      "abbreviation": "PX280901",
      "description": "The DMS scale is a 7-item instrument that assesses a person’s prior experiences of mistreatment while getting health care that were attributed to race, ancestry, national origin, sex, disability, or age. Each question is rated on a 5-point Likert scale (1-never, 2-rarely, 3-sometimes, 4-most of the ",
      "domain": "Health Technology & Spirituality",
      "citation": "Bird, S. T., & Bogart, L. M. (2001). Perceived race-based and socioeconomic status(SES)-based discrimination in interactions with health care providers. Ethnicity & Disease, 11(3), 554-563. Thorburn, S., & Lindly, O. J. (2022). A systematic search and review of the discrimination in health care measure, and its adaptations. Patient Education and Counseling, 105(7), 1703-1713. https://doi.org/10.1016/j.pec.2021.10.008 [PhenX: https://www.phenxtoolkit.org/protocols/view/280901]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/280901"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
