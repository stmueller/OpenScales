  "translations": {
    "en": {
      "recovery_selfassessment_provider_welcoming_staff": "Staff make a concerted effort to welcome people in recovery and help them to feel comfortable in this Program. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_facilities": "This program/agency offers an inviting and dignified physical environment (e.g., the lobby, waiting rooms, etc.). Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_encouragement": "Staff encourage program participants to have hope and high expectations for their recovery. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_flexibility": "Program participants can change their clinician or case manager if they wish. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_treatment_records": "Program participants can easily access their treatment records if they wish. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_threats_bribes": "Staff do not use threats, bribes, or other forms of pressure to influence the behavior of program participants. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_staff_hopeful": "Staff believe in the ability of program participants to recover. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_symptoms": "Staff believe that program participants have the ability to manage their own symptoms. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_independence": "Staff believe that program participants can make their own life choices regarding things such as where to live, when to work, whom to be friends with, etc. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_decisions": "Staff listen to and respect the decisions that program participants make about their treatment and care. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_interests": "Staff regularly ask program participants about their interests and the things they would like to do in the community. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_risks": "Staff encourage program participants to take risks and try new things. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_cultural_acceptance": "This program offers specific services that fit each participant�s unique culture and life experiences. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_spiritual_needs": "Staff offer participants opportunities to discuss their spiritual needs and interests when they wish. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_sexual_needs": "Staff offer participants opportunities to discuss their sexual needs and interests when they wish. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_life_goals": "Staff help program participants to develop and plan for life goals beyond managing symptoms or staying stable (e.g., employment, education, physical fitness, connecting with family and friends, hobbies). Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_job_search": "Staff routinely assist program participants with getting jobs. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_other_activities": "Staff actively help program participants to get involved in non-mental health/addiction related activities, such as church groups, adult education, sports, or hobbies. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_support_network": "Staff work hard to help program participants to include people who are important to them in their recovery/treatment planning (such as family, friends, clergy, or an employer). Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_role_models": "Staff actively introduce program participants to persons in recovery who can serve as role models or mentors. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_network": "Staff actively connect program participants with self- help, peer support, or consumer advocacy groups and programs. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_volunteering": "Staff actively help people find ways to give back to their community (i.e., volunteering, community services, neighborhood watch/cleanup). Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_new_development": "People in recovery are encouraged to help staff with the development of new groups, programs, or services. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_evaluation": "People in recovery are encouraged to be involved in the evaluation of this agency�s programs, services, and service providers. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_attend_meetings": "People in recovery are encouraged to attend agency advisory boards and management meetings. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_complete_program": "Staff talk with program participants about what it takes to complete or exit the program. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_personal_goals": "Progress made towards an individual�s own personal goals is tracked regularly. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_assist": "The primary role of agency staff is to assist a person with fulfilling his/her own goals and aspirations. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_help_train": "Persons in recovery are involved with facilitating staff trainings and education at this program. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_staff_training": "Staff at this program regularly attend trainings on cultural competency. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_specialinterest_groups": "Staff are knowledgeable about special interest groups and activities in the community. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_provider_diversity": "Agency staff are diverse in terms of culture, ethnicity, lifestyle, and interests. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "likert_1": "1",
      "likert_2": "2",
      "likert_3": "3",
      "likert_4": "4",
      "likert_5": "5",
      "likert_6": "Not applicable",
      "likert_7": "Don't know"
    }
  }
}
