  "translations": {
    "en": {
      "lack_prosocial_emotions_children_self_report_express_feelings": "How well does the student expresses his/her feelings openly.",
      "lack_prosocial_emotions_children_self_report_right_wrong": "The student does not seem to know \"right\" from \"wrong\".",
      "lack_prosocial_emotions_children_self_report_care_school_work_": "The student seems motivated to do his/her best in structured activities.",
      "lack_prosocial_emotions_children_self_report_hurt": "The student does not care who he/she hurts to get what he/she wants.",
      "lack_prosocial_emotions_children_self_report_bad_guilt": "The student feels bad or guilty when he/she has done something wrong.",
      "lack_prosocial_emotions_children_self_report_show_emotions": "The student does not show emotions.",
      "lack_prosocial_emotions_children_self_report_punctual": "The student does not care about being on time.",
      "lack_prosocial_emotions_children_self_report_concerned_others_feelings": "The student is concerned about the feelings of others.",
      "lack_prosocial_emotions_children_self_report_trouble": "The student does not care if he/she is in trouble.",
      "lack_prosocial_emotions_children_self_report_feelings": "The student does not let feelings control him/her",
      "lack_prosocial_emotions_children_self_report_careless": "The student does not care about doing things well.",
      "lack_prosocial_emotions_children_self_report_cold_uncaring_others": "The student seems very cold and uncaring.",
      "lack_prosocial_emotions_children_self_report_admit_wrong": "The student easily admits to being wrong.",
      "lack_prosocial_emotions_children_self_report_easy_others_feelings": "It is easy to tell how he/she is feeling.",
      "lack_prosocial_emotions_children_self_report_try_best": "The student always tries his/her best.",
      "lack_prosocial_emotions_children_self_report_apologize": "The student apologizes (\"says he/she is sorry\") to persons he/she has hurt.",
      "lack_prosocial_emotions_children_self_report_others_feelings_important": "The student tries not to hurt others' feelings.",
      "lack_prosocial_emotions_children_self_report_remorseful": "The student shows no remorse when he/she has done something wrong.",
      "lack_prosocial_emotions_children_self_report_expressive_emotional": "The student is very expressive and emotional.",
      "lack_prosocial_emotions_children_self_report_time_perform_well": "The student does not like to put the time into doing things well.",
      "lack_prosocial_emotions_children_self_report_others_feelings_unimportant": "The feelings of others are unimportant to him/her.",
      "lack_prosocial_emotions_children_self_report_hide_feelings": "The student hides his/her feelings from others",
      "lack_prosocial_emotions_children_self_report_work_hard": "The student works hard on everything.",
      "lack_prosocial_emotions_children_self_report_motivation_others_feelings": "The student does things to make others feel good.",
      "likert_1": "Not at all true",
      "likert_2": "Somewhat true",
      "likert_3": "Very true",
      "likert_4": "Definitely true"
    }
  }
