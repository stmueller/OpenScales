{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Negative Perceptions of Science Scale",
      "code": "NPSS",
      "abbreviation": "NPSS",
      "description": "20-item scale measuring negative perceptions of science across four dimensions: Corrupt (5 items), Onerous (5 items), Heretical (5 items), and Limited (5 items). 5-point Likert scale. Final validated version from Table 4 of Morgan, Wisneski, & Skitka (2018).",
      "citation": "Morgan, G. S., Wisneski, D. C., & Skitka, L. J. (2018). Identifying relevant anti-science perceptions to improve science-based communication: The Negative Perceptions of Science Scale. Social Sciences, 7(4), 64. https://doi.org/10.3390/socsci7040064",
      "license": "CC BY 4.0",
      "license_explanation": "Published in MDPI Social Sciences under Creative Commons Attribution 4.0 International License.",
      "license_url": "https://creativecommons.org/licenses/by/4.0/",
      "version": "1.0",
      "url": "https://doi.org/10.3390/socsci7040064",
      "domain": "Attitudes"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "corrupt",
        "name": "Science as Corrupt",
        "description": "Distrust of scientists and the scientific process (5 items)."
      },
      {
        "id": "onerous",
        "name": "Science as Onerous",
        "description": "Perception of science as overly complex and aversive (5 items)."
      },
      {
        "id": "heretical",
        "name": "Science as Heretical",
        "description": "Belief that science conflicts with religious beliefs (5 items)."
      },
      {
        "id": "limited",
        "name": "Science as Limited",
        "description": "Belief that science has limitations and cannot explain everything (5 items)."
      }
    ],
