  "translations": {
    "en": {
      "household_chaos_unpredictability_commotion": "There is very little commotion in our home.",
      "household_chaos_unpredictability_commotion_opt_1": "TRUE",
      "household_chaos_unpredictability_commotion_opt_2": "FALSE",
      "household_chaos_unpredictability_find_things": "We can usually find things when we need them.",
      "household_chaos_unpredictability_find_things_opt_1": "TRUE",
      "household_chaos_unpredictability_find_things_opt_2": "FALSE",
      "household_chaos_unpredictability_feel_rushed": "We almost always seem to be rushed.",
      "household_chaos_unpredictability_feel_rushed_opt_1": "TRUE",
      "household_chaos_unpredictability_feel_rushed_opt_2": "FALSE",
      "household_chaos_unpredictability_engaged": "We are usually able to stay on top of things.",
      "household_chaos_unpredictability_engaged_opt_1": "TRUE",
      "household_chaos_unpredictability_engaged_opt_2": "FALSE",
      "household_chaos_unpredictability_running_late": "No matter how hard we try, we always seem to be running late.",
      "household_chaos_unpredictability_running_late_opt_1": "TRUE",
      "household_chaos_unpredictability_running_late_opt_2": "FALSE",
      "household_chaos_unpredictability_zoo_home": "It's a real zoo in our home.",
      "household_chaos_unpredictability_zoo_home_opt_1": "TRUE",
      "household_chaos_unpredictability_zoo_home_opt_2": "FALSE",
      "household_chaos_unpredictability_interruption": "At home we can talk to each other without being interrupted.",
      "household_chaos_unpredictability_interruption_opt_1": "TRUE",
      "household_chaos_unpredictability_interruption_opt_2": "FALSE",
      "household_chaos_unpredictability_fuss": "There is often a fuss going on at our home.",
      "household_chaos_unpredictability_fuss_opt_1": "TRUE",
      "household_chaos_unpredictability_fuss_opt_2": "FALSE",
      "household_chaos_unpredictability_family_plans_fail": "No matter what our family plans, it usually doesn't seem to work out.",
      "household_chaos_unpredictability_family_plans_fail_opt_1": "TRUE",
      "household_chaos_unpredictability_family_plans_fail_opt_2": "FALSE",
      "household_chaos_unpredictability_hear_yourself": "You can't hear yourself think in our home.",
      "household_chaos_unpredictability_hear_yourself_opt_1": "TRUE",
      "household_chaos_unpredictability_hear_yourself_opt_2": "FALSE",
      "household_chaos_unpredictability_other_people_arguments": "I often get drawn into other people's arguments at home.",
      "household_chaos_unpredictability_other_people_arguments_opt_1": "TRUE",
      "household_chaos_unpredictability_other_people_arguments_opt_2": "FALSE",
      "household_chaos_unpredictability_home_relax": "Our home is a good place to relax.",
      "household_chaos_unpredictability_home_relax_opt_1": "TRUE",
      "household_chaos_unpredictability_home_relax_opt_2": "FALSE",
      "household_chaos_unpredictability_telephone_home": "The telephone takes up a lot of our time at home.",
      "household_chaos_unpredictability_telephone_home_opt_1": "TRUE",
      "household_chaos_unpredictability_telephone_home_opt_2": "FALSE",
      "household_chaos_unpredictability_atmosphere_calm": "The atmosphere in our home is calm.",
      "household_chaos_unpredictability_atmosphere_calm_opt_1": "TRUE",
      "household_chaos_unpredictability_atmosphere_calm_opt_2": "FALSE",
      "household_chaos_unpredictability_regular_routine_home": "First thing in the day, we have a regular routine at home.",
      "household_chaos_unpredictability_regular_routine_home_opt_1": "TRUE",
      "household_chaos_unpredictability_regular_routine_home_opt_2": "FALSE"
    }
  }
}
