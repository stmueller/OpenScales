      "use_cocaine_soon_as_possible_opt_2": "2",
      "use_cocaine_soon_as_possible_opt_3": "3",
      "use_cocaine_soon_as_possible_opt_4": "4",
      "use_cocaine_soon_as_possible_opt_5": "5",
