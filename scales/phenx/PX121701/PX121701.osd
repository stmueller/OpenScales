  "translations": {
    "en": {
      "depression_adult_falling_asleep": "What response best decribes you falling asleep over the past seven days?",
      "depression_adult_falling_asleep_opt_0": "I never take longer than 30 minutes to fall asleep.",
      "depression_adult_falling_asleep_opt_1": "I take at least 30 minutes to fall asleep, less than half the time.",
      "depression_adult_falling_asleep_opt_2": "I take at least 30 minutes to fall asleep, more than half the time.",
      "depression_adult_falling_asleep_opt_3": "I take more than 60 minutes to fall asleep, more than half the time.",
      "depression_adult_sleep_night": "What response best decribes your sleep during the night over the past seven days?",
      "depression_adult_sleep_night_opt_0": "I do not wake up at night.",
      "depression_adult_sleep_night_opt_1": "I have a restless, light sleep with a few brief awakenings each night.",
      "depression_adult_sleep_night_opt_2": "I wake up at least once a night, but I go back to sleep easily.",
      "depression_adult_sleep_night_opt_3": "I awaken more than once a night and stay awake for 20 minutes or more, more than half the time.",
      "depression_adult_waking_up": "What response best decribes you waking up too early over the past seven days?",
      "depression_adult_waking_up_opt_0": "Most of the time, I awaken no more than 30 minutes before I need to get up.",
      "depression_adult_waking_up_opt_1": "More than half the time, I awaken more than 30 minutes before I need to get up.",
      "depression_adult_waking_up_opt_2": "I almost always awaken at least one hour or so before I need to, but I go back to sleep eventually.",
      "depression_adult_waking_up_opt_3": "I awaken at least one hour before I need to, and can't go back to sleep.",
      "depression_adult_sleeping_too_much": "What response best decribes you sleeping too much over the past seven days?",
      "depression_adult_sleeping_too_much_opt_0": "I sleep no longer than 7-8 hours/night, without napping during the day.",
      "depression_adult_sleeping_too_much_opt_1": "I sleep no longer than 10 hours in a 24-hour period including naps.",
      "depression_adult_sleeping_too_much_opt_2": "I sleep no longer than 12 hours in a 24-hour period including naps.",
      "depression_adult_sleeping_too_much_opt_3": "I sleep longer than 12 hours in a 24-hour period including naps.",
      "depression_adult_feeling_sad": "What response best decribes you feeling sad over the past seven days?",
      "depression_adult_feeling_sad_opt_0": "I do not feel sad.",
      "depression_adult_feeling_sad_opt_1": "I feel sad less than half the time.",
      "depression_adult_feeling_sad_opt_2": "I feel sad more than half the time.",
      "depression_adult_feeling_sad_opt_3": "I feel sad nearly all of the time.",
      "depression_adult_decreased_appetite": "What response best decribes you have decreased appetite over the past seven days?",
      "depression_adult_decreased_appetite_opt_0": "There is no change in my usual appetite.",
      "depression_adult_decreased_appetite_opt_1": "I eat somewhat less often or lesser amounts of food than usual.",
      "depression_adult_decreased_appetite_opt_2": "I eat much less than usual and only with personal effort.",
      "depression_adult_decreased_appetite_opt_3": "I rarely eat within a 24-hour period, and only with extreme personal effort or when others persuade me to eat.",
      "depression_adult_increased_appetite": "What response best decribes you have increased appetite over the past seven days?",
      "depression_adult_increased_appetite_opt_0": "There is no change from my usual appetite.",
      "depression_adult_increased_appetite_opt_1": "I feel a need to eat more frequently than usual.",
      "depression_adult_increased_appetite_opt_2": "I regularly eat more often and/or greater amounts of food than usual.",
      "depression_adult_increased_appetite_opt_3": "I feel driven to overeat both at mealtime and between meals.",
      "depression_adult_decreased_weight": "What response best decribes you have decreased weight over the past two weeks?",
      "depression_adult_decreased_weight_opt_0": "I have not had a change in my weight.",
      "depression_adult_decreased_weight_opt_1": "I feel as if I've had a slight weight loss.",
      "depression_adult_decreased_weight_opt_2": "I have lost 2 pounds or more.",
      "depression_adult_decreased_weight_opt_3": "I have lost 5 pounds or more.",
      "depression_adult_increased_weight": "What response best decribes you increased weight over the past two weeks?",
      "depression_adult_increased_weight_opt_0": "I have not had a change in my weight.",
      "depression_adult_increased_weight_opt_1": "I feel as if I've had a slight weight gain.",
      "depression_adult_increased_weight_opt_2": "I have gained 2 pounds or more.",
      "depression_adult_increased_weight_opt_3": "I have gained 5 pounds or more.",
      "depression_adult_concentration": "What response best decribes you concentration/decision making over the past seven days?",
      "depression_adult_concentration_opt_0": "There is no change in my usual capacity to concentrate or make decisions.",
      "depression_adult_concentration_opt_1": "I occasionally feel indecisive or find that my attention wanders.",
      "depression_adult_concentration_opt_2": "Most of the time, I struggle to focus my attention or to make decisions.",
      "depression_adult_concentration_opt_3": "I cannot concentrate well enough to read or cannot make even minor decisions.",
      "depression_adult_view_yourself": "What response best decribes your view of yourself over the past seven days?",
      "depression_adult_view_yourself_opt_0": "I see myself as equally worthwhile and deserving as other people.",
      "depression_adult_view_yourself_opt_1": "I am more self-blaming than usual.",
      "depression_adult_view_yourself_opt_2": "I largely believe that I cause problems for others.",
      "depression_adult_view_yourself_opt_3": "I think almost constantly about major and minor defects in myself.",
      "depression_adult_death_suicide": "What response best decribes your thoughts of death or suicide over the past seven days?",
      "depression_adult_death_suicide_opt_0": "I do not think of suicide or death.",
      "depression_adult_death_suicide_opt_1": "I feel that life is empty or wonder if it's worth living.",
      "depression_adult_death_suicide_opt_2": "I think of suicide or death several times a week for several minutes.",
      "depression_adult_death_suicide_opt_3": "I think of suicide or death several times a day in some detail, or I have made specific plans for suicide or have actually tried to take my life.",
      "depression_adult_general_interest": "What response best decribes your general Interest over the past seven days?",
      "depression_adult_general_interest_opt_0": "There is no change from usual in how interested I am in other people or activities.",
      "depression_adult_general_interest_opt_1": "I notice that I am less interested in people or activities.",
      "depression_adult_general_interest_opt_2": "I find I have interest in only one or two of my formerly pursued activities.",
      "depression_adult_general_interest_opt_3": "I have virtually no interest in formerly pursued activities.",
      "depression_adult_energy_level": "What response best decribes your energy Level over the past seven days?",
      "depression_adult_energy_level_opt_0": "There is no change in my usual level of energy.",
      "depression_adult_energy_level_opt_1": "I get tired more easily than usual.",
      "depression_adult_energy_level_opt_2": "I have to make a big effort to start or finish my usual daily activities (for example, shopping, homework, cooking, or going to work).",
      "depression_adult_energy_level_opt_3": "I really cannot carry out most of my usual daily activities because I just don't have the energy.",
      "depression_adult_slowed_down": "What response best decribes you feeling slowed down over the past seven days?",
      "depression_adult_slowed_down_opt_0": "I think, speak, and move at my usual rate of speed.",
      "depression_adult_slowed_down_opt_1": "I find that my thinking is slowed down or my voice sounds dull or flat.",
      "depression_adult_slowed_down_opt_2": "It takes me several seconds to respond to most questions and I'm sure my thinking is slowed.",
      "depression_adult_slowed_down_opt_3": "I am often unable to respond to questions without extreme effort.",
      "depression_adult_restless": "What response best decribes you feeling restless over the past seven days?",
      "depression_adult_restless_opt_0": "I do not feel restless.",
      "depression_adult_restless_opt_1": "I'm often fidgety, wringing my hands, or need to shift how I am sitting.",
      "depression_adult_restless_opt_2": "I have impulses to move about and am quite restless.",
      "depression_adult_restless_opt_3": "At times, I am unable to stay seated and need to pace around.",
      "likert_1": "I never take longer than 30 minutes to fall asleep.",
      "likert_2": "I take at least 30 minutes to fall asleep, less than half the time.",
      "likert_3": "I take at least 30 minutes to fall asleep, more than half the time.",
      "likert_4": "I take more than 60 minutes to fall asleep, more than half the time."
    }
  }
}
