{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Pre-existing Conditions Associated with Cancer",
      "code": "PX070801",
      "abbreviation": "PX070801",
      "description": "This self-administered protocol asks respondents to indicate the year of diagnosis for clinician-diagnosed illnesses. The respondent is also asked to provide the year of first diagnosis.",
