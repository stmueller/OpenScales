        "dimension": "high_standards"
      }
    ],
    "scoring": {
      "alt_search": {
        "description": "Mean of Alternative Search items (1-7). Higher scores indicate a greater tendency to seek out all possible alternatives before deciding. Corresponds to items 1, 2, and 4 of the original Schwartz et al. (2002) 13-item scale.",
        "method": "mean_coded",
        "items": [
          "smi1",
          "smi2",
          "smi3"
        ]
      },
      "decision_difficulty": {
        "description": "Mean of Decision Difficulty items (1-7). Higher scores indicate greater experienced difficulty when making decisions. Corresponds to items 7, 8, and 9 of the original Schwartz et al. (2002) 13-item scale.",
        "method": "mean_coded",
        "items": [
          "smi4",
          "smi5",
          "smi6"
        ]
      },
      "high_standards": {
        "description": "Mean of High Standards items (1-7). Higher scores indicate higher personal standards and expectations for oneself and one's choices. Corresponds to items 11, 12, and 13 of the original Schwartz et al. (2002) 13-item scale.",
        "method": "mean_coded",
        "items": [
          "smi7",
          "smi8",
          "smi9"
        ]
      }
    }
  },
  "translations": {
    "en": {
      "likert_1": "Completely Disagree",
      "likert_2": "Disagree",
      "likert_3": "Somewhat Disagree",
      "likert_4": "Neither Agree nor Disagree",
      "likert_5": "Somewhat Agree",
      "likert_6": "Agree",
      "likert_7": "Completely Agree",
      "question_head": "Please indicate how much you agree or disagree with each of the following statements.",
      "smi1": "When I watch TV, I channel surf, often scanning through the available options even while attempting to watch one program.",
      "smi2": "When I am in the car listening to the radio, I often check other stations to see if something better is playing, even if I am relatively satisfied with what I'm listening to.",
      "smi3": "No matter how satisfied I am with my job, it's only right for me to be on the lookout for better opportunities.",
      "smi4": "I often find it difficult to shop for a gift for a friend.",
      "smi5": "When shopping, I have a hard time finding clothing that I really love.",
      "smi6": "Renting videos is really difficult. I'm always struggling to pick the best one.",
      "smi7": "No matter what I do, I have the highest standards for myself.",
      "smi8": "I never settle for second best.",
      "smi9": "Whenever I'm faced with a choice, I try to imagine what all the other possibilities are, even ones that aren't present at the moment."
    }
  }
}
