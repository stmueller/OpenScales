  "translations": {
    "en": {
      "weight_in_pounds": "Enter weight in pounds or kilograms",
      "weight_in_pounds_opt_1": "pounds",
      "weight_in_pounds_opt_2": "kilograms",
      "twentyweek_weight_before_kgs": "For women who are currently at least 20 weeks pregnant, ask the following questions:  Just before you got pregnant with your current pregnancy, how much did you weigh?",
      "twentyweek_weight_before_lbs": "For women who are currently at least 20 weeks pregnant, ask the following questions:  Just before you got pregnant with your current pregnancy, how much did you weigh?",
      "twentyweek_weight_before_lbs_coded": "For women who are currently at least 20 weeks pregnant, ask the following questions:  Just before you got pregnant with your current pregnancy, how much did you weigh?",
      "twentyweek_weight_before_lbs_coded_opt_1": "REFUSED",
      "twentyweek_weight_before_lbs_coded_opt_2": "DON'T KNOW",
      "twentyweek_weight_gained_kgs": "For women who are currently at least 20 weeks pregnant, ask the following questions:  How much weight have you gained during this pregnancy?",
      "twentyweek_weight_gained_lbs": "For women who are currently at least 20 weeks pregnant, ask the following questions:  How much weight have you gained during this pregnancy?",
      "twentyweek_weight_gained_coded": "For women who are currently at least 20 weeks pregnant, ask the following questions:  How much weight have you gained during this pregnancy?",
      "twentyweek_weight_gained_coded_opt_1": "I LOST weight during your pregnancy",
      "twentyweek_weight_gained_coded_opt_2": "I don't know",
      "pregnancy_weeks": "For women who are currently at least 20 weeks pregnant, ask the following questions:  How many weeks pregnant are you currently?",
      "parous_weight_before_kgs": "For women who are not currently pregnant (but parous), ask the following questions:  How much did you weigh before your most recent pregnancy?",
      "parous_weight_before_lbs": "For women who are not currently pregnant (but parous), ask the following questions:  How much did you weigh before your most recent pregnancy?",
      "parous_weight_gained_kgs": "For women who are not currently pregnant (but parous), ask the following questions:  How much weight did you gain during your most recent pregnancy?",
      "parous_weight_gained_lbs": "For women who are not currently pregnant (but parous), ask the following questions:  How much weight did you gain during your most recent pregnancy?",
      "parous_weight_gained_coded": "For women who are not currently pregnant (but parous), ask the following questions:  How much weight did you gain during your most recent pregnancy?",
      "parous_weight_gained_coded_opt_1": "I LOST weight during your pregnancy",
      "parous_weight_gained_coded_opt_2": "I don't know",
      "parous_delivery_weeks": "For women who are not currently pregnant (but parous), ask the following questions:  For your most recent pregnancy, how many weeks along were you when you delivered?"
    }
