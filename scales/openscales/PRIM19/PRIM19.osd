  "definition": {
    "scale_info": {
      "name": "Positive Relationships Scale (PRIM+19)",
      "code": "PRIM19",
      "abbreviation": "PRIM+19",
      "description": "19-item measure of positive relationships (PRIM+19). Three subscales: Development of Positive Bonds (6 items), Management of Interpersonal Relationships (5 items), Integration in the Social Circle (8 items). Scored 0 (does not describe me) to 3 (describes me very well). All items direct; higher scores indicate greater positive relationships.",
      "citation": "Vilca, L. W., Aquino-Hidalgo, J. M., Esteban-Brañes, J., & Caycho-Rodríguez, T. (2023). Development and psychometric study of the scale of the positive relationship PRIM+19 in Peruvian university students. BMC Psychology, 11(1). https://doi.org/10.1186/s40359-023-01094-6. [APA PsycTests: https://doi.org/10.1037/t95443-000]",
      "license": "CC BY 4.0",
      "license_explanation": "Published in BMC Psychology under Creative Commons Attribution 4.0 International License.",
      "license_url": "https://doi.org/10.1186/s40359-023-01094-6",
      "version": "1.0",
      "url": "https://doi.org/10.1186/s40359-023-01094-6",
      "domain": "Social",
      "n_items": "19"
    },
    "likert_options": {
      "points": 4,
      "min": 0,
      "max": 3,
      "labels": [
        "likert_0",
        "likert_1",
        "likert_2",
        "likert_3"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "bonds",
        "name": "Development of Positive Bonds",
        "description": "Development of positive interpersonal bonds (6 items: 1,5,9,13,16,19)."
      },
      {
        "id": "management",
        "name": "Management of Interpersonal Relationships",
        "description": "Management of interpersonal relationships (5 items: 2,6,10,14,17)."
      },
      {
        "id": "integration",
        "name": "Integration in the Social Circle",
        "description": "Integration in the social circle (8 items: 3,4,7,8,11,12,15,18)."
      },
      {
        "id": "total",
        "name": "Total Positive Relationships",
        "description": "Mean of all 19 items (range 0-3). Higher scores indicate greater positive relationships."
      }
    ],
