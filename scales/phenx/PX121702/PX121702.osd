  "translations": {
    "en": {
      "depression_questionnaire_children_felt_miserable": "I felt miserable or unhappy.",
      "depression_questionnaire_children_enjoy": "I didn't enjoy anything at all.",
      "depression_questionnaire_children_sat_around": "I felt so tired I just sat around and did nothing.",
      "depression_questionnaire_children_restless": "I was very restless.",
      "depression_questionnaire_children_no_good": "I felt I was no good anymore.",
      "depression_questionnaire_children_cried": "I cried a lot.",
      "depression_questionnaire_children_hard_to_think": "I found it hard to think properly or concentrate.",
      "depression_questionnaire_children_hate_myself": "I hated myself.",
      "depression_questionnaire_children_bad_person": "I was a bad person.",
      "depression_questionnaire_children_felt_lonely": "I felt lonely.",
      "depression_questionnaire_children_loved_me": "I thought nobody really loved me.",
      "depression_questionnaire_children_good_other_kids": "I thought I could never be as good as other kids.",
