  "translations": {
    "en": {
      "prenatal_postpartum_depression_laugh_funny": "I have been able to laugh and see the funny side of things",
      "prenatal_postpartum_depression_laugh_funny_opt_1": "As much as I always could",
      "prenatal_postpartum_depression_laugh_funny_opt_2": "Not quite so much now",
      "prenatal_postpartum_depression_laugh_funny_opt_3": "Definitely not so much now",
      "prenatal_postpartum_depression_laugh_funny_opt_4": "Not at all",
      "prenatal_postpartum_depression_enjoyment": "I have looked forward with enjoyment to things",
      "prenatal_postpartum_depression_enjoyment_opt_1": "As much as I ever did",
      "prenatal_postpartum_depression_enjoyment_opt_2": "Rather less than I used to",
      "prenatal_postpartum_depression_enjoyment_opt_3": "Definitely less than I used to",
      "prenatal_postpartum_depression_enjoyment_opt_4": "Hardly at all",
      "prenatal_postpartum_depression_blame": "I have blamed myself unnecessarily when things went wrong",
      "prenatal_postpartum_depression_blame_opt_1": "Yes, most of the time",
      "prenatal_postpartum_depression_blame_opt_2": "Yes, some of the time",
      "prenatal_postpartum_depression_blame_opt_3": "Not very often",
      "prenatal_postpartum_depression_blame_opt_4": "No, never",
      "prenatal_postpartum_depression_anxiety_worry": "I have been anxious or worried for no good reason",
      "prenatal_postpartum_depression_anxiety_worry_opt_1": "No, not at all",
      "prenatal_postpartum_depression_anxiety_worry_opt_2": "Hardly ever",
      "prenatal_postpartum_depression_anxiety_worry_opt_3": "Yes, sometimes",
      "prenatal_postpartum_depression_anxiety_worry_opt_4": "Yes, very often",
      "prenatal_postpartum_depression_scared_panicky": "I have felt scared or panicky for no very good reason",
      "prenatal_postpartum_depression_scared_panicky_opt_1": "Yes, quite a lot",
      "prenatal_postpartum_depression_scared_panicky_opt_2": "Yes, sometimes",
      "prenatal_postpartum_depression_scared_panicky_opt_3": "No, not much",
      "prenatal_postpartum_depression_scared_panicky_opt_4": "No, not at all",
      "prenatal_postpartum_depression_overwhelmed": "Things have been getting on top of me",
      "prenatal_postpartum_depression_overwhelmed_opt_1": "Yes, most of the time I haven't been able to cope at all",
      "prenatal_postpartum_depression_overwhelmed_opt_2": "Yes, sometimes I haven't been coping as well as usual",
      "prenatal_postpartum_depression_overwhelmed_opt_3": "No, most of the time I have coped quite well",
      "prenatal_postpartum_depression_overwhelmed_opt_4": "No, have been coping as well as ever",
      "prenatal_postpartum_depression_unhappy_affect_sleep": "I have been so unhappy that I have had difficulty sleeping",
      "prenatal_postpartum_depression_unhappy_affect_sleep_opt_1": "Yes, most of the time",
      "prenatal_postpartum_depression_unhappy_affect_sleep_opt_2": "Yes, sometimes",
      "prenatal_postpartum_depression_unhappy_affect_sleep_opt_3": "Not very often",
      "prenatal_postpartum_depression_unhappy_affect_sleep_opt_4": "No, not at all",
      "prenatal_postpartum_depression_sad_miserable": "I have felt sad or miserable",
      "prenatal_postpartum_depression_sad_miserable_opt_1": "Yes, most of the time",
      "prenatal_postpartum_depression_sad_miserable_opt_2": "Yes, quite often",
      "prenatal_postpartum_depression_sad_miserable_opt_3": "Not very often",
      "prenatal_postpartum_depression_sad_miserable_opt_4": "No, not at all",
      "prenatal_postpartum_depression_unhappy_crying": "I have been so unhappy that I have been crying",
      "prenatal_postpartum_depression_unhappy_crying_opt_1": "Yes, most of the time",
      "prenatal_postpartum_depression_unhappy_crying_opt_2": "Yes, quite often",
      "prenatal_postpartum_depression_unhappy_crying_opt_3": "Only occasionally",
      "prenatal_postpartum_depression_unhappy_crying_opt_4": "No, never",
      "prenatal_postpartum_depression_self_harm": "The thought of harming myself has occurred to me",
      "prenatal_postpartum_depression_self_harm_opt_1": "Yes, quite often",
      "prenatal_postpartum_depression_self_harm_opt_2": "Sometimes",
      "prenatal_postpartum_depression_self_harm_opt_3": "Hardly ever",
      "prenatal_postpartum_depression_self_harm_opt_4": "Never"
    }
  }
}
