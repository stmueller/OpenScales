  "translations": {
    "en": {
      "SubstanceUse_Ever_Smoked_Cigarettes": "Have you ever smoked cigarettes?",
      "SubstanceUse_PastMonth_Smoking_Frequency": "How frequently have you smoked cigarettes during the past 30 days?",
      "SubstanceUse_Ever_SmokelessTobacco": "Have you ever taken or used smokeless tobacco (snuff, plug, dipping tobacco, chewing tobacco, snus, dissolvable tobacco)?",
      "SubstanceUse_PastMonth_SmokelessTobacco_Frequency": "How frequently have you taken smokeless tobacco during the past 30 days?",
      "SubstanceUse_Ever_Drink_Alcohol": "Next we want to ask you about drinking alcoholic beverages, including beer, wine, liquor, and any other beverage that contains alcohol. Have you ever had any alcoholic beverage to drink-more than just a few sips?",
      "SubstanceUse_Ever_Drink_Alcohol_opt_1": "No",
      "SubstanceUse_Ever_Drink_Alcohol_opt_2": "Yes",
      "SubstanceUse_Lifetime_Alcohol": "On how many occasions have you had alcoholic beverages to drink - more than just a few sips in your lifetime?",
      "SubstanceUse_PastYear_Alcohol": "On how many occasions have you had alcoholic beverages to drink - more than just a few sips during the last 12 months?",
      "SubstanceUse_PastMonth_Alcohol": "On how many occasions have you had alcoholic beverages to drink - more than just a few sips during the last 30 days?",
      "SubstanceUse_PastTwoWeeks_Five_Drinks": "Think back over the LAST TWO WEEKS. How many times have you had five or more drinks in a row? (A \"drink\" is a glass of wine, a bottle of beer, a shot glass or liquor, a mixed drink, etc.)",
      "SubstanceUse_Lifetime_Marijuana_Hashish": "On how many occasions (if any) have you used marijuana (weed, pot) or hashish (hash, hash oil) in your lifetime?",
      "SubstanceUse_PastYear_Marijuana_Hashish": "On how many occasions (if any) have you used marijuana (weed, pot) or hashish (hash, hash oil) during the last 12 months?",
      "SubstanceUse_PastMonth_Marijuana_Hashish": "On how many occasions (if any) have you used marijuana (weed, pot) or hashish (hash, hash oil) during the last 30 days?",
      "SubstanceUse_Lifetime_LSD": "On how many occasions (if any) have you used LSD (\"acid\") in your lifetime?",
      "SubstanceUse_PastYear_LSD": "On how many occasions (if any) have you used LSD (\"acid\") during the last 12 months?",
      "SubstanceUse_PastMonth_LSD": "On how many occasions (if any) have you used LSD (\"acid\") during the last 30 days?",
      "SubstanceUse_Lifetime_Other_Hallucinogen": "On how many occasions (if any) have you used hallucinogens other than LSD (like mescaline, peyote, 'shrooms' or psilocybin, PCP) in your lifetime?",
      "SubstanceUse_PastYear_Other_Hallucinogen": "On how many occasions (if any) have you used hallucinogens other than LSD (like mescaline, peyote, 'shrooms' or psilocybin, PCP) during the last 12 months?",
      "SubstanceUse_PastMonth_Other_Hallucinogen": "On how many occasions (if any) have you used hallucinogens other than LSD (like mescaline, peyote, 'shrooms' or psilocybin, PCP) during the last 30 days?",
      "SubstanceUse_Lifetime_Cocaine": "On how many occasions (if any) have you used cocaine (sometimes called 'coke,' 'crack', 'rock') if your lifetime?",
      "SubstanceUse_PastYear_Cocaine": "On how many occasions (if any) have you used cocaine (sometimes called 'coke,' 'crack', 'rock') during the last 12 months?",
      "SubstanceUse_PastMonth_Cocaine": "On how many occasions (if any) have you used cocaine (sometimes called 'coke,' 'crack', 'rock') during the last 30 days?",
      "SubstanceUse_Lifetime_Crack": "On how many occasions (if any) have you used \"crack\" in your lifetime?",
      "SubstanceUse_PastYear_Crack": "On how many occasions (if any) have you used \"crack\" during the last 12 months?",
      "SubstanceUse_PastMonth_Crack": "On how many occasions (if any) have you used \"crack\" during the last 30 days?",
      "SubstanceUse_Lifetime_Other_Cocaine": "On how many occasions (if any) have you used cocaine in any other form in your lifetime?",
      "SubstanceUse_PastYear_Other_Cocaine": "On how many occasions (if any) have you used cocaine in any other form during the last 12 months?",
      "SubstanceUse_PastMonth_Other_Cocaine": "On how many occasions (if any) have you used cocaine in any other form during the last 30 days?",
      "SubstanceUse_Lifetime_Amphetamines": "On how many occasions (if any) have you taken amphetamines or other prescription stimulant drugs on your own�that is, without a doctor telling you to take them in your lifetime?",
      "SubstanceUse_PastYear_Amphetamines": "On how many occasions (if any) have you taken amphetamines or other prescription stimulant drugs on your own�that is, without a doctor telling you to take them during the last 12 months?",
      "SubstanceUse_PastMonth_Amphetamines": "On how many occasions (if any) have you taken amphetamines or other prescription stimulant drugs on your own�that is, without a doctor telling you to take them during the last 30 days?",
      "SubstanceUse_Lifetime_Methamphetamine": "On how many occasions (if any) have you used methamphetamine (\"meth,\" \"speed,\" \"crank,\" \"crystal meth\") by any method in your lifetime?",
      "SubstanceUse_PastYear_Methamphetamine": "On how many occasions (if any) have you used methamphetamine (\"meth,\" \"speed,\" \"crank,\" \"crystal meth\") by any method during the last 12 months?",
      "SubstanceUse_PastMonth_Methamphetamine": "On how many occasions (if any) have you used methamphetamine (\"meth,\" \"speed,\" \"crank,\" \"crystal meth\") by any method during the last 30 days?",
