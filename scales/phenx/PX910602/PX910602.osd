  "translations": {
    "en": {
      "school_work_attendance_adult_current_employment": "Are you currently employed (working for pay)?",
      "school_work_attendance_adult_current_employment_opt_1": "Yes",
      "school_work_attendance_adult_current_employment_opt_2": "No",
      "school_work_attendance_adult_past_week_missed_work_health": "During the past seven days, how many hours did you miss from work because of your health problems?",
      "school_work_attendance_adult_past_week_missed_work_vacation": "During the past seven days, how many hours did you miss from work because of any other reason, such as vacation, holidays, time off to participate in this study?",
      "school_work_attendance_adult_past_week_hours_worked": "During the past seven days, how many hours did you actually work?",
      "school_work_attendance_adult_past_week_health_productivity": "During the past seven days, how much did your health problems affect your productivity while you were working?",
      "school_work_attendance_adult_past_week_health_productivity_opt_1": "0 = Health problems had no effect on my work",
      "school_work_attendance_adult_past_week_health_productivity_opt_2": "1",
      "school_work_attendance_adult_past_week_health_productivity_opt_3": "2",
      "school_work_attendance_adult_past_week_health_productivity_opt_4": "3",
      "school_work_attendance_adult_past_week_health_productivity_opt_5": "4",
      "school_work_attendance_adult_past_week_health_productivity_opt_6": "5",
