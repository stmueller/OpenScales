  "translations": {
    "en": {
      "likert_1": "Very untrue of me",
      "likert_2": "Moderately untrue of me",
      "likert_3": "Neither true nor untrue of me",
      "likert_4": "Moderately true of me",
      "likert_5": "Very true of me",
      "question_head": "<h3>How Accurately Can You Describe Yourself?</h3>\nDescribe yourself as you generally are now, not as you wish to be in the future. Describe yourself as you honestly see yourself, in relation to other people you know of the same sex as you are, and roughly your same age. So that you can describe yourself in an honest manner, your responses will be kept in absolute confidence. Indicate how true each statement is of you.",
      "ipip_catpd_001": "Act without planning.",
      "ipip_catpd_002": "Am a firm believer in thinking things through.",
      "ipip_catpd_003": "Do things without thinking of the consequences.",
      "ipip_catpd_004": "Jump into things without thinking.",
      "ipip_catpd_005": "Make careful choices.",
      "ipip_catpd_006": "Prefer to 'live in the moment' rather than plan things out.",
      "ipip_catpd_007": "Am a cold-hearted person.",
      "ipip_catpd_008": "Am indifferent to the feelings of others.",
      "ipip_catpd_009": "Am not a caring person.",
      "ipip_catpd_010": "Am not a sympathetic person.",
      "ipip_catpd_011": "Can't be bothered with others' needs.",
      "ipip_catpd_012": "Care about others.",
      "ipip_catpd_013": "Do not care how my actions affect others.",
      "ipip_catpd_014": "Am a law-abiding citizen.",
      "ipip_catpd_015": "Get in trouble with the law.",
      "ipip_catpd_016": "Got in trouble a lot at school.",
      "ipip_catpd_017": "Have a rebellious side that gets me into trouble.",
      "ipip_catpd_018": "Have always been a rule-breaker.",
      "ipip_catpd_019": "Have done many things for which I could have been (or was) arrested.",
      "ipip_catpd_020": "Respect authority.",
      "ipip_catpd_021": "Am a strange person.",
      "ipip_catpd_022": "Am considered to be kind of eccentric.",
      "ipip_catpd_023": "Am odd.",
      "ipip_catpd_024": "Have been told that my behavior often is bizarre.",
      "ipip_catpd_025": "Would describe myself as a normal person.",
      "ipip_catpd_026": "Am a very reliable person.",
      "ipip_catpd_027": "Am not a dependable person.",
      "ipip_catpd_028": "Avoid responsibilities.",
      "ipip_catpd_029": "Cannot be counted on to get things done.",
      "ipip_catpd_030": "Follow through with my plans.",
      "ipip_catpd_031": "Keep my appointments.",
      "ipip_catpd_032": "Neglect my duties.",
      "ipip_catpd_033": "Am a workaholic, with little time for fun or pleasure.",
      "ipip_catpd_034": "Have noticed that I put my work ahead of too many other things.",
      "ipip_catpd_035": "Work longer hours than most people.",
      "ipip_catpd_036": "Work so hard that my relationships have suffered.",
      "ipip_catpd_037": "Work too much.",
      "ipip_catpd_038": "Am able to describe my feelings easily.",
      "ipip_catpd_039": "Am emotionally reserved.",
      "ipip_catpd_040": "Am not good at describing the emotions I feel throughout the day.",
      "ipip_catpd_041": "Am open about my feelings.",
      "ipip_catpd_042": "Have difficulty expressing my feelings.",
      "ipip_catpd_043": "Have difficulty showing affection.",
      "ipip_catpd_044": "Think it's best to keep my emotions to myself.",
      "ipip_catpd_045": "Am able to read the minds of others.",
      "ipip_catpd_046": "Believe I have supernatural powers.",
      "ipip_catpd_047": "Can control objects with my mind.",
      "ipip_catpd_048": "Can predict the outcome of events.",
      "ipip_catpd_049": "Can see into the future.",
      "ipip_catpd_050": "Have the power to cast spells on others.",
      "ipip_catpd_051": "Use magic to ward off bad thoughts about me.",
      "ipip_catpd_052": "Am afraid that my life will be cut short by illness.",
      "ipip_catpd_053": "Am prone to complain about my health.",
      "ipip_catpd_054": "Have medical problems that my doctors don't understand.",
      "ipip_catpd_055": "Often am concerned about diseases I might have.",
      "ipip_catpd_056": "Think that I am in good medical condition.",
      "ipip_catpd_057": "Worry a lot about catching a serious illness.",
      "ipip_catpd_058": "Worry about my health.",
      "ipip_catpd_059": "Am always worried that my partner is going to leave me.",
      "ipip_catpd_060": "Am paralyzed by a fear of rejection.",
      "ipip_catpd_061": "Am secure in my relationships.",
      "ipip_catpd_062": "Am usually convinced that my friends and romantic partners will betray me.",
      "ipip_catpd_063": "Generally trust my partners to be faithful to me.",
      "ipip_catpd_064": "Get jealous easily.",
      "ipip_catpd_065": "Usually believe that my friends will abandon me.",
      "ipip_catpd_066": "Am an energetic person.",
      "ipip_catpd_067": "Am not a joyful person.",
      "ipip_catpd_068": "Feel that nothing seems to make me feel good.",
      "ipip_catpd_069": "Find nothing excites me.",
      "ipip_catpd_070": "Have a lot of fun.",
      "ipip_catpd_071": "Have trouble getting interested in things.",
      "ipip_catpd_072": "Am an honest person.",
      "ipip_catpd_073": "Cheat to get ahead.",
      "ipip_catpd_074": "Deceive people.",
      "ipip_catpd_075": "Have exploited others for my own gain.",
      "ipip_catpd_076": "Like to trick people into doing things for me.",
      "ipip_catpd_077": "Take advantage of others.",
      "ipip_catpd_078": "Am convinced that my way is the best way.",
      "ipip_catpd_079": "Am inflexible when I think I'm right.",
      "ipip_catpd_080": "Am often accused of being narrow-minded.",
      "ipip_catpd_081": "Believe strongly that the world would be a much better place if I had my way.",
      "ipip_catpd_082": "Believe that most questions have one right answer.",
      "ipip_catpd_083": "Do not like reading or hearing opinions that go against my way of thinking.",
      "ipip_catpd_084": "Find it difficult to compromise in policy debates.",
      "ipip_catpd_085": "Find it difficult to consider as valid opinions that differ from my own.",
      "ipip_catpd_086": "Have been told that I am rigid and inflexible.",
      "ipip_catpd_087": "Have fixed opinions.",
      "ipip_catpd_088": "Am easily controlled by others in my life.",
      "ipip_catpd_089": "Let myself be directed by others.",
      "ipip_catpd_090": "Let myself be pushed around.",
      "ipip_catpd_091": "Let others take advantage of me.",
      "ipip_catpd_092": "Need others to help run my life",
      "ipip_catpd_093": "Prefer that others make the major decisions in my life.",
      "ipip_catpd_094": "Am easily disoriented.",
      "ipip_catpd_095": "Easily lose my train of thought.",
      "ipip_catpd_096": "Formulate ideas clearly.",
      "ipip_catpd_097": "Frequently get things mixed up in my head.",
      "ipip_catpd_098": "Have a good memory for things I've done throughout the day.",
      "ipip_catpd_099": "Often feel like my thoughts make no sense.",
      "ipip_catpd_100": "Often have disorganized thoughts.",
      "ipip_catpd_101": "Often space out and lose track of what's going on.",
      "ipip_catpd_102": "Am easily distracted.",
      "ipip_catpd_103": "Am quick to quit when the going gets tough.",
      "ipip_catpd_104": "Finish what I start.",
      "ipip_catpd_105": "Have difficulty keeping my attention on a task.",
      "ipip_catpd_106": "Quickly lose interest in the tasks I start.",
      "ipip_catpd_107": "Quit tasks as soon as I get bored.",
      "ipip_catpd_108": "Am easily startled.",
      "ipip_catpd_109": "Am generally a fearful person.",
      "ipip_catpd_110": "Am nervous or tense most of the time.",
      "ipip_catpd_111": "Feel my anxiety overwhelms me.",
      "ipip_catpd_112": "Feel that my worry and anxiety is out of control.",
      "ipip_catpd_113": "Panic easily.",
      "ipip_catpd_114": "Am excited to inflict pain on others.",
      "ipip_catpd_115": "Am often out for revenge.",
      "ipip_catpd_116": "Am ready to hit someone when I get angry.",
      "ipip_catpd_117": "Enjoy a good brawl.",
      "ipip_catpd_118": "Get even with others.",
      "ipip_catpd_119": "Hurt people.",
      "ipip_catpd_120": "Like to start fights.",
      "ipip_catpd_121": "Will spread false rumors as a way to hurt others.",
      "ipip_catpd_122": "Am known as a controlling person.",
      "ipip_catpd_123": "Boss people around.",
      "ipip_catpd_124": "Have a strong need for power.",
      "ipip_catpd_125": "Insist that others do things my way.",
      "ipip_catpd_126": "Like having authority over others.",
      "ipip_catpd_127": "Make demands on others.",
      "ipip_catpd_128": "Am not happy until all the details are taken care of.",
      "ipip_catpd_129": "Don't consider a task finished until it's perfect.",
