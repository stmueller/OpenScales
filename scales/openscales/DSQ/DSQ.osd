{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Decision Styles Questionnaire",
      "code": "DSQ",
      "abbreviation": "DSQ",
      "description": "43-item self-report questionnaire measuring individual differences in decision-making styles and decisional self-esteem. Developed through factor analysis retaining 9 factors: Avoidant (5 items), Dependent (6 items), Vigilant (6 items), Brooding (5 items), Intuitive (5 items), Anxious (5 items), Spontaneous (4 items), Confident (5 items), and Respected (2 items). Confident and Respected together form Decisional Self-Esteem. Items rated on a 5-point scale (1 = Never/Almost Never, 5 = Always/Almost Always). Higher scores on each subscale indicate a stronger tendency toward that style.",
      "citation": "Leykin, Y., & DeRubeis, R. J. (2010). Decision-making styles and depressive symptomatology: Development of the Decision Styles Questionnaire. Judgment and Decision Making, 5(7), 506-515. https://doi.org/10.1017/S1930297500001674",
      "license": "CC BY 4.0",
      "version": "1.0",
      "url": "https://doi.org/10.1017/S1930297500001674"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5"
      ],
      "question_head": "question_head"
    },
    "shuffle_questions": 1,
    "dimensions": [
      {
        "id": "avoidant",
        "name": "Avoidant",
        "abbreviation": "DSQ-AV",
        "description": "Tendency to avoid or postpone decision making (5 items)"
      },
      {
        "id": "dependent",
        "name": "Dependent",
        "abbreviation": "DSQ-DE",
        "description": "Tendency to rely on advice and support from others when making decisions (6 items)"
      },
      {
        "id": "vigilant",
        "name": "Vigilant",
        "abbreviation": "DSQ-VG",
        "description": "Tendency to carefully consider all alternatives and information before deciding (6 items)"
      },
      {
        "id": "brooding",
        "name": "Brooding",
        "abbreviation": "DSQ-BR",
        "description": "Tendency to ruminate and dwell on past decisions and outcomes (5 items)"
      },
      {
        "id": "intuitive",
        "name": "Intuitive",
        "abbreviation": "DSQ-IN",
        "description": "Tendency to rely on gut feelings and intuition when making decisions (5 items)"
      },
      {
        "id": "anxious",
        "name": "Anxious",
        "abbreviation": "DSQ-AN",
        "description": "Tendency to experience anxiety and distress during decision making (5 items)"
      },
      {
        "id": "spontaneous",
        "name": "Spontaneous",
        "abbreviation": "DSQ-SP",
        "description": "Tendency to make quick, immediate decisions without extended deliberation (4 items)"
      },
      {
        "id": "confident",
        "name": "Confident",
        "abbreviation": "DSQ-CO",
        "description": "Perceived competence and confidence as a decision maker (5 items, 2 reverse-coded). Part of Decisional Self-Esteem."
      },
      {
        "id": "respected",
        "name": "Respected",
        "abbreviation": "DSQ-RE",
        "description": "Others seek one's help and advice in decision making (2 items). Part of Decisional Self-Esteem."
      }
    ],
