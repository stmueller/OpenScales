    "scale_info": {
      "name": "Long COVID - Symptoms Due to COVID-19 - Cardiovascular Symptom Course",
      "code": "PX992009",
      "abbreviation": "PX992009",
      "description": "A self-administered questionnaire to better describe and understand the patient experience and recovery of those with confirmed or suspected COVID-19, with a specific emphasis on Long COVID experience especially with heavy limbs, heart rate, temperature regulation and dizziness.",
