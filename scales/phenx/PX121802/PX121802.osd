  "translations": {
    "en": {
      "sec_below_is_a_list_of_sentences_that_descri_title": "Below is a list of sentences that describe how people feel. Read each phrase and decide if it is \"Not True or Hardly Ever True\" or \"Somewhat True or Sometimes True\" or \"Very True or Often True\" for you. Then, for each sentence, fill in one circle that corresponds to the response that seems to describe you for the last 3 months.",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_frightened_breathing": "When I feel frightened, it is hard to breathe.",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_frightened_breathing_opt_0": "Not true or hardly ever true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_frightened_breathing_opt_1": "Somewhat true or sometimes true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_frightened_breathing_opt_2": "Very true or often true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_headaches_school": "I get headaches when I am at school.",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_headaches_school_opt_0": "Not true or hardly ever true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_headaches_school_opt_1": "Somewhat true or sometimes true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_headaches_school_opt_2": "Very true or often true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_feelings_strangers": "I don't like to be with people I don't know well.",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_feelings_strangers_opt_0": "Not true or hardly ever true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_feelings_strangers_opt_1": "Somewhat true or sometimes true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_feelings_strangers_opt_2": "Very true or often true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_scared_sleep_away_from_home": "I get scared if I sleep away from home.",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_scared_sleep_away_from_home_opt_0": "Not true or hardly ever true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_scared_sleep_away_from_home_opt_1": "Somewhat true or sometimes true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_scared_sleep_away_from_home_opt_2": "Very true or often true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_worry_others_liking_me": "I worry about other people liking me.",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_worry_others_liking_me_opt_0": "Not true or hardly ever true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_worry_others_liking_me_opt_1": "Somewhat true or sometimes true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_worry_others_liking_me_opt_2": "Very true or often true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_frightened_passing_out": "When I get frightened, I feel like passing out.",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_frightened_passing_out_opt_0": "Not true or hardly ever true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_frightened_passing_out_opt_1": "Somewhat true or sometimes true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_frightened_passing_out_opt_2": "Very true or often true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_nervous": "I am nervous.",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_nervous_opt_0": "Not true or hardly ever true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_nervous_opt_1": "Somewhat true or sometimes true",
