    "en": {
      "recovery_selfassessment_patient_welcoming_staff": "Staff welcome me and help me feel comfortable in this program. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_patient_welcoming_staff_opt_1": "1",
      "recovery_selfassessment_patient_welcoming_staff_opt_2": "2",
