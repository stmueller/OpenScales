      "psychopathologyquestionnaire_dissatisfaction_shape_opt_5": "5",
      "psychopathologyquestionnaire_dissatisfaction_shape_opt_6": "Markedly",
      "psychopathologyquestionnaire_uncomfortable_seeing_body": "Over the past 28 days, how uncomfortable have you felt seeing your body (for example, seeing your shape in the mirror, in a shop window reflection, while undressing or taking a bath or shower)?",
      "psychopathologyquestionnaire_uncomfortable_seeing_body_opt_0": "Not at all",
      "psychopathologyquestionnaire_uncomfortable_seeing_body_opt_1": "1",
      "psychopathologyquestionnaire_uncomfortable_seeing_body_opt_2": "Slightly",
      "psychopathologyquestionnaire_uncomfortable_seeing_body_opt_3": "3",
      "psychopathologyquestionnaire_uncomfortable_seeing_body_opt_4": "Moderately",
      "psychopathologyquestionnaire_uncomfortable_seeing_body_opt_5": "5",
      "psychopathologyquestionnaire_uncomfortable_seeing_body_opt_6": "Markedly",
      "psychopathologyquestionnaire_uncomfortable_others_seeing_body": "Over the past 28 days, how uncomfortable have you felt about others seeing your shape or figure (for example, in communal changing rooms, when swimming, or wearing tight clothes?",
      "psychopathologyquestionnaire_uncomfortable_others_seeing_body_opt_0": "Not at all",
