  "translations": {
    "en": {
      "vfq1": "In general, would you say your overall health is:",
      "vfq_health1": "Excellent",
      "vfq_health2": "Very good",
      "vfq_health3": "Good",
      "vfq_health4": "Fair",
      "vfq_health5": "Poor",
      "vfq2": "At the present time, would you say your eyesight using both eyes (with glasses or contact lenses, if you wear them) is excellent, good, fair, poor, or very poor, or are you completely blind?",
      "vfq_vis1": "Excellent",
      "vfq_vis2": "Good",
      "vfq_vis3": "Fair",
      "vfq_vis4": "Poor",
      "vfq_vis5": "Very poor",
      "vfq_vis6": "Completely blind",
      "vfq3": "How much of the time do you worry about your eyesight?",
      "vfq_freq1": "None of the time",
      "vfq_freq2": "A little of the time",
      "vfq_freq3": "Some of the time",
      "vfq_freq4": "Most of the time",
      "vfq_freq5": "All of the time",
      "vfq4": "How much pain or discomfort have you had in and around your eyes (for example, burning, itching, or aching)? Would you say it is:",
      "vfq_pain1": "None",
      "vfq_pain2": "Mild",
      "vfq_pain3": "Moderate",
      "vfq_pain4": "Severe",
      "vfq_pain5": "Very severe",
      "vfq_act_head": "The next questions are about how much difficulty, if any, you have doing certain activities wearing your glasses or contact lenses if you use them.",
      "vfq_diff1": "No difficulty at all",
      "vfq_diff2": "A little difficulty",
      "vfq_diff3": "Moderate difficulty",
      "vfq_diff4": "Extreme difficulty",
      "vfq_diff5": "Stopped doing this because of your eyesight",
      "vfq5": "How much difficulty do you have reading ordinary print in newspapers?",
      "vfq6": "How much difficulty do you have doing work or hobbies that require you to see well up close, such as cooking, sewing, fixing things around the house, or using hand tools?",
      "vfq7": "Because of your eyesight, how much difficulty do you have finding something on a crowded shelf?",
      "vfq8": "How much difficulty do you have reading street signs or the names of stores?",
      "vfq9": "Because of your eyesight, how much difficulty do you have going down steps, stairs, or curbs in dim light or at night?",
      "vfq10": "Because of your eyesight, how much difficulty do you have noticing objects off to the side while you are walking?",
      "vfq11": "Because of your eyesight, how much difficulty do you have seeing how people react to things you say?",
      "vfq12": "Because of your eyesight, how much difficulty do you have picking out and matching your own clothes?",
      "vfq13": "Because of your eyesight, how much difficulty do you have visiting with people in their homes, at parties, or in restaurants?",
      "vfq14": "Because of your eyesight, how much difficulty do you have going out to see movies, plays, or sports events?",
      "vfq15": "Are you currently driving, at least once in a while?",
      "vfq15_yes": "Yes",
      "vfq15_no": "No",
      "vfq15a": "Have you never driven a car or have you given up driving?",
      "vfq15a_never": "Never drove",
      "vfq15a_gaveup": "Gave up",
      "vfq15b": "Was that mainly because of your eyesight, mainly for some other reason, or because of both your eyesight and other reasons?",
      "vfq15b_eyesight": "Mainly eyesight",
      "vfq15b_other": "Mainly other reasons",
      "vfq15b_both": "Both eyesight and other reasons",
      "vfq15c": "How much difficulty do you have driving during the daytime in familiar places?",
      "vfq_drv1": "No difficulty at all",
      "vfq_drv2": "A little difficulty",
      "vfq_drv3": "Moderate difficulty",
      "vfq_drv4": "Extreme difficulty",
      "vfq17": "How much difficulty do you have doing work or hobbies that require you to see well up close, such as cooking, sewing, fixing things around the house, or using hand tools?",
      "vfq18": "Because of your eyesight, how much difficulty do you have accomplishing as much as you would like to?",
      "vfq19": "How much of the time do you have pain or discomfort in and around your eyes?",
      "vfq_dep1": "No, not at all",
      "vfq_dep2": "A little of the time",
      "vfq_dep3": "Some of the time",
      "vfq_dep4": "Most of the time",
      "vfq_dep5": "All of the time",
      "vfq20": "Because of your eyesight, how much do you rely on what other people tell you?",
      "vfq21": "How much does pain or discomfort in or around your eyes keep you from doing what you would like to be doing?",
      "vfq22": "How much of the time do you feel frustrated a lot because of your eyesight?",
      "vfq23": "How much difficulty do you have staying home most of the time because of your eyesight?",
      "vfq24": "How much of the time do you need a lot of help from others because of your eyesight?",
      "vfq25": "How much of the time do you worry about doing things that will hurt your eyes?",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}