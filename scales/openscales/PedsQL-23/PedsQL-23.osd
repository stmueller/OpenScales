  "translations": {
    "en": {
      "pedsql_question_head": "In the past ONE month, how much of a problem has this been for you?",
      "pedsql_r0": "Never",
      "pedsql_r1": "Almost never",
      "pedsql_r2": "Sometimes",
      "pedsql_r3": "Often",
      "pedsql_r4": "Almost always",
      "pedsql_physical_head": "About my health and activities (check one number):",
      "pedsql1": "It is hard for me to walk more than one block",
      "pedsql2": "It is hard for me to run",
      "pedsql3": "It is hard for me to do sports activity or exercise",
      "pedsql4": "It is hard for me to lift something heavy",
      "pedsql5": "It is hard for me to take a bath or shower by myself",
      "pedsql6": "It is hard for me to do chores around the house",
      "pedsql7": "I hurt or ache",
      "pedsql8": "I have low energy",
      "pedsql_emotional_head": "About my feelings (check one number):",
      "pedsql9": "I feel afraid or scared",
      "pedsql10": "I feel sad or blue",
      "pedsql11": "I feel angry",
      "pedsql12": "I have trouble sleeping",
      "pedsql13": "I worry about what will happen to me",
      "pedsql_social_head": "About how I get along with other people (check one number):",
      "pedsql14": "I have trouble getting along with other kids",
      "pedsql15": "Other kids do not want to be my friend",
      "pedsql16": "Other kids tease me",
      "pedsql17": "I cannot do things that other kids my age can do",
      "pedsql18": "It is hard to keep up when I play with other kids",
      "pedsql_school_head": "About school (check one number):",
      "pedsql19": "It is hard to pay attention in class",
      "pedsql20": "I forget things",
      "pedsql21": "I have trouble keeping up with my schoolwork",
      "pedsql22": "I miss school because of not feeling well",
      "pedsql23": "I miss school to go to the doctor or hospital",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}