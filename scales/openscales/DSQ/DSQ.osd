  "translations": {
    "en": {
      "question_head": "Please indicate to what extent the statements below match your style of making important decisions (e.g., career or work related decisions; financial decisions, including decisions about expensive purchases or investments; decisions about education; decisions about relationships; and other decisions that can affect your life or the lives of your loved ones).",
      "likert_1": "Never",
      "likert_2": "Rarely",
      "likert_3": "Sometimes",
      "likert_4": "Often",
      "likert_5": "Always",
      "dsq1": "I don't make decisions unless I really have to.",
      "dsq2": "I postpone decision-making whenever possible.",
      "dsq3": "I procrastinate when it comes to making important decisions.",
      "dsq4": "I put off making many decisions because thinking about them makes me uneasy.",
      "dsq5": "I worry that making a decision will close out other options, so I postpone the decision.",
      "dsq6": "I use the advice of other people in making my important decisions.",
      "dsq7": "I need the assistance of other people when making important decisions.",
      "dsq8": "I do not seek advice from others when I make decisions.",
      "dsq9": "When I need to make a decision, I consult family or friends.",
      "dsq10": "If I have the support of others it is easier for me to make important decisions.",
      "dsq11": "I like to have someone to steer me in the right direction when I am faced with important decisions.",
      "dsq12": "I like to consider all the alternatives.",
      "dsq13": "When making decisions I like to collect lots of information.",
      "dsq14": "My decision making requires careful thought.",
      "dsq15": "When making a decision, I consider various options in terms of specific goals.",
      "dsq16": "I weigh the pros and cons of each option before I make a decision.",
      "dsq17": "I try to be clear about my objectives before choosing.",
      "dsq18": "I think about all the bad decisions I have made in my life.",
      "dsq19": "Whenever I make a choice, I try to get information about how the other alternatives turned out.",
      "dsq20": "If I make a choice and it turns out well, I still feel like something of a failure if I find out that another choice would have turned out better.",
      "dsq21": "When I make decisions, my top priority is to not get \"burned\".",
      "dsq22": "The possibility that some small thing might go wrong causes me to change my mind abruptly.",
      "dsq23": "When making decisions, I do what seems natural at the moment.",
      "dsq24": "When making decisions, I rely upon my instincts.",
      "dsq25": "When I make a decision, I trust my inner feelings and reactions.",
      "dsq26": "When I make decisions, I tend to rely on my intuition.",
      "dsq27": "When I make a decision, it is more important for me to feel the decision is right than to have a rational reason for it.",
      "dsq28": "I feel very anxious when I need to make a decision.",
      "dsq29": "I panic when I think that my decision might be wrong.",
      "dsq30": "When making a decision, I am afraid that I might be wrong.",
      "dsq31": "I can't think straight if I have to make decisions in a hurry.",
      "dsq32": "I feel as if I am under tremendous time pressure when making decisions.",
      "dsq33": "I make decisions on the spur of the moment.",
      "dsq34": "I make decisions quickly.",
      "dsq35": "My decisions are spontaneous.",
      "dsq36": "I make impulsive decisions.",
      "dsq37": "I feel inferior to most people in making decisions.",
      "dsq38": "I feel confident about my ability to make decisions.",
      "dsq39": "I don't trust my ability to make important decisions.",
      "dsq40": "I have faith in my decisions.",
      "dsq41": "I think I am a good decision maker.",
      "dsq42": "My friends or family seek my advice when they have to make important decisions.",
      "dsq43": "Others seek my help in making their decisions."
    }
  }
}
