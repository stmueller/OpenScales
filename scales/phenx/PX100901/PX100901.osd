  "translations": {
    "en": {
      "undescended_testicle_born": "Were you born with one or both of your testicles undescended (not completely down in the scrotum)?",
      "undescended_testicle_specify": "Which testicle was this?",
      "undescended_testicle_specify_opt_1": "Right",
      "undescended_testicle_specify_opt_2": "Left",
      "undescended_testicle_specify_opt_3": "Both",
      "undescended_testicle_down_scrotum_itself": "Did the testicle go down to the scrotum by itself?",
      "undescended_testicle_receive_treatment": "Did you receive treatment?",
      "undescended_testicle_treatment_specify": "What treatment?",
      "undescended_testicle_treatment_specify_opt_1": "Surgery",
      "undescended_testicle_treatment_specify_opt_2": "Hormones",
      "undescended_testicle_treatment_specify_opt_3": "Other (specify)",
      "undescended_testicle_treatment_specify_opt_4": "Don't know",
      "disease_penis_testicles_urinary_scrotum": "Has your doctor or another health care provider ever told you that you had other diseases of the penis, testicles, urinary tract or scrotum (specify)?",
      "hypospadius_ever": "Has your doctor or another health care provider ever told you that you had hypospadius?",
      "hypospadius_ever_opt_1": "No",
      "hypospadius_ever_opt_2": "Yes",
      "most_treatment_medication": "What was your most recent treatment or medication (if any)?",
      "most_treatment_year": "When was your most recent treatment or medication (if any)? (YEAR)",
      "opt_1": "No",
      "opt_2": "Yes",
      "opt_3": "Don't know"
    }
