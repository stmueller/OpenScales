    "en": {
      "lk_opt_1": "Almost never",
      "lk_opt_2": "Sometimes",
      "lk_opt_3": "Often",
      "lk_opt_4": "Almost always",
      "difficulty_achieving_erection": "How often did you have difficulty with Achieving an erection?",
      "difficulty_ejaculating_early": "How often did you have difficulty with Ejaculating too early?",
      "difficulty_ejaculating": "How often did you have difficulty with Difficulty ejaculating?",
      "difficulty_lack_interest_sex": "How often did you have difficulty with Lack of interest in sex?",
      "erection_during_sexual_activity": "Over the past four weeks how often were you able to get an erection during sexual activity?",
      "erection_hard_enough_penetration": "Over the past four weeks when you had erections with sexual stimulation, how often were your erections hard enough for penetration?",
      "penetrate_sexual_intercourse": "Over the past four weeks when you attempted sexual intercourse, how often were you able to penetrate (enter) your partner?",
      "maintain_erection_after_penetrated": "Over the past four weeks during sexual intercourse, how often were you able to maintain your erection after you had penetrated (entered) your partner?",
      "maintain_erection_completion_intercourse": "Over the past four weeks during sexual intercourse, how difficult was it to maintain your erection to completion of intercourse?",
      "attempt_sexual_intercourse_times": "Over the past four weeks how many times have you attempted sexual intercourse?",
      "attempt_sexual_intercourse_satisfactory": "Over the past four weeks when you attempted sexual intercourse, how often was it satisfactory for you?",
      "enjoy_sexual_intercourse": "Over the past four weeks how much have you enjoyed sexual intercourse?",
      "sexual_stimulation_intercourse_ejaculate": "Over the past four weeks when you had sexual stimulation or intercourse, how often did you ejaculate?",
      "sexual_stimulation_intercourse_orgasm_climax": "Over the past four weeks when you had sexual stimulation or intercourse, how often did you have the feeling of orgasm or climax?",
      "sexual_desire_felt": "Over the past four weeks how often have you felt sexual desire?",
      "sexual_desire_level_rate": "Over the past four weeks how would you rate your level of sexual desire?",
      "overall_sex_life_satisfied": "Over the past four weeks how satisfied have you been with your overall sex life?",
      "sex_relationship_satisfied": "Over the past four weeks how satisfied have you been with your sexual relationship with your partner?",
      "confidence_get_keep_erection": "Over the past four weeks how do you rate your confidence that you could get and keep an erection?"
    }
