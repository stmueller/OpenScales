    "scoring": {
      "social_capital": {
        "description": "Social Capital: sum_coded of 7 items (range 7-28). Reverse-coded items scored 4→1, 3→2, 2→3, 1→4.",
        "method": "sum_coded",
        "items": {
          "multidimensional_assessment_recovery_capital_support_others": 1,
          "multidimensional_assessment_recovery_capital_family_difficult": -1,
          "multidimensional_assessment_recovery_capital_friend_support": 1,
          "multidimensional_assessment_recovery_capital_family_support": 1,
          "multidimensional_assessment_recovery_capital_people_not_recover": -1,
          "multidimensional_assessment_recovery_capital_feel_alone": -1,
          "multidimensional_assessment_recovery_capital_part_community": 1
        }
      },
      "physical_capital": {
        "description": "Physical Capital: sum_coded of 7 items (range 7-28). Reverse-coded items scored 4→1, 3→2, 2→3, 1→4.",
        "method": "sum_coded",
        "items": {
          "multidimensional_assessment_recovery_capital_helpful_housing": 1,
          "multidimensional_assessment_recovery_capital_difficult_transport": -1,
          "multidimensional_assessment_recovery_capital_unstable_housing": -1,
          "multidimensional_assessment_recovery_capital_enough_money": 1,
          "multidimensional_assessment_recovery_capital_not_enough_money": -1,
          "multidimensional_assessment_recovery_capital_afford_care": 1,
          "multidimensional_assessment_recovery_capital_access_communication": 1
        }
      },
      "human_capital": {
        "description": "Human Capital: sum_coded of 7 items (range 7-28). Reverse-coded items scored 4→1, 3→2, 2→3, 1→4.",
        "method": "sum_coded",
        "items": {
          "multidimensional_assessment_recovery_capital_hard_fun": -1,
          "multidimensional_assessment_recovery_capital_physically_healthy": 1,
          "multidimensional_assessment_recovery_capital_guilt_shame": -1,
          "multidimensional_assessment_recovery_capital_stress": -1,
          "multidimensional_assessment_recovery_capital_education_training_prepare": 1,
          "multidimensional_assessment_recovery_capital_mental_health": -1,
          "multidimensional_assessment_recovery_capital_purpose_meaning": 1
        }
      },
      "cultural_capital": {
        "description": "Cultural Capital: sum_coded of 7 items (range 7-28). Reverse-coded items scored 4→1, 3→2, 2→3, 1→4.",
        "method": "sum_coded",
        "items": {
          "multidimensional_assessment_recovery_capital_hard_trust": -1,
          "multidimensional_assessment_recovery_capital_fun_activities": 1,
          "multidimensional_assessment_recovery_capital_disconnected_culture": -1,
          "multidimensional_assessment_recovery_capital_feel_outcast": -1,
          "multidimensional_assessment_recovery_capital_helpful_services_avail": 1,
          "multidimensional_assessment_recovery_capital_let_go_identity": -1,
          "multidimensional_assessment_recovery_capital_neighborhood_safe": 1
        }
      },
      "total": {
        "description": "Overall Recovery Capital: sum of 4 subscale scores (range 28-112). Higher = greater recovery capital.",
        "method": "sum_coded",
        "scores": [
          "social_capital",
          "physical_capital",
          "human_capital",
          "cultural_capital"
        ]
      }
    },
    "_scoring_notes": "<div class=\"rich-text-field-label\"><p>Scoring Instructions:<br><br>Please see the written instructions below. For a visual example, see the sample scoring chart and blank scoring chart included at: <a href=\"https://socialwork.buffalo.edu/resources/multidimensional-inventory-recovery-capital.html\">socialwork.buffalo.edu/resources/multidimensional-inventory-recovery-capital.html.</a><br><br>Step 1. Write the score for each survey item in the 'Starting Score' column.<br><br>Step 2. For the items highlighted in yellow (items 2, 5, 6, 9, 10, 12, 15, 17, 18, 20, 22, 24, 25, and 27), change the scores from 4 to 1, 3 to 2, 2 to 3, or 1 to 4. Write the new score in the 'Reverse Score' column.<br><br>Step 3. If the item has a 'Reverse Score' write that in the 'Final Score' column. If it does not, write the 'Starting Score' in the 'Final Score' column.<br><br>Step 4. Add the final scores in each section together. Write this in the light gray Social, Physical, Human, and Cultural Capital 'Total' boxes. The minimum score is 7, the middle score is 17-18, and the maximum score is 28.<br><br>Step 5. Add the 'Total' scores from each section and write this in the dark gray 'Overall Recovery Capital' 'Total' box. The minimum score is 28, the middle score is 70, and the maximum score is 112.</p></div>",
    "likert_options": {
      "points": 4,
      "min": 1,
      "max": 4,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4"
      ]
    }
  },
