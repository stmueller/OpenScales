  "translations": {
    "en": {
      "autonomic_assessment_adult_lightheadedness": "Have you had any of the following health symptoms during the past 6 months? Do you have lightheadedness?",
      "autonomic_assessment_adult_lightheadedness_opt_1": "Yes",
      "autonomic_assessment_adult_lightheadedness_opt_0": "No",
      "autonomic_assessment_adult_lightheadedness_symptoms_discomfort": "If you answered yes in Q1a, how much would you say the symptom bothers you?",
      "autonomic_assessment_adult_lightheadedness_symptoms_discomfort_opt_1": "Not at all",
      "autonomic_assessment_adult_lightheadedness_symptoms_discomfort_opt_2": "A little",
      "autonomic_assessment_adult_lightheadedness_symptoms_discomfort_opt_3": "Some",
      "autonomic_assessment_adult_lightheadedness_symptoms_discomfort_opt_4": "A moderate amount",
      "autonomic_assessment_adult_lightheadedness_symptoms_discomfort_opt_5": "A lot",
      "autonomic_assessment_adult_dry_mouth_dry_eyes": "Have you had any of the following health symptoms during the past 6 months? Do you have a dry mouth or dry eyes?",
      "autonomic_assessment_adult_dry_mouth_dry_eyes_opt_1": "Yes",
      "autonomic_assessment_adult_dry_mouth_dry_eyes_opt_0": "No",
      "autonomic_assessment_adult_dry_mouth_dry_eyes_symptoms_discomfort": "If you answered yes in Q2a, how much would you say the symptom bothers you?",
      "autonomic_assessment_adult_dry_mouth_dry_eyes_symptoms_discomfort_opt_1": "Not at all",
      "autonomic_assessment_adult_dry_mouth_dry_eyes_symptoms_discomfort_opt_2": "A little",
      "autonomic_assessment_adult_dry_mouth_dry_eyes_symptoms_discomfort_opt_3": "Some",
      "autonomic_assessment_adult_dry_mouth_dry_eyes_symptoms_discomfort_opt_4": "A moderate amount",
      "autonomic_assessment_adult_dry_mouth_dry_eyes_symptoms_discomfort_opt_5": "A lot",
      "autonomic_assessment_adult_feet_pale_blue": "Have you had any of the following health symptoms during the past 6 months? Are your feet pale or blue?",
      "autonomic_assessment_adult_feet_pale_blue_opt_1": "Yes",
      "autonomic_assessment_adult_feet_pale_blue_opt_0": "No",
      "autonomic_assessment_adult_feet_pale_blue_symptoms_discomfort": "If you answered yes in Q3a, how much would you say the symptom bothers you?",
      "autonomic_assessment_adult_feet_pale_blue_symptoms_discomfort_opt_1": "Not at all",
      "autonomic_assessment_adult_feet_pale_blue_symptoms_discomfort_opt_2": "A little",
      "autonomic_assessment_adult_feet_pale_blue_symptoms_discomfort_opt_3": "Some",
      "autonomic_assessment_adult_feet_pale_blue_symptoms_discomfort_opt_4": "A moderate amount",
      "autonomic_assessment_adult_feet_pale_blue_symptoms_discomfort_opt_5": "A lot",
      "autonomic_assessment_adult_feet_colder": "Have you had any of the following health symptoms during the past 6 months? Are your feet colder than the rest of your body?",
