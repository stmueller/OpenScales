  "translations": {
    "en": {
      "hand_write": "Please indicate your preferences in the use of hands in writing.",
      "hand_draw": "Please indicate your preferences in the use of hands in drawing.",
      "hand_throw": "Please indicate your preferences in the use of hands in throwing.",
      "hand_hold_racquet": "Please indicate your preferences in the use of hands in holding a racquet.",
      "hand_clean_teeth": "Please indicate your preferences in the use of hands in cleaning teeth.",
      "hand_hammer": "Please indicate your preferences in the use of hands in hammering.",
      "hand_strike_match": "Please indicate your preferences in the use of hands in striking a match.",
      "hand_use_eraser": "Please indicate your preferences in the use of hands in using an eraser.",
      "hand_deal_card": "Please indicate your preferences in the use of hands in dealing cards.",
      "hand_thread_needle": "Please indicate your preferences in the use of hands in threading a needle.",
      "hand_cut_food": "Please indicate your preferences in the use of hands in cutting food with a knife.",
      "hand_total_right": "How many \"Right hand\" in Questions 1-11?",
      "hand_total_left": "How many \"Left hand\" in Questions 1-11?",
      "hand_total_both": "How many \"Both hands\" in Questions 1-11?",
      "handedness": "Handedness is classified by the score.",
      "handedness_opt_1": "Left-handed",
      "handedness_opt_2": "Mixed-handed",
      "handedness_opt_3": "Right-handed",
