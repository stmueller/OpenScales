{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Mental Health Test",
      "code": "MHT",
      "abbreviation": "MHT",
      "description": "18-item complex mental health measure in a positive psychological framework. Five subscales: Well-being (W), Savoring (S), Creative and Executive Efficiency (C), Self-regulation (SR), and Resilience (R). 6-point Likert (1=Strongly disagree to 6=Strongly agree); item 18 uses a different format (1=Very bad to 6=Very good). SR items (2,8,16) and Resilience item 13 are reverse coded using 7-x transformation. Higher scores indicate better mental health.",
      "citation": "Zábó, V., Oláh, A., & Vargha, A. (2022). A new complex mental health test in a positive psychological framework. Frontiers in Psychology, 13. https://doi.org/10.3389/fpsyg.2022.775622. [APA PsycTests: https://doi.org/10.1037/t95738-000]",
      "license": "CC BY 4.0",
      "license_explanation": "Published in Frontiers in Psychology under Creative Commons Attribution 4.0 International License.",
      "license_url": "https://doi.org/10.3389/fpsyg.2022.775622",
      "version": "1.0",
      "url": "https://doi.org/10.3389/fpsyg.2022.775622",
      "domain": "Well-being"
    },
    "likert_options": {
      "points": 6,
      "min": 1,
      "max": 6,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5",
        "likert_6"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "wellbeing",
        "name": "Well-being",
        "description": "General well-being (items 1, 14, 18). Mean score, range 1-6."
      },
      {
        "id": "savoring",
        "name": "Savoring",
        "description": "Ability to savor positive experiences (items 3, 10, 12). Mean score, range 1-6."
      },
      {
        "id": "creative",
        "name": "Creative and Executive Efficiency",
        "description": "Creative thinking and problem-solving (items 5, 7, 9, 15, 17). Mean score, range 1-6."
      },
      {
        "id": "selfregulation",
        "name": "Self-regulation",
        "description": "Emotional self-regulation (items 2, 8, 16, all reverse coded). Mean score after 7-x inversion, range 1-6."
      },
      {
        "id": "resilience",
        "name": "Resilience",
        "description": "Ability to recover from setbacks (items 4, 11, 13). Item 13 is reverse coded. Item 6 removed per authors. Mean score, range 1-6."
      }
    ],
