{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Screening and Severity of Substance Use Problems - Adolescents",
      "code": "PX510202",
      "abbreviation": "PX510202",
      "description": "The Simple Screening Instrument for Alcohol and Other Drugs (SSI-AOD) is a 16-item screening instrument developed by a consensus panel of experts, sponsored by the Center for Substance Abuse Treatment (CSAT) of the U.S. Department of Health and Human Services. The tool includes yes/no questions abou",
      "domain": "Substance Use - Screening & Family History",
      "citation": "American Academy of Pediatrics, Committee on Substance Abuse. (2001). Alcohol use and abuse: A pediatric concern. Pediatrics, 108 (1), 185–189. [PhenX: https://www.phenxtoolkit.org/protocols/view/510202]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/510202"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
