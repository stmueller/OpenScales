          "pcl7"
        ]
      },
      "cognition": {
        "description": "Sum of Criterion D negative cognition and mood items (0-28).",
        "method": "sum_coded",
        "items": [
          "pcl8",
          "pcl9",
          "pcl10",
          "pcl11",
          "pcl12",
          "pcl13",
          "pcl14"
        ]
      },
      "arousal": {
        "description": "Sum of Criterion E arousal and reactivity items (0-24).",
        "method": "sum_coded",
        "items": [
          "pcl15",
          "pcl16",
          "pcl17",
          "pcl18",
          "pcl19",
          "pcl20"
        ]
      },
      "total": {
        "description": "Sum of all 20 items (0-80). A score of 31-33 or higher is suggested as a threshold for probable PTSD.",
        "method": "sum_coded",
        "items": [
          "pcl1",
          "pcl2",
          "pcl3",
          "pcl4",
          "pcl5",
          "pcl6",
