      "SubstanceUse_Ever_Smoked_Cigarettes_opt_3": "Occasionally but not regularly",
      "SubstanceUse_Ever_Smoked_Cigarettes_opt_4": "Regularly in the past",
      "SubstanceUse_Ever_Smoked_Cigarettes_opt_5": "Regularly now",
