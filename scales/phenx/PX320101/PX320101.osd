      "part_full_time_change_ongoing_opt_1": "Yes",
      "part_full_time_change_ongoing_opt_2": "No",
      "full_part_time_change_ever": "Did you ever change from working full-time to working part-time?",
      "full_part_time_change_ever_opt_1": "Yes",
      "full_part_time_change_ever_opt_2": "No",
      "full_part_time_change_when": "When did you change from working full-time to working part-time?",
      "full_part_time_change_when_opt_1": "At the time of diagnosis",
      "full_part_time_change_when_opt_2": "During treatment",
      "full_part_time_change_when_opt_3": "Less than one year after treatment was finished",
      "full_part_time_change_when_opt_4": "One year or more after treatment was finished",
