  "translations": {
    "en": {
      "ever_taken_estrogen": "Have you ever taken estrogen (female hormones\") for symptoms of menopause (the change of life) or for other reasons?\"",
      "ever_taken_estrogen_opt_1": "No",
      "ever_taken_estrogen_opt_2": "Yes, and I am currently taking estrogens",
      "ever_taken_estrogen_opt_3": "Yes, but I am no longer taking estrogens",
      "ever_premarin": "The most frequently used estrogen is oral  Premarin�. Have you ever taken Premarin� by mouth (as pills)?",
      "premarin_age_first": "At what age did you first take Premarin�?",
      "premarin_age_last": "At what age did you last take Premarin�?",
      "premarin_years": "How many years in total did you take Premarin� (exclude those periods when you temporarily stopped)?",
      "premarin_dose_green": "Five commonly used doses of Premarin� can be distinguished by the color of the pill. Please indicate any you have ever used and the one you used for the longest period.  Green (0.3 mg).",
      "premarin_dose_brown_red": "Five commonly used doses of Premarin� can be distinguished by the color of the pill. Please indicate any you have ever used and the one you used for the longest period.  Brown/Red (0.625 mg).",
      "premarin_dose_white": "Five commonly used doses of Premarin� can be distinguished by the color of the pill. Please indicate any you have ever used and the one you used for the longest period.  White (0.9 mg).",
      "premarin_dose_yellow_orange": "Five commonly used doses of Premarin� can be distinguished by the color of the pill. Please indicate any you have ever used and the one you used for the longest period.  Yellow/Orange (1.25 mg).",
      "premarin_dose_purple": "Five commonly used doses of Premarin� can be distinguished by the color of the pill. Please indicate any you have ever used and the one you used for the longest period.  Purple (2.5 mg).",
      "premarin_dose_longest_used": "Longest Used",
      "premarin_dose_longest_used_opt_1": "Green (0.3 mg)",
      "premarin_dose_longest_used_opt_2": "Brown/Red (0.625 mg)",
      "premarin_dose_longest_used_opt_3": "White (0.9 mg)",
      "premarin_dose_longest_used_opt_4": "Yellow/Orange (1.25 mg)",
      "premarin_dose_longest_used_opt_5": "Purple (2.5 mg)",
      "ever_estrogen_by_mouth": "Have you ever used estrogen other than Premarin� pills?  Estrogen by mouth?",
      "ever_estrogen_by_injection": "Have you ever used estrogen other than Premarin� pills?  Estrogen by injection?",
      "ever_estrogen_by_patch_implant": "Have you ever used estrogen other than Premarin� pills?  Estrogen by patch or implant?",
      "ever_estrogen_by_cream_suppository": "Have you ever used estrogen other than Premarin� pills?  Estrogen vaginal cream or suppository?",
      "estrogen_except_premarin_age_first": "At what age did you first use estrogens other than Premarin� pills?",
      "estrogen_except_premarin_age_last": "At what age did you last use estrogens other than Premarin� pills?",
      "estrogen_except_premarin_years": "How many years in total did you take estrogens other than Premarin� pills (exclude any time when you temporarily stopped)?",
      "ever_progesterone_progestin": "Sometimes another type of female hormone, progesterone (or progestin)  is given for symptoms of menopause  either alone or in combination with estrogen. The most frequently used progestin is Provera� (medroxyprogestoerone acetate). Have you ever used progesterone or a progestin?",
      "ever_progesterone_progestin_opt_1": "No",
      "ever_progesterone_progestin_opt_2": "Provera� only",
      "ever_progesterone_progestin_opt_3": "Another type only",
      "ever_progesterone_progestin_opt_4": "Provera� and another type of progestin",
      "ever_progesterone_progestin_opt_5": "Yes, but don't know type",
      "progesterone_progestin_age_first": "At what age did you first take progesterone or a progestin?",
      "progesterone_progestin_age_first_opt_1": "Before age 40",
      "progesterone_progestin_age_first_opt_2": "40-44",
      "progesterone_progestin_age_first_opt_8": "70 years or older",
      "progesterone_progestin_age_last": "At what age did you last take progesterone or a progestin?",
      "progesterone_progestin_age_last_opt_1": "Currently taking",
      "progesterone_progestin_age_last_opt_2": "Before 45",
      "progesterone_progestin_age_last_opt_8": "70 years or older",
      "progesterone_progestin_years": "How many years in total did you take progesterone or a progestin (excluding any time when you temporarily stopped)?",
      "provera_dose": "If you used Provera�, what was your usual dose?",
      "provera_dose_opt_1": "Did not use Provera�",
      "provera_dose_opt_2": "2.5 mg per day",
      "provera_dose_opt_3": "5.0 mg per day",
      "provera_dose_opt_4": "10 mg per day",
      "provera_dose_opt_5": "20 mg per day",
      "provera_dose_opt_6": "Another dose",
      "provera_dose_opt_7": "Don't know",
      "progesterone_progestin_days": "When using progestin or progesterone, for how many days each month would you usually take it?",
      "opt_1": "Before age 45",
      "opt_2": "45-49",
      "opt_3": "50-54",
      "opt_4": "55-59",
      "opt_5": "60-64",
      "opt_6": "65-69",
      "opt_7": "70 or older",
      "grp2_opt_1": "Currently taking",
      "grp2_opt_2": "Before age 45",
      "grp2_opt_8": "70 or older",
      "grp3_opt_1": "Less than 1 year",
      "grp3_opt_2": "1-2 years",
      "grp3_opt_3": "3-5 years",
      "grp3_opt_4": "6-9 years",
      "grp3_opt_5": "10-14 years",
      "grp3_opt_6": "15-19 years",
      "grp3_opt_7": "20 years or more"
