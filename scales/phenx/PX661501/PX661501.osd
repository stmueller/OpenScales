  "translations": {
    "en": {
      "recovery_selfassessment_administrator_welcoming_staff": "Staff make a concerted effort to welcome people in recovery and help them to feel comfortable in this program. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_administrator_welcoming_staff_opt_1": "1",
      "recovery_selfassessment_administrator_welcoming_staff_opt_2": "2",
      "recovery_selfassessment_administrator_welcoming_staff_opt_3": "3",
      "recovery_selfassessment_administrator_welcoming_staff_opt_4": "4",
