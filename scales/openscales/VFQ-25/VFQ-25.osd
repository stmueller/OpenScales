{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "National Eye Institute Visual Function Questionnaire-25",
      "code": "VFQ-25",
      "abbreviation": "NEI VFQ-25",
      "description": "25-item self-report measure of vision-related quality of life developed by the National Eye Institute and RAND Corporation. Assesses 12 subscales covering general health, general vision, ocular pain, near and distance activities, social functioning, mental health, role difficulties, dependency, driving, color vision, and peripheral vision. All subscales are scored 0–100 (higher = better visual function). Subscale score = mean of recoded item values × 25; see Mangione et al. (2001) for full recoding tables. A composite score (mean of all subscales excluding general health) is also commonly reported.",
      "citation": "Mangione, C.M., Lee, P.P., Gutierrez, P.R., Spritzer, K., Berry, S., & Hays, R.D. (2001). Development of the 25-item National Eye Institute Visual Function Questionnaire. Archives of Ophthalmology, 119(7), 1050–1058. https://doi.org/10.1001/archopht.119.7.1050",
      "license": "Public Domain",
      "version": "2000",
      "url": "https://www.rand.org/health-care/surveys_tools/vfq.html",
      "domain": "Health",
      "license_explanation": "RAND Corporation and NEI place their health survey instruments in the public domain. RAND explicitly states these instruments are available for use without permission or fee.",
      "license_url": "https://www.rand.org/health-care/surveys_tools/vfq.html"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "dimensions": [
      {
        "id": "general_health",
        "name": "General Health",
        "abbreviation": "GH",
        "description": "Single item rating overall health. Item: vfq1.",
        "enabled_param": null
      },
      {
        "id": "general_vision",
        "name": "General Vision",
        "abbreviation": "GV",
        "description": "Single item rating vision without glasses or contact lenses. Item: vfq2.",
        "enabled_param": null
      },
      {
        "id": "ocular_pain",
        "name": "Ocular Pain",
        "abbreviation": "OP",
        "description": "Pain or discomfort in/around eyes. Items: vfq4, vfq19.",
        "enabled_param": null
      },
      {
        "id": "near_activities",
        "name": "Near Activities",
        "abbreviation": "NA",
        "description": "Difficulty with near vision tasks. Items: vfq5, vfq6, vfq7.",
        "enabled_param": null
      },
      {
        "id": "distance_activities",
        "name": "Distance Activities",
        "abbreviation": "DA",
        "description": "Difficulty with distance vision tasks. Items: vfq8, vfq9, vfq14.",
        "enabled_param": null
      },
      {
        "id": "social_functioning",
        "name": "Social Functioning",
        "abbreviation": "SF",
        "description": "Vision-related limitations in social activities. Items: vfq11, vfq13.",
        "enabled_param": null
      },
      {
        "id": "mental_health",
        "name": "Mental Health",
        "abbreviation": "MH",
        "description": "Vision-related emotional distress. Items: vfq3, vfq21, vfq22, vfq25.",
        "enabled_param": null
      },
      {
        "id": "role_difficulties",
        "name": "Role Difficulties",
        "abbreviation": "RD",
        "description": "Vision-related limitations in work and daily role activities. Items: vfq17, vfq18.",
        "enabled_param": null
      },
      {
        "id": "dependency",
        "name": "Dependency",
        "abbreviation": "DEP",
        "description": "Reliance on others due to vision problems. Items: vfq20, vfq23, vfq24.",
        "enabled_param": null
      },
      {
        "id": "driving",
        "name": "Driving",
        "abbreviation": "DRV",
        "description": "Vision-related driving difficulties. Screening: vfq15, vfq15a, vfq15b. Scored: vfq15c (daytime driving difficulty). N/A if not currently driving.",
        "enabled_param": null
      },
      {
        "id": "color_vision",
        "name": "Color Vision",
        "abbreviation": "CV",
        "description": "Difficulty distinguishing colors. Item: vfq12.",
        "enabled_param": null
      },
      {
        "id": "peripheral_vision",
        "name": "Peripheral Vision",
        "abbreviation": "PV",
        "description": "Difficulty with peripheral vision. Item: vfq10.",
        "enabled_param": null
      }
    ],
