  "translations": {
    "en": {
      "lk_opt_1": "Not at all",
      "lk_opt_2": "A little bit",
      "lk_opt_3": "Somewhat",
      "lk_opt_4": "Quite a bit",
      "lk_opt_5": "Very much",
      "info_820101": "Adult Sickle Cell Quality of Life Measurement Information System (ASCQ-Me)Answer all the questions by selecting the best answer to the right of the questions.? You are sometimes told to skip over some questions in this survey. When this happens you will see an arrow with a note that tells you what question to answer next, like this:         [ ] Yes ? If Yes, Go to Question 1         [ ] No",
      "qualityofcareadults_doctor_appointment_past12months": "In the past 12 months, did you try to make an appointment to see a doctor or nurse?",
      "qualityofcareadults_doctor_appointment_past12months_opt_1": "Yes",
      "qualityofcareadults_doctor_appointment_past12months_opt_2": "No (If No, Go to Question 4)",
      "qualityofcareadults_frequency_get_appointment_past12months": "In the past 12 months, when you tried to make an appointment to see a doctor or nurse, how often were you able to get one as soon as you wanted?",
      "qualityofcareadults_satisfiedcarereceived_appointment_past12months": "In the past 12 months, how often were you satisfied with the care you received during these scheduled appointments?",
      "qualityofcareadults_doctornurse_usuallysee": "Do you have a doctor or nurse who you usually see if you need a check-up, want advice about a health problem, or get sick or hurt?",
      "qualityofcareadults_doctornurse_usuallysee_opt_1": "Yes",
      "qualityofcareadults_doctornurse_usuallysee_opt_2": "No (If No, Go to Question 13)",
      "qualityofcareadults_visits_doctornurse_usuallysee_past12months": "In the past 12 months, how many visits have you had with this doctor or nurse?",
      "qualityofcareadults_visits_doctornurse_usuallysee_past12months_opt_1": "0 visits (If 0 visits, Go to Question 13)",
      "qualityofcareadults_visits_doctornurse_usuallysee_past12months_opt_2": "1 visit",
      "qualityofcareadults_visits_doctornurse_usuallysee_past12months_opt_3": "2 visits",
      "qualityofcareadults_visits_doctornurse_usuallysee_past12months_opt_4": "3 visits",
      "qualityofcareadults_visits_doctornurse_usuallysee_past12months_opt_5": "4 or more visits",
      "qualityofcareadults_explainthings_doctornurse_usuallysee_past12months": "In the past 12 months, how often did this doctor or nurse explain things in a way that is easy to understand?",
      "qualityofcareadults_listencarefully_doctornurse_usuallysee_past12months": "In the past 12 months, how often did this doctor or nurse listen carefully to you?",
      "qualityofcareadults_courtesyrespect_doctornurse_usuallysee_past12months": "In the past 12 months, how often did this doctor or nurse treat you with courtesy and respect?",
      "qualityofcareadults_enoughtime_doctornurse_usuallysee_past12months": "In the past 12 months, how often did this doctor or nurse spend enough time with you?",
      "qualityofcareadults_satisfiedcare_doctornurse_usuallysee_past12months": "In the past 12 months, how often were you satisfied with the care you received from this doctor or nurse?",
      "qualityofcareadults_doctornurse_usuallysee_knowaffects_personally": "How much does this doctor or nurse know how sickle cell affects you personally?",
      "qualityofcareadults_doctornurse_usuallysee_knowaffects_personally_opt_1": "Nothing",
      "qualityofcareadults_doctornurse_usuallysee_knowaffects_personally_opt_2": "A little bit",
      "qualityofcareadults_doctornurse_usuallysee_knowaffects_personally_opt_3": "Some",
      "qualityofcareadults_doctornurse_usuallysee_knowaffects_personally_opt_4": "Quite a bit",
      "qualityofcareadults_doctornurse_usuallysee_knowaffects_personally_opt_5": "Very much",
      "qualityofcareadults_doctornurse_usuallysee_treatlot_patients": "Does this doctor or nurse treat a lot of patients with sickle cell disease?",
      "qualityofcareadults_doctornurse_usuallysee_treatlot_patients_opt_1": "Yes",
      "qualityofcareadults_doctornurse_usuallysee_treatlot_patients_opt_2": "No",
      "qualityofcareadults_emergencyroom_rightaway_past12months": "In the past 12 months, did you go to an emergency room for any sickle cell care you needed right away?",
      "qualityofcareadults_emergencyroom_rightaway_past12months_opt_1": "Yes",
      "qualityofcareadults_emergencyroom_rightaway_past12months_opt_2": "No (If No, Go to Question 19)",
      "qualityofcareadults_emergencyroom_oftencare_soonwanted_past12months": "In the past 12 months, when you went to the emergency room for this care, how often did you get it as soon as you wanted?",
      "qualityofcareadults_emergencyroom_oftendoctors_care_past12months": "In the past 12 months, when you went to the emergency room for this care, how often did the DOCTORS treating you seem to really care about you?",
      "qualityofcareadults_emergencyroom_oftennurses_care_past12months": "In the past 12 months, when you went to the emergency room for this care, how often did the NURSES treating you seem to really care about you?",
      "qualityofcareadults_emergencyroom_clerksreceptionists_courtesyrespect_past12months": "In the past 12 months, when you went to the emergency room for this care, how often did the clerks and receptionists treat you with courtesy and respect?",
      "qualityofcareadults_emergencyroom_oftensatisfied_care_past12months": "In the past 12 months, when you went to the emergency room for this care, how often were you satisfied with the care you received?",
      "qualityofcareadults_painattackcrisis_manage_home_past12months": "In the past 12 months, how many times did you manage a pain attack (crisis) at home without going to a doctor, clinic, or hospital?",
      "qualityofcareadults_painattackcrisis_manage_home_past12months_opt_1": "I did not have a pain attack (crisis) in the past 12 months (If you did not have a pain attack in the last 12 months, Go to Question 27)",
      "qualityofcareadults_painattackcrisis_manage_home_past12months_opt_2": "0 times",
      "qualityofcareadults_painattackcrisis_manage_home_past12months_opt_3": "1 time",
      "qualityofcareadults_painattackcrisis_manage_home_past12months_opt_4": "2 times",
      "qualityofcareadults_painattackcrisis_manage_home_past12months_opt_5": "3 times",
      "qualityofcareadults_painattackcrisis_manage_home_past12months_opt_6": "4 or more times",
      "qualityofcareadults_emergencyroom_delayavoidcare_past12months": "In the past 12 months, did you ever delay or avoid going to an emergency room when you thought you needed care?",
      "qualityofcareadults_emergencyroom_delayavoidcare_past12months_opt_1": "Yes, I did not always go for care when I needed it",
      "qualityofcareadults_emergencyroom_delayavoidcare_past12months_opt_2": "No, I always went for care when I thought I needed it  (If No, Go to Question 23)",
      "qualityofcareadults_bad_experiences_emergencyroom": "How important were bad experiences in the emergency room in your decision to avoid going for care?",
      "qualityofcareadults_health_insurance_avoid_care": "How important were health insurance issues in your decision to avoid going for care?",
      "qualityofcareadults_emergencyroom_painattackcrisis_past12months": "In the past 12 months, how many times did you go to the emergency room because of a pain attack (crisis)?",
      "qualityofcareadults_emergencyroom_painattackcrisis_past12months_opt_1": "0 times (If 0 times, Go to Question 27)",
      "qualityofcareadults_emergencyroom_painattackcrisis_past12months_opt_2": "1 time",
      "qualityofcareadults_emergencyroom_painattackcrisis_past12months_opt_3": "2 times",
      "qualityofcareadults_emergencyroom_painattackcrisis_past12months_opt_4": "3 times",
      "qualityofcareadults_emergencyroom_painattackcrisis_past12months_opt_5": "4 or more times",
      "qualityofcareadults_emergencyroom_doctorsnurses_helppain_past12months": "In the past 12 months, how much were the emergency room doctors and nurses able to help your pain?",
      "qualityofcareadults_emergencyroom_doctorsnurses_believepain_past12months": "In the past 12 months, how much did the emergency room doctors and nurses believe that you had very bad sickle cell pain?",
      "qualityofcareadults_emergencyroom_wait_paintreated_past12months": "In the past 12 months, what is the longest you had to wait in the emergency room before your sickle cell pain was treated?",
      "qualityofcareadults_emergencyroom_wait_paintreated_past12months_opt_1": "Less than 5 minutes",
      "qualityofcareadults_emergencyroom_wait_paintreated_past12months_opt_2": "5 to 15 minutes",
