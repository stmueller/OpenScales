  "translations": {
    "en": {
      "professional_dental_care_last_visit": "About how long has it been since {you/SP} last visited a dentist? Include all types of dentists, such as, orthodontists, oral surgeons, and all other dental specialists, as well as dental hygienists.",
      "professional_dental_care_last_visit_opt_1": "6 months or less",
      "professional_dental_care_last_visit_opt_2": "More than 6 months, but not more than 1 year ago",
      "professional_dental_care_last_visit_opt_3": "More than 1 year, but not more than 2 years ago",
      "professional_dental_care_last_visit_opt_4": "More than 2 years, but not more than 3 years ago",
      "professional_dental_care_last_visit_opt_5": "More than 3 years, but not more than 5 years ago",
      "professional_dental_care_last_visit_opt_6": "More than 5 years ago",
      "professional_dental_care_last_visit_opt_7": "Never have been",
      "professional_dental_care_last_visit_opt_77": "Refused",
      "professional_dental_care_last_visit_opt_99": "Don't know",
      "professional_dental_care_visit_reason": "What was the main reason {you/SP} last visited the dentist?",
      "professional_dental_care_visit_reason_opt_1": "Went in on own for check-up, examination, or cleaning",
      "professional_dental_care_visit_reason_opt_2": "Was called in by the dentist for check-up, examination, or cleaning",
      "professional_dental_care_visit_reason_opt_3": "Something was wrong, bothering or hurting {Me/SP}",
      "professional_dental_care_visit_reason_opt_4": "Went for treatment of a condition that dentist discovered at earlier check-up or examination",
      "professional_dental_care_visit_reason_opt_5": "Other",
      "professional_dental_care_visit_reason_opt_7": "Refused",
      "professional_dental_care_visit_reason_opt_9": "Don't know"
    }
  }
