      "psychopathologyquestionnaire_judgeyourself_influence_weight_opt_5": "5",
      "psychopathologyquestionnaire_judgeyourself_influence_weight_opt_6": "Markedly",
      "psychopathologyquestionnaire_judgeyourself_influence_shape": "Over the past 28 days, has your shape influenced how you think about (judge) yourself as a person?",
      "psychopathologyquestionnaire_judgeyourself_influence_shape_opt_0": "Not at all",
      "psychopathologyquestionnaire_judgeyourself_influence_shape_opt_1": "1",
      "psychopathologyquestionnaire_judgeyourself_influence_shape_opt_2": "Slightly",
