  "translations": {
    "en": {
      "lk_opt_1": "Strongly Agree",
      "lk_opt_2": "Somewhat Agree",
      "lk_opt_3": "Neutral",
      "lk_opt_4": "Somewhat Disagree",
      "lk_opt_5": "Strongly Disagree",
      "sec_in_the_first_6_statements_below_the_word_title": "In the first 6 statements below, the word \"people\" refers to people in general, not members of your family. In the last 2 statements below, the word \"doctor\" refers to all of the doctors you have seen for sickle cell pain.Public Subscale",
      "external_stigma_sickle_cell_disease_people_patient_fault1": "People believe that it is mostly the patient's fault when his/her pain does not get better",
      "external_stigma_sickle_cell_disease_people_excuse_medication": "People believe that sickle cell is used as an excuse to get pain medication.",
      "external_stigma_sickle_cell_disease_people_think_less_unable_work": "People think less of someone who is unable to work because of sickle cell.",
      "external_stigma_sickle_cell_disease_people_sign_weakness": "People believe that having sickle cell pain is a sign of weakness.",
      "external_stigma_sickle_cell_disease_people_prescription_drug_addict": "People think that someone taking prescription pain medication on a regular basis is a \"drug addict\".",
      "external_stigma_sickle_cell_disease_people_think_mental_emotional_problem": "When people hear that someone has sickle cell pain, they think that person is also likely to have mental or emotional problems.",
      "external_stigma_sickle_cell_disease_doctor_think_want_more_medication_than_needed": "Many doctors think that people with sickle cell pain want more pain medication than is necessary for their physical pain.",
      "external_stigma_sickle_cell_disease_doctor_think_mental_emotional_problem": "Doctors think that sickle cell pain is mostly a mental or emotional problem.",
      "sec_in_the_following_7_statements_the_word_f_title": "In the following 7 statements, the word \"family\" refers to the people who are most important and significant to you.Family Subscale",
      "external_stigma_sickle_cell_disease_family_think_need_less_medication": "My family thinks I need less pain medication than I take.",
      "external_stigma_sickle_cell_disease_family_exaggerate_pain": "My family feels that I exaggerate how much I hurt in order to get out of doing things that I don't want to do.",
      "external_stigma_sickle_cell_disease_family_could_be_more_active": "My family thinks that I could be more physically active if I wanted.",
      "external_stigma_sickle_cell_disease_family_prescription_drug_addict": "My family thinks that by taking pain medication on a regular basis, I have become a \"drug addict\".",
      "external_stigma_sickle_cell_disease_family_less_respect": "I feel that my family has less respect for me since I have sickle cell.",
      "external_stigma_sickle_cell_disease_family_think_mental_emotional_problem": "My family thinks that sickle cell pain is more of a mental or emotional problem than a physical problem.",
      "external_stigma_sickle_cell_disease_family_embarrassed": "My family feels embarrassed to tell people that I have sickle cell.",
      "sec_in_the_following_6_statements_the_word_n_title": "In the following 6 statements, the word \"nurse\" refers to all of the nurses you have seen for sickle cell pain.Nurse Subscale",
      "external_stigma_sickle_cell_disease_nurse_exaggerate_pain": "Nurses think that people with sickle cell exaggerate their pain.",
      "external_stigma_sickle_cell_disease_nurse_think_want_more_medication_than_needed": "Many nurses think that people with sickle cell pain want more pain medication than is necessary for their physical pain.",
      "external_stigma_sickle_cell_disease_nurse_think_mental_emotional_problem": "Nurses think that sickle cell pain is mostly a mental or emotional problem.",
      "external_stigma_sickle_cell_disease_nurse_could_be_more_active": "Many nurses believe that people with sickle cell could be more physically active if they wanted.",
      "external_stigma_sickle_cell_disease_nurse_prescription_drug_addict": "Many nurses think that people with sickle cell pain are \"drug addicts\".",
      "external_stigma_sickle_cell_disease_nurse_prefer_not_care": "Most nurses would prefer not to care for people with sickle cell disease.",
      "external_stigma_sickle_cell_disease_scoring_instructions": "Each subscale score is the sum of the items in the subscale scale (P2 Range= 8-40; Family Range= 7-35; Nurse Range= 6-30).The total score is the sum of all 3 subscale scores (Range: 21-105)."
    }
  }
}