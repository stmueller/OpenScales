{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Five Facet Mindfulness Questionnaire",
      "code": "FFMQ",
      "abbreviation": "FFMQ-39",
      "description": "39-item measure of five facets of mindfulness: Observing, Describing, Acting with Awareness, Non-Judging, and Non-Reactivity. 5-point scale (1=Never or very rarely true to 5=Very often or always true). 19 items are reverse-scored. Set use_short_form=1 to administer the 15-item FFMQ-15 subset.",
      "citation": "Baer, R. A., Smith, G. T., Hopkins, J., Krietemeyer, J., & Toney, L. (2006). Using self-report assessment methods to explore facets of mindfulness. Assessment, 13(1), 27–45. https://doi.org/10.1177/1073191105283504",
      "license": "CC BY 3.0",
      "license_explanation": "Items published under CC BY 3.0 in Gu et al. (2016), Psychological Assessment, 28(7), 791–802. https://psycnet.apa.org/fulltext/2016-17965-001.html. Also freely available from developer at ruthbaer.com.",
      "license_url": "https://psycnet.apa.org/fulltext/2016-17965-001.html",
      "version": "1.0",
      "url": "https://ruthbaer.com/academics/FFMQ.pdf",
      "domain": "Self & Coping"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "parameters": {
      "use_short_form": {
        "type": "boolean",
        "default": 0,
        "description": "Use FFMQ-15 (15-item short form). When 1, 24 items are hidden."
      }
    },
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "ffmq_r1",
        "ffmq_r2",
        "ffmq_r3",
        "ffmq_r4",
        "ffmq_r5"
      ],
      "question_head": "ffmq_head"
    },
    "dimensions": [
      {
        "id": "observe",
        "name": "Observing",
        "description": "Noticing internal and external experiences (8 items). All forward-scored."
      },
      {
        "id": "describe",
        "name": "Describing",
        "description": "Labeling internal experiences with words (8 items). Items 12, 16, 22 reverse-scored."
      },
      {
        "id": "act_aware",
        "name": "Acting with Awareness",
        "description": "Attending to activities in the moment (8 items). All reverse-scored."
      },
      {
        "id": "nonjudge",
        "name": "Non-Judging of Inner Experience",
        "description": "Non-evaluative stance toward thoughts/feelings (8 items). All reverse-scored."
      },
      {
        "id": "nonreact",
        "name": "Non-Reactivity to Inner Experience",
        "description": "Allowing thoughts/feelings to come and go (7 items). All forward-scored."
      }
    ],
    "items": [
