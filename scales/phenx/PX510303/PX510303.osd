      "SubstanceUse_Lifetime_Alcohol_opt_1": "0 occasions",
      "SubstanceUse_Lifetime_Alcohol_opt_2": "1-2 occasions",
      "SubstanceUse_Lifetime_Alcohol_opt_3": "3-5 occasions",
