{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Reward and Punishment Responsivity and Motivation Questionnaire",
      "code": "RPRM-Q",
      "abbreviation": "RPRM-Q",
      "description": "18-item questionnaire measuring reward and punishment responsivity and motivation. Four subscales: Reward Responsivity (RR, 4 items), Motivation to Approach Reward (MR, 5 items), Punishment Responsivity (PR, 5 items), Motivation to Avoid Punishment (MP, 4 items). 5-point scale (1 = does not apply to me at all; 5 = applies to me completely). Higher scores indicate greater responsivity or motivation.",
      "citation": "Jonker, N. C., Timmerman, M. E., & de Jong, P. J. (2022). Frontiers in Psychology. https://doi.org/10.3389/fpsyg.2022.868963. [APA PsycTests: https://doi.org/10.1037/t95928-000]",
      "license": "CC BY 4.0",
      "license_explanation": "Items published in Jonker et al. (2022), Frontiers in Psychology, which publishes under CC BY 4.0.",
      "license_url": "https://doi.org/10.3389/fpsyg.2022.929255",
      "version": "1.0",
      "url": "https://doi.org/10.3389/fpsyg.2022.929255",
      "domain": "Self & Coping"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-02",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5"
      ],
      "question_head": "question_head",
      "likert_reverse": true
    },
    "dimensions": [
      {
        "id": "RR",
        "name": "Reward Responsivity",
        "description": "Responsivity to rewards (4 items)."
      },
      {
        "id": "MR",
        "name": "Motivation to Approach Reward",
        "description": "Motivation to approach rewarding outcomes (5 items)."
      },
      {
        "id": "PR",
        "name": "Punishment Responsivity",
        "description": "Responsivity to punishment (5 items)."
      },
      {
        "id": "MP",
        "name": "Motivation to Avoid Punishment",
        "description": "Motivation to avoid punishing outcomes (4 items)."
      }
    ],
