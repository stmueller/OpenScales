      "name": "Expectancies - Alcohol, Cigarette Smoking, and Other Smoking - Illegal Stimulant Drugs",
      "code": "PX520402",
      "abbreviation": "PX520402",
      "description": "The Stimulant Effect Expectancy Questionnaire (SEEQ) is a modification of the Cocaine Effect Expectancy Questionnaire that assesses stimulants in general, rather than cocaine only. Subjects are asked to answer 71 questions regarding the stimulant with which they are most familiar and according to th",
      "domain": "Substance Use",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/520402]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/520402"
    },
