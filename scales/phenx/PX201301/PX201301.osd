{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Voice Impairments - Adults",
      "code": "PX201301",
      "abbreviation": "PX201301",
      "description": "The Voice Handicap Index (VHI) is a 30-item self-administered questionnaire that asks individuals to describe their voice and the effects of their voice on their life. Three subscales cover the areas of functional, emotional, and physical aspects of voice disorders. Points from the questions can be ",
      "domain": "Health",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/201301]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/201301"
    },
    "implementation": {
