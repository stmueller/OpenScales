    "scoring": {
      "physical": {
        "method": "mean_coded",
        "items": [
          "pedsql1",
          "pedsql2",
          "pedsql3",
          "pedsql4",
          "pedsql5",
          "pedsql6",
          "pedsql7",
          "pedsql8"
        ],
        "description": "Mean of 8 physical functioning items. Reverse-coded (item_coding=-1: 4 − response) then transform to 0–100: mean_reversed × 25. Higher = better physical functioning.",
        "item_coding": {
          "pedsql1": -1,
          "pedsql2": -1,
          "pedsql3": -1,
          "pedsql4": -1,
          "pedsql5": -1,
          "pedsql6": -1,
          "pedsql7": -1,
          "pedsql8": -1
        },
        "transform": [
          {
            "op": "multiply",
            "value": 25
          }
        ],
        "norms": {
          "source": "Varni et al. (2001). PedsQL 4.0 Generic Core Scales. Assessment, 8(3), 257–265. Healthy US children ages 8–12 (child self-report): mean ≈ 87.5 (SD 14.3).",
          "thresholds": [
            {
              "min": 0,
              "max": 69,
              "label": "At risk for impaired physical functioning"
            },
            {
              "min": 70,
              "max": 100,
              "label": "Within typical range"
            }
          ]
        }
      },
