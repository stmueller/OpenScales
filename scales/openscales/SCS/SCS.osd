        "norms": {
          "thresholds": [
            {
              "min": 1.0,
              "max": 2.49,
              "label": "Low Self-Compassion"
            },
            {
              "min": 2.5,
              "max": 3.5,
              "label": "Moderate Self-Compassion"
            },
            {
              "min": 3.51,
              "max": 5.0,
              "label": "High Self-Compassion"
            }
          ]
        }
      }
