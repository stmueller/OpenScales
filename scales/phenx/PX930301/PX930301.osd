    "scale_info": {
      "name": "Use of Personal Protective Equipment (PPE) by Healthcare Workers",
      "code": "PX930301",
      "abbreviation": "PX930301",
      "description": "This is a self-reported survey for healthcare workers on their access to and reuse of Personal Protective Equipment (PPE). It consists of two multiple choice questions and a table consisting of Likert-style questions on access to specific types of PPE.",
      "domain": "Social",
      "citation": "HERO Registry Protective Equipment Survey. As implemented in: PhenX Toolkit. Use of Personal Protective Equipment (PPE) by Healthcare Workers. https://www.phenxtoolkit.org/protocols/view/930301",
