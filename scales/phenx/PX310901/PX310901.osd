  "definition": {
    "scale_info": {
      "name": "Patient Response to Genetic Testing",
      "code": "PX310901",
      "abbreviation": "PX310901",
      "description": "The Feelings About genomiC Testing Results (FACToR) instrument is used to measure the psychosocial impact of returning genomic findings to patients in research and clinical practice. The instrument includes 12 items and 4 subscales (negative emotions, positive emotions, uncertainty, privacy concerns",
      "domain": "Health",
      "citation": "Niu, X ., Amendola, L. M ., Hart, R ., Bennette, C. S ., Heagerty, P ., Horike-Pyne, M ., Trinidad, S. B ., Rosenthal, E. A ., Comstock, B ., Nefcy, C ., Hisam, F. M ., Bennett, R. L ., Grady, W. M ., Gallego, C. J ., Tarczy-Hornoch, P ., Fullerton, S. M ., Burke, W ., Regier, D. A ., Dorschner, M. O ., Shirts, B. H ., Robertson, P. D ., Nickerson, D. A ., Patrick, D. L ., Jarvik, G. P ., & Veenstra, D. L .(2019). Clinical exome sequencing vs. usual care for hereditary colorectal cancer diagnosis: A pilot comparative effectiveness study. Contemporary Clinical Trials, 84, 105820. [PhenX: https://www.phenxtoolkit.org/protocols/view/310901]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/310901"
    },
    "implementation": {
