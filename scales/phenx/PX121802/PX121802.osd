      "anxiety_disorder_symptoms_children_self_report_past_three_months_follow_parent": "I follow my mother or father wherever they go.",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_follow_parent_opt_0": "Not true or hardly ever true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_follow_parent_opt_1": "Somewhat true or sometimes true",
      "anxiety_disorder_symptoms_children_self_report_past_three_months_follow_parent_opt_2": "Very true or often true",
