        "name": "General Satisfaction",
        "abbreviation": "GSAT",
        "description": "Items 3(+), 33(–), 42(+), 21(–), 11(+), 49(–). Sum range 6–30."
      },
      {
        "id": "tech",
        "name": "Technical Quality",
        "abbreviation": "TECH",
        "description": "Items 15(+), 2(–), 8(+), 12(–), 23(+), 36(–), 50(+), 45(–), 31(+), 41(–). Sum range 10–50."
      },
      {
        "id": "inter",
        "name": "Interpersonal Manner",
        "abbreviation": "INTER",
        "description": "Items 29(–), 47(+), 39(–), 17(+), 26(–), 34(+), 9(–). Sum range 7–35."
      },
      {
        "id": "comm",
        "name": "Communication",
        "abbreviation": "COMM",
        "description": "Items 6(+), 18(–), 13(+), 38(–), 43(+). Sum range 5–25."
      },
      {
        "id": "finan",
        "name": "Financial Aspects",
        "abbreviation": "FINAN",
        "description": "Items 14(+), 4(–), 27(+), 10(–), 44(+), 24(–), 32(+), 19(–). Sum range 8–40."
      },
      {
        "id": "time",
        "name": "Time Spent with Doctor",
        "abbreviation": "TIME",
        "description": "Items 46(+), 35(–). Sum range 2–10."
      },
      {
        "id": "access",
        "name": "Access/Availability/Convenience",
        "abbreviation": "ACCESS",
        "description": "Items 1(+), 16(–), 5(+), 22(–), 37(+), 28(–), 40(+), 48(–), 20(+), 7(–), 25(+), 51(+). Sum range 12–60."
      }
    ],
