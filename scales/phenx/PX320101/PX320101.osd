      "full_part_time_change_length_opt_1": "Less than 2 months",
      "full_part_time_change_length_opt_2": "2 months to less than 6 months",
      "full_part_time_change_length_opt_3": "6 months to less than 1 year",
      "full_part_time_change_length_opt_4": "1 year to 3 years",
      "full_part_time_change_length_opt_5": "More than 3 years",
      "full_part_time_change_ongoing": "Is this change ongoing?",
      "full_part_time_change_ongoing_opt_1": "Yes",
      "full_part_time_change_ongoing_opt_2": "No",
      "work_schedule_change_ever": "Did you ever change from a set work schedule, where you start and end at the same time every day, to a flexible work schedule, where your start and end times vary from day-to-day?",
      "work_schedule_change_ever_opt_1": "Yes",
      "work_schedule_change_ever_opt_2": "No",
      "work_schedule_change_when": "When did you change to a flexible work schedule?",
      "work_schedule_change_when_opt_1": "At the time of diagnosis",
      "work_schedule_change_when_opt_2": "During treatment",
      "work_schedule_change_when_opt_3": "Less than one year after treatment was finished",
      "work_schedule_change_when_opt_4": "One year or more after treatment was finished",
      "work_schedule_change_less_demand": "Did you ever change to a less demanding job?",
      "work_schedule_change_less_demand_opt_1": "Yes",
      "work_schedule_change_less_demand_opt_2": "No",
      "work_schedule_change_less_demand_when": "When did you change to a less demanding job?",
      "work_schedule_change_less_demand_when_opt_1": "At the time of diagnosis",
      "work_schedule_change_less_demand_when_opt_2": "During treatment",
      "work_schedule_change_less_demand_when_opt_3": "Less than one year after treatment was finished",
      "work_schedule_change_less_demand_when_opt_4": "One year or more after treatment was finished",
      "work_schedule_change_ongoing": "Is this change ongoing?",
      "work_schedule_change_ongoing_opt_1": "Yes",
      "work_schedule_change_ongoing_opt_2": "No",
      "other_work_arrangements": "Did you make any other type of work arrangements because of your cancer, its treatment, or the lasting effects of that treatment?",
      "other_work_arrangements_opt_1": "Yes",
      "other_work_arrangements_opt_2": "No",
      "other_work_arrangements_describe": "27b. If Yes, please describe:",
      "cancer_treatment_effects_pursue_advancement_promotion": "Because of your cancer, its treatment, or the lasting effects of that treatment, did you ever decide not to pursue an advancement or promotion?",
      "cancer_treatment_effects_pursue_advancement_promotion_opt_1": "Yes",
      "cancer_treatment_effects_pursue_advancement_promotion_opt_2": "No",
      "cancer_treatment_effects_retire_earlier": "Because of your cancer, its treatment, or the lasting effects of that treatment, did you retire earlier than you had planned?",
      "cancer_treatment_effects_retire_earlier_opt_1": "Yes",
      "cancer_treatment_effects_retire_earlier_opt_2": "No",
      "cancer_treatment_effects_delay_retirement": "Because of your cancer, its treatment, or the lasting effects of that treatment, did you delay retirement beyond when you had planned?",
      "cancer_treatment_effects_delay_retirement_opt_1": "Yes",
      "cancer_treatment_effects_delay_retirement_opt_2": "No",
      "cancer_treatment_effects_interfere_physical_tasks": "Did you ever feel that your cancer, its treatment, or the lasting affects of that treatment interfered with your ability to perform any physical tasks required by your job?",
      "cancer_treatment_effects_interfere_physical_tasks_opt_1": "Yes",
      "cancer_treatment_effects_interfere_physical_tasks_opt_2": "No",
      "cancer_treatment_effects_interfere_physical_tasks_opt_3": "I was never required to perform physical tasks as part of my job",
      "cancer_treatment_effects_interfere_mental_tasks": "Did you ever feel that your cancer, its treatment, or the lasting effects of that treatment interfered with your ability to perform any mental tasks required by your job?",
      "cancer_treatment_effects_interfere_mental_tasks_opt_1": "Yes",
      "cancer_treatment_effects_interfere_mental_tasks_opt_2": "No",
      "cancer_treatment_effects_less_productive": "Did you ever feel that, because of your cancer, its treatment, or the lasting effects of that treatment, you were less productive at work?",
      "cancer_treatment_effects_less_productive_opt_1": "Yes",
      "cancer_treatment_effects_less_productive_opt_2": "No",
      "cancer_treatment_effects_force_retirement_quit": "Did you ever worry that, because of the effects of cancer on your health, you might be forced to retire or quit work before you are ready?",
      "cancer_treatment_effects_force_retirement_quit_opt_1": "Yes",
      "cancer_treatment_effects_force_retirement_quit_opt_2": "No",
      "stay_job_health_insurance": "Did you ever stay at a job in part because you were concerned about losing your health insurance?",
      "stay_job_health_insurance_opt_1": "Yes",
      "stay_job_health_insurance_opt_2": "No",
      "losing_health_insurance": "Were you concerned about losing your health insurance because of your cancer?",
      "losing_health_insurance_opt_1": "Yes",
      "losing_health_insurance_opt_2": "No",
      "cancer_treatment_effects_work_life_career": "Thinking about your work life or career, what effect has your experience with cancer, its treatment, or the lasting effects of that treatment had on it?",
      "cancer_treatment_effects_work_life_career_opt_1": "Mostly positive effect",
      "cancer_treatment_effects_work_life_career_opt_2": "Mostly negative effect",
      "cancer_treatment_effects_work_life_career_opt_3": "Equally positive and negative effect",
      "cancer_treatment_effects_work_life_career_opt_4": "Neither positive nor negative effect",
      "spouse_health_insurance": "Did your spouse or significant other ever stay at a job in part because he/she was concerned about losing health insurance for the family?",
      "spouse_health_insurance_opt_1": "Yes",
      "spouse_health_insurance_opt_2": "No",
      "spouse_health_insurance_opt_3": "Does not apply"
    }
