  "translations": {
    "en": {
      "glasses_contact_lenses_correct_currently": "Does your child currently wear glasses or contact lenses to correct, or partially correct, his/her eyesight?",
      "glasses_contact_lenses_correct_currently_opt_1": "No",
      "glasses_contact_lenses_correct_currently_opt_2": "Glasses",
      "glasses_contact_lenses_correct_currently_opt_3": "Contact lenses",
      "glasses_contact_lenses_frequency_currently": "How often are the glasses or contact lenses worn?",
      "glasses_contact_lenses_frequency_currently_opt_1": "All the time",
      "glasses_contact_lenses_frequency_currently_opt_2": "Most of the time",
      "glasses_contact_lenses_frequency_currently_opt_3": "Sometimes",
      "glasses_contact_lenses_frequency_currently_opt_4": "Hardly ever",
      "glasses_contact_lenses_frequency_currently_opt_5": "Only when eyes feel tired",
      "glasses_contact_lenses_astigmatism": "Were the glasses/contact lenses prescribed for Astigmatism?",
      "glasses_contact_lenses_short_sightedness_myopia": "Were the glasses/contact lenses prescribed for Short-sightedness/myopia?",
      "glasses_contact_lenses_long_sightedness_hyperopia": "Were the glasses/contact lenses prescribed for Long-sightedness/hyperopia?",
      "glasses_contact_lenses_other": "Were the glasses/contact lenses prescribed for Other?",
      "glasses_contact_lenses_other_specify": "Specify other glasses/contact lenses prescribed.",
      "glasses_contact_lenses_no_longer_need": "Has your child worn glasses or contact lenses in the past, but no longer needs to wear them?",
      "glasses_contact_lenses_no_longer_need_opt_1": "No",
      "glasses_contact_lenses_no_longer_need_opt_2": "Yes",
      "glasses_contact_lenses_no_longer_need_opt_3": "Unsure",
      "glasses_contact_lenses_first_date": "Please state the date when first prescribed.",
      "glasses_contact_lenses_first_age": "Please state the age when first prescribed.",
      "glasses_contact_lenses_stop_date": "Date stopped?",
      "glasses_contact_lenses_stop_reason": "Reason stopped?",
      "glasses_contact_lenses_frequency_before": "How often did you child wear their glasses/contact lenses?",
      "glasses_contact_lenses_frequency_before_opt_1": "All the time",
      "glasses_contact_lenses_frequency_before_opt_2": "Most of the time",
      "glasses_contact_lenses_frequency_before_opt_3": "Sometimes",
      "glasses_contact_lenses_frequency_before_opt_4": "Hardly ever",
      "glasses_contact_lenses_frequency_before_opt_5": "Only when eyes feel tired",
      "opt_1": "Yes",
      "opt_2": "No",
