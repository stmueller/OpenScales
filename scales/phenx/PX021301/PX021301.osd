        "id": "weight_in_pounds",
        "text_key": "weight_in_pounds",
        "type": "multi",
        "options": [
          {
            "text_key": "weight_in_pounds_opt_1",
            "value": 1
          },
          {
            "text_key": "weight_in_pounds_opt_2",
            "value": 2
          }
        ]
      },
      {
