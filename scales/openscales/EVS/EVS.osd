    "scoring": {
      "criticism": {
        "description": "Mean of criticism vulnerability items (1-4). Higher scores indicate greater vulnerability to criticism.",
        "method": "mean_coded",
        "items": [
          "evs1",
          "evs2",
          "evs3",
          "evs4"
        ]
      },
      "relationships": {
        "description": "Mean of relationship vulnerability items (1-4). Higher scores indicate greater vulnerability related to worsening relationships.",
        "method": "mean_coded",
        "items": [
          "evs5",
          "evs6",
          "evs7",
          "evs8"
        ]
      },
      "discord": {
        "description": "Mean of interpersonal discord vulnerability items (1-4). Higher scores indicate greater vulnerability to interpersonal discord.",
        "method": "mean_coded",
        "items": [
          "evs9",
          "evs10",
          "evs11",
          "evs12"
        ]
      },
      "avoidance": {
        "description": "Mean of avoidance vulnerability items (1-4). Higher scores indicate greater vulnerability related to procrastination and emotional avoidance.",
        "method": "mean_coded",
        "items": [
          "evs13",
          "evs14",
          "evs15",
          "evs16"
        ]
      }
    }
  },
  "translations": {
    "en": {
      "likert_1": "I completely disagree",
      "likert_2": "I somewhat disagree",
      "likert_3": "I somewhat agree",
      "likert_4": "I completely agree",
      "question_head": "Please indicate how much you agree with each statement.",
      "evs1": "I get hurt when my opinion is criticized.",
      "evs2": "I get hurt when my thoughts are denied.",
      "evs3": "I get hurt when someone criticizes me.",
      "evs4": "I get hurt when someone advises me.",
      "evs5": "I do not want to be hated, so I feel hurt if I cannot decline an invitation.",
      "evs6": "I am afraid of being hated by people, and I feel weak and hurt for accepting requests.",
      "evs7": "I feel hurt if I cannot refuse what people have asked me to do.",
      "evs8": "I feel weak and hurt when I cannot oppose people's ideas.",
      "evs9": "I get hurt when I am directly told bad things about myself.",
      "evs10": "I get hurt when I am indirectly told bad things about myself.",
      "evs11": "I get hurt when my relationship with my friends goes bad.",
      "evs12": "I get hurt when someone I trust does not talk to me.",
      "evs13": "I feel vulnerable when I try to avoid things I do not like.",
      "evs14": "I feel hurt avoiding things that cause inconvenience to me.",
      "evs15": "I feel regret and hurt when I turn my back toward a problem.",
      "evs16": "I feel hurt when I put off things I do not like.",
      "debrief": "Thank you for completing the Emotional Vulnerability Scale."
    }
  }
}
