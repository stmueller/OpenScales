          "ebq7",
          "ebq11",
          "ebq15"
        ]
      },
      "pos_usefulness": {
        "description": "Mean of 4 Positive-Usefulness items (1-7). Higher scores indicate stronger beliefs that positive emotions are useless or harmful.",
        "method": "mean_coded",
        "items": [
          "ebq4",
          "ebq8",
          "ebq12",
          "ebq16"
        ]
      },
      "general_controllability": {
        "description": "Mean of all 8 controllability items (Negative-Controllability + Positive-Controllability). CFA supported combining these into a single factor.",
        "method": "mean_coded",
