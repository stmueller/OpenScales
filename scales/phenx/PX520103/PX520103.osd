  "translations": {
    "en": {
      "instructions_520103": "You will be asked to indicate your answers to the following questions about the drug you consumed by marking on the line to indicate how much the adjective or description applies to you. Please indicate how you are feeling right now by using  the image below to measure the result  in mm for every question.",
      "line": "Image_line.jpg",
      "feel_drug_effect_now": "Do you FEEL a drug effect right now?",
      "like_effects_you_are_feeling": "Do you LIKE any of the effects you are feeling right now?",
      "dislike_effects_you_are_feeling": "Do you DISLIKE any of the effects you are feeling right now?",
      "are_you_high": "Are you HIGH right now?",
      "like_more_of_the_drug": "Would you like MORE of the drug you took, right now?"
    }
  }
