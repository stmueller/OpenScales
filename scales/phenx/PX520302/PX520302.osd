    "scoring": {
      "the_scores_from": {
        "description": "The scores from: sum_coded of 6 items.",
        "method": "sum_coded",
        "items": [
          "want_cocaine_almost_taste",
          "urge_for_cocaine",
          "use_cocaine_soon_as_possible",
          "crave_coke",
          "want_to_use_cocaine",
          "cocaine_make_things_perfect"
        ]
      }
    },
    "_scoring_notes": "Scoring Procedure and InterpretationEach item is scored on a scale ranging from 1 for \"Strongly Disagree\" to 7 for \"Strongly Agree.\" The scores from items 1-3, 5, 6, and 8-10 are used as the raw scores. Items 4 and 7 should be reverse-scored (raw score = 8 minus reverse-keyed item score) (Heinz et al., 2006). A total score is obtained by averaging all items (Sussner et al., 2006).",
    "likert_options": {
      "points": 7,
      "min": 1,
      "max": 7,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5",
        "likert_6",
        "likert_7"
      ]
    }
  },
  "translations": {
    "en": {
      "instructions_520302": "Indicate how strongly you agree or disagree with each of the following statements by selecting a number between 1 (STRONGLY DISAGREE) and 7 (STRONGLY AGREE). The closer your selection to one end or the other indicates the strength of your agreement or disagreement If you don't agree or disagree with a statement, select the mid-point number 4. Please complete every item. We are interested in how you are thinking or feeling right now as you are filling out the questionnaire.",
      "want_cocaine_almost_taste": "I want cocaine so bad I can almost taste it.",
