  "translations": {
    "en": {
      "likert_1": "Very Inaccurate",
      "likert_2": "Moderately Inaccurate",
      "likert_3": "Neither Accurate Nor Inaccurate",
      "likert_4": "Moderately Accurate",
      "likert_5": "Very Accurate",
      "question_head": "<h3>How Accurately Can You Describe Yourself?</h3>\nDescribe yourself as you generally are now, not as you wish to be in the future. Describe yourself as you honestly see yourself, in relation to other people you know of the same sex as you are, and roughly your same age. So that you can describe yourself in an honest manner, your responses will be kept in absolute confidence. Indicate how accurately this statement describes you.",
      "ipip_via_001": "Admit when I am wrong.",
      "ipip_via_002": "Am a good listener.",
      "ipip_via_003": "Am committed to principles of justice and equality.",
      "ipip_via_004": "Believe that everyone should have a say.",
      "ipip_via_005": "Believe that everyone's rights are equally important.",
      "ipip_via_006": "Give everyone a chance.",
      "ipip_via_007": "Take advantage of others.",
      "ipip_via_008": "Treat all people equally.",
      "ipip_via_009": "Treat others differently if I don't like them.",
      "ipip_via_010": "Allow others to make a fresh start.",
      "ipip_via_011": "Believe that it is best to forgive and forget.",
      "ipip_via_012": "Do not give anyone a second chance to hurt me.",
      "ipip_via_013": "Don't try to get even.",
      "ipip_via_014": "Hate to see anyone suffer, even my worst enemy.",
      "ipip_via_015": "Hold grudges.",
      "ipip_via_016": "Let bygones be bygones.",
      "ipip_via_017": "Never seek vengeance.",
      "ipip_via_018": "Try to respond with understanding when someone treats me badly.",
      "ipip_via_019": "Am a brave person.",
      "ipip_via_020": "Avoid dealing with awkward situations.",
      "ipip_via_021": "Avoid dealing with uncomfortable emotions.",
      "ipip_via_022": "Call for action while others talk.",
      "ipip_via_023": "Can face my fears.",
      "ipip_via_024": "Do not stand up for my beliefs.",
      "ipip_via_025": "Don't hesitate to express an unpopular opinion.",
      "ipip_via_026": "Don't speak my mind freely when there might be negative results.",
      "ipip_via_027": "Have taken frequent stands in the face of strong opposition.",
      "ipip_via_028": "Speak up in protest when I hear someone say mean things.",
      "ipip_via_029": "Am a firm believer in thinking things through.",
      "ipip_via_030": "Am valued by my friends for my good judgment.",
      "ipip_via_031": "Am valued by others for my objectivity.",
      "ipip_via_032": "Don't tend to think things through critically.",
      "ipip_via_033": "Don't think about different possibilities when making decisions.",
      "ipip_via_034": "Make decisions only after I have all of the facts.",
      "ipip_via_035": "Try to have good reasons for my important decisions.",
      "ipip_via_036": "Try to identify the reasons for my actions.",
      "ipip_via_037": "Weigh the pro's and the con's.",
      "ipip_via_038": "Am a goal-oriented person.",
      "ipip_via_039": "Am a hard worker.",
      "ipip_via_040": "Do not tend to stick with what I decide to do.",
      "ipip_via_041": "Don't finish what I start.",
      "ipip_via_042": "Don't get sidetracked when I work.",
      "ipip_via_043": "Don't quit a task before it is finished.",
      "ipip_via_044": "Finish things despite obstacles in the way.",
      "ipip_via_045": "Give up easily.",
      "ipip_via_046": "Am a highly disciplined person.",
      "ipip_via_047": "Am not very good at getting things done.",
      "ipip_via_048": "Can always say \"enough is enough.\"",
      "ipip_via_049": "Can stay on a diet.",
      "ipip_via_050": "Can't resist eating candy or cookies if they are around.",
      "ipip_via_051": "Do my tasks only just before they need to be done.",
      "ipip_via_052": "Do not exercise on a regular basis.",
      "ipip_via_053": "Forego things that are bad for me in the long run even if they make me feel good in the short run.",
      "ipip_via_054": "Give in to my urges.",
      "ipip_via_055": "Have no trouble eating healthy foods.",
