{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Quality of Life in Epilepsy Inventory-89",
      "code": "QOLIE-89",
      "abbreviation": "QOLIE-89",
      "description": "89-item self-report measure of health-related quality of life for adults with epilepsy. The QOLIE-89 is the full version of the QOLIE-31, covering 17 health concepts across four summary domains: Epilepsy-Targeted, Mental Health, Physical Health, and Cognitive. All subscales scored 0–100 (higher = better quality of life). A weighted composite overall score is computed. NOTE: Exact item text requires the official RAND instrument — see URL above. Item text provided here reflects the published structure from Devinsky et al. (1995) and is based on the MOS/SF-36 item pool plus epilepsy-specific items.",
      "citation": "Devinsky, O., Vickrey, B.G., Cramer, J., Perrine, K., Hermann, B., Meador, K., & Hays, R.D. (1995). Development of the quality of life in epilepsy inventory. Epilepsia, 36(11), 1089–1104. https://doi.org/10.1111/j.1528-1157.1995.tb00467.x",
      "license": "Public Domain",
      "version": "1.0",
      "url": "https://www.rand.org/health-care/surveys_tools/qolie.html",
      "domain": "Health",
      "license_explanation": "RAND Corporation places their health survey instruments in the public domain. RAND explicitly states these instruments are available for use without permission or fee.",
      "license_url": "https://www.rand.org/health-care/surveys_tools/qolie.html"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "dimensions": [
      {
        "id": "overall_qol",
        "name": "Overall Quality of Life",
        "abbreviation": "QOL",
        "description": "Overall quality of life. Items 2 (0–10) and 49 (QoL ladder).",
        "enabled_param": null
      },
      {
        "id": "overall_health",
        "name": "Overall Health/QoL",
        "abbreviation": "OH",
        "description": "Change in health over past year. Item 3 (standalone).",
        "enabled_param": null
      },
      {
        "id": "physical_function",
        "name": "Physical Function",
        "abbreviation": "PF",
        "description": "Limitations in physical activities due to health. Items: qolie89_4–qolie89_13 (SF-36 physical functioning items).",
        "enabled_param": null
      },
      {
        "id": "role_limitations_physical",
        "name": "Role Limitations — Physical",
        "abbreviation": "RP",
        "description": "Limitations in work due to physical health. Items: qolie89_14–qolie89_17, qolie89_rp5.",
        "enabled_param": null
      },
      {
        "id": "role_limitations_emotional",
        "name": "Role Limitations — Emotional",
        "abbreviation": "RE",
        "description": "Limitations in work due to emotional problems. Items: qolie89_14–qolie89_17, qolie89_rp5 (rows shared with RP grid).",
        "enabled_param": null
      },
      {
        "id": "pain",
        "name": "Pain",
        "abbreviation": "PAIN",
        "description": "Bodily pain and its interference. Items: qolie89_21–qolie89_22.",
        "enabled_param": null
      },
      {
        "id": "emotional_wellbeing",
        "name": "Emotional Well-Being",
        "abbreviation": "EWB",
        "description": "Psychological distress and well-being. Items: qolie89_23–qolie89_27.",
        "enabled_param": null
      },
      {
        "id": "energy_fatigue",
        "name": "Energy/Fatigue",
        "abbreviation": "EF",
        "description": "Energy level and fatigue. Items: qolie89_28–qolie89_31.",
        "enabled_param": null
      },
      {
        "id": "health_perceptions",
        "name": "Health Perceptions",
        "abbreviation": "HP",
        "description": "Personal evaluation of health and health outlook. Items: qolie89_32–qolie89_36.",
        "enabled_param": null
      },
      {
        "id": "memory",
        "name": "Memory",
        "abbreviation": "MEM",
        "description": "Memory difficulties. Items 50–54 and 75.",
        "enabled_param": null
      },
      {
        "id": "attention_concentration",
        "name": "Attention/Concentration",
        "abbreviation": "AC",
        "description": "Difficulty sustaining attention and concentration. Items: 37, 38, 41, 60–64, 73.",
        "enabled_param": null
      },
      {
        "id": "language",
        "name": "Language",
        "abbreviation": "LNG",
        "description": "Difficulty with language functions (word finding, communication). Items: qolie89_65–qolie89_69.",
        "enabled_param": null
      },
      {
        "id": "seizure_worry",
        "name": "Seizure Worry",
        "abbreviation": "SW",
        "description": "Worry about having seizures and their consequences. Items: qolie89_70–qolie89_76.",
        "enabled_param": null
      },
      {
        "id": "medication_effects",
        "name": "Medication Effects",
        "abbreviation": "ME",
        "description": "Bothersomeness of medication side effects and long-term concerns. Items: qolie89_77–qolie89_81.",
        "enabled_param": null
      },
      {
        "id": "health_discouragement",
        "name": "Health Discouragement",
        "abbreviation": "HD",
        "description": "Feelings of discouragement, hopelessness, and despair related to health. Items: qolie89_82–qolie89_84.",
        "enabled_param": null
      },
      {
        "id": "work_driving_social",
        "name": "Work/Driving/Social Function",
        "abbreviation": "WDS",
        "description": "Impact of epilepsy on work, driving, and social activities. Items: 26, 36, 43, 65–68, 76–78, 85.",
        "enabled_param": null
      },
      {
        "id": "social_support",
        "name": "Social Support",
        "abbreviation": "SS",
        "description": "Perceived availability of social support. Item: qolie89_89.",
        "enabled_param": null
      },
      {
        "id": "social_isolation",
        "name": "Social Isolation",
        "abbreviation": "SI",
        "description": "Social isolation: feeling left out or isolated. Items 87–88.",
        "enabled_param": null
      },
      {
        "id": "total",
        "name": "Overall QOLIE-89 Score",
        "abbreviation": "Total",
        "description": "Weighted composite of all 17 subscales (Table 3 weights), expressed as a T-score (normative mean=50, SD=10; higher=better QoL).",
        "enabled_param": null
      }
    ],
