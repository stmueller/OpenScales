{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Sickle Cell Disease Responses to Stress - Youth",
      "code": "PX870701",
      "abbreviation": "PX870701",
      "description": "The Responses to Stress Questionnaire - Sickle Cell Disease version (RSQ-SC) is a self-reported instrument that includes eight sickle cell disease stressors and 57 questions that capture voluntary (coping) and involuntary (automatic) stress responses. The RSQ-SC contains items to measure three types",
      "domain": "Health",
      "citation": "Prussien, K. V., DeBaun, M. R., Yarboi, J., Bemis, H., McNally, C., Williams, E., & Compas, B. E. (2018). Cognitive function, coping, and depressive symptoms in children and adolescents with sickle cell disease. Journal of Pediatric Psychology, 43(5), 543-551. doi:10.1093/jpepsy/jsx141 Prussien, K. V., Siciliano, R. E., Ciriegio, A. E., Lee, C. A., DeBaun, M. R., Jordan, L. C., & Compas, B. E. (2021). Preliminary study of coping, perceived control, and depressive symptoms in youth with sickle cell anemia. Journal of Developmental and Behavioral Pediatrics, 42(6), 485-489. doi:10.1097/DBP.0000000000000922 [PhenX: https://www.phenxtoolkit.org/protocols/view/870701]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/870701"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
