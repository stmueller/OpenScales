          "pfi11",
          "pfi12"
        ],
        "description": "Total well-being score (0–36). Negative affect items are reverse-coded so that higher scores indicate greater well-being.",
        "item_coding": {
          "pfi1": -1,
          "pfi2": 1,
          "pfi3": -1,
          "pfi4": 1,
          "pfi5": 1,
          "pfi6": -1,
          "pfi7": 1,
          "pfi8": -1,
          "pfi9": 1,
          "pfi10": 1,
          "pfi11": -1,
          "pfi12": -1
        }
      }
    }
  },
  "translations": {
    "en": {
      "likert_0": "Never",
      "likert_1": "Rarely",
      "likert_2": "Sometimes",
      "likert_3": "Often",
      "pfi_inst": "Next, you will read a number of statements that people have made to describe how they feel. Please read each one and select the option which best describes how frequently you felt that way in <b>the past seven days, including today</b>. Some statements describe positive feelings and some describe negative feelings. You may have experienced both positive and negative feelings at different times during the past seven days.",
      "question_head": "Select which best describes how frequently you have felt this way in the past seven days, including today.",
      "pfi1": "I felt dissatisfied with my life",
      "pfi2": "I felt happy",
      "pfi3": "I felt cheerless",
      "pfi4": "I felt pleased with the way I am",
      "pfi5": "I felt that life was enjoyable",
      "pfi6": "I felt that life was meaningless",
      "pfi7": "I felt content",
      "pfi8": "I felt tense",
      "pfi9": "I felt calm",
      "pfi10": "I felt relaxed",
      "pfi11": "I felt upset",
      "pfi12": "I felt worried",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
