          },
          {
            "op": "multiply",
            "value": 100
          }
        ]
      },
      "overall": {
        "description": "Overall Social Support: raw sum of all 19 functional support items (range 19–95; higher = greater overall perceived support). To obtain the 0–100 overall score: ((mean_of_items − 1) / 4) × 100.",
        "method": "mean_coded",
        "items": [
          "mossocial2",
