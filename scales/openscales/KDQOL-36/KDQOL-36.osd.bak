      "kdqol36_oh7": "7",
      "kdqol36_oh8": "8",
      "kdqol36_oh9": "9",
      "kdqol36_oh10": "10 — Best possible health",
      "kdqol36_agree1": "Strongly agree",
      "kdqol36_agree2": "Agree",
      "kdqol36_agree3": "Neither agree nor disagree",
      "kdqol36_agree4": "Disagree",
      "kdqol36_agree5": "Strongly disagree",
      "kdqol36_bother1": "Not at all bothered",
      "kdqol36_bother2": "Somewhat bothered",
      "kdqol36_bother3": "Moderately bothered",
      "kdqol36_bother4": "Very much bothered",
      "kdqol36_bother5": "Extremely bothered",
      "kdqol36_effect1": "Not at all",
      "kdqol36_effect2": "Slightly",
      "kdqol36_effect3": "Moderately",
      "kdqol36_effect4": "Quite a bit",
      "kdqol36_effect5": "Extremely",
      "kdqol36_1": "In general, would you say your health is:",
      "kdqol36_sf12_pf_head": "The following two questions are about activities you might do during a typical day. Does your health now limit you in these activities? If so, how much?",
      "kdqol36_2": "Moderate activities, such as moving a table, pushing a vacuum cleaner, bowling, or playing golf",
      "kdqol36_3": "Climbing several flights of stairs",
      "kdqol36_rp_head": "During the past 4 weeks, have you had any of the following problems with your work or other regular daily activities as a result of your physical health?",
      "kdqol36_4": "Accomplished less than you would like",
      "kdqol36_5": "Were limited in the kind of work or other activities",
      "kdqol36_re_head": "During the past 4 weeks, have you had any of the following problems with your work or other regular daily activities as a result of any emotional problems (such as feeling depressed or anxious)?",
      "kdqol36_6": "Accomplished less than you would like",
      "kdqol36_7": "Didn't do work or other activities as carefully as usual",
      "kdqol36_8": "During the past 4 weeks, to what extent has your physical health or emotional problems interfered with your normal social activities with family, friends, neighbors, or groups?",
      "kdqol36_mh_head": "How much of the time during the past 4 weeks —",
      "kdqol36_9": "Have you felt calm and peaceful?",
      "kdqol36_10": "Did you have a lot of energy?",
      "kdqol36_11": "Have you felt downhearted and blue?",
      "kdqol36_12": "How would you rate your overall health? (0=worst possible, 10=best possible)",
      "kdqol36_burden_head": "Please indicate the extent to which you agree or disagree with each of the following statements about your kidney disease.",
      "kdqol36_13": "Kidney disease takes too much of my time.",
      "kdqol36_14": "Kidney disease is frustrating.",
      "kdqol36_15": "I feel like a burden to my family.",
      "kdqol36_16": "Kidney disease has been a financial burden on me and my family.",
      "kdqol36_symp_head": "How much were you bothered by the following problems during the past 4 weeks?",
      "kdqol36_17": "Muscle soreness",
      "kdqol36_18": "Chest pain",
      "kdqol36_19": "Cramps",
      "kdqol36_20": "Itchy skin",
      "kdqol36_21": "Dry skin",
      "kdqol36_22": "Shortness of breath",
      "kdqol36_23": "Faintness or dizziness",
      "kdqol36_24": "Lack of appetite",
      "kdqol36_25": "Worn out or fatigued",
      "kdqol36_26": "Bone/joint pain",
      "kdqol36_27": "Trouble with fistula, graft, or catheter (access site) — if applicable",
      "kdqol36_28": "Headaches",
      "kdqol36_eff_head": "How much does kidney disease affect your daily life? Please indicate the extent to which each of the following activities is affected by your kidney disease.",
      "kdqol36_29": "Fluid limitations",
      "kdqol36_30": "Dietary limitations",
      "kdqol36_31": "Your ability to work around the house",
      "kdqol36_32": "Your ability to travel",
      "kdqol36_33": "Being dependent on doctors and other medical staff",
      "kdqol36_34": "Stress or worries caused by your kidney disease",
      "kdqol36_35": "Your sex life",
      "kdqol36_36": "Your personal appearance",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
