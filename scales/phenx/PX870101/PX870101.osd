  "translations": {
    "en": {
      "lk_opt_1": "Never",
      "lk_opt_2": "Not often",
      "lk_opt_3": "Sometimes",
      "lk_opt_4": "Often",
      "lk_opt_5": "Very often",
      "child_stigma_scale_feel_different_other_kids": "How often do you feel different from other kids because you have SCD?",
      "child_stigma_scale_feel_people_not_like_you": "How often do you feel people may not like you if they know you have SCD?",
      "child_stigma_scale_feel_other_children_uncomfortable": "How often do you feel other children are uncomfortable with you because of your SCD?",
      "child_stigma_scale_feel_other_people_not_friends": "How often do you feel other people may not want to be friends with you if they know you have SCD?",
      "child_stigma_scale_feel_people_not_go_out": "How often do you feel people would not want to go out with you or ask you to parties if they know you have SCD?",
      "child_stigma_scale_feel_embarassed": "How often do you feel embarrassed about your SCD?",
      "child_stigma_scale_keep_scd_secret_other_kids": "How often do you keep your SCD a secret from other kids?",
      "child_stigma_scale_avoid_talk_other_about_scd": "How often do you try to avoid talking to other people about your SCD?"
    }
  }
