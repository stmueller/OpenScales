  "translations": {
    "en": {
      "sec_which_of_the_following_strategies_have_b_title": "Which of the following strategies [have been/were] helpful to YOUR CHILD while staying at home because of the COVID-19 outbreak?",
      "helpful_strategies_outbreak_family": "Texting, calling or video-calling family members or friends",
      "helpful_strategies_outbreak_therapist": "Talking to therapist",
      "helpful_strategies_outbreak_exercise": "Exercising/walking",
      "helpful_strategies_outbreak_cooking": "Cooking/baking",
      "helpful_strategies_outbreak_crafts": "Arts and crafts project",
      "helpful_strategies_outbreak_chores": "Cleaning/doing household chores",
      "helpful_strategies_outbreak_games_family": "Playing games with family members",
      "helpful_strategies_outbreak_games_online": "Playing online games",
      "helpful_strategies_outbreak_virtual_entertainment": "Virtual entertainment (concerts, live shows, sports, museums, etc.)",
