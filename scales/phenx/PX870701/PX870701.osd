  "translations": {
    "en": {
      "responses_stress_sickle_cell_disease_youth_intro": "RESPONSES TO STRESS - [SC] (SR-C)This is a list of things about having sickle cell disease that children and teenagers sometimes find stressful or a problem to deal with.",
      "responses_stress_sickle_cell_disease_youth_not_able_do_things_other_kids_do": "Please circle the number indicating how stressful the following things have been for you in the past 6 months. Not being able to do the things that other kids can do or are allowed to do",
      "responses_stress_sickle_cell_disease_youth_not_able_do_things_other_kids_do_opt_1": "Not at all",
      "responses_stress_sickle_cell_disease_youth_not_able_do_things_other_kids_do_opt_2": "A Little",
      "responses_stress_sickle_cell_disease_youth_not_able_do_things_other_kids_do_opt_3": "Somewhat",
      "responses_stress_sickle_cell_disease_youth_not_able_do_things_other_kids_do_opt_4": "Very",
      "responses_stress_sickle_cell_disease_youth_go_to_hospital_often": "Please circle the number indicating how stressful the following things have been for you in the past 6 months. Having to go to the hospital or clinic so often",
      "responses_stress_sickle_cell_disease_youth_go_to_hospital_often_opt_1": "Not at all",
      "responses_stress_sickle_cell_disease_youth_go_to_hospital_often_opt_2": "A Little",
      "responses_stress_sickle_cell_disease_youth_go_to_hospital_often_opt_3": "Somewhat",
      "responses_stress_sickle_cell_disease_youth_go_to_hospital_often_opt_4": "Very",
      "responses_stress_sickle_cell_disease_youth_missing_school_falling_behind_work": "Please circle the number indicating how stressful the following things have been for you in the past 6 months. Missing school days or falling behind in school work",
      "responses_stress_sickle_cell_disease_youth_missing_school_falling_behind_work_opt_1": "Not at all",
      "responses_stress_sickle_cell_disease_youth_missing_school_falling_behind_work_opt_2": "A Little",
      "responses_stress_sickle_cell_disease_youth_missing_school_falling_behind_work_opt_3": "Somewhat",
      "responses_stress_sickle_cell_disease_youth_missing_school_falling_behind_work_opt_4": "Very",
      "responses_stress_sickle_cell_disease_youth_concerns_family_friends": "Please circle the number indicating how stressful the following things have been for you in the past 6 months. Concerns about my family and friends",
      "responses_stress_sickle_cell_disease_youth_concerns_family_friends_opt_1": "Not at all",
      "responses_stress_sickle_cell_disease_youth_concerns_family_friends_opt_2": "A Little",
      "responses_stress_sickle_cell_disease_youth_concerns_family_friends_opt_3": "Somewhat",
      "responses_stress_sickle_cell_disease_youth_concerns_family_friends_opt_4": "Very",
      "responses_stress_sickle_cell_disease_youth_feeling_confused_why_got_it": "Please circle the number indicating how stressful the following things have been for you in the past 6 months. Feeling confused about what sickle cell disease is and why I got it",
      "responses_stress_sickle_cell_disease_youth_feeling_confused_why_got_it_opt_1": "Not at all",
      "responses_stress_sickle_cell_disease_youth_feeling_confused_why_got_it_opt_2": "A Little",
      "responses_stress_sickle_cell_disease_youth_feeling_confused_why_got_it_opt_3": "Somewhat",
      "responses_stress_sickle_cell_disease_youth_feeling_confused_why_got_it_opt_4": "Very",
      "responses_stress_sickle_cell_disease_youth_not_understanding_doctors_tell": "Please circle the number indicating how stressful the following things have been for you in the past 6 months. Not understanding what doctors tell me about sickle cell disease",
      "responses_stress_sickle_cell_disease_youth_not_understanding_doctors_tell_opt_1": "Not at all",
      "responses_stress_sickle_cell_disease_youth_not_understanding_doctors_tell_opt_2": "A Little",
      "responses_stress_sickle_cell_disease_youth_not_understanding_doctors_tell_opt_3": "Somewhat",
      "responses_stress_sickle_cell_disease_youth_not_understanding_doctors_tell_opt_4": "Very",
      "responses_stress_sickle_cell_disease_youth_having_pain_crises": "Please circle the number indicating how stressful the following things have been for you in the past 6 months. Having sickle cell pain crises",
      "responses_stress_sickle_cell_disease_youth_having_pain_crises_opt_1": "Not at all",
      "responses_stress_sickle_cell_disease_youth_having_pain_crises_opt_2": "A Little",
      "responses_stress_sickle_cell_disease_youth_having_pain_crises_opt_3": "Somewhat",
      "responses_stress_sickle_cell_disease_youth_having_pain_crises_opt_4": "Very",
      "responses_stress_sickle_cell_disease_youth_concerns_future": "Please circle the number indicating how stressful the following things have been for you in the past 6 months. Concerns about the future",
      "responses_stress_sickle_cell_disease_youth_concerns_future_opt_1": "Not at all",
      "responses_stress_sickle_cell_disease_youth_concerns_future_opt_2": "A Little",
      "responses_stress_sickle_cell_disease_youth_concerns_future_opt_3": "Somewhat",
      "responses_stress_sickle_cell_disease_youth_concerns_future_opt_4": "Very",
      "responses_stress_sickle_cell_disease_youth_concerns_future_other": "Please circle the number indicating how stressful the following things have been for you in the past 6 months. Other:",
      "responses_stress_sickle_cell_disease_youth_concerns_future_other_opt_1": "Not at all",
      "responses_stress_sickle_cell_disease_youth_concerns_future_other_opt_2": "A Little",
      "responses_stress_sickle_cell_disease_youth_concerns_future_other_opt_3": "Somewhat",
      "responses_stress_sickle_cell_disease_youth_concerns_future_other_opt_4": "Very",
      "responses_stress_sickle_cell_disease_youth_concerns_future_other_write": "Please circle the number indicating how stressful the following things have been for you in the past 6 months. Other (Specify):",
      "responses_stress_sickle_cell_disease_youth_circle_control_over_problems": "Circle the number that shows how much control you generally think you have over these problems.",
      "responses_stress_sickle_cell_disease_youth_circle_control_over_problems_opt_1": "None",
      "responses_stress_sickle_cell_disease_youth_circle_control_over_problems_opt_2": "A Little",
      "responses_stress_sickle_cell_disease_youth_circle_control_over_problems_opt_3": "Some",
      "responses_stress_sickle_cell_disease_youth_circle_control_over_problems_opt_4": "A lot",
      "responses_stress_sickle_cell_disease_youth_feeling_intro": "Below is a list of things that children and teenagers sometimes do, think, or feel when they are dealing with sickle cell disease. Everyone deals with problems in their own way - some people do a lot of the things on this list or have a bunch of feelings, other people just do or think a few of these things.Think of all the stressful parts of having sickle cell disease that you indicated above. For each item below, circle one number from 1 (not at all) to 4 (a lot) that shows how much you do or feel these things when you have the problems with sickle cell like the ones you indicated above. Please let us know about everything you do, think, and feel, even if you don't think it helps make things better.",
      "responses_stress_sickle_cell_disease_youth_try_not_feel_anything": "WHEN DEALING WITH THE STRESS OF SICKLE CELL DISEASE: I try not to feel anything.",
      "responses_stress_sickle_cell_disease_youth_try_not_feel_anything_opt_1": "Not at all",
      "responses_stress_sickle_cell_disease_youth_try_not_feel_anything_opt_2": "A Little",
