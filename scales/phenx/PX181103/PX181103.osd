  "translations": {
    "en": {
      "temperament_infant_squirm": "When being dressed or undressed during the last week, how often did the baby squirm and/or try to roll away?",
      "temperament_infant_squirm_opt_1": "never",
      "temperament_infant_squirm_opt_2": "very rarely",
      "temperament_infant_squirm_opt_3": "less than half the time",
      "temperament_infant_squirm_opt_4": "about half the time",
      "temperament_infant_squirm_opt_5": "more than half the time",
      "temperament_infant_squirm_opt_6": "almost always",
      "temperament_infant_squirm_opt_7": "always",
      "temperament_infant_squirm_opt_NA": "does not apply",
