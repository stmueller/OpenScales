    "scale_info": {
      "name": "Long COVID - Symptoms Due to COVID-19 - Psychiatric (Long Form)",
      "code": "PX992007",
      "abbreviation": "PX992007",
      "description": "A self-administered questionnaire to better describe and understand the patient experience and recovery of those with confirmed or suspected COVID-19, with a specific emphasis on Long COVID experience especially with sleep and hallucinations.",
