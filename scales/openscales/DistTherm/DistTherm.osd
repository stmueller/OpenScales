          "grid_physical_16",
          "grid_physical_17",
          "grid_physical_18",
          "grid_physical_19",
          "grid_physical_20",
          "grid_physical_21"
        ]
      }
    },
    "report": {
      "template": "standard",
      "include": [
        "timestamp",
        "completion_time",
        "dimension_scores"
      ],
      "header": "Distress Thermometer Report",
      "footer_refs": [
        "Roth, A. J., et al. (1998). Rapid screening for psychologic distress in men with prostate carcinoma. Cancer, 82(10), 1904–1908.",
        "Distress rating: 0–4 low (green), 5–6 moderate (yellow, monitor), 7–10 high (red, refer). Cut-off of 4+ recommended for referral to psychological consultation."
      ]
    }
  },
  "translations": {
    "en": {
      "dt_problem_list_section": "Problem List",
      "dt_inst1": "First, please indicate how much distress you have been experiencing in <b>the past week including today</b>.",
      "distress_q": "How much distress have you been experiencing in the past week including today?",
      "dt_vas_min": "No distress",
      "dt_vas_max": "Extreme distress",
      "dt_inst2": "Indicate if any of the following have been a problem for you in <b>the past week including today</b>.",
      "dt_grid_head": "Indicate if any of the following have been a problem for you in <b>the past week, including today</b>.",
      "dt_sub_practical": "Practical Problems",
