  "translations": {
    "en": {
      "patient_results_information_source": "Which of the following sources, if any, did you use to find more information about the genetic test results you received at your last visit?",
      "patient_results_information_source_opt_1": "Family or friends",
      "patient_results_information_source_opt_2": "Facebook",
      "patient_results_information_source_opt_3": "Support Groups",
      "patient_results_information_source_opt_4": "My/my child's other doctors",
      "patient_results_information_source_opt_5": "Internet search (i.e., Google, PubMed, etc.)",
      "patient_results_information_source_opt_6": "Books and other print media",
      "patient_results_information_source_opt_7": "Information provided by the doctor who ordered my/my child's genetic test",
      "patient_results_information_source_opt_8": "Other",
      "patient_results_information_source_opt_9": "None",
      "patient_results_information_source_family_friend": "Please rate the usefulness of the source you used.  (Family or friends)",
      "patient_results_information_source_family_friend_opt_1": "Not useful at all",
      "patient_results_information_source_family_friend_opt_5": "Very useful",
      "patient_results_information_source_facebook": "Please rate the usefulness of the source you used.  (Facebook)",
      "patient_results_information_source_facebook_opt_1": "Not useful at all",
      "patient_results_information_source_facebook_opt_5": "Very useful",
      "patient_results_information_source_support_group": "Please rate the usefulness of the source you used.  (Support groups)",
      "patient_results_information_source_support_group_opt_1": "Not useful at all",
      "patient_results_information_source_support_group_opt_5": "Very useful",
      "patient_results_information_source_other_doctor": "Please rate the usefulness of the source you used.  (My/my child's other doctors)",
      "patient_results_information_source_other_doctor_opt_1": "Not useful at all",
      "patient_results_information_source_other_doctor_opt_5": "Very useful",
      "patient_results_information_source_internet": "Please rate the usefulness of the source you used.  (Internet search (i.e., Google, PubMed, etc.))",
      "patient_results_information_source_internet_opt_1": "Not useful at all",
      "patient_results_information_source_internet_opt_5": "Very useful",
      "patient_results_information_source_internet_helpful_website": "If you used the Internet to search for information about the results, please list any websites you found helpful",
      "patient_results_information_source_support_book_print_media": "Please rate the usefulness of the source you used.  (Books and other print media)",
      "patient_results_information_source_support_book_print_media_opt_1": "Not useful at all",
      "patient_results_information_source_support_book_print_media_opt_5": "Very useful",
      "patient_results_information_source_genetic_test": "Please rate the usefulness of the source you used.  (Information provided by the doctor who ordered my/mychild's genetic test)",
      "patient_results_information_source_genetic_test_opt_1": "Not useful at all",
      "patient_results_information_source_genetic_test_opt_5": "Very useful",
      "patient_results_information_source_other": "Please rate the usefulness of the source you used.  (Other)",
      "patient_results_information_source_other_opt_1": "Not useful at all",
      "patient_results_information_source_other_opt_5": "Very useful",
      "patient_results_information_source_other_detail": "If Other, please specify the sources used."
    }
  }
