    "scale_info": {
      "name": "Personal Perception and Knowledge of Smoking-related Cancer Risk",
      "code": "PX070701",
      "abbreviation": "PX070701",
      "description": "These questions ask current and former smokers how often they worry about lung cancer and ask them to assess their perception of being diagnosed with lung cancer.",
      "domain": "Health",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/70701]",
