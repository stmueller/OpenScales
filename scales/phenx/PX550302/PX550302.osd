  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Perceived Availability of Illegal Drugs and Alcohol",
      "code": "PX550302",
      "abbreviation": "PX550302",
      "description": "The Monitoring the Future (MTF) project studies changes in the beliefs, attitudes, and behavior of young people in the United States. The MTF is a repeated series of surveys in which the same segments of the population (8th-, 10th-, and 12th-graders; college students; and young adults) are presented",
      "domain": "Substance Use - Attitudes & Social Norms",
      "citation": "Johnston, L. D., O’Malley, P. M., Bachman, J. G., & Schulenberg, J. E. (2011). Monitoring the Future national survey results on drug use, 1975-2010. Volume I: Secondary school students . Ann Arbor: Institute for Social Research, University of Michigan. Swaim, R. (2003). Individual and school level effects of perceived harm, perceived availability, and community size on marijuana use among 12th-grade students: A random effects Model. Prevention Science 4 (2), 89-98. [PhenX: https://www.phenxtoolkit.org/protocols/view/550302]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/550302"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
