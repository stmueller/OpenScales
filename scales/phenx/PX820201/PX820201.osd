{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Adult Sickle Cell Quality of Life Measurement Information System (ASCQ-Me)",
      "code": "PX820201",
      "abbreviation": "PX820201",
      "description": "This protocol includes 30 self-administered questions from the short form of the Adult Sickle Cell Quality of Life Measurement Information System (ASCQ-Me). Domains covered include emotional impact (5 items), social functioning impact (5 items), sleep impact (5 items), stiffness impact (5 items), pa",
      "domain": "Health",
      "citation": "Treadwell, M. J., Hassell, K., Levine, R., & Keller, S. (2014). Adult sickle cell quality-of-life measurement information system (ASCQ-Me): Conceptual model based on review of the literature and formative research. The Clinical Journal of Pain 30 (10), 902-14. Panepinto, J. A. (2012). Health-related quality of life in patients with hemoglobinopathies. Hematology American Society Hematology Education Program 2012, 284-289. doi:10.1182/asheducation-2012.1.284 [PhenX: https://www.phenxtoolkit.org/protocols/view/820201]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/820201"
    },
