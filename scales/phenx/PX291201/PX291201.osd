  "translations": {
    "en": {
      "sec_think_about_the_different_facilities_in__title": "Think about the different facilities in and around your neighborhood. By this we mean the area ALL around your home that you could walk to in 10-15 minutes.",
      "physical_activity_neighborhood_environment_main_type_housing": "What is the main type of housing in your neighborhood?",
      "physical_activity_neighborhood_environment_main_type_housing_opt_1": "Detached single-family housing",
      "physical_activity_neighborhood_environment_main_type_housing_opt_2": "Townhouses, row houses, apartments, or condos of 2-3 stories",
      "physical_activity_neighborhood_environment_main_type_housing_opt_3": "Mix of single-family residences and townhouses, row houses, apartments or condos",
      "physical_activity_neighborhood_environment_main_type_housing_opt_4": "Apartments or condos of 4-12 stories",
      "physical_activity_neighborhood_environment_main_type_housing_opt_5": "Apartments or condos of more than 12 stories",
      "physical_activity_neighborhood_environment_main_type_housing_opt_77": "Don't know/Not sure",
      "sec_the_next_items_are_statements_about_your_title": "The next items are statements about your neighborhood related to walking and bicycling",
