  "definition": {
    "scale_info": {
      "name": "Educational Impact Due to COVID-19",
      "code": "PX970101",
      "abbreviation": "PX970101",
      "description": "This protocol asks a series of questions about how the education and childcare of children from preschool through post-secondary school who have been impacted by the coronavirus epidemic.",
      "domain": "Social",
      "citation": "Coronavirus Tracking Survey of the Understanding America Survey (UAS). As implemented in: PhenX Toolkit. Educational Impact Due to COVID-19. https://www.phenxtoolkit.org/protocols/view/970101",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/970101"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
