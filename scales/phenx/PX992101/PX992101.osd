  "translations": {
    "en": {
      "long_covid_daily_living_climb_stairs_transfer_before_help_need_before_help_need_desc": "This includes any of the following: getting into/out of bed, standing up/sitting down in a chair, getting into/out of a car, getting on/off a toilet, stepping onto a curb.",
      "long_covid_daily_living_climb_stairs_transfer_before_help_need_before_help_need": "Climbing stairs and transferring - BEFORE you were diagnosed with COVID-19, how much help did you need climbing stairs/transferring?<br><i>This includes any of the following: getting into/out of bed, standing up/sitting down in a chair, getting into/out of a car, getting on/off a toilet, stepping onto a curb.</i>",
      "long_covid_daily_living_climb_stairs_transfer_before_help_need_before_help_need_opt_1": "None, I can perform these tasks independently",
      "long_covid_daily_living_climb_stairs_transfer_before_help_need_before_help_need_opt_2": "A little help",
      "long_covid_daily_living_climb_stairs_transfer_before_help_need_before_help_need_opt_3": "A Lot of help",
      "long_covid_daily_living_climb_stairs_transfer_before_help_need_before_help_need_opt_4": "Unable to perform task",
      "long_covid_daily_living_climb_stairs_transfer_today_help_need_today_help_need_desc": "This includes any of the following: getting into/out of bed, standing up/sitting down in a chair, getting into/out of a car, getting on/off a toilet, stepping onto a curb.",
      "long_covid_daily_living_climb_stairs_transfer_today_help_need_today_help_need": "Climbing stairs and transferring - TODAY, how much help do you need climbing stairs/transferring?<br><i>This includes any of the following: getting into/out of bed, standing up/sitting down in a chair, getting into/out of a car, getting on/off a toilet, stepping onto a curb.</i>",
      "long_covid_daily_living_climb_stairs_transfer_today_help_need_today_help_need_opt_1": "None, I can perform these tasks independently",
      "long_covid_daily_living_climb_stairs_transfer_today_help_need_today_help_need_opt_2": "A little help",
      "long_covid_daily_living_climb_stairs_transfer_today_help_need_today_help_need_opt_3": "A Lot of help",
      "long_covid_daily_living_climb_stairs_transfer_today_help_need_today_help_need_opt_4": "Unable to perform task",
      "long_covid_daily_living_climb_stairs_transfer_impact": "Climbing stairs and transferring - Please state which activities, if any, have been impacted and describe how they have been impacted.<br><i>(Ex: Prior to my illness, I would need to sit for a moment before rising out of bed independently. Now I require another persons help to get out of bed.)</i>",
      "long_covid_daily_living_climb_stairs_transfer_impact_desc": "(Ex: Prior to my illness, I would need to sit for a moment before rising out of bed independently. Now I require another persons help to get out of bed.)",
      "long_covid_daily_living_personal_grooming_dressing_before_help_need": "Personal grooming and dressing - BEFORE you were diagnosed with COVID-19, how much help did you need with personal grooming and dressing?",
      "long_covid_daily_living_personal_grooming_dressing_before_help_need_opt_1": "None, I can perform these tasks independently",
      "long_covid_daily_living_personal_grooming_dressing_before_help_need_opt_2": "A little help",
      "long_covid_daily_living_personal_grooming_dressing_before_help_need_opt_3": "A Lot of help",
      "long_covid_daily_living_personal_grooming_dressing_before_help_need_opt_4": "Unable to perform task",
      "long_covid_daily_living_personal_grooming_dressing_before_help_need_desc": "This includes any of the following: brushing/flossing teeth, denture care, skin care, shaving, putting on socks and shoes, taking off underwear, putting on pants, putting on a jacket.",
      "long_covid_daily_living_personal_grooming_dressing_today_help_need": "Personal grooming and dressing - TODAY, how much help do you need with personal grooming and dressing?<br><i>This includes any of the following: brushing/flossing teeth, denture care, skin care, shaving, putting on socks and shoes, taking off underwear, putting on pants, putting on a jacket.</i>",
      "long_covid_daily_living_personal_grooming_dressing_today_help_need_opt_1": "None, I can perform these tasks independently",
      "long_covid_daily_living_personal_grooming_dressing_today_help_need_opt_2": "A little help",
      "long_covid_daily_living_personal_grooming_dressing_today_help_need_opt_3": "A Lot of help",
      "long_covid_daily_living_personal_grooming_dressing_today_help_need_opt_4": "Unable to perform task",
      "long_covid_daily_living_personal_grooming_dressing_today_help_need_desc": "This includes any of the following: brushing/flossing teeth, denture care, skin care, shaving, putting on socks and shoes, taking off underwear, putting on pants, putting on a jacket.",
      "long_covid_daily_living_personal_grooming_dressing_impact": "Personal grooming and dressing - Please state which activities, if any, have been impacted and describe how they have been impacted.<br><i>This includes any of the following: brushing/flossing teeth, denture care, skin care, shaving, putting on socks and shoes, taking off underwear, putting on pants, putting on a jacket.</i><br><i>(Ex: Prior to my illness, I would need to sit for a moment before rising out of bed independently. Now I require another persons help to get out of bed.)</i>",
      "long_covid_daily_living_personal_grooming_dressing_impact_desc": "(Ex: Prior to my illness, I would need to sit for a moment before rising out of bed independently. Now I require another persons help to get out of bed.)",
      "long_covid_daily_living_toilet_bath_before_help_need": "Using the toilet and bathing - BEFORE you were diagnosed with COVID-19, how much help did you need using the restroom and bathing?",
      "long_covid_daily_living_toilet_bath_before_help_need_opt_1": "None, I can perform these tasks independently",
      "long_covid_daily_living_toilet_bath_before_help_need_opt_2": "A little help",
      "long_covid_daily_living_toilet_bath_before_help_need_opt_3": "A Lot of help",
      "long_covid_daily_living_toilet_bath_before_help_need_opt_4": "Unable to perform task",
      "long_covid_daily_living_toilet_bath_before_help_need_desc": "This includes any of the following: wiping your body with wipes, taking a shower or bath, scrubbing and rinsing your body, wiping after you use the toilet.",
      "long_covid_daily_living_toilet_bath_today_help_need": "Using the toilet and bathing - TODAY, how much help do you need using the restroom and bathing?<br><i>This includes any of the following: wiping your body with wipes, taking a shower or bath, scrubbing and rinsing your body, wiping after you use the toilet.</i>",
      "long_covid_daily_living_toilet_bath_today_help_need_opt_1": "None, I can perform these tasks independently",
      "long_covid_daily_living_toilet_bath_today_help_need_opt_2": "A little help",
      "long_covid_daily_living_toilet_bath_today_help_need_opt_3": "A Lot of help",
      "long_covid_daily_living_toilet_bath_today_help_need_opt_4": "Unable to perform task",
      "long_covid_daily_living_toilet_bath_today_help_need_desc": "This includes any of the following: wiping your body with wipes, taking a shower or bath, scrubbing and rinsing your body, wiping after you use the toilet.",
      "long_covid_daily_living_toilet_bath_impact": "Using the toilet and bathing - Please state which activities, if any, have been impacted and describe how they have been impacted.<br><i>This includes any of the following: wiping your body with wipes, taking a shower or bath, scrubbing and rinsing your body, wiping after you use the toilet.</i><br><i>(Ex: Prior to my illness, I would need to sit for a moment before rising out of bed independently. Now I require another persons help to get out of bed.)</i>",
      "long_covid_daily_living_toilet_bath_impact_desc": "(Ex: Prior to my illness, I would need to sit for a moment before rising out of bed independently. Now I require another persons help to get out of bed.)",
      "long_covid_daily_living_household_chores_desc": "Doing household chores - This includes any of the following: food preparation, cooking, folding laundry, vacuuming the floor, making the bed, feeding pets, wiping a table, loading the dishwasher, tidying up a room.",
      "long_covid_daily_living_household_chores_before_help_need": "Doing household chores - BEFORE you were diagnosed with COVID-19, how much help did you need doing household chores?<br><i>This includes any of the following: food preparation, cooking, folding laundry, vacuuming the floor, making the bed, feeding pets, wiping a table, loading the dishwasher, tidying up a room.</i>",
      "long_covid_daily_living_household_chores_before_help_need_opt_1": "None, I can perform these tasks independently",
      "long_covid_daily_living_household_chores_before_help_need_opt_2": "A little help",
      "long_covid_daily_living_household_chores_before_help_need_opt_3": "A Lot of help",
