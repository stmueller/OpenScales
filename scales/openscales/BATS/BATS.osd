    "hu": {
      "bat_r1": "Soha",
      "bat_r2": "Ritkán",
      "bat_r3": "Néha",
      "bat_r4": "Gyakran",
      "bat_r5": "Mindig",
      "bat_inst": "A következő állítások a munkában tapasztaltakra vonatkoznak. Kérem, jelölje be, milyen gyakorisággal igazak az alábbi állítások az Ön esetében!",
      "bat1": "Mentálisan kimerültnek érzem magam a munkámban.",
      "bat2": "Minden tevékenység, amit a munkám során végzek, rendkívüli erőfeszítést kíván.",
      "bat3": "A munkanap végén nehezemre esik visszanyerni az energiámat.",
      "bat4": "A munkám során fizikailag kimerültnek érzem magam.",
      "bat5": "Amikor reggel felkelek, nincs energiám, hogy új napot kezdjek a munkahelyemen.",
      "bat6": "Szeretnék aktív lenni a munkámban, de valami oknál fogva ezt képtelen vagyok megtenni.",
      "bat7": "Amikor gyakorlom a munkám, a szokásosnál hamarabb kifáradok.",
      "bat8": "A munkanap végére mentálisan kimerültnek és lecsapoltnak érzem magam.",
      "bat9": "Nehezemre esik, hogy lelkesedést találjak a munkám iránt.",
      "bat10": "A munkában nem gondolkodom azon, hogy mit csinálok, és automatikus pilóton működöm.",
      "bat11": "Erős ellenérzésem van a munkám iránt.",
      "bat12": "Közömbösnek érzem magam a munkámmal kapcsolatban.",
      "bat13": "Cinikus vagyok azzal kapcsolatban, hogy a munka mit jelent másoknak.",
      "bat14": "Nehezemre esik fókuszáltnak maradni a munkám során.",
      "bat15": "A munkám során küzdök azért, hogy tisztán tudjak gondolkodni.",
      "bat16": "Feledékeny és zavart vagyok a munkámban.",
      "bat17": "Nehezemre esik koncentrálni, amikor dolgozom.",
      "bat18": "Hibákat vétek a munkámban, mert más dolgok járnak az eszemben.",
      "bat19": "A munkám során képtelennek érzem magam az érzelmeim kontrollálására.",
      "bat20": "Nem ismerek magamra a munkám kapcsán adott érzelmi reakcióim során.",
      "bat21": "A munkám közben ingerültté válok, ha a dolgok nem úgy mennek, ahogyan azt szeretném.",
      "bat22": "Zaklatottá és szomorúvá válok a munkahelyemen, anélkül, hogy tudnám, ez miért van.",
      "bat23": "A munkámban akaratlanul is túlreagálhatok dolgokat.",
