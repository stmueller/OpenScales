      "scoliosis_qol_last_week_liftbooks_opt_3": "3 - Very hard",
      "scoliosis_qol_last_week_liftbooks_opt_4": "4 - Can't do at all",
      "scoliosis_qol_last_week_liftbooks_opt_5": "5 - Too young for this activity",
      "scoliosis_qol_last_week_pourmilk": "During the last week was it easy or hard for your child to Pour a half gallon of milk?",
