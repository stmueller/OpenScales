    "scale_info": {
      "name": "Emotional State - Adult",
      "code": "PX180501",
      "abbreviation": "PX180501",
      "description": "The Positive Affect and Negative Affect Schedule-Expanded Form (PANAS X) is a 60-item scale used to measure the respondent’s emotions during the past few weeks.",
      "domain": "Mental Health & Quality of Life",
      "citation": "Watson, D., & Naragon-Gainey, K. (2010). On the specificity of positive emotional dysfunction in psychopathology: Evidence from the mood and anxiety disorders and schizophrenia/schizotypy. Clinical Psychology Review, 30 , 839-848. [PhenX: https://www.phenxtoolkit.org/protocols/view/180501]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/180501"
    },
