{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Psychiatric Symptoms - Frequency",
      "code": "PX660901",
      "abbreviation": "PX660901",
      "description": "The modified Colorado Symptom Index (CSI) is a 14-item, self-report scale designed to assess frequency of positive mood and cognitive symptoms. Items are rated on a 5-point Likert-style scale (Not at all, Once during the month, Several times during the month, Several times a week, at least every day",
      "domain": "Psychiatric Symptoms & Wellbeing",
      "citation": "Fukui, S., Davidson, L. J., Holter, M. C., & Rapp, C. A. (2010). Pathways to recovery (PTR): Impact of peer-led group participation on mental health recovery outcomes. Psychiatric Rehabilitation Journal, 34 (1), 42-48. Shern, D. L., Wilson, N. Z., & Coen, A. S. (1994). Client outcomes II: Longitudinal client data from the Colorado treatment outcome study. Millbank Quarterly, 72 (1), 123-148. [PhenX: https://www.phenxtoolkit.org/protocols/view/660901]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/660901"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
