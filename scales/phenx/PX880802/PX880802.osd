  "translations": {
    "en": {
      "sexual_function_male_interest_activity": "In the past 30 days, how interested have you been in sexual activity?",
      "sexual_function_male_interest_activity_opt_1": "Not at all",
      "sexual_function_male_interest_activity_opt_2": "A little bit",
      "sexual_function_male_interest_activity_opt_3": "Somewhat",
      "sexual_function_male_interest_activity_opt_4": "Quite a bit",
      "sexual_function_male_interest_activity_opt_5": "Very",
      "sexual_function_male_want_activity": "In the past 30 days, how often have you felt like you wanted to have sexual activity?",
      "sexual_function_male_want_activity_opt_1": "Never",
      "sexual_function_male_want_activity_opt_2": "Rarely",
      "sexual_function_male_want_activity_opt_3": "Sometimes",
      "sexual_function_male_want_activity_opt_4": "Often",
      "sexual_function_male_want_activity_opt_5": "Always",
      "sexual_function_male_any_activity": "In the past 30 days, did you have any type of sexual activity? (Examples of sexual activity are masturbation, oral sex, and sexual intercourse.)",
      "sexual_function_male_any_activity_opt_1": "No",
      "sexual_function_male_any_activity_opt_2": "Yes",
      "sexual_function_male_no_activity_reason": "There are many reasons why people may not have had sexual activity during the month. What are the reasons why you did not have sexual activity in the past 30 days? Please read the list carefully and check every reason that applies to you, even if it happened only one time during the past 30 days.",
      "sexual_function_male_no_activity_reason_opt_1": "Was not interested in having sexual activity",
      "sexual_function_male_no_activity_reason_opt_2": "Difficulties with my erections (penis not hard or is painful)",
      "sexual_function_male_no_activity_reason_opt_3": "Difficulties with orgasm/climax",
      "sexual_function_male_no_activity_reason_opt_4": "Don't enjoy sexual activity",
      "sexual_function_male_no_activity_reason_opt_5": "Health condition",
      "sexual_function_male_no_activity_reason_opt_6": "No partner",
      "sexual_function_male_no_activity_reason_opt_7": "Partner was away",
      "sexual_function_male_no_activity_reason_opt_8": "Partner was not interested in sexual activity",
      "sexual_function_male_no_activity_reason_opt_9": "Partner's health condition",
      "sexual_function_male_no_activity_reason_opt_10": "Some other reason (Specify)",
      "sexual_function_male_no_activity_reason_specify": "There are many reasons why people may not have had sexual activity during the month. What are the reasons why you did not have sexual activity in the past 30 days? Please read the list carefully and check every reason that applies to you, even if it happened only one time during the past 30 days. Specify",
      "sexual_function_male_often_erection_activity": "In the past 30 days, how often were you able to get an erection (get hard) during sexual activity?",
      "sexual_function_male_often_erection_activity_opt_1": "Almost never/never",
      "sexual_function_male_often_erection_activity_opt_2": "A few times (much less than half the time)",
      "sexual_function_male_often_erection_activity_opt_3": "Sometimes (about half the time)",
      "sexual_function_male_often_erection_activity_opt_4": "Most times (much more than half the time)",
      "sexual_function_male_often_erection_activity_opt_5": "Almost always/always",
      "sexual_function_male_intercourse_maintain_erection": "In the past 30 days, during sexual intercourse how often were you able to maintain your erection (stay hard) after you had penetrated (entered) your partner?",
      "sexual_function_male_intercourse_maintain_erection_opt_0": "Did not attempt intercourse",
      "sexual_function_male_intercourse_maintain_erection_opt_1": "Almost never/never",
      "sexual_function_male_intercourse_maintain_erection_opt_2": "A few times (much less than half the time)",
      "sexual_function_male_intercourse_maintain_erection_opt_3": "Sometimes (about half the time)",
      "sexual_function_male_intercourse_maintain_erection_opt_4": "Most times (much more than half the time)",
      "sexual_function_male_intercourse_maintain_erection_opt_5": "Almost always/always",
      "sexual_function_male_often_orgasm": "In the past 30 days, how often have you been able to have an orgasm/climax when you wanted to?",
      "sexual_function_male_often_orgasm_opt_0": "Have not tried to have an orgasm/climax in the past 30 days",
      "sexual_function_male_often_orgasm_opt_1": "Never",
      "sexual_function_male_often_orgasm_opt_2": "Rarely",
      "sexual_function_male_often_orgasm_opt_3": "Sometimes",
      "sexual_function_male_often_orgasm_opt_4": "Often",
      "sexual_function_male_often_orgasm_opt_5": "Always",
      "sexual_function_male_satisfying_orgasm": "In the past 30 days, how satisfying have your orgasms or climaxes been?",
      "sexual_function_male_satisfying_orgasm_opt_0": "Have not had an orgasm/climax in the past 30 days",
      "sexual_function_male_satisfying_orgasm_opt_1": "Not at all",
      "sexual_function_male_satisfying_orgasm_opt_2": "A little bit",
      "sexual_function_male_satisfying_orgasm_opt_3": "Somewhat",
      "sexual_function_male_satisfying_orgasm_opt_4": "Quite a bit",
      "sexual_function_male_satisfying_orgasm_opt_5": "Very",
      "sexual_function_male_satisfied_sex_life": "In the past 30 days, how satisfied have you been with your sex life?",
      "sexual_function_male_satisfied_sex_life_opt_1": "Not at all",
      "sexual_function_male_satisfied_sex_life_opt_2": "A little bit",
      "sexual_function_male_satisfied_sex_life_opt_3": "Somewhat",
      "sexual_function_male_satisfied_sex_life_opt_4": "Quite a bit",
      "sexual_function_male_satisfied_sex_life_opt_5": "Very",
      "sexual_function_male_pleasure_sex_life": "In the past 30 days, how much pleasure has your sex life given you?",
      "sexual_function_male_pleasure_sex_life_opt_1": "None",
      "sexual_function_male_pleasure_sex_life_opt_2": "A little bit",
      "sexual_function_male_pleasure_sex_life_opt_3": "Some",
      "sexual_function_male_pleasure_sex_life_opt_4": "Quite a bit",
      "sexual_function_male_pleasure_sex_life_opt_5": "A lot",
      "likert_1": "Did not attempt intercourse",
      "likert_2": "Almost never/never",
      "likert_3": "A few times (much less than half the time)",
      "likert_4": "Sometimes (about half the time)",
      "likert_5": "Most times (much more than half the time)",
