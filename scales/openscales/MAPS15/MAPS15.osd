  "translations": {
    "en": {
      "likert_1": "Not at all",
      "likert_2": "A little",
      "likert_3": "Somewhat",
      "likert_4": "Quite a bit",
      "likert_5": "Completely",
      "question_head": "Please indicate how much each statement describes you.",
      "maps1": "I work in a non-systematic (disorganized) way.",
      "maps2": "I am always behind with my work.",
      "maps3": "I am always interrupting my work to smoke, have a coffee, walk around, chat with someone.",
      "maps4": "I do not care enough about my studies.",
      "maps5": "I work on and off, when I feel like it.",
      "maps6": "I would like to have a real incentive to work.",
      "maps7": "I find it difficult to make the decision to start studying.",
      "maps8": "I have a study routine that I stick to.",
      "maps9": "I keep on top of my studies.",
      "maps10": "I usually postpone studying because I think I still have a lot of time left to do it.",
      "maps11": "I usually think that I will be able to do more things in a day than I can actually get done.",
      "maps12": "I usually manage to study everything I set out to study for a session.",
      "maps13": "I tend to study instead of doing things that I might feel like more.",
      "maps14": "When I've been studying and prepping for exams, I wasted time doing other things.",
      "maps15": "When I am studying, I waste a lot of time on irrelevant information before I get down to the main ideas of a subject.",
      "debrief": "Thank you for completing the Multidimensional Academic Procrastination Scale."
    },
    "es": {
      "likert_1": "Nada",
      "likert_2": "Un poco",
      "likert_3": "Algo",
      "likert_4": "Bastante",
      "likert_5": "Completamente",
      "question_head": "Por favor, indica en qué medida cada afirmación te describe.",
      "maps1": "Trabajo en forma no sistemática (desordenada).",
      "maps2": "Voy siempre atrasado/a con mi trabajo.",
      "maps3": "Continuamente interrumpo mi trabajo para fumar, tomar un café, dar vueltas alrededor, conversar con alguien.",
      "maps4": "No me preocupo lo suficiente de mis estudios.",
      "maps5": "Trabajo irregularmente, por impulsos.",
      "maps6": "Echo de menos un incentivo real para trabajar.",
      "maps7": "Me cuesta tomar la decisión de ponerme a estudiar.",
      "maps8": "Tengo una rutina para estudiar que suelo cumplir.",
      "maps9": "Suelo llevar al día el estudio.",
      "maps10": "Habitualmente pospongo estudiar porque pienso que aún me queda mucho tiempo para hacerlo.",
      "maps11": "Suelo tener la sensación de que podré hacer más cosas en el día de las que finalmente puedo hacer.",
      "maps12": "Habitualmente consigo estudiar todo lo que me había propuesto para una sesión.",
      "maps13": "Suelo ponerme a estudiar, en vez de ponerme a hacer cosas que pueden ser más apetecibles.",
      "maps14": "Cuando he estado estudiando y preparando los exámenes he perdido el tiempo haciendo otras cosas.",
      "maps15": "Cuando estoy estudiando pierdo bastante el tiempo con información irrelevante, antes de centrarme en las ideas principales de un tema.",
      "debrief": "Gracias por completar la Escala Multidimensional de Procrastinación Académica."
    }
  }
}
