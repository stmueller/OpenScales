    "scoring": {
      "emotional_info": {
        "description": "Emotional/Informational Support: raw sum of 8 items (range 8–40; higher = greater perceived support). To obtain the 0–100 subscale score: ((mean_of_items − 1) / 4) × 100.",
        "method": "mean_coded",
        "items": [
          "mossocial2",
          "mossocial3",
          "mossocial4",
          "mossocial8",
          "mossocial9",
          "mossocial13",
          "mossocial14",
          "mossocial18"
        ],
        "transform": [
          {
            "op": "subtract",
            "value": 1
          },
          {
            "op": "divide",
            "value": 4
          },
          {
            "op": "multiply",
            "value": 100
          }
        ]
      },
      "tangible": {
        "description": "Tangible Support: raw sum of 4 items (range 4–20; higher = greater perceived support). To obtain the 0–100 subscale score: ((mean_of_items − 1) / 4) × 100.",
        "method": "mean_coded",
        "items": [
          "mossocial5",
          "mossocial10",
          "mossocial11",
          "mossocial16"
        ],
