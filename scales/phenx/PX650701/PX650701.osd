  "translations": {
    "en": {
      "info_650701": "Intolerance of Uncertainty Scale (IUS)You will find below a series of statements which describe how people may react to the uncertainties of life. Please use the scale below to describe to what extent each item is characteristic of you.1= Not at all characteristic of me2=3= Somewhat characteristic of me4=5= Entirely characteristic of mePlease select the option that describes you best.",
      "intoleranceofuncertainty_scale_prevents_firmopinion": "Uncertainty stops me from having a firm opinion",
      "intoleranceofuncertainty_scale_means_disorganization": "Being uncertain means that a person is disorganized",
      "intoleranceofuncertainty_scale_makes_life_tolerable": "Uncertainty makes life intolerable",
      "intoleranceofuncertainty_scale_unfair_noguarantees": "It's unfair not having any guarantees in life",
      "intoleranceofuncertainty_scale_mind_cant_relax": "My mind can't be relaxed if I don't know what will happen tomorrow",
      "intoleranceofuncertainty_scale_uneasy_anxious_stressed": "Uncertainty makes me uneasy, anxious, or stressed",
      "intoleranceofuncertainty_scale_unforeseenevents_upsetting": "Unforeseen events upset me greatly",
      "intoleranceofuncertainty_scale_frustration_incomplete_information": "It frustrates me not having all the information I need",
      "intoleranceofuncertainty_scale_living_full_life": "Uncertainty keeps me from living a full life",
      "intoleranceofuncertainty_scale_lookahead_avoid_surprises": "One should always look ahead so as to avoid surprises",
      "intoleranceofuncertainty_scale_unforeseenevents_spoil_everything": "A small unforeseen event can spoil everything, even with the best of planning",
      "intoleranceofuncertainty_scale_uncertainty_paralysis": "When it's time to act, uncertainty paralyses me",
      "intoleranceofuncertainty_scale_uncertain_not_firstrate": "Being uncertain means that I am not first rate",
      "intoleranceofuncertainty_scale_uncertain_cant_goforward": "When I am uncertain, I can't go forward",
      "intoleranceofuncertainty_scale_uncertain_notfunction_well": "When I am uncertain I can't function very well",
      "intoleranceofuncertainty_scale_others_seemto_know": "Unlike me, others always seem to know where they are going with their lives",
      "intoleranceofuncertainty_scale_vulnerable_unhappy_sad": "Uncertainty makes me vulnerable, unhappy, or sad",
      "intoleranceofuncertainty_scale_know_thefuture": "I always want to know what the future has in store for me",
      "intoleranceofuncertainty_scale_cant_stand_surprise": "I can't stand being taken by surprise",
      "intoleranceofuncertainty_scale_smallest_doubt_stop": "The smallest doubt can stop me from acting",
      "intoleranceofuncertainty_scale_organize_in_advance": "I should be able to organize everything in advance",
      "intoleranceofuncertainty_scale_uncertain_lack_confidence": "Being uncertain means that I lack confidence",
      "intoleranceofuncertainty_scale_unfair_others_knowfuture": "I think it's unfair that other people seem sure about their future",
      "intoleranceofuncertainty_scale_uncertainty_sleep_soundly": "Uncertainty keeps me from sleeping soundly",
      "intoleranceofuncertainty_scale_getaway_uncertain_situations": "I must get away from all uncertain situations",
      "intoleranceofuncertainty_scale_ambiguities_stress": "The ambiguities in life stress me",
      "intoleranceofuncertainty_scale_anxious_undecided_future": "I can't stand being undecided about my future",
      "likert_1": "Not all characteristic of me",
      "likert_2": "Not at all/Somewhat characteristic of me",
      "likert_3": "Somewhat characteristic of me",
      "likert_4": "Somewhat/Entirely characteristic of me",
      "likert_5": "Entirely characteristic of me"
    }
  }
}
