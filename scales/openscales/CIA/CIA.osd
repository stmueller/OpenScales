    "scoring": {
      "personal_impairment": {
        "description": "Sum of 6 personal impairment items (range 0–18). Mean in clinical sample: 10.2.",
        "method": "sum_coded",
        "items": [
          "cia9",
          "cia11",
          "cia2",
          "cia14",
          "cia8",
          "cia16"
        ],
        "norms": {
          "thresholds": [
            {
              "min": 0,
              "max": 10,
              "label": "Below Average"
            },
            {
              "min": 11,
              "max": 18,
              "label": "Above Average"
            }
          ]
        }
      },
      "social_impairment": {
        "description": "Sum of 5 social impairment items (range 0–15). Mean in clinical sample: 5.36.",
        "method": "sum_coded",
        "items": [
          "cia7",
          "cia10",
          "cia12",
          "cia3",
          "cia15"
        ],
