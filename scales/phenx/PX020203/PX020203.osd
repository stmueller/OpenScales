            "text_key": "proxy_reported_birthweight_4100g_opt_9",
            "value": 9
          }
        ]
      }
    ]
  },
  "translations": {
    "en": {
      "proxy_birthwt_gram": "How much did participant weigh at birth? ENTER WEIGHT IN GRAMS OR POUNDS AND OUNCES",
      "proxy_birthwt_gram_opt_1": "Grams",
      "proxy_birthwt_gram_opt_2": "Pounds and ounces",
      "proxy_birthwt_gram_opt_3": "Unknown",
      "proxy_report_birthwt_g": "How much did {you/[participant]} weigh at birth in grams?",
      "proxy_reported_birthweight_pounds": "How much did {you/[participant]} weigh at birth in pounds?",
      "proxy_reported_birthweight_ounces": "How much did {you/[participant]} weigh at birth in ounces?",
      "proxy_reported_birthweight_2500g": "Did {you/[participant]} weigh ...?",
      "proxy_reported_birthweight_2500g_opt_1": "More than 5 1/2 pounds (2500 g)",
      "proxy_reported_birthweight_2500g_opt_2": "Less than 5 1/2 pounds (2500 g)",
      "proxy_reported_birthweight_2500g_opt_7": "Refused",
      "proxy_reported_birthweight_2500g_opt_9": "Don't know",
      "proxy_reported_birthweight_4100g": "Did {you/[participant]} weigh ...?",
      "proxy_reported_birthweight_4100g_opt_1": "More than 9 pounds (4100 g)",
      "proxy_reported_birthweight_4100g_opt_2": "Less than 9 pounds (4100 g)",
      "proxy_reported_birthweight_4100g_opt_7": "Refused",
