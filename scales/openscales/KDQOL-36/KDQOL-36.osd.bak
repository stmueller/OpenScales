      "kdqol36_freq4": "Some of the time",
      "kdqol36_freq5": "A little of the time",
      "kdqol36_freq6": "None of the time",
      "kdqol36_oh0": "0 — Worst possible health",
      "kdqol36_oh1": "1",
      "kdqol36_oh2": "2",
      "kdqol36_oh3": "3",
