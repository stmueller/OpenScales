    "dimensions": [
      {
        "id": "stimulation",
        "name": "Stimulation"
      },
      {
        "id": "sedation",
        "name": "Sedation"
      }
    ],
    "scoring": {
      "stimulation": {
        "description": "Stimulation subscale: sum of 7 items (Elated, Energized, Excited, Stimulated, Talkative, Up, Vigorous).",
        "method": "sum_coded",
        "items": [
          "elated",
          "energized",
          "excited",
          "stimulated",
          "talkative",
          "up",
          "vigorous"
        ]
      },
      "sedation": {
        "description": "Sedation subscale: sum of 7 items (Difficulty concentrating, Down, Heavy head, Inactive, Sedated, Slow thoughts, Sluggish).",
        "method": "sum_coded",
        "items": [
          "difficulty_concentrating",
          "down",
          "heavy_head",
          "inactive",
          "sedated",
          "slow_thoughts",
          "sluggish"
        ]
      }
    },
    "_scoring_notes": "Scoring Procedures and InterpretationThe Sedation and Stimulation subscales are calculated by summing the following items (for the 14-point scale):Stimulation: = BAES3 + BAES4 + BAES5 + BAES11 + BAES12 + BAES13 +BAES14Sedation: = BAES1 + BAES2 + BAES6 + BAES7 + BAES8 + BAES9 + BAES10",
    "likert_options": {
      "points": 11,
      "min": 0,
      "max": 10,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5",
        "likert_6",
        "likert_7",
        "likert_8",
        "likert_9",
        "likert_10",
        "likert_11"
      ]
    }
  },
  "translations": {
    "en": {
      "insttructions_520102": "A baseline assessment of how the person feels may be obtained prior to alcohol administration by using the following instructions:Please rate the extent to which these words describe your feelings at the present time.To measure responses following alcohol consumption, the following instructions are used:The following adjectives describe feelings that some people have after drinking alcohol. Please rate the extent to which drinking alcohol has produced these feelings in you at the present time.",
      "quesitons_520102": "The following 14 adjectives describe feelings that some people have after drinking alcohol. Please rate the extent to which drinking alcohol has produced these feelings in you at the present time.  Select the number that most closely represents your feelings.  0= Not at All10= Extremely",
      "difficulty_concentrating": "Difficulty concentrating",
      "down": "Down",
