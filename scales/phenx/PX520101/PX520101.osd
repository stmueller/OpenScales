  "translations": {
    "en": {
      "amphetamine_scale": "Amphetamine Scale:",
      "more_popular_with_people_amphetamine": "I feel as if I would be more popular with people right now.",
      "more_popular_with_people_amphetamine_opt_1": "T",
      "more_popular_with_people_amphetamine_opt_2": "F",
      "pleasant_emptiness_amphetamine": "I feel a very pleasant emptiness.",
      "pleasant_emptiness_amphetamine_opt_1": "T",
      "pleasant_emptiness_amphetamine_opt_2": "F",
      "thoughts_come_more_easily_amphetamine": "My thoughts come more easily than usual.",
      "thoughts_come_more_easily_amphetamine_opt_1": "T",
      "thoughts_come_more_easily_amphetamine_opt_2": "F",
      "feel_less_discouraged_amphetamine": "I feel less discouraged than usual.",
      "feel_less_discouraged_amphetamine_opt_1": "T",
      "feel_less_discouraged_amphetamine_opt_2": "F",
      "more_excited_than_dreamy_amphetamine": "I feel more excited than dreamy.",
      "more_excited_than_dreamy_amphetamine_opt_1": "T",
      "more_excited_than_dreamy_amphetamine_opt_2": "F",
      "answering_questions_is_easy_amphetamine": "Answering these questions is very easy right now.",
      "answering_questions_is_easy_amphetamine_opt_1": "T",
      "answering_questions_is_easy_amphetamine_opt_2": "F",
      "my_memory_seems_sharper_amphetamine": "My memory seems sharper to me than usual.",
      "my_memory_seems_sharper_amphetamine_opt_1": "T",
      "my_memory_seems_sharper_amphetamine_opt_2": "F",
      "write_for_hours_amphetamine": "I feel as if I could write for hours.",
      "write_for_hours_amphetamine_opt_1": "T",
      "write_for_hours_amphetamine_opt_2": "F",
      "feel_very_patient_amphetamine": "I feel very patient.",
      "feel_very_patient_amphetamine_opt_1": "T",
      "feel_very_patient_amphetamine_opt_2": "F",
      "body_parts_tingling_amphetamine": "Some parts of my body are tingling.",
      "body_parts_tingling_amphetamine_opt_1": "T",
      "body_parts_tingling_amphetamine_opt_2": "F",
      "weird_feeling_amphetamine": "I have a weird feeling.",
      "weird_feeling_amphetamine_opt_1": "T",
      "weird_feeling_amphetamine_opt_2": "F",
      "morphine_scale": "Morphine-Benzedrine Scale:",
      "say_things_easiest_morphine": "I feel as though I say things in the easiest possible way right now.",
      "say_things_easiest_morphine_opt_1": "T",
      "say_things_easiest_morphine_opt_2": "F",
      "things_seem_more_pleasing_morphine": "Things around me seem more pleasing than usual.",
      "things_seem_more_pleasing_morphine_opt_1": "T",
      "things_seem_more_pleasing_morphine_opt_2": "F",
      "pleasant_feeling_in_stomach_morphine": "I have a pleasant feeling in my stomach.",
      "pleasant_feeling_in_stomach_morphine_opt_1": "T",
      "pleasant_feeling_in_stomach_morphine_opt_2": "F",
      "fear_lose_contentment_morphine": "I fear I will lose the contentment that I have now.",
      "fear_lose_contentment_morphine_opt_1": "T",
      "fear_lose_contentment_morphine_opt_2": "F",
      "feel_in_complete_harmony_morphine": "I feel in complete harmony with the world and those around me.",
      "feel_in_complete_harmony_morphine_opt_1": "T",
      "feel_in_complete_harmony_morphine_opt_2": "F",
      "appreciate_what_others_say_morphine": "I can completely appreciate what others are saying when I am in this mood.",
      "appreciate_what_others_say_morphine_opt_1": "T",
      "appreciate_what_others_say_morphine_opt_2": "F",
      "happy_all_the_time_morphine": "I would be happy all the time if I felt as good as I feel now.",
      "happy_all_the_time_morphine_opt_1": "T",
      "happy_all_the_time_morphine_opt_2": "F",
      "other_people_can_tell_morphine": "I feel so good that I know other people can tell it.",
      "other_people_can_tell_morphine_opt_1": "T",
      "other_people_can_tell_morphine_opt_2": "F",
      "feel_something_pleasant_happened_morphine": "I feel as if something pleasant had just happened to me.",
      "feel_something_pleasant_happened_morphine_opt_1": "T",
      "feel_something_pleasant_happened_morphine_opt_2": "F",
      "happy_all_the_time2_morphine": "I would be happy all the time if I felt as I do now.",
      "happy_all_the_time2_morphine_opt_1": "T",
      "happy_all_the_time2_morphine_opt_2": "F",
      "more_clear_headed_than_dreamy_morphine": "I feel more clear headed than dreamy.",
      "more_clear_headed_than_dreamy_morphine_opt_1": "T",
      "more_clear_headed_than_dreamy_morphine_opt_2": "F",
      "more_popular_with_people_morphine": "I feel as if I would be more popular with people right now.",
      "more_popular_with_people_morphine_opt_1": "T",
      "more_popular_with_people_morphine_opt_2": "F",
      "talk_about_feelings_morphine": "I am in the mood to talk about the feelings I have.",
      "talk_about_feelings_morphine_opt_1": "T",
      "talk_about_feelings_morphine_opt_2": "F",
      "pleasant_emptiness_morphine": "I feel a very pleasant emptiness.",
      "pleasant_emptiness_morphine_opt_1": "T",
      "pleasant_emptiness_morphine_opt_2": "F",
      "thoughts_come_more_easily_morphine": "My thoughts come more easily than usual.",
      "thoughts_come_more_easily_morphine_opt_1": "T",
      "thoughts_come_more_easily_morphine_opt_2": "F",
      "less_discouraged_morphine": "I feel less discouraged than usual.",
      "less_discouraged_morphine_opt_1": "T",
      "less_discouraged_morphine_opt_2": "F",
      "lsd_scale": "Lysergic Acid Diethylamide (LSD) Scale:",
      "feel_drowsy_lsd": "I feel drowsy.",
