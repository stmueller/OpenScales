  "translations": {
    "en": {
      "desc1": "<div class=\"rich-text-field-label\"><table style=\"width: 386.75pt; border-collapse: collapse; border: none;\"> <tbody> <tr> <td style=\"width: 386.75pt; border: solid windowtext 1.0pt; padding: 0in 5.4pt 0in 5.4pt;\"> <p style=\"tab-stops: 255.75pt; text-autospace: none;\">Answer each question by marking the box to the left of your answer.</p> <p style=\"tab-stops: 255.75pt; text-autospace: none;\"> </p> <p style=\"tab-stops: 255.75pt; text-autospace: none;\">You are sometimes told to skip over some questions in this survey. When this happens, you will see an arrow with a note that tells you what questions to answer next, like this:</p> <p style=\"tab-stops: 255.75pt; text-autospace: none;\">[ ] Yes</p> <p style=\"tab-stops: 255.75pt; text-autospace: none;\">[x] No→ <strong>If No, go to #1 on page 3</strong></p> </td> </tr> </tbody> </table></div>",
      "sec_contacting_your_drug_therapy_team_title": "Contacting Your Drug Therapy Team",
      "cancer_team_encourage_contact": "Drug therapy team refers to the doctors, nurses, therapists, technicians, and their support staff involved with your drug therapy through this cancer center. Since it was decided that you would have drug therapy, did your drug therapy team encourage you to contact them with questions between visits?",
      "cancer_team_call_side_effects": "Since it was decided that you would have drug therapy, did your drug therapy team tell you to call them immediately if you have certain symptoms or side effects?",
      "cancer_team_contact_after_hours": "Since it was decided that you would have drug therapy, did your drug therapy team give you clear instructions about how to contact them after regular office hours?",
      "cancer_team_involve_family": "Since it was decided that you would have drug therapy, did your drug therapy team involve your family members or close friends in discussions about your cancer or cancer care as much as you wanted?",
      "last_time_drug_therapy_center": "When was the last time you received drug therapy for cancer from this cancer center?",
      "last_time_drug_therapy_center_opt_1": "In the last 6 months",
      "last_time_drug_therapy_center_opt_2": "More than 6 months ago",
      "sec_your_care_team_from_this_cancer_center_title": "Your Care Team from This Cancer Center",
      "cancer_center_visit_times": "In the last 6 months, how many times did you visit this cancer center to get care from your drug therapy team? Do not include telephone calls or emails.",
      "cancer_center_visit_times_opt_1": "None",
      "cancer_center_visit_times_opt_2": "1 to 5 times",
      "cancer_center_visit_times_opt_3": "6 to 10 times",
      "cancer_center_visit_times_opt_4": "11 or more times",
      "cancer_center_contact_immediate_care": "In the last 6 months, did you contact this cancer center to get an appointment for an illness, injury, or condition that needed care right away?",
      "cancer_center_appointment_immediacy": "In the last 6 months, when you contacted this cancer center to get an appointment for care you needed right away, how often did you get an appointment as soon as you needed?",
      "cancer_center_appointment_last_six_months": "In the last 6 months, did you make any appointments for a check - up or routine care at this cancer center?",
      "cancer_immediacy": "In the last 6 months, when you made an appointment for a check - up or routine care at this cancer center, how often did you get an appointment as soon as you needed?",
      "cancer_center_question_office_hours": "In the last 6 months, did you contact this cancer center with a medical question during regular office hours?",
      "cancer_center_question_office_hours_same_day_answer": "In the last 6 months, when you contacted this cancer center during regular office hours, how often did you get an answer to your medical question that same day?",
      "sec_your_drug_therapy_team_title": "Your Drug Therapy Team",
      "drug_therapy_team_explain_understand": "Drug therapy team refers to the doctors, nurses, therapists, technicians, and their support staff involved with your drug therapy through this cancer center. In the last 6 months, how often did your drug therapy team explain things in a way that was easy to understand?",
      "drug_therapy_team_listen": "In the last 6 months, how often did your drug therapy team listen carefully to you?",
      "drug_therapy_team_know_medical_history": "In the last 6 months, how often did your drug therapy team seem to know the important information about your medical history?",
      "drug_therapy_team_respect": "In the last 6 months, how often did your drug therapy team show respect for what you had to say?",
      "drug_therapy_team_time": "In the last 6 months, how often did your drug therapy team spend enough time with you?",
      "drug_therapy_team_order_test": "In the last 6 months, did your drug therapy team order a blood test, x - ray, or other test for you? Do not include drug therapy.",
      "test_center_followup": "In the last 6 months, when you had blood tests, x - rays, or other tests as part of your cancer treatment, how often did someone from this cancer center follow up to give you those results?",
      "last_six_months_prescription": "In the last 6 months, did you take any prescription medicine?",
      "last_six_months_prescription_opt_1": "No",
      "last_six_months_prescription_opt_2": "Yes",
      "last_six_months_drug_therapy_team_prescription_talk": "In the last 6 months, how often did you and your drug therapy team talk about all the prescription medicines you were taking?",
      "last_six_months_drug_therapy_team_pain_talk": "In the last 6 months, did you and your drug therapy team talk about pain related to your cancer or drug therapy?",
      "last_six_months_pain_drug_therapy": "In the last 6 months, were you bothered by pain from your cancer or drug therapy?",
      "last_six_months_drug_therapy_team_pain_advice": "In the last 6 months, did your drug therapy team advise you about or help you deal with this pain?",
      "last_six_months_change_energy_drug_therapy": "In the last 6 months, did you and your drug therapy team talk about any changes in your energy levels related to your cancer or drug therapy?",
      "last_six_months_change_energy_drug_therapy_bother": "In the last 6 months, were you bothered by changes in your energy levels related to your cancer or drug therapy?",
      "last_six_months_change_energy_drug_therapy_advice": "In the last 6 months, did your drug therapy team advise you about or help you deal with these changes in your energy levels?",
      "last_six_months_emotional_problem_drug_therapy": "In the last 6 months, did you and your drug therapy team talk about any emotional problems, such as anxiety or depression, related to your cancer or drug therapy?",
      "last_six_months_emotional_problem_drug_therapy_bother": "In the last 6 months, were you bothered by any emotional problems, such as anxiety or depression, related to your cancer or drug therapy?",
      "last_six_months_emotional_problem_drug_therapy_advice": "In the last 6 months, did your drug therapy team advise you about or help you deal with these emotional problems?",
      "last_six_months_drug_therapy_additional_service": "Additional services to manage your cancer care at home include home health care, special medical equipment, or special supplies. In the last 6 months, did you and your drug therapy team talk about these additional services?",
      "last_six_months_health_maintain_treatment": "In the last 6 months, did you and your drug therapy team talk about things you can do to maintain your health during cancer treatment such as what to eat and what exercises to do?",
      "drug_therapy_team_rating": "Using any number from 0 to 10, where 0 is the worst drug therapy team possible and 10 is the best drug therapy team possible, what number would you use to rate your drug therapy team?",
      "drug_therapy_team_rating_opt_0": "0 - Worst cancer surgery team possible",
      "drug_therapy_team_rating_opt_1": "1",
      "drug_therapy_team_rating_opt_2": "2",
      "drug_therapy_team_rating_opt_3": "3",
      "drug_therapy_team_rating_opt_4": "4",
      "drug_therapy_team_rating_opt_5": "5",
      "drug_therapy_team_rating_opt_6": "6",
      "drug_therapy_team_rating_opt_7": "7",
      "drug_therapy_team_rating_opt_8": "8",
      "drug_therapy_team_rating_opt_9": "9",
      "drug_therapy_team_rating_opt_10": "10 - Best cancer surgery team possible",
      "last_six_months_need_interpreter": "An interpreter is someone who helps you talk with others who do not speak your language. Interpreters can include staff from this cancer center, telephone interpreters, friends, or family members. In the last 6 months, was there any time when you needed an interpreter at this cancer center?",
      "last_six_months_need_interpreter_drug_therapy": "In the last 6 months, when you needed an interpreter to speak with your drug therapy team, how often did you get one?",
      "cancer_center_care_rating": "Considering all your cancer care at this cancer center, using any number from 0 to 10, where 0 is the worst overall cancer care experience possible and 10 is the best overall cancer care experience possible, what number would you use to rate your overall cancer care experience?",
      "cancer_center_care_rating_opt_0": "0 - Worst overall cancer care experience possible",
      "cancer_center_care_rating_opt_1": "1",
      "cancer_center_care_rating_opt_2": "2",
      "cancer_center_care_rating_opt_3": "3",
      "cancer_center_care_rating_opt_4": "4",
      "cancer_center_care_rating_opt_5": "5",
      "cancer_center_care_rating_opt_6": "6",
      "cancer_center_care_rating_opt_7": "7",
