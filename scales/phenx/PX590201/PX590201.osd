  "translations": {
    "en": {
      "brief_assessment_social_network_characteristics_how_many_friends_family_regularly_contact": "About how many friends and family members (including your spouse, lover/s, or partner/s) do you regularly have contact with? (By regularly, we mean you see them or talk on the phone with them once or more every couple of weeks.)",
      "brief_assessment_social_network_characteristics_how_many_heavy_drinkers_drug_use": "Of the [Q1] people you regularly have contact with, how many are heavy drinkers or drug users?",
      "brief_assessment_social_network_characteristics_how_many_drug_users_see_once_twice_week": "How many of these heavy drinkers or drug users do you see at least once or twice a week?",
      "brief_assessment_social_network_characteristics_how_many_encourage_drink_use": "Of the [Q1] people you regularly have contact with, how many encourage you to drink or use drugs?",
      "brief_assessment_social_network_characteristics_how_many_dont_drink_use_atall": "Of the [Q1] people that you regularly have contact with, how many don't drink or use drugs at all?",
      "brief_assessment_social_network_characteristics_how_many_support_your_effort_quit": "Of the [Q1] people you regularly have contact with, how many actively support your effort to quit drinking and using drugs?",
      "brief_assessment_social_network_characteristics_meet_people_support_quitting_aa_ca_na": "Did you meet any of these [Q4] people who support your quitting in AA, CA, or NA?",
      "brief_assessment_social_network_characteristics_meet_people_support_quitting_aa_ca_na_opt_1": "Yes",
      "brief_assessment_social_network_characteristics_meet_people_support_quitting_aa_ca_na_opt_2": "No",
      "brief_assessment_social_network_characteristics_how_many_meet_in_aa_ca_na": "How many did you meet in [AA, CA, or NA]?",
      "brief_assessment_social_network_characteristics_how_many_no_longer_contact_with": "How many people are you no longer in contact with because of their drinking or drug use?"
    }
  }
}