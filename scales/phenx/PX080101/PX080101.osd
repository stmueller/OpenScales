{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Breast or Bottle Feeding Patterns",
      "code": "PX080101",
      "abbreviation": "PX080101",
      "description": "These parent-reported, self-administered questions obtain information on the infants feeding schedule, frequency of adding supplemental foods, and feeding lengths.",
      "domain": "Health",
      "citation": "Warren, J. J., Weber-Gasparoni, K., Marshall, T. A., Drake, D. R., Dehkordi-Vakil, F., Dawson, D. V., & Tharp, K. M. (2009). A longitudinal study of dental caries risk among very young low SES children. Community Dentistry and Oral Epidemiology, 37 (2), 116–122. [PhenX: https://www.phenxtoolkit.org/protocols/view/80101]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/80101"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
