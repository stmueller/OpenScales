      "control_things_better_heroin_opt_7": "STRONGLY AGREE",
      "unable_to_stop_more_heroin": "If I tried a little heroin right now, I would not be able to stop using more of it.",
      "unable_to_stop_more_heroin_opt_1": "STRONGLY DISAGREE",
      "unable_to_stop_more_heroin_opt_2": "2",
      "unable_to_stop_more_heroin_opt_3": "3",
