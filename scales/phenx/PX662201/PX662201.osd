  "translations": {
    "en": {
      "burden_assessment_financial_problems": "Because of name's illness, to what extent have you: had financial problems",
      "burden_assessment_financial_problems_opt_1": "Not at all",
      "burden_assessment_financial_problems_opt_2": "A little",
      "burden_assessment_financial_problems_opt_3": "Some",
      "burden_assessment_financial_problems_opt_4": "A lot",
      "burden_assessment_financial_problems_opt_5": "NA",
      "burden_assessment_missed_work": "Because of name's illness, to what extent have you: missed days at work (or school)",
      "burden_assessment_missed_work_opt_1": "Not at all",
      "burden_assessment_missed_work_opt_2": "A little",
      "burden_assessment_missed_work_opt_3": "Some",
      "burden_assessment_missed_work_opt_4": "A lot",
      "burden_assessment_missed_work_opt_5": "NA",
      "burden_assessment_difficulty_concentrating": "Because of name's illness, to what extent have you: found it difficult to concentrate on your own activities",
      "burden_assessment_difficulty_concentrating_opt_1": "Not at all",
      "burden_assessment_difficulty_concentrating_opt_2": "A little",
      "burden_assessment_difficulty_concentrating_opt_3": "Some",
      "burden_assessment_difficulty_concentrating_opt_4": "A lot",
      "burden_assessment_difficulty_concentrating_opt_5": "NA",
      "burden_assessment_change_personal_plans": "Because of name's illness, to what extent have you: had to change your personal plans like taking a new job, or going on vacation",
      "burden_assessment_change_personal_plans_opt_1": "Not at all",
      "burden_assessment_change_personal_plans_opt_2": "A little",
      "burden_assessment_change_personal_plans_opt_3": "Some",
      "burden_assessment_change_personal_plans_opt_4": "A lot",
      "burden_assessment_change_personal_plans_opt_5": "NA",
      "burden_assessment_less_leisure": "Because of name's illness, to what extent have you: cut down on leisure time",
      "burden_assessment_less_leisure_opt_1": "Not at all",
      "burden_assessment_less_leisure_opt_2": "A little",
      "burden_assessment_less_leisure_opt_3": "Some",
      "burden_assessment_less_leisure_opt_4": "A lot",
      "burden_assessment_less_leisure_opt_5": "NA",
      "burden_assessment_routine_upsetting": "Because of name's illness, to what extent have you: found the household routine was upset",
      "burden_assessment_routine_upsetting_opt_1": "Not at all",
      "burden_assessment_routine_upsetting_opt_2": "A little",
      "burden_assessment_routine_upsetting_opt_3": "Some",
      "burden_assessment_routine_upsetting_opt_4": "A lot",
      "burden_assessment_routine_upsetting_opt_5": "NA",
      "burden_assessment_less_social": "Because of name's illness, to what extent have you: had less time to spend with friends",
      "burden_assessment_less_social_opt_1": "Not at all",
      "burden_assessment_less_social_opt_2": "A little",
      "burden_assessment_less_social_opt_3": "Some",
      "burden_assessment_less_social_opt_4": "A lot",
      "burden_assessment_less_social_opt_5": "NA",
      "burden_assessment_neglected_others": "Because of name's illness, to what extent have you: neglected other family members' needs",
      "burden_assessment_neglected_others_opt_1": "Not at all",
      "burden_assessment_neglected_others_opt_2": "A little",
      "burden_assessment_neglected_others_opt_3": "Some",
      "burden_assessment_neglected_others_opt_4": "A lot",
      "burden_assessment_neglected_others_opt_5": "NA",
      "burden_assessment_family_tensions": "Because of name's illness, to what extent have you: experienced family frictions and arguments",
      "burden_assessment_family_tensions_opt_1": "Not at all",
      "burden_assessment_family_tensions_opt_2": "A little",
      "burden_assessment_family_tensions_opt_3": "Some",
      "burden_assessment_family_tensions_opt_4": "A lot",
      "burden_assessment_family_tensions_opt_5": "NA",
      "burden_assessment_tension_others": "Because of name's illness, to what extent have you: experienced frictions with neighbors, friends, or relatives outside the home",
      "burden_assessment_tension_others_opt_1": "Not at all",
      "burden_assessment_tension_others_opt_2": "A little",
      "burden_assessment_tension_others_opt_3": "Some",
      "burden_assessment_tension_others_opt_4": "A lot",
      "burden_assessment_tension_others_opt_5": "NA",
      "burden_assessment_embarrassed_behavior": "Because of name's illness, to what extent have you: became embarrassed because of (name's) behavior",
