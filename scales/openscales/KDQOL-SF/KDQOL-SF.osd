          "kd31"
        ]
      },
      "sleep": {
        "description": "Sleep (rating 0-10 + 3 frequency items).",
        "method": "mean_coded",
        "items": [
          "kd35",
          "kd36",
          "kd37",
          "kd38"
        ]
      },
      "social_support": {
        "description": "Social Support / Family Satisfaction (2 items, 4-pt).",
        "method": "mean_coded",
        "items": [
          "kd39",
          "kd40"
        ]
      },
      "dialysis_care": {
        "description": "Satisfaction with Dialysis Care (3 items: 1 satisfaction + 2 true/false).",
        "method": "mean_coded",
        "items": [
          "kd44",
          "kd45",
          "kd46"
        ]
      }
    },
    "parameters": {
      "hemodialysis": {
        "type": "boolean",
        "default": 1,
        "description": "Include hemodialysis access site question (item 14l)"
      },
      "peritoneal": {
        "type": "boolean",
        "default": 1,
        "description": "Include peritoneal dialysis catheter site question (item 14m)"
      },
      "dialysis_care": {
        "type": "boolean",
        "default": 1,
        "description": "Include dialysis care satisfaction questions (sections 23-24)"
      }
    },
    "likert_options": {
      "points": 3,
      "min": 1,
      "max": 3,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3"
      ]
    }
  },
  "translations": {
    "en": {
      "kdqolsf_intro": "This survey asks for your views about your health. This information will help keep track of how you feel and how well you are able to do your usual activities. Thank you for completing these questions!",
      "kdqolsf_health1": "Excellent",
      "kdqolsf_health3": "Good",
      "kdqolsf_health4": "Fair",
      "kdqolsf_health5": "Poor",
      "kdqolsf_pain1": "None",
      "kdqolsf_pain2": "Very mild",
      "kdqolsf_pain3": "Mild",
      "kdqolsf_pain4": "Moderate",
      "kdqolsf_pain5": "Severe",
      "kdqolsf_pain6": "Very severe",
      "kdqolsf_change1": "Much better now than one year ago",
      "kdqolsf_change2": "Somewhat better now than one year ago",
      "kdqolsf_change3": "About the same as one year ago",
      "kdqolsf_change4": "Somewhat worse now than one year ago",
      "kdqolsf_change5": "Much worse now than one year ago",
      "kdqolsf1": "<b>Vigorous activities</b>, such as running, lifting heavy objects, participating in strenuous sports",
      "kdqolsf2": "<b>Moderate activities</b>, such as moving a table, pushing a vacuum cleaner, bowling, or playing golf",
      "kdqolsf3": "Lifting or carrying <b>groceries</b>",
      "kdqolsf4": "Climbing <b>several</b> flights of stairs",
      "kdqolsf5": "Climbing <b>one</b> flight of stairs",
      "kdqolsf6": "Bending, kneeling, or stooping",
      "kdqolsf7": "Walking <b>more than a mile</b>",
      "kdqolsf8": "Walking <b>several blocks</b>",
      "kdqolsf9": "Walking <b>one block</b>",
      "kdqolsf10": "Bathing or dressing yourself",
      "kdqolsf11": "Cut down the <b>amount of time</b> you spent on work or other activities",
      "kdqolsf12": "<b>Accomplished less</b> than you would like",
      "kdqolsf13": "Were limited in the <b>kind</b> of work or other activities",
      "kdqolsf14": "Had <b>difficulty</b> performing the work or other activities (for example, it took extra effort)",
      "kdqolsf15": "Cut down the <b>amount of time</b> you spent on work or other activities",
      "kdqolsf16": "<b>Accomplished less</b> than you would like",
      "kdqolsf17": "Didn't do work or other activities as <b>carefully</b> as usual",
      "kdqolsf18": "During the <b>past 4 weeks</b>, to what extent has your <b>physical health or emotional problems</b> interfered with your normal social activities with family, friends, neighbors, or groups?",
      "kdqolsf19": "How much <b>bodily</b> pain have you had during the <b>last 4 weeks</b>?",
      "kdqolsf20": "During the <b>past 4 weeks</b>, how much did <b>pain</b> interfere with your normal work (including both work outside the home and housework)?",
      "kdqolsf21": "In general, would you say your health is:",
      "kdqolsf22": "Compared to one year ago, how would you rate your health in general now?",
      "kdqolsf23": "...did you feel <b>full of pep</b>?",
      "kdqolsf24": "...have you been a <b>very nervous person</b>?",
      "kdqolsf25": "...have you felt so <b>down in the dumps</b> that nothing could cheer you up?",
      "kdqolsf26": "...have you felt <b>calm and peaceful</b>?",
      "kdqolsf27": "...did you have <b>a lot of energy</b>?",
      "kdqolsf28": "...have you felt <b>downhearted and blue</b>?",
      "kdqolsf29": "...did you feel <b>worn out</b>?",
      "kdqolsf30": "...have you been a <b>happy person</b>?",
      "kdqolsf31": "...did you feel <b>tired</b>?",
      "kdqolsf32": "During the <b>past 4 weeks</b>, how much of the time has your <b>physical health or emotional problems</b> interfered with your social activities (like visiting with friends, relatives, etc.)?",
      "kdqolsf33": "I seem to get <b>sick a little easier</b> than other people",
      "kdqolsf34": "I am <b>as healthy as anybody</b> I know",
      "kdqolsf35": "I expect my health to <b>get worse</b>",
      "kdqolsf36": "My health is <b>excellent</b>",
      "debrief": "Thank you for completing this questionnaire.",
      "qh_pf": "The following items are about activities you might do during a typical day. Does <b>your health</b> now limit you in these activities? If so, how much?",
      "qh_rp": "During the <b>past 4 weeks</b>, have you had any of the following problems with your work or other regular daily activities <b>as a result of your physical health</b>?",
      "qh_re": "During the <b>past 4 weeks</b>, have you had any of the following problems with your work or other regular daily activities <b>as a result of any emotional problems</b> (such as feeling depressed or anxious)?",
      "qh_vitality": "These questions are about how you feel and how things have been with you <b>during the past 4 weeks</b>. For each question, please give the one answer that comes closest to the way you have been feeling. How much of the time during the <b>past 4 weeks</b>...",
      "qh_gh_statements": "How <b>TRUE</b> or <b>FALSE</b> is <i>each</i> of the following statements for you?",
      "freq6_1": "All of the time",
      "freq6_2": "Most of the time",
      "freq6_3": "A good bit of the time",
      "freq6_4": "Some of the time",
      "freq6_5": "A little of the time",
      "freq6_6": "None of the time",
      "freq5_1": "All of the time",
      "freq5_2": "Most of the time",
      "freq5_3": "Some of the time",
      "freq5_4": "A little of the time",
      "freq5_5": "None of the time",
      "tf5_1": "Definitely true",
      "tf5_2": "Mostly true",
      "tf5_3": "Don't know",
      "tf5_4": "Mostly false",
      "tf5_5": "Definitely false",
      "kidney_inst": "<b>Your Kidney Disease</b>",
      "qh_12": "How <b>true</b> or <b>false</b> is each of the following statements for you?",
      "kd1": "My kidney disease interferes too much with my life.",
      "kd2": "Too much of my time is spent dealing with my kidney disease.",
      "kd3": "I feel frustrated dealing with my kidney disease.",
      "kd4": "I feel like a burden on my family.",
      "qh_13": "These questions are about how you feel and how things have been going during the <b>past 4 weeks</b>. For each question, please give the one answer that comes closest to the way you have been feeling.<br><br>How much of the time during the <b>past 4 weeks</b> did you...",
      "freq6r_1": "None of the time",
      "freq6r_2": "A little of the time",
      "freq6r_3": "Some of the time",
      "freq6r_4": "A good bit of the time",
