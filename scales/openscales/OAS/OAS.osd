  "translations": {
    "en": {
      "av_head": "Could you do this right now?",
      "dist_head": "How anxious would you feel doing this?",
      "avoidance_yes": "Yes, I could do this now",
      "avoidance_no": "No, I'd get too anxious",
      "dist_0": "No distress",
      "dist_5": "Moderate distress",
      "dist_10": "Extreme distress",
      "oas1": "Stand outside your home on your own for 5 minutes",
      "oas2": "Walk down a quiet street on your own",
      "oas3": "Walk down a busy street with someone you know",
      "oas4": "Travel on your own on the bus for several stops",
      "oas5": "Sit in the waiting room of your GP/health centre on your own for 5 minutes",
      "oas6": "Purchase an item in a local shop, from a shop assistant",
      "oas7": "Go to a shopping centre on your own for 15 minutes",
      "oas8": "Sit in a café on your own for 10 minutes",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
