  "definition": {
    "scale_info": {
      "name": "Personality Inventory for DSM-5 Brief Form",
      "code": "PID5BF",
      "abbreviation": "PID-5-BF",
      "description": "25-item brief self-report measure of the DSM-5 maladaptive personality trait model, covering five broad domains: Negative Affect, Detachment, Antagonism, Disinhibition, and Psychoticism. Each domain is assessed with 5 items scored 0–3.",
      "citation": "Krueger, R. F., Derringer, J., Markon, K. E., Watson, D., & Skodol, A. E. (2012). Initial construction of a maladaptive personality trait model and inventory for DSM-5. Psychological Medicine, 42(9), 1879–1890. https://doi.org/10.1017/S0033291711002674",
      "license": "free for research/clinical",
      "version": "1.0",
      "url": "https://www.psychiatry.org/psychiatrists/practice/dsm/educational-resources/assessment-measures",
      "license_explanation": "Copyright 2013 American Psychiatric Association. All Rights Reserved. May be reproduced without permission by researchers and by clinicians for use with their patients.",
      "license_url": "https://www.psychiatry.org/psychiatrists/practice/dsm/educational-resources/assessment-measures",
      "domain": "Personality"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
