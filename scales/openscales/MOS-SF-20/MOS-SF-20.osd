{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "MOS 20-Item Short Form Health Survey",
      "code": "MOS-SF-20",
      "abbreviation": "MOS-SF-20",
      "description": "20-item short form general health survey from the Medical Outcomes Study measuring six dimensions: Physical Functioning (6 items), Role Functioning (2 items), Social Functioning (1 item), Mental Health (5 items), Health Perceptions (5 items including general health), and Pain (1 item). Mixed response formats. Higher scores indicate better health. Public Domain (RAND Corporation).",
      "citation": "Stewart, A. L., Hays, R. D., & Ware, J. E. (1988). The MOS Short-Form General Health Survey: Reliability and validity in a patient population. Medical Care, 26(7), 724–735. https://doi.org/10.1097/00005650-198807000-00007",
      "license": "Public Domain",
      "version": "1.0",
      "url": "https://www.rand.org/health/surveys/mos/20-item-short-form.html",
      "domain": "Health",
      "license_explanation": "RAND Corporation places their health survey instruments in the public domain.",
      "license_url": "https://www.rand.org/health-care/surveys_tools.html"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 6,
      "min": 1,
      "max": 6,
      "labels": [
        "sf20_freq1",
        "sf20_freq2",
        "sf20_freq3",
        "sf20_freq4",
        "sf20_freq5",
        "sf20_freq6"
      ],
      "question_head": "sf20_freq_head"
    },
    "dimensions": [
      {
        "id": "physical_functioning",
        "name": "Physical Functioning",
        "abbreviation": "PF",
        "description": "Items 2a–2f. Activity limitations. Higher = less limited."
      },
      {
        "id": "role_functioning",
        "name": "Role Functioning",
        "abbreviation": "RF",
        "description": "Items 4, 5. Health limiting work. Higher = less limited."
      },
      {
        "id": "social_functioning",
        "name": "Social Functioning",
        "abbreviation": "SF",
        "description": "Item 6. Health limiting social activities. Higher = better."
      },
      {
        "id": "mental_health",
        "name": "Mental Health",
        "abbreviation": "MH",
        "description": "Items 7–11. Past month feelings. Items 8, 10 reverse-coded. Higher = better."
      },
      {
        "id": "health_perceptions",
        "name": "Health Perceptions",
        "abbreviation": "HP",
        "description": "Items 1, 12a–12d. Items 12a, 12d reverse-coded. Higher = better perceived health."
      },
      {
        "id": "pain",
        "name": "Pain",
        "abbreviation": "BP",
        "description": "Item 3. Bodily pain. Higher = less pain."
      }
    ],
