        "dist_10"
      ],
      "question_head": "dist_head"
    },
    "dimensions": [
      {
        "id": "avoidance",
        "name": "Avoidance",
        "description": "Number of activities avoided due to anxiety (0–8). Higher scores = greater avoidance."
      },
      {
        "id": "distress",
        "name": "Distress",
        "description": "Sum of anticipated distress ratings 0–10 per activity (total 0–80). Higher scores = greater anticipated distress."
      }
    ],
