{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Multidimensional Academic Procrastination Scale",
      "code": "MAPS15",
      "abbreviation": "MAPS-15",
      "description": "15-item self-report measure of academic procrastination with three dimensions: Core Procrastination (6 items), Poor Time Management (4 items), and Work Disconnection (5 items). Items 8, 9, 12, and 13 are reverse-scored. 5-point scale (1-5).",
      "citation": "Gonzalez-Brignardello, M. P., & Sanchez-Elvira Paniagua, A. (2023). Dimensional structure of MAPS-15: Validation of the multidimensional academic procrastination scale. International Journal of Environmental Research and Public Health, 20(4), 3201. https://doi.org/10.3390/ijerph20043201",
      "license": "CC BY 4.0",
      "license_explanation": "Published in IJERPH (MDPI) under Creative Commons Attribution 4.0 International License.",
      "license_url": "https://creativecommons.org/licenses/by/4.0/",
      "version": "1.0",
      "url": "https://doi.org/10.3390/ijerph20043201",
      "domain": "Education"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "core_procrastination",
        "name": "Core Procrastination",
        "description": "Pure dimension of procrastinating behavior and difficulty in carrying out the action (items 4, 5, 6, 7, 10, 13r)."
      },
      {
        "id": "poor_time_management",
        "name": "Poor Time Management",
        "description": "Dimension related to time organization and perceived control over time (items 2, 8r, 9r, 12r)."
      },
      {
        "id": "work_disconnection",
        "name": "Work Disconnection",
        "description": "Dimension related to lack of persistence and work interruptions (items 1, 3, 11, 14, 15)."
      }
    ],
    "items": [
