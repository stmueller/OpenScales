  "translations": {
    "en": {
      "likert_1": "Very Inaccurate",
      "likert_2": "Moderately Inaccurate",
      "likert_3": "Neither Accurate Nor Inaccurate",
      "likert_4": "Moderately Accurate",
      "likert_5": "Very Accurate",
      "question_head": "<h3>How Accurately Can You Describe Yourself?</h3>\nDescribe yourself as you generally are now, not as you wish to be in the future. Describe yourself as you honestly see yourself, in relation to other people you know of the same sex as you are, and roughly your same age. So that you can describe yourself in an honest manner, your responses will be kept in absolute confidence. Indicate how accurately this statement describes you.",
      "ipip_dissociation_001": "Drove or rode somewhere without remembering later what happened during all or part of the trip.",
      "ipip_dissociation_002": "Felt as though I was looking at the world through a fog so that people and objects appeared far away or unclear.",
      "ipip_dissociation_003": "Felt like I was disconnected from my body.",
      "ipip_dissociation_004": "Felt like I was dreaming when I was awake.",
      "ipip_dissociation_005": "Felt that I could not move my hands or feet.",
      "ipip_dissociation_006": "Find that I sometimes sit staring off into space, thinking of nothing, and am not aware of the passage of time.",
      "ipip_dissociation_007": "Find that in certain situations I am able to do things with amazing ease and spontaneity that would usually be difficult for me.",
      "ipip_dissociation_008": "Find that in one situation I act so differently from when I'm in another situation that I feel almost as if I were two different people.",
      "ipip_dissociation_009": "Found evidence that I had done things that I did not remember doing.",
      "ipip_dissociation_010": "Found myself dressed in clothes I didn't remember putting on.",
      "ipip_dissociation_011": "Found myself in a place and had no idea how I had gotten there.",
      "ipip_dissociation_012": "Found new things among my belongings that I didn't remember buying.",
      "ipip_dissociation_013": "Found that I became so involved in a fantasy or daydream that it felt like it was really happening to me.",
      "ipip_dissociation_014": "Found that I could not remember whether I had done something or had just thought about doing that thing.",
      "ipip_dissociation_015": "Found that I had no memory for some important event in my life (for example, a wedding or graduation).",
      "ipip_dissociation_016": "Found that I heard voices inside my head that told me to do things or commented on things that I was doing.",
      "ipip_dissociation_017": "Found that I was able to ignore pain.",
      "ipip_dissociation_018": "Found that when I was watching television or a movie I became so absorbed in the story that I was unaware of other events happening around me.",
      "ipip_dissociation_019": "Found writings, drawings, or notes among my belongings that I must have done but cannot remember doing.",
      "ipip_dissociation_020": "Had the experience of being accused of lying when I did not think I had lied.",
      "ipip_dissociation_021": "Had the experience of being in a familiar place but finding it strange and unfamiliar.",
      "ipip_dissociation_022": "Had the experience of feeling as though I was standing next to myself, or watching myself as if I was looking at a different person.",
      "ipip_dissociation_023": "Had the experience of feeling that my body did not belong to me.",
      "ipip_dissociation_024": "Had the experience of feeling that other people, objects, and the world around me were not real.",
      "ipip_dissociation_025": "Had the experience of looking in a mirror and not recognizing myself.",
      "ipip_dissociation_026": "Had the experience of not being sure whether things I remember happening really did happen, or whether I just dreamed them.",
      "ipip_dissociation_027": "Had the experience of remembering a past event so vividly that it felt like I was reliving that event.",
      "ipip_dissociation_028": "Talked out loud to myself.",
      "ipip_dissociation_029": "Was approached by someone I didn't know who called me by another name or who insisted that he or she had met me before.",
      "ipip_dissociation_030": "Was listening to someone talk and suddenly realized I did not hear part or all of what was said.",
      "ipip_dissociation_031": "Was told that I sometimes do not recognize a friend or family member.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
