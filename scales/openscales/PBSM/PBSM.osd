        "norms": {
          "thresholds": [
            {
              "min": 17,
              "max": 42,
              "label": "Low PBS use (T < 36)"
            },
            {
              "min": 43,
              "max": 76,
              "label": "Average PBS use (T 36–49)"
            },
            {
              "min": 77,
              "max": 102,
              "label": "High PBS use (T ≥ 50)"
            }
          ],
          "source": "IRT T-score conversion table (Pedersen et al., 2017). T-scores: M=50, SD=10. Sum 17→T=15; 50→T=39; 77→T=50; 102→T=73."
        }
      }
