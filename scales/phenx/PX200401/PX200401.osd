{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Family History of Speech and Language Impairment",
      "code": "PX200401",
      "abbreviation": "PX200401",
      "description": "The Family History Questionnaire is a 9-item proxy-administered questionnaire completed by a parent for their young child. It asks about the child's personal and family history of speech and language impairment.",
      "domain": "Health",
      "citation": "Rice, M. L., Haney, K. R., & Wexler, K. (1998). Family histories of children with SLI who show extended optional infinitives. Journal of Speech, Language, and Hearing Research, 41, 419–432. [PhenX: https://www.phenxtoolkit.org/protocols/view/200401]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/200401"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
