  "translations": {
    "en": {
      "sexual_function_female_interest_activity": "In the past 30 days, how interested have you been in sexual activity?",
      "sexual_function_female_wanted_activity": "In the past 30 days, how often have you felt like you wanted to have sexual activity?",
      "sexual_function_female_any_activity": "In the past 30 days, did you have any type of sexual activity? (Examples of sexual activity are masturbation, oral sex, and sexual intercourse.)",
      "sexual_function_female_any_activity_opt_1": "No",
      "sexual_function_female_any_activity_opt_2": "Yes",
      "sexual_function_female_no_activity": "There are many reasons why people may not have had sexual activity during the month. What are the reasons why you did not have sexual activity? Please read the list carefully and check every reason that applies to you, even if it happened only one time during the past 30 days.",
      "sexual_function_female_no_activity_opt_1": "Was not interested in having sexual activity",
      "sexual_function_female_no_activity_opt_2": "Dryness or pain in or around my vagina",
      "sexual_function_female_no_activity_opt_3": "Difficulties with orgasm/climax",
      "sexual_function_female_no_activity_opt_4": "Don't enjoy sexual activity",
      "sexual_function_female_no_activity_opt_5": "Health condition",
      "sexual_function_female_no_activity_opt_6": "No partner",
      "sexual_function_female_no_activity_opt_7": "Partner was away",
      "sexual_function_female_no_activity_opt_8": "Partner was not interested in sexual activity",
      "sexual_function_female_no_activity_opt_9": "Partner's health condition",
      "sexual_function_female_no_activity_opt_10": "Some other reason (Specify)",
      "sexual_function_female_no_activity_specify": "There are many reasons why people may not have had sexual activity during the month. What are the reasons why you did not have sexual activity? Please read the list carefully and check every reason that applies to you, even if it happened only one time during the past 30 days. Specify",
      "sexual_function_female_lubricated_during_intercourse": "In the past 30 days, how often did you become lubricated (\"wet\") during sexual activity or intercourse?",
      "sexual_function_female_lubricated_during_intercourse_opt_5": "Almost always or always",
      "sexual_function_female_lubricated_during_intercourse_opt_4": "Most times (more than half the time)",
      "sexual_function_female_lubricated_during_intercourse_opt_3": "Sometimes (about half the time)",
      "sexual_function_female_lubricated_during_intercourse_opt_2": "A few times (less than half the time)",
      "sexual_function_female_lubricated_during_intercourse_opt_1": "Almost never or never",
      "sexual_function_female_difficult_maintain_lubrication": "In the past 30 days, how difficult was it to maintain your lubrication (\"wetness\") until completion of sexual activity or intercourse?",
      "sexual_function_female_discomfort_inside_vagina": "In the past 30 days, when you have had sexual activity, how much discomfort have you felt inside your vagina?",
      "sexual_function_female_pain_inside_vagina": "In the past 30 days, when you have had sexual activity, how much pain have you felt inside your vagina?",
      "sexual_function_female_discomfort_labia": "In the past 30 days, when you have had sexual activity, how much discomfort have you had in your labia (lips around the opening of the vagina)?",
      "sexual_function_female_discomfort_clitoris": "In the past 30 days, when you have had sexual activity, how much discomfort have you had in your clitoris (clit)?",
      "sexual_function_female_often_orgasm": "In the past 30 days, how often have you been able to have an orgasm/climax when you wanted to?",
      "sexual_function_female_often_orgasm_opt_0": "Have not tried to have an orgasm/climax",
      "sexual_function_female_often_orgasm_opt_1": "Never",
      "sexual_function_female_often_orgasm_opt_2": "Rarely",
      "sexual_function_female_often_orgasm_opt_3": "Sometimes",
      "sexual_function_female_often_orgasm_opt_4": "Often",
      "sexual_function_female_often_orgasm_opt_5": "Always",
      "sexual_function_female_satisfying_orgasm": "In the past 30 days, how satisfying have your orgasms or climaxes been?",
      "sexual_function_female_satisfying_orgasm_opt_0": "Have not had an orgasm/climax",
      "sexual_function_female_satisfying_orgasm_opt_1": "Not at all",
      "sexual_function_female_satisfying_orgasm_opt_2": "A little bit",
      "sexual_function_female_satisfying_orgasm_opt_3": "Somewhat",
      "sexual_function_female_satisfying_orgasm_opt_4": "Quite a bit",
      "sexual_function_female_satisfying_orgasm_opt_5": "Very",
      "sexual_function_female_satisfied_sex_life": "In the past 30 days, how satisfied have you been with your sex life?",
      "sexual_function_female_pleasure_sex_life": "In the past 30 days, how much pleasure has your sex life given you?",
      "likert_1": "Not at all",
      "likert_2": "A little bit",
      "likert_3": "Somewhat",
      "likert_4": "Quite a bit",
      "likert_5": "Very"
    }
  }
}
