  "translations": {
    "en": {
      "instructions_540301": "This is not a test, so there are no right or wrong answers; we would like you to work quickly, so that you can finish. Some of the questions have the following format:Please check the answer that best describes how you feel about that sentence.Mark (the BIG) YES! if you think the statement is definitely true for you.Mark (the little) yes if you think the statement is mostly true for you.Mark (the little) no if you think the statement is mostly not true for you.Mark (the BIG) NO! if you think the statement is definitely not true for you.This set of questions asks about your family. When answering these questions please think about the people you consider to be your family. For example, parents, stepparents, grandparents, aunts, uncles, etc.",
      "how_wrong_parents_feel_drink": "How wrong do your parents feel it would be for you to: drink beer, wine or hard liquor (for example, vodka, whiskey, or gin) regularly (at least once or twice a month)?",
      "how_wrong_parents_feel_drink_opt_1": "Very wrong",
      "how_wrong_parents_feel_drink_opt_2": "Wrong",
      "how_wrong_parents_feel_drink_opt_3": "A little bit wrong",
      "how_wrong_parents_feel_drink_opt_4": "Not wrong at all",
      "how_wrong_parents_feel_cigarettes": "How wrong do your parents feel it would be for you to: smoke cigarettes?",
      "how_wrong_parents_feel_cigarettes_opt_1": "Very wrong",
      "how_wrong_parents_feel_cigarettes_opt_2": "Wrong",
      "how_wrong_parents_feel_cigarettes_opt_3": "A little bit wrong",
      "how_wrong_parents_feel_cigarettes_opt_4": "Not wrong at all",
      "how_wrong_parents_feel_marijuana": "How wrong do your parents feel it would be for you to: smoke marijuana?",
      "how_wrong_parents_feel_marijuana_opt_1": "Very wrong",
      "how_wrong_parents_feel_marijuana_opt_2": "Wrong",
      "how_wrong_parents_feel_marijuana_opt_3": "A little bit wrong",
      "how_wrong_parents_feel_marijuana_opt_4": "Not wrong at all",
      "how_wrong_parents_feel_steal": "How wrong do your parents feel it would be for you to: steal something worth more than $5?",
      "how_wrong_parents_feel_steal_opt_1": "Very wrong",
      "how_wrong_parents_feel_steal_opt_2": "Wrong",
      "how_wrong_parents_feel_steal_opt_3": "A little bit wrong",
      "how_wrong_parents_feel_steal_opt_4": "Not wrong at all",
      "how_wrong_parents_feel_graffit": "How wrong do your parents feel it would be for you to: draw graffiti, or write things or draw pictures on buildings or other property (without the owner's permission)?",
      "how_wrong_parents_feel_graffit_opt_1": "Very wrong",
      "how_wrong_parents_feel_graffit_opt_2": "Wrong",
      "how_wrong_parents_feel_graffit_opt_3": "A little bit wrong",
      "how_wrong_parents_feel_graffit_opt_4": "Not wrong at all",
      "how_wrong_parents_feel_fight": "How wrong do your parents feel it would be for you to: pick a fight with someone?",
      "how_wrong_parents_feel_fight_opt_1": "Very wrong",
      "how_wrong_parents_feel_fight_opt_2": "Wrong",
      "how_wrong_parents_feel_fight_opt_3": "A little bit wrong",
      "how_wrong_parents_feel_fight_opt_4": "Not wrong at all",
      "brothers_sisters_ever_drunk": "Have any of your brothers or sisters ever: drunk beer, wine or hard liquor (for example, vodka, whiskey, or gin)?",
      "brothers_sisters_ever_drunk_opt_1": "No",
      "brothers_sisters_ever_drunk_opt_5": "Yes",
      "brothers_sisters_ever_drunk_opt_0": "I don't have any brothers or sisters",
      "brothers_sisters_ever_smoked_marijuana": "Have any of your brothers or sisters ever: smoked marijuana?",
      "brothers_sisters_ever_smoked_marijuana_opt_1": "No",
      "brothers_sisters_ever_smoked_marijuana_opt_5": "Yes",
      "brothers_sisters_ever_smoked_marijuana_opt_0": "I don't have any brothers or sisters",
      "brothers_sisters_ever_smoked_cigarettes": "Have any of your brothers or sisters ever: smoked cigarettes?",
      "brothers_sisters_ever_smoked_cigarettes_opt_1": "No",
      "brothers_sisters_ever_smoked_cigarettes_opt_5": "Yes",
      "brothers_sisters_ever_smoked_cigarettes_opt_0": "I don't have any brothers or sisters",
      "brothers_sisters_taken_handgun_school": "Have any of your brothers or sisters ever: taken a handgun to school?",
      "brothers_sisters_taken_handgun_school_opt_1": "No",
      "brothers_sisters_taken_handgun_school_opt_5": "Yes",
      "brothers_sisters_taken_handgun_school_opt_0": "I don't have any brothers or sisters",
      "brothers_sisters_been_suspended_expelled": "Have any of your brothers or sisters ever: been suspended or expelled from school?",
      "brothers_sisters_been_suspended_expelled_opt_1": "No",
      "brothers_sisters_been_suspended_expelled_opt_5": "Yes",
      "brothers_sisters_been_suspended_expelled_opt_0": "I don't have any brothers or sisters",
      "family_rules_are_clear": "The rules in my family are clear.",
      "family_rules_are_clear_opt_4": "NO!",
      "family_rules_are_clear_opt_3": "no",
      "family_rules_are_clear_opt_2": "yes",
