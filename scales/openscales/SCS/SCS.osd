    "scoring": {
      "self_kindness": {
        "description": "Mean of items 5, 12, 19, 23, 26 (range 1–5). Higher scores indicate greater self-kindness.",
        "method": "mean_coded",
        "items": [
          "scs5",
          "scs12",
          "scs19",
          "scs23",
          "scs26"
        ]
      },
      "self_judgment": {
        "description": "Mean of items 1, 8, 11, 16, 21, reverse-scored (range 1–5). Higher scores indicate less self-judgment (more self-compassion).",
        "method": "mean_coded",
        "items": {
          "scs1": -1,
          "scs8": -1,
          "scs11": -1,
          "scs16": -1,
          "scs21": -1
        }
      },
      "common_humanity": {
        "description": "Mean of items 3, 7, 10, 15 (range 1–5). Higher scores indicate greater sense of common humanity.",
        "method": "mean_coded",
        "items": [
          "scs3",
          "scs7",
          "scs10",
          "scs15"
        ]
      },
      "isolation": {
        "description": "Mean of items 4, 13, 18, 25, reverse-scored (range 1–5). Higher scores indicate less isolation (more self-compassion).",
