          }
        ]
      },
      "affectionate": {
        "description": "Affectionate Support: raw sum of 3 items (range 3–15; higher = greater perceived support). To obtain the 0–100 subscale score: ((mean_of_items − 1) / 4) × 100.",
        "method": "mean_coded",
        "items": [
          "mossocial6",
          "mossocial12",
          "mossocial15"
        ],
        "transform": [
