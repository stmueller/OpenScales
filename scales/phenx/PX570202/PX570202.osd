  "translations": {
    "en": {
      "tested_for_hiv": "Have you ever been tested for HIV?",
      "tested_for_hiv_opt_0": "No",
      "tested_for_hiv_opt_1": "Yes",
      "tested_for_hiv_opt_7": "Refused to answer",
      "tested_for_hiv_opt_9": "Don't know",
      "most_recent_hiv_test_month": "When did you have your most recent HIV test? Month",
      "most_recent_hiv_test_year": "When did you have your most recent HIV test? Year",
      "most_recent_hiv_test_result": "What was the result of your most recent HIV test?",
      "most_recent_hiv_test_result_opt_1": "Negative",
      "most_recent_hiv_test_result_opt_2": "Positive",
      "most_recent_hiv_test_result_opt_3": "Never obtained results",
      "most_recent_hiv_test_result_opt_4": "Indeterminate",
      "most_recent_hiv_test_result_opt_7": "Refused to answer",
      "most_recent_hiv_test_result_opt_9": "Don't know",
      "reason_not_tested_for_hiv": "I'm going to read you a list of reasons why some people have not been tested for HIV. Which of these best describes the most important reason you have not been tested for HIV in the past 12 months?",
      "reason_not_tested_for_hiv_opt_1": "You think you are at low risk for HIV infection?",
      "reason_not_tested_for_hiv_opt_2": "You were afraid of finding out that you had HIV?",
      "reason_not_tested_for_hiv_opt_3": "You didn't have time?",
      "reason_not_tested_for_hiv_opt_4": "Some other reason?",
      "reason_not_tested_for_hiv_opt_5": "No particular reason",
      "reason_not_tested_for_hiv_opt_7": "Refused to answer",
      "reason_not_tested_for_hiv_opt_9": "Don't know"
    }
