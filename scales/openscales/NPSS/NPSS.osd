  "translations": {
    "en": {
      "likert_1": "Strongly Disagree",
      "likert_2": "Disagree",
      "likert_3": "Neither Agree nor Disagree",
      "likert_4": "Agree",
      "likert_5": "Strongly Agree",
      "question_head": "Please indicate your level of agreement with each statement.",
      "npss1": "Scientists are often dishonest about their research findings.",
      "npss2": "Scientists often falsify data to manipulate results or findings.",
      "npss3": "Science has been co-opted by corporate interests.",
      "npss4": "Most scientists are politically biased.",
      "npss5": "Scientists are typically arrogant people.",
      "npss6": "Science is too complicated to understand.",
      "npss7": "Scientific results are presented in ways that are too complex to understand.",
      "npss8": "Scientific jargon is too complex to understand.",
      "npss9": "I don't care to know the answers to scientific questions.",
      "npss10": "Scientific discovery makes me nervous.",
      "npss11": "Religious scriptures (e.g., The Bible) are the ultimate explanation for how the world works.",
      "npss12": "God is the ultimate way of knowing, not science.",
      "npss13": "If people trusted the Scriptures, they would know all they need to know.",
      "npss14": "Religious doctrine tells us all we need to know about the world.",
      "npss15": "The Scriptures are sufficient to explain everything that is important.",
      "npss16": "Science cannot explain everything.",
      "npss17": "The scientific method is limited.",
      "npss18": "Scientific principles do not always make sense.",
      "npss19": "Science produces many contradictory findings.",
      "npss20": "Science has significant limitations.",
      "debrief": "Thank you for completing the Negative Perceptions of Science Scale."
    }
  }
}
