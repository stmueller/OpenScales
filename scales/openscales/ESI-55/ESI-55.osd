{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Epilepsy Surgery Inventory-55",
      "code": "ESI-55",
      "abbreviation": "ESI-55",
      "description": "55-item health-related quality of life measure developed specifically for patients being evaluated for or having undergone epilepsy surgery. Adapted from the RAND 36-Item Health Survey (SF-36) plus 19 epilepsy-specific items covering cognitive function, role limitations, and overall quality of life. Covers 11 health concepts scored 0–100 (higher = better health/quality of life). NOTE: Exact item text requires the official RAND instrument — see URL above. Item text provided here is based on Vickrey et al. (1992) and the published scale structure.",
      "citation": "Vickrey, B.G., Hays, R.D., Graber, J., Rausch, R., Engel, J., Jr., & Brook, R.H. (1992). A health-related quality of life instrument for patients evaluated for epilepsy surgery. Medical Care, 30(4), 299–319. https://doi.org/10.1097/00005650-199204000-00003",
      "license": "Public Domain",
      "version": "1.0",
      "url": "https://www.rand.org/health-care/surveys_tools/esi.html",
      "domain": "Health",
      "license_explanation": "Public Domain (RAND Corporation)."
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "dimensions": [
      {
        "id": "health_perceptions",
        "name": "Health Perceptions",
        "abbreviation": "HP",
        "description": "Personal evaluation of overall health. Items: esi1, esi2, esi20, esi32, esi33.",
        "enabled_param": null
      },
      {
        "id": "energy_fatigue",
        "name": "Energy/Fatigue",
        "abbreviation": "EF",
        "description": "Level of energy and fatigue over the past 4 weeks. Items: esi23, esi27, esi29, esi31.",
        "enabled_param": null
      },
      {
        "id": "overall_qol",
        "name": "Overall Quality of Life",
        "abbreviation": "OQL",
        "description": "Global quality of life rating. Items: esi3, esi4.",
        "enabled_param": null
      },
      {
        "id": "social_function",
        "name": "Social Function",
        "abbreviation": "SF",
        "description": "Degree to which health or emotional problems interfere with social activities. Items: esi17, esi18.",
        "enabled_param": null
      },
      {
        "id": "emotional_wellbeing",
        "name": "Emotional Well-Being",
        "abbreviation": "EWB",
        "description": "Psychological distress and well-being over the past 4 weeks. Items: esi24, esi25, esi26, esi28, esi30.",
        "enabled_param": null
      },
      {
        "id": "cognitive_function",
        "name": "Cognitive Function",
        "abbreviation": "CF",
        "description": "Perceived cognitive difficulties including memory and concentration. Items: esi34–esi44.",
        "enabled_param": null
      },
      {
        "id": "physical_function",
        "name": "Physical Function",
        "abbreviation": "PF",
        "description": "Extent to which health limits physical activities. Items: esi5–esi14.",
        "enabled_param": null
      },
      {
        "id": "role_physical",
        "name": "Role Limitations — Physical",
        "abbreviation": "RP",
        "description": "Limitations in work due to physical health problems. Items: esi15, esi16.",
        "enabled_param": null
      },
      {
        "id": "role_emotional",
        "name": "Role Limitations — Emotional",
        "abbreviation": "RE",
        "description": "Limitations in work due to emotional problems. Items: esi19, esi21, esi22.",
        "enabled_param": null
      },
      {
        "id": "pain",
        "name": "Pain",
        "abbreviation": "PAIN",
        "description": "Intensity of bodily pain and its interference with activities. Items: esi45, esi46.",
        "enabled_param": null
      },
      {
        "id": "epilepsy_specific",
        "name": "Epilepsy-Targeted Inventory",
        "abbreviation": "ETI",
        "description": "Epilepsy-specific items covering seizure frequency, memory complaints, attention, and adaptation to epilepsy. Items: esi47–esi55.",
        "enabled_param": null
      },
      {
        "id": "role_memory",
        "name": "Role Limitations — Memory",
        "description": "Role limitations due to memory, speech, or language problems (items 49-55)."
      }
    ],
