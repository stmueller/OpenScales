  "definition": {
    "scale_info": {
      "name": "Worksite Policies",
      "code": "PX751402",
      "abbreviation": "PX751402",
      "description": "This protocol includes 10 questions from the 2016 Nebraska Worksite Wellness Survey that are used to assess a respondent’s exposure to and compliance with worksite policies on tobacco.",
      "domain": "Tobacco - Social Norms & Awareness",
      "citation": "Hefler, M., Durkin, S.J., Cohen, J.E., Henriksen, L., OConnor, R., Barnoya, J., Hill, S.E. and Malone, R.E., 2023. New policy of people-first language to replace ‘smoker’, ‘vaper’, ‘ tobacco user’ and other behaviour-based labels. Tobacco control, 32(2), pp.133-134. Unger JB, Chaloupka FJ, Vallone D, Thrasher JF, Nettles DS, Hendershot TP, Swan GE. PhenX: environment measures for tobacco regulatory research. Tobacco Control. 2020 Jan;29(Suppl 1):s35. [PhenX: https://www.phenxtoolkit.org/protocols/view/751402]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/751402"
    },
