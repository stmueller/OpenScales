      "burden_assessment_upset_opt_5": "NA",
      "burden_assessment_behavior_worsen_illness": "Because of name's illness, to what extent have you: worried about how your behavior with (name) might make the illness worse",
      "burden_assessment_behavior_worsen_illness_opt_1": "Not at all",
      "burden_assessment_behavior_worsen_illness_opt_2": "A little",
      "burden_assessment_behavior_worsen_illness_opt_3": "Some",
      "burden_assessment_behavior_worsen_illness_opt_4": "A lot",
      "burden_assessment_behavior_worsen_illness_opt_5": "NA",
      "burden_assessment_future": "Because of name's illness, to what extent have you: worried about what the future holds for (name)",
      "burden_assessment_future_opt_1": "Not at all",
      "burden_assessment_future_opt_2": "A little",
      "burden_assessment_future_opt_3": "Some",
      "burden_assessment_future_opt_4": "A lot",
      "burden_assessment_future_opt_5": "NA",
      "burden_assessment_stigma_illness": "Because of name's illness, to what extent have you: found the stigma of the illness upsetting",
      "burden_assessment_stigma_illness_opt_1": "Not at all",
      "burden_assessment_stigma_illness_opt_2": "A little",
