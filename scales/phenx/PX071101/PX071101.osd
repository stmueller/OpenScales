{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Cancer Treatments",
      "code": "PX071101",
      "abbreviation": "PX071101",
      "description": "These questions start by asking if the respondent has had cancer. For respondents who have had cancer, detailed follow-up questions ask about the type of cancer treatment, including surgery, chemotherapy, radiation, and hormone therapy.",
      "domain": "Health",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/71101]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/71101"
    },
