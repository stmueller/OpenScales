    "scoring": {
      "rest": {
        "description": "Cravings for Rest: sum of items 3-7 (range 0-50). Higher scores indicate greater desire for rest.",
        "method": "sum_coded",
        "items": [
          "crve3",
          "crve4",
          "crve5",
          "crve6",
          "crve7"
        ]
      },
      "vee": {
        "description": "Volitional Energy Expenditure: sum of items 1,2,8-13 (range 0-80). Higher scores indicate greater desire for physical activity.",
