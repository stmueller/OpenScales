  "definition": {
    "scale_info": {
      "name": "Scoliosis - Quality of Life",
      "code": "PX221501",
      "abbreviation": "PX221501",
      "description": "The Pediatric Outcomes Data Collection Instrument (PODCI) was developed by the American Academy of Orthopaedic Surgeons®, Pediatric Orthopaedic Society of North America, American Academy of Pediatrics, and Shriners Hospitals. The protocol here is based on Version 2.0 of the PODCI which was revised, ",
      "domain": "Education",
      "citation": "Allen, D. D., Gorton, G. E., Oeffinger, D. J., Tylkowski, C., Tucker, C. A., & Haley, S. M. (2008). Analysis of the Pediatric Outcomes Data Collection Instrument (PODCI) in ambulatory children with cerebral palsy using confirmatory factor analysis and item response theory methods. Journal of Pediatric Orthopedics , 28 (2), 192-198. Kunkel, S., Eismann, E., & Cornwall, R. (2011). Utility of the pediatric outcomes data collection instrument for assessing acute hand and wrist injuries in children. Journal of Pediatric Orthopaedics , 31 (7), 767-772. [PhenX: https://www.phenxtoolkit.org/protocols/view/221501]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/221501"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
