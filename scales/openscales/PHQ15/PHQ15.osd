        "description": "Sum of all items (0-30). Severity: 0-4 minimal, 5-9 low, 10-14 medium, ≥15 high.",
        "method": "sum_coded",
        "items": [
          "phq15_1",
          "phq15_2",
          "phq15_3",
          "phq15_4",
          "phq15_5",
