  "translations": {
    "en": {
      "natural_teeth_number_adult": "How many natural teeth do you have?",
      "natural_teeth_number_adult_opt_1": "None",
      "natural_teeth_number_adult_opt_2": "1-10",
      "natural_teeth_number_adult_opt_3": "11-16",
      "natural_teeth_number_adult_opt_4": "17-24",
      "natural_teeth_number_adult_opt_5": "25-32",
      "natural_teeth_number_child": "How many natural teeth does your child have?",
