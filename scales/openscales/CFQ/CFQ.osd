  "translations": {
    "en": {
      "cfq_r1": "Never",
      "cfq_r2": "Very rarely",
      "cfq_r3": "Seldom",
      "cfq_r4": "Sometimes",
      "cfq_r5": "Often",
      "cfq_r6": "Almost always",
      "cfq_r7": "Always",
      "cfq_inst": "Below are a number of statements. Please rate how often each statement is true for you.",
      "cfq1": "My thoughts cause me distress or emotional pain.",
      "cfq2": "I get so caught up in my thoughts that I am unable to do the things that I most want to do.",
      "cfq3": "I overanalyze situations to the point where it's unhelpful to me.",
      "cfq4": "I struggle with my thoughts.",
      "cfq5": "I get upset with myself for having certain thoughts.",
      "cfq6": "I tend to get very entangled in my thoughts.",
      "cfq7": "It's such a struggle to let go of upsetting thoughts even when I know that letting go would be helpful.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}