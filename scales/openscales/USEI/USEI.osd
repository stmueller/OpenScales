{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "University Student Engagement Inventory",
      "code": "USEI",
      "abbreviation": "USEI",
      "description": "15-item multidimensional measure of student engagement in higher education across behavioural, emotional, and cognitive dimensions. Validated across seven countries.",
      "citation": "Marôco, J., Marôco, A. L., Campos, J. A. D. B., & Fredricks, J. A. (2016). University student's engagement: Development of the University Student Engagement Inventory (USEI). Psicologia: Reflexão e Crítica, 29, 21. https://doi.org/10.1186/s41155-016-0042-8",
      "license": "CC BY 4.0",
      "version": "1.0",
      "url": "https://doi.org/10.1186/s41155-016-0042-8",
      "domain": "Education"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "usei_l1",
        "usei_l2",
        "usei_l3",
        "usei_l4",
        "usei_l5"
      ],
      "question_head": "usei_head"
    },
    "dimensions": [
      {
        "id": "behavioural",
        "name": "Behavioural Engagement"
      },
      {
        "id": "emotional",
        "name": "Emotional Engagement"
      },
      {
        "id": "cognitive",
        "name": "Cognitive Engagement"
      }
    ],
    "items": [
