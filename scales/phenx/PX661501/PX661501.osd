      "recovery_selfassessment_administrator_flexibility_opt_7": "Don't know",
      "recovery_selfassessment_administrator_treatment_records": "Program participants can easily access their treatment records if they wish. Rate on a 5-point scale (1 = Strongly Disagree; 5 = Strongly agree)",
      "recovery_selfassessment_administrator_treatment_records_opt_1": "1",
      "recovery_selfassessment_administrator_treatment_records_opt_2": "2",
      "recovery_selfassessment_administrator_treatment_records_opt_3": "3",
