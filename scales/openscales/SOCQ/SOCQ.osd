{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Sociotype Questionnaire",
      "code": "SOCQ",
      "abbreviation": "SOCQ",
      "description": "16-item measure of social relationships across four domains. Four subscales: Family (items 1-4), Friends (items 5-8), Acquaintances (items 9-12), Peers/Colleagues (items 13-16). Scored 0 (never) to 5 (always); items 10 and 12 are reverse scored. Higher scores indicate stronger social connections.",
      "citation": "Marijuan, P. C., Montero-Marin, J., Navarro, J., Garcia-Campayo, J., & del Moral, R. (2017). The 'sociotype' construct. PLOS ONE. https://doi.org/10.1371/journal.pone.0185551. [APA PsycTests: https://doi.org/10.1037/t67623-000]",
      "license": "CC BY 4.0",
      "license_explanation": "Items published in Marijuan et al. (2017), PLOS ONE, which publishes under CC BY 4.0.",
      "license_url": "https://doi.org/10.1371/journal.pone.0189568",
      "version": "1.0",
      "url": "https://doi.org/10.1371/journal.pone.0189568",
      "domain": "Social"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-02",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 6,
      "min": 0,
      "max": 5,
      "labels": [
        "likert_0",
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "family",
        "name": "Family",
        "description": "Quality and frequency of family relationships."
      },
      {
        "id": "friends",
        "name": "Friends",
        "description": "Quality and frequency of friendships."
      },
      {
        "id": "acquaintances",
        "name": "Acquaintances",
        "description": "Ease and quality of interactions with acquaintances."
      },
      {
        "id": "peers",
        "name": "Peers",
        "description": "Quality and perceived value in peer relationships."
      }
    ],
    "items": [
      {
