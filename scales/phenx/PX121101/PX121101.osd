  "translations": {
    "en": {
      "instr1_0121101": "The following statements concern your perception about yourself in a variety of situations. Your task is to indicate the strength of your agreement with each statement, utilizing a scale in which 1 denotes strong disagreement, 5 denotes strong agreement, and 2, 3, and 4 represent intermediate judgments. In the boxes after each statement, write a number from 1 to 5 from the following scale:       1. Strongly disagree       2. Disagree       3. Neither disagree nor agree       4. Agree       5. Strongly agreeSelect the number that most closely reflects you on each statement.",
      "sec_i_see_myself_as_someone_who_title": "I see myself as someone who...",
      "talkative": "Is talkative",
      "finds_fault": "Tends to find fault with others",
      "thorough_job": "Does a thorough job",
      "depressed": "Is depressed, blue",
      "original": "Is original, comes up with new ideas",
      "reserved": "Is reserved",
      "helpful": "Is helpful and unselfish with others",
      "somewhat_careless": "Can be somewhat careless",
      "relaxed": "Is relaxed, handles stress well",
      "curious": "Is curious about many different things",
      "energetic": "Is full of energy",
      "starts_quarrels": "Starts quarrels with others",
      "reliable_worker": "Is a reliable worker",
      "tense": "Can be tense",
      "ingenious": "Is ingenious, a deep thinker",
      "generates_enthusiasm": "Generates a lot of enthusiasm",
      "forgiving": "Has a forgiving nature",
      "disorganized": "Tends to be disorganized",
      "worries": "Worries a lot",
      "active_imagination": "Has an active imagination",
      "pxt121101_quiet": "Tends to be quiet",
      "trusting": "Is generally trusting",
      "lazy": "Tends to be lazy",
      "emotionally_stable": "Is emotionally stable, not easily upset",
      "inventive": "Is inventive",
      "assertive": "Has an assertive personality",
      "aloof": "Can be cold and aloof",
      "persevere": "Perseveres until the task is finished",
      "moody": "Can be moody",
      "artistic_experiences": "Values artistic, aesthetic experiences",
      "shy_inhibited": "Is sometimes shy, inhibited",
      "considerate": "Is considerate, kind to almost everyone",
      "efficient": "Does things efficiently",
      "remains_calm": "Remains calm in tense situations",
      "prefers_routine": "Prefers work that is routine",
      "outgoing": "Is outgoing, sociable",
      "rude_to_others": "Is sometimes rude to others",
      "follows_through_on_plans": "Makes plans and follows through on them",
      "gets_nervous": "Gets nervous easily",
      "reflective": "Likes to reflect, play with ideas",
      "few_artistic_interests": "Has few artistic interests",
      "cooperates_with_others": "Likes to cooperate with others",
      "easily_distracted": "Is easily distracted",
      "sophisticated_art_music_literature": "Is sophisticated in art, music or literature",
      "likert_1": "Strongly disagree",
      "likert_2": "Disagree",
      "likert_3": "Neither disagree nor agree",
      "likert_4": "Agree",
      "likert_5": "Strongly agree"
    }
  }
}
