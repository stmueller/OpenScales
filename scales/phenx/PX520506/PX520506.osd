  "translations": {
    "en": {
      "motive_drugs_desc": "What have been the most important reasons:",
      "motive_drugs_marijuana": "for your using marijuana or hashish? (Mark all that apply.)",
      "motive_drugs_amphetamines": "for your taking amphetamines or other stimulant drugs without a doctor's orders? (Mark all that apply.)",
      "motive_drugs_tranquilizers": "for your taking tranquilizers? (Mark all that apply.)",
      "motive_drugs_cocaine": "for your taking cocaine? (Mark all that apply.)",
      "motive_drugs_heroin": "for your using narcotics other than heroin without a doctor's orders? (Mark all that apply.)",
      "opt_1": "To experiment - to see what it's like",
      "opt_2": "To relax or relieve tension",
      "opt_3": "To feel good or get high",
      "opt_4": "To seek deeper insights and understanding",
      "opt_5": "To have a good time with my friends",
      "opt_6": "To fit in with a group I like",
      "opt_7": "To get away from my problems or troubles",
      "opt_8": "Because of boredom, nothing else to do",
      "opt_9": "Because of anger or frustration",
      "opt_10": "To get through the day",
      "opt_11": "To increase the effects of some other drug(s)",
      "opt_12": "To decrease (offset) the effects of some other drug(s)",
      "opt_13": "To get to sleep",
      "opt_14": "Because it tastes good",
      "opt_15": "Because I am \"hooked\"- I feel I have to drink"
    }
  }
}
