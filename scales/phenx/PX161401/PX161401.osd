    "scale_info": {
      "name": "Personal and Family History of Autoimmune and Inflammatory Disorders",
      "code": "PX161401",
      "abbreviation": "PX161401",
      "description": "This protocol includes self-administered questions from the Lupus Family Registry and Repository (LFRR). Respondents answer questions regarding their personal history and family history of various autoimmune and inflammatory disorders.",
