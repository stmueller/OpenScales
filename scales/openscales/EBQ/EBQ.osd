    "scoring": {
      "neg_controllability": {
        "description": "Mean of 4 Negative-Controllability items (1-7). Higher scores indicate stronger beliefs that negative emotions are uncontrollable.",
        "method": "mean_coded",
        "items": [
          "ebq1",
          "ebq5",
          "ebq9",
          "ebq13"
        ]
      },
      "pos_controllability": {
        "description": "Mean of 4 Positive-Controllability items (1-7). Higher scores indicate stronger beliefs that positive emotions are uncontrollable.",
        "method": "mean_coded",
        "items": [
          "ebq2",
          "ebq6",
          "ebq10",
          "ebq14"
        ]
      },
      "neg_usefulness": {
        "description": "Mean of 4 Negative-Usefulness items (1-7). Higher scores indicate stronger beliefs that negative emotions are useless or harmful.",
        "method": "mean_coded",
        "items": [
