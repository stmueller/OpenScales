{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Ritvo Autism Asperger Diagnostic Scale-Revised",
      "code": "RAADSR",
      "abbreviation": "RAADS-R",
      "description": "80-item self-report instrument for diagnosing autism spectrum disorder in adults (18+) with average or above-average intelligence. Four subscales: Social Relatedness, Circumscribed Interests, Language, and Sensory Motor. Total score range 0–240; a score of 65 or greater is consistent with ASD. Designed for clinician-administered use.",
      "citation": "Ritvo, R. A., Ritvo, E. R., Guthrie, D., Ritvo, M. J., Hufnagel, D. H., McMahon, W., Tonge, B., Mataix-Cols, D., Jassi, A., Attwood, T., & Eloff, J. (2011). The Ritvo Autism Asperger Diagnostic Scale-Revised (RAADS-R): A scale to assist the diagnosis of autism spectrum disorder in adults: An international validation study. Journal of Autism and Developmental Disorders, 41(8), 1076–1089. https://doi.org/10.1007/s10803-010-1133-5",
      "license": "free to use",
      "license_explanation": "The RAADS-R is published in open access and freely available for clinical and research use.",
      "license_url": "https://link.springer.com/article/10.1007/s10803-010-1133-5",
      "version": "1.0",
      "url": "https://doi.org/10.1007/s10803-010-1133-5",
      "domain": "Mental Health"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "dimensions": [
      {
        "id": "social_relatedness",
        "name": "Social Relatedness",
        "description": "39 items assessing social interaction, empathy, and interpersonal functioning."
      },
      {
        "id": "circumscribed_interests",
        "name": "Circumscribed Interests",
        "description": "14 items assessing narrow interests, rigidity, and repetitive behaviors."
      },
      {
        "id": "language",
        "name": "Language",
        "description": "7 items assessing pragmatic language and figurative speech comprehension."
      },
      {
        "id": "sensory_motor",
        "name": "Sensory Motor",
        "description": "20 items assessing sensory sensitivities and motor characteristics."
      },
      {
        "id": "total",
        "name": "Total Score",
        "description": "Sum of all 80 items (0–240)."
      }
    ],
