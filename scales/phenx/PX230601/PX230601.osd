    "_scoring_notes": "SCORING KEY FOR THE NIGHT EATING QUESTIONNAIRE(NEQ)A. Items 1, 4 and 14 are reverse scored. Items 1-12 and 14 are summed.B. Item 13 is not included in the total score, but is used to rule out the parasomnia, Nocturnal Sleep Related Eating Disorder (NS-RED).C. Item 15 is not added to the total score, but instead is used as a descriptor of the course of the symptoms.D. Items 16 and 17 are used to confirm the presence of distress or impairment if NES is present.A score of 25 or greater is suggestive of night eating syndrome, and a score of 30 and above is a strong indicator of NES, but we suggest that the answers are reviewed with the patient in an interview before a firm diagnosis is made. For example, many patients with night eating symptoms over-estimate their intake at night. Also, if patients aredepressed in the late evening and have trouble falling asleep, but only minimal night eating, this could inflate their scores.",
    "likert_options": {
      "points": 5,
      "min": 0,
      "max": 4,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5"
      ]
    }
  },
  "translations": {
    "en": {
      "nighteating_howhungry_morning": "How hungry are you usually in the morning?",
      "nighteating_wheneat_firsttime": "When do you usually eat for the first time?",
      "nighteating_cravings_after_supper": "Do you have cravings or urges to eat snacks after supper, but before bedtime?",
      "nighteating_control_eating_betweensupperbedtime": "How much control do you have over your eating between supper and bedtime?",
      "nighteating_howmuch_dailyintake_aftersuppertime": "How much of your daily food intake do you consume after suppertime?",
      "nighteating_howmuch_dailyintake_aftersuppertime_opt_5": "0 - 0%",
      "nighteating_howmuch_dailyintake_aftersuppertime_opt_6": "1 - 1-25% (up to a quarter)",
      "nighteating_howmuch_dailyintake_aftersuppertime_opt_7": "2 - 26-50% (about half)",
      "nighteating_howmuch_dailyintake_aftersuppertime_opt_8": "3 - 51-75% (more than half)",
      "nighteating_howmuch_dailyintake_aftersuppertime_opt_9": "4 - 76 - 100% (almost all)",
      "nighteating_currently_feeling_bluedownindumps": "Are you currently feeling blue or down in the dumps?",
      "nighteating_whenfeelingblue_moodlower": "When you are feeling blue, is your mood lower in the:",
      "nighteating_whenfeelingblue_moodlower_check": "Does your mood does not change during the day",
      "nighteating_whenfeelingblue_moodlower_check_opt_1": "Yes",
      "nighteating_whenfeelingblue_moodlower_check_opt_2": "No",
      "nighteating_howoften_trouble_gettingtosleep": "How often do you have trouble getting to sleep",
      "nighteating_getupmiddleofnight_howoften": "Other than only to use the bathroom, how often do you get up at least once in the middle of the night?",
      "nighteating_cravingsurges_eat_whenup_atnight": "Do you have cravings or urges ot eat snacks when you wake up at night?",
      "nighteating_needtoeat_backtosleep": "Do you need to eat in order to get back to sleep when you awake at night?",
      "nighteating_middleofnight_snack_howoften": "When you get up in the middle of the night, how often do you snack?",
      "nighteating_middleofnight_howaware_ofeating": "When you snack in the middle of the night, how aware are you of your eating?",
      "nighteating_controlover_eating_upatnight": "How much control do you have over your eating while you are up at night?",
      "nighteating_howlong_difficulties_nighteating_years": "How long have your current difficulties with night eating been going on? YEARS",
      "nighteating_howlong_difficulties_nighteating_months": "15a. How long have your current difficulties with night eating been going on?  MONTHS",
      "nighteating_isit_upsetting_toyou": "Is night eating upsetting you?",
      "nighteating_howmuch_lifeaffected": "How much has your night eating affected your life?",
      "likert_1": "0 Not at all",
      "likert_2": "1 A little",
      "likert_3": "2 Somewhat",
      "likert_4": "3 Moderately",
      "likert_5": "4 Very"
    }
  }
