  "translations": {
    "en": {
      "sexual_risk_behavior_male_sex": "Have you ever had any kind of sex",
      "sexual_risk_behavior_male_sex_opt_1": "Yes",
      "sexual_risk_behavior_male_sex_opt_2": "No",
      "sexual_risk_behavior_male_sex_opt_99": "Refused",
      "sexual_risk_behavior_male_sex_opt_77": "Don't Know",
      "sexual_risk_behavior_male_women_vaginal": "Have you ever had vaginal sex, also called sexual intercourse, with a woman? This means putting your penis in a woman's vagina.",
      "sexual_risk_behavior_male_women_vaginal_opt_1": "Yes",
      "sexual_risk_behavior_male_women_vaginal_opt_2": "No",
      "sexual_risk_behavior_male_women_vaginal_opt_99": "Refused",
      "sexual_risk_behavior_male_women_vaginal_opt_77": "Don't Know",
      "sexual_risk_behavior_male_women_oral": "Have you ever performed oral sex on a woman? This means putting your mouth on a woman's vagina or genitals.",
      "sexual_risk_behavior_male_women_oral_opt_1": "Yes",
      "sexual_risk_behavior_male_women_oral_opt_2": "No",
      "sexual_risk_behavior_male_women_oral_opt_99": "Refused",
      "sexual_risk_behavior_male_women_oral_opt_77": "Don't Know",
      "sexual_risk_behavior_male_women_anal": "Have you ever had anal sex with a woman? This means contact between your penis and a woman's anus or butt.",
