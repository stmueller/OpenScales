  "translations": {
    "en": {
      "long_covid_symptoms_pediatric_symptoms_covid_how_much_agree_recovered": "If you have had symptoms of COVID-19, how much do you agree with the following statement? \\I have fully recovered from COVID-19\\\"\"",
      "long_covid_symptoms_pediatric_symptoms_covid_how_much_agree_recovered_opt_1": "0",
      "long_covid_symptoms_pediatric_symptoms_covid_how_much_agree_recovered_opt_2": "1",
      "long_covid_symptoms_pediatric_symptoms_covid_how_much_agree_recovered_opt_3": "2",
      "long_covid_symptoms_pediatric_symptoms_covid_how_much_agree_recovered_opt_4": "3",
      "long_covid_symptoms_pediatric_symptoms_covid_how_much_agree_recovered_opt_5": "4",
      "long_covid_symptoms_pediatric_symptoms_covid_how_much_agree_recovered_opt_6": "5",
      "long_covid_symptoms_pediatric_symptoms_covid_how_much_agree_recovered_opt_7": "6",
      "long_covid_symptoms_pediatric_symptoms_covid_how_much_agree_recovered_opt_8": "7",
      "long_covid_symptoms_pediatric_symptoms_covid_how_much_agree_recovered_opt_9": "8",
      "long_covid_symptoms_pediatric_symptoms_covid_how_much_agree_recovered_opt_10": "9",
      "long_covid_symptoms_pediatric_symptoms_covid_how_much_agree_recovered_opt_11": "10",
      "long_covid_symptoms_pediatric_how_feel_right_now": "How do you feel right now?",
      "long_covid_symptoms_pediatric_how_feel_right_now_opt_1": "I feel as healthy as normal",
      "long_covid_symptoms_pediatric_how_feel_right_now_opt_2": "I am not feeling quite right",
      "long_covid_symptoms_pediatric_do_you_have_fever": "Do you have a fever?",
      "long_covid_symptoms_pediatric_do_you_have_chills_shiver": "Do you feel chills or shivers (feel too cold)?",
      "long_covid_symptoms_pediatric_what_your_temperature": "If you are able to measure it, what is your temperature?",
      "long_covid_symptoms_pediatric_persistent_cough": "Do you have a persistent cough (coughing a lot for more than an hour, or 3 or more coughing episodes in 24 hours)?",
      "long_covid_symptoms_pediatric_experiencing_unusual_fatigue_tiredness": "Are you experiencing unusual fatigue/tiredness?",
      "long_covid_symptoms_pediatric_experiencing_unusual_fatigue_tiredness_opt_1": "No",
      "long_covid_symptoms_pediatric_experiencing_unusual_fatigue_tiredness_opt_2": "Mild fatigue",
      "long_covid_symptoms_pediatric_experiencing_unusual_fatigue_tiredness_opt_3": "Severe fatigue - I struggle to get out of bed",
      "long_covid_symptoms_pediatric_experiencing_problems_sleep": "Are you experiencing problems with your sleep, including getting to sleep, waking in the night or waking early?",
      "long_covid_symptoms_pediatric_experiencing_problems_sleep_describe": "Are you experiencing problems with your sleep, including getting to sleep, waking in the night or waking early? If yes, please describe",
      "long_covid_symptoms_pediatric_experiencing_shortness_breath": "Are you experiencing unusual shortness of breath?",
      "long_covid_symptoms_pediatric_experiencing_shortness_breath_opt_1": "No",
      "long_covid_symptoms_pediatric_experiencing_shortness_breath_opt_2": "Yes, mild symptoms - slight shortness of breath during ordinary activity",
      "long_covid_symptoms_pediatric_experiencing_shortness_breath_opt_3": "Yes, significant symptoms - breathing is comfortable only at rest",
      "long_covid_symptoms_pediatric_experiencing_shortness_breath_opt_4": "Yes, severe symptoms - breathing is difficult even at rest",
      "long_covid_symptoms_pediatric_current_symptoms": "What are your current symptoms? (Please tick all that apply)",
      "long_covid_symptoms_pediatric_current_symptoms_opt_1": "loss of smell/taste",
      "long_covid_symptoms_pediatric_current_symptoms_opt_2": "unusually hoarse voice",
      "long_covid_symptoms_pediatric_current_symptoms_opt_3": "unusual chest pain or tightness in your chest",
      "long_covid_symptoms_pediatric_current_symptoms_opt_4": "unusual abdominal pain",
      "long_covid_symptoms_pediatric_current_symptoms_opt_5": "diarrhoea",
      "long_covid_symptoms_pediatric_current_symptoms_opt_6": "headache",
      "long_covid_symptoms_pediatric_current_symptoms_opt_7": "confusion, disorientation or drowsiness",
      "long_covid_symptoms_pediatric_current_symptoms_opt_8": "unusual eye-soreness or discomfort (e.g. light sensitivity, excessive tears, or pink/red eye)",
      "long_covid_symptoms_pediatric_current_symptoms_opt_9": "skipping meals",
      "long_covid_symptoms_pediatric_current_symptoms_opt_10": "dizziness or light-headedness",
      "long_covid_symptoms_pediatric_current_symptoms_opt_11": "sore throat",
      "long_covid_symptoms_pediatric_current_symptoms_opt_12": "unusual strong muscle pains",
      "long_covid_symptoms_pediatric_current_symptoms_opt_13": "earache or ringing in your ears (tinnitus)",
      "long_covid_symptoms_pediatric_current_symptoms_opt_14": "raised, red, itchy welts on the skin or sudden swelling of the face or lips",
      "long_covid_symptoms_pediatric_current_symptoms_opt_15": "red/purple sores or blisters on your feet, including your toes",
      "long_covid_symptoms_pediatric_current_symptoms_opt_16": "no symptoms",
      "long_covid_symptoms_pediatric_current_symptoms_opt_17": "other",
      "long_covid_symptoms_pediatric_current_symptoms_other": "What are your current symptoms? (Please tick all that apply) Are there other important symptoms you want to share with us?",
      "long_covid_symptoms_pediatric_start_period_longer_week_no_symptom": "Since the start of your COVID-19 symptoms, have you had a period longer than one week with none of the above symptoms at all (where you were back to how you were pre-COVID)",
      "long_covid_symptoms_pediatric_start_period_longer_week_no_symptom_opt_1": "Yes (I have had a period of one week or more since my test with none of the above symptoms)",
      "long_covid_symptoms_pediatric_start_period_longer_week_no_symptom_opt_2": "No (My symptoms have been continuous since Covid test)",
      "long_covid_symptoms_pediatric_start_period_longer_week_no_symptom_opt_3": "Not applicable",
      "opt_1": "Yes",
      "opt_2": "No"
    }
  }
}
