{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Self-Compassion Scale",
      "code": "SCS",
      "abbreviation": "SCS",
      "description": "26-item self-report measure of self-compassion across six subscales: Self-Kindness, Self-Judgment (R), Common Humanity, Isolation (R), Mindfulness, and Over-Identification (R). 5-point Likert scale (1 = Almost never, 5 = Almost always). Total score is the mean of the six subscale means after reverse-scoring the three negative subscales. Range 1–5.",
      "citation": "Neff, K. D. (2003). Development and validation of a scale to measure self-compassion. Self and Identity, 2, 223–250. https://doi.org/10.1080/15298860309027",
      "license": "free to use",
      "license_explanation": "The SCS is freely available for research and educational use from https://self-compassion.org/",
      "license_url": "https://self-compassion.org/the-scales/",
      "version": "1.0",
      "url": "https://self-compassion.org/the-scales/",
      "domain": "Self & Coping"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "scs_r1",
        "scs_r2",
        "scs_r3",
        "scs_r4",
        "scs_r5"
      ],
      "question_head": "scs_head"
    },
    "dimensions": [
      {
        "id": "self_kindness",
        "name": "Self-Kindness",
        "description": "Items 5, 12, 19, 23, 26. Positive subscale."
      },
      {
        "id": "self_judgment",
        "name": "Self-Judgment",
        "description": "Items 1, 8, 11, 16, 21. Negative subscale (reverse-scored)."
      },
      {
        "id": "common_humanity",
        "name": "Common Humanity",
        "description": "Items 3, 7, 10, 15. Positive subscale."
      },
      {
        "id": "isolation",
        "name": "Isolation",
        "description": "Items 4, 13, 18, 25. Negative subscale (reverse-scored)."
      },
      {
        "id": "mindfulness",
        "name": "Mindfulness",
        "description": "Items 9, 14, 17, 22. Positive subscale."
      },
      {
        "id": "over_identification",
        "name": "Over-Identification",
        "description": "Items 2, 6, 20, 24. Negative subscale (reverse-scored)."
      },
      {
        "id": "total",
        "name": "Total Self-Compassion",
        "description": "Mean of all 26 items after reverse-scoring negative subscales (range 1–5)."
      }
    ],
