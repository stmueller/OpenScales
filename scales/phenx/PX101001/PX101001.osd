    "scale_info": {
      "name": "Male Sexual Function",
      "code": "PX101001",
      "abbreviation": "PX101001",
      "description": "The participant answers whether he has had difficulty with erections and sexual function during the past 4 weeks.",
      "domain": "Education",
      "citation": "Berner, M. M., Kriston, L., & Harms, A. (2006). Efficacy of PDE-5-inhibitors for erectile dysfunction. A comparative meta-analysis of fixed-dose regimen randomized controlled trials administering the International Index of Erectile Function in broad-spectrum populations. International Journal of Impotence Research, 18 (3), 229-235. [PhenX: https://www.phenxtoolkit.org/protocols/view/101001]",
