  "translations": {
    "en": {
      "likert_1": "Strongly Disagree",
      "likert_2": "Disagree",
      "likert_3": "Somewhat Disagree",
      "likert_4": "Somewhat Agree",
      "likert_5": "Agree",
      "likert_6": "Strongly Agree",
      "question_head": "Please indicate how much you agree or disagree with each of the following statements.",
      "mi1": "I usually try to find a couple of good options and then choose between them.",
      "mi2": "At some point you need to make a decision about things.",
      "mi3": "In life I try to make the most of whatever path I take.",
      "mi4": "There are usually several good options in a decision situation.",
      "mi5": "I try to gain plenty of information before I make a decision, but then I go ahead and make it.",
      "mi6": "Good things can happen even when things don't go right at first.",
      "mi7": "I can't possibly know everything before making a decision.",
      "mi8": "All decisions have pros and cons.",
      "mi9": "I know that if I make a mistake in a decision that I can go “back to the drawing board.”",
      "mi10": "I accept that life often has uncertainty.",
      "mi11": "I usually have a hard time making even simple decisions.",
      "mi12": "I am usually worried about making a wrong decision.",
      "mi13": "I often wonder why decisions can't be more easy.",
      "mi14": "I often put off making a difficult decision until a deadline.",
      "mi15": "I often experience buyer's remorse.",
      "mi16": "I often think about changing my mind after I have already made my decision.",
      "mi17": "The hardest part of making a decision is knowing I will have to leave the item I didn't choose behind.",
      "mi18": "I often change my mind several times before making a decision.",
      "mi19": "It's hard for me to choose between two good alternatives.",
      "mi20": "Sometimes I procrastinate in deciding even if I have a good idea of what decision I will make.",
      "mi21": "I find myself often faced with difficult decisions.",
      "mi22": "I do not agonize over decisions.",
      "mi23": "I can't come to a decision unless I have carefully considered all of my options.",
      "mi24": "I take time to read the whole menu when dining out.",
      "mi25": "I will continue shopping for an item until it reaches all of my criteria.",
      "mi26": "I usually continue to search for an item until it reaches my expectations.",
      "mi27": "When shopping, I plan on spending a lot of time looking for something.",
      "mi28": "When shopping, if I can't find exactly what I'm looking for, I will continue to search for it.",
      "mi29": "I find myself going to many different stores before finding the thing I want.",
      "mi30": "When shopping for something, I don't mind spending several hours looking for it.",
      "mi31": "I take the time to consider all alternatives before making a decision.",
      "mi32": "When I see something that I want, I always try to find the best deal before purchasing it.",
      "mi33": "If a store doesn't have exactly what I'm shopping for, then I will go somewhere else.",
      "mi34": "I just won't make a decision until I am comfortable with the process."
    }
  }
}
