  "translations": {
    "en": {
      "instructions": "To be completed by physician who signed the death certificate and/or the patient's physician.",
      "physician_familiar_with_event": "Are you familiar with the events surrounding the decedent's death?",
      "physician_familiar_with_event_opt_1": "Yes",
      "physician_familiar_with_event_opt_2": "No",
      "physician_witness_death": "Did you witness the death?",
      "physician_witness_death_opt_1": "Yes",
      "physician_witness_death_opt_2": "No",
      "pain": "Was there any pain in the chest, left arm or shoulder or jaw within 72 hours of death?",
      "pain_include_chest": "Did the pain include the chest?",
      "pain_cardiac_origin": "Did you think this pain was of a cardiac origin?",
      "pain_cardiac_origin_specify_cause": "Did you think this pain was of a cardiac origin? If no, specify what you think was the cause.",
      "cpr": "Was cardiopulmonary resuscitation (CPR) and/or cardioversion performed within 24 hours of death?",
      "symptom_time": "Please give time between onset of acute symptoms to death. (We are defining death as the point where spontaneous breathing ceased and the patient never recovered).",
      "symptom_time_opt_1": "More than three days",
      "symptom_time_opt_2": "Two - three days",
      "symptom_time_opt_3": "One day",
      "symptom_time_opt_4": "At least 12 hours, but less than 24 hours",
      "symptom_time_opt_5": "At least 4 hours, but less than 12 hours",
      "symptom_time_opt_6": "At least 1 hour, but less than 4 hours",
      "symptom_time_opt_7": "Less than 1 hour",
      "symptom_time_opt_8": "Death instantaneous, no symptoms",
      "symptom_time_opt_9": "Unknown",
      "chd": "Would you classify the decedent's cause of death as due to Coronary Heart Disease (CHD)?",
      "location": "Location of death",
      "location_opt_1": "Out-of-Hospital",
      "location_opt_2": "Emergency Room (not dead on arrival- DOA)",
      "location_opt_3": "In Hospital",
      "location_opt_4": "Nursing Home, Skilled Nursing Facility (SNF), or Extended Care Facility (ECF)",
      "location_opt_5": "Other",
      "location_other_specify": "Location of death",
      "witness_record": "Was the death witnessed?",
      "witness_record_opt_1": "Yes",
      "witness_record_opt_2": "No",
      "witness_record_opt_3": "Unknown",
      "cause": "Multi-Ethnic Study of Atherosclerosis (MESA) classification of underlying cause of death (choose one)",
      "cause_opt_1": "Atherosclerotic coronary heart disease",
      "cause_opt_2": "Stroke",
      "cause_opt_3": "Atherosclerotic disease other than coronary disease or stroke",
      "cause_opt_4": "Other cardiovascular disease, not defined above",
      "cause_opt_5": "Non-cardiovascular disease",
      "cause_opt_6": "Unknown because death certificate unavailable",
      "cause_other_atherosclerotic_disease_specify": "Multi-Ethnic Study of Atherosclerosis (MESA) classification of underlying cause of death: Atherosclerotic disease other than coronary disease or stroke (specify)",
      "cause_other_cardiovascular_disease_specify": "Multi-Ethnic Study of Atherosclerosis (MESA) classification of underlying cause of death: Other cardiovascular disease, not defined above (specify)",
      "cause_noncardiovascular_disease_specify": "Multi-Ethnic Study of Atherosclerosis (MESA) classification of underlying cause of death: Non-cardiovascular disease (specify)",
      "fatal_chd_type": "Type of fatal coronary heart disease.",
      "fatal_chd_type_opt_1": "Definite fatal myocardial infarction (MI) (no known non-atherosclerotic cause and definite myocardial infarction within 4 weeks of death)",
      "fatal_chd_type_opt_2": "Definite fatal coronary heart disease (CHD) (no known non-atherosclerotic cause, and one or both of the following: chest pain within 72 hours of death or a history of chronic ischemic heart disease)",
      "fatal_chd_type_opt_3": "Possible fatal coronary heart disease (CHD) (no known non-atherosclerotic cause, and death certificate underlying cause: I20-25, I46, I51.6, R96 or R98-99)",
      "symptom_time_estimated": "Estimated time between onset of acute cardiac symptoms and death.",
      "symptom_time_estimated_opt_1": "Less than five minutes",
      "symptom_time_estimated_opt_2": "Five minutes to one hour",
      "symptom_time_estimated_opt_3": "One hour to 24 hours",
      "symptom_time_estimated_opt_4": "More than 24 hours",
      "symptom_time_estimated_opt_5": "Unknown",
      "mechanism": "Mechanism of death in patients dying of cardiovascular causes (check all that apply).",
      "mechanism_opt_1": "Primary arrhythmic death",
      "mechanism_opt_2": "Secondary arrhythmic/mechanical death",
      "mechanism_opt_3": "Congestive heart failure (CHF)",
      "mechanism_opt_4": "Cardiac procedure such as coronary artery bypass graft (CABG) or angioplasty",
      "mechanism_opt_5": "Hemorrhage from thrombolytic therapy",
      "mechanism_opt_6": "Other",
      "mechanism_opt_7": "Unknown or Uncertain",
      "mechanism_other_specify": "Mechanism of death in patients dying of cardiovascular causes",
      "opt_1": "Yes",
      "opt_2": "No",
      "opt_3": "Uncertain"
    }
  }
