      "burden_assessment_trapped_opt_4": "A lot",
      "burden_assessment_trapped_opt_5": "NA",
      "burden_assessment_upset": "Because of name's illness, to what extent have you: were upset about how much (name) had changed from his or her former self",
      "burden_assessment_upset_opt_1": "Not at all",
      "burden_assessment_upset_opt_2": "A little",
      "burden_assessment_upset_opt_3": "Some",
