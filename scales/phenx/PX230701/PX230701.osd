  "translations": {
    "en": {
      "weightchange_goals_tryingtodo_yourweight": "Which of the following are you trying to do about your weight?",
      "weightchange_goals_tryingtodo_yourweight_opt_1": "A. Lose weight",
      "weightchange_goals_tryingtodo_yourweight_opt_2": "B. Gain weight",
      "weightchange_goals_tryingtodo_yourweight_opt_3": "C. Stay the same weight",
      "weightchange_goals_tryingtodo_yourweight_opt_4": "D. I am not trying to do anything about my weight",
      "weightchange_goals_describe_your_weight": "How do you describe your weight?",
      "weightchange_goals_describe_your_weight_opt_1": "A. Very underweight",
      "weightchange_goals_describe_your_weight_opt_2": "B. Slightly underweight",
      "weightchange_goals_describe_your_weight_opt_3": "C. About the right weight",
      "weightchange_goals_describe_your_weight_opt_4": "D. Slightly overweight",
      "weightchange_goals_describe_your_weight_opt_5": "E. Very overweight"
