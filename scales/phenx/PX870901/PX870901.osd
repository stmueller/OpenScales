  "translations": {
    "en": {
      "transition_readiness_understand_behaviors_cause_pain_episoderecord_id": "Record ID",
      "sec_div_class_rich_text_field_label_p_span_s_title": "<div class=\"rich-text-field-label\"><p><span style=\"text-decoration: underline;\">Independent Living Skill Set</span></p></div>",
      "health_care_section_description": "How much do you know about sickle cell? Do you know how to manage your own health care? How to talk to doctors? Take a few minutes to identify your areas of strength and highlight where there is room to grow!",
      "transition_readiness_understand_behaviors_cause_pain_episode": "I understand behaviors that can cause a pain episode.",
      "transition_readiness_understand_behaviors_cause_pain_episode_opt_1": "Strongly Agree",
      "transition_readiness_understand_behaviors_cause_pain_episode_opt_2": "Somewhat Agree",
      "transition_readiness_understand_behaviors_cause_pain_episode_opt_3": "Neither Agree nor Disagree",
      "transition_readiness_understand_behaviors_cause_pain_episode_opt_4": "Somewhat Disagree",
      "transition_readiness_understand_behaviors_cause_pain_episode_opt_5": "Strongly Disagree",
      "transition_readiness_understand_behaviors_cause_pain_episode_opt_6": "Not Applicable",
      "transition_readiness_understand_behaviors_cause_pain_episode_comments": "I understand behaviors that can cause a pain episode. Comments:",
      "transition_readiness_answer_doctors_questions_during_clinical_visits": "I can answer my doctor's questions during my clinic visits.",
      "transition_readiness_answer_doctors_questions_during_clinical_visits_opt_1": "Strongly Agree",
      "transition_readiness_answer_doctors_questions_during_clinical_visits_opt_2": "Somewhat Agree",
      "transition_readiness_answer_doctors_questions_during_clinical_visits_opt_3": "Neither Agree nor Disagree",
      "transition_readiness_answer_doctors_questions_during_clinical_visits_opt_4": "Somewhat Disagree",
      "transition_readiness_answer_doctors_questions_during_clinical_visits_opt_5": "Strongly Disagree",
      "transition_readiness_answer_doctors_questions_during_clinical_visits_opt_6": "Not Applicable",
      "transition_readiness_answer_doctors_questions_during_clinical_visits_comments": "I can answer my doctor's questions during my clinic visits. Comments:",
      "transition_readiness_keep_track_medical_appointments": "I keep track of my medical appointments.",
      "transition_readiness_keep_track_medical_appointments_opt_1": "Strongly Agree",
      "transition_readiness_keep_track_medical_appointments_opt_2": "Somewhat Agree",
      "transition_readiness_keep_track_medical_appointments_opt_3": "Neither Agree nor Disagree",
