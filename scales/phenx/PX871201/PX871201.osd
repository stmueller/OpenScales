  "translations": {
    "en": {
      "prolonged_grief_disorder_lost_someone_significant": "Have you lost someone significant to you?",
      "prolonged_grief_disorder_lost_someone_significant_opt_1": "Yes",
      "prolonged_grief_disorder_lost_someone_significant_opt_2": "No",
      "prolonged_grief_disorder_months_significant_other_died": "How many months has it been since your significant other died?",
      "sec_for_each_item_below_please_indicate_how__title": "For each item below, please indicate how you currently feel. Since the death, or as a result of the death...",
      "prolonged_grief_disorder_longing_person_died": "Do you feel yourself longing or yearning for the person who died?",
      "prolonged_grief_disorder_longing_person_died_opt_1": "Not at all",
      "prolonged_grief_disorder_longing_person_died_opt_2": "Slightly",
      "prolonged_grief_disorder_longing_person_died_opt_3": "Somewhat",
      "prolonged_grief_disorder_longing_person_died_opt_4": "Quite a bit",
      "prolonged_grief_disorder_longing_person_died_opt_5": "Overwhelmingly",
      "prolonged_grief_disorder_trouble_doing_normal_things": "Do you have trouble doing the things you normally do because you are thinking so much about the person who died?",
      "prolonged_grief_disorder_trouble_doing_normal_things_opt_1": "Not at all",
      "prolonged_grief_disorder_trouble_doing_normal_things_opt_2": "Slightly",
      "prolonged_grief_disorder_trouble_doing_normal_things_opt_3": "Somewhat",
      "prolonged_grief_disorder_trouble_doing_normal_things_opt_4": "Quite a bit",
      "prolonged_grief_disorder_trouble_doing_normal_things_opt_5": "Overwhelmingly",
      "prolonged_grief_disorder_confused_role_life": "Do you feel confused about your role in life or feel like you don't know who you are any more (i.e., feeling like that a part of you has died)?",
      "prolonged_grief_disorder_confused_role_life_opt_1": "Not at all",
      "prolonged_grief_disorder_confused_role_life_opt_2": "Slightly",
      "prolonged_grief_disorder_confused_role_life_opt_3": "Somewhat",
      "prolonged_grief_disorder_confused_role_life_opt_4": "Quite a bit",
      "prolonged_grief_disorder_confused_role_life_opt_5": "Overwhelmingly",
      "prolonged_grief_disorder_trouble_believe_person_really_gone": "Do you have trouble believing that the person who died is really gone?",
      "prolonged_grief_disorder_trouble_believe_person_really_gone_opt_1": "Not at all",
      "prolonged_grief_disorder_trouble_believe_person_really_gone_opt_2": "Slightly",
      "prolonged_grief_disorder_trouble_believe_person_really_gone_opt_3": "Somewhat",
      "prolonged_grief_disorder_trouble_believe_person_really_gone_opt_4": "Quite a bit",
      "prolonged_grief_disorder_trouble_believe_person_really_gone_opt_5": "Overwhelmingly",
      "prolonged_grief_disorder_avoid_reminder_person_really_gone": "Do you avoid reminders that the person who died is really gone?",
      "prolonged_grief_disorder_avoid_reminder_person_really_gone_opt_1": "Not at all",
      "prolonged_grief_disorder_avoid_reminder_person_really_gone_opt_2": "Slightly",
      "prolonged_grief_disorder_avoid_reminder_person_really_gone_opt_3": "Somewhat",
      "prolonged_grief_disorder_avoid_reminder_person_really_gone_opt_4": "Quite a bit",
      "prolonged_grief_disorder_avoid_reminder_person_really_gone_opt_5": "Overwhelmingly",
      "prolonged_grief_disorder_emotional_pain": "Do you feel emotional pain (e.g., anger, bitterness, sorrow) related to the death?",
      "prolonged_grief_disorder_emotional_pain_opt_1": "Not at all",
      "prolonged_grief_disorder_emotional_pain_opt_2": "Slightly",
      "prolonged_grief_disorder_emotional_pain_opt_3": "Somewhat",
      "prolonged_grief_disorder_emotional_pain_opt_4": "Quite a bit",
      "prolonged_grief_disorder_emotional_pain_opt_5": "Overwhelmingly",
      "prolonged_grief_disorder_trouble_engage_life": "Do you feel that you have trouble re-engaging in life (e.g., problems engaging with friends, pursuing interests, planning for the future)?",
      "prolonged_grief_disorder_trouble_engage_life_opt_1": "Not at all",
      "prolonged_grief_disorder_trouble_engage_life_opt_2": "Slightly",
      "prolonged_grief_disorder_trouble_engage_life_opt_3": "Somewhat",
      "prolonged_grief_disorder_trouble_engage_life_opt_4": "Quite a bit",
      "prolonged_grief_disorder_trouble_engage_life_opt_5": "Overwhelmingly",
      "prolonged_grief_disorder_emotionally_numb_detach": "Do you feel emotionally numb or detached from others?",
      "prolonged_grief_disorder_emotionally_numb_detach_opt_1": "Not at all",
      "prolonged_grief_disorder_emotionally_numb_detach_opt_2": "Slightly",
      "prolonged_grief_disorder_emotionally_numb_detach_opt_3": "Somewhat",
      "prolonged_grief_disorder_emotionally_numb_detach_opt_4": "Quite a bit",
      "prolonged_grief_disorder_emotionally_numb_detach_opt_5": "Overwhelmingly",
      "prolonged_grief_disorder_life_meaningless": "Do you feel that life is meaningless without the person who died?",
      "prolonged_grief_disorder_life_meaningless_opt_1": "Not at all",
      "prolonged_grief_disorder_life_meaningless_opt_2": "Slightly",
      "prolonged_grief_disorder_life_meaningless_opt_3": "Somewhat",
      "prolonged_grief_disorder_life_meaningless_opt_4": "Quite a bit",
      "prolonged_grief_disorder_life_meaningless_opt_5": "Overwhelmingly",
      "prolonged_grief_disorder_alone_without_deceased": "Do you feel alone or lonely without the deceased?",
      "prolonged_grief_disorder_alone_without_deceased_opt_1": "Not at all",
      "prolonged_grief_disorder_alone_without_deceased_opt_2": "Slightly",
      "prolonged_grief_disorder_alone_without_deceased_opt_3": "Somewhat",
      "prolonged_grief_disorder_alone_without_deceased_opt_4": "Quite a bit",
      "prolonged_grief_disorder_alone_without_deceased_opt_5": "Overwhelmingly",
      "prolonged_grief_disorder_significant_impariment_function": "Have the symptoms above caused significant impairment in social, occupational, or other important areas of functioning?",
      "prolonged_grief_disorder_significant_impariment_function_opt_1": "Yes",
      "prolonged_grief_disorder_significant_impariment_function_opt_2": "No",
      "prolonged_grief_disorder_outro": "Scoring: A summary score for the symptom items is calculated by totaling each individual item score from 1 (not at all) to 5 (overwhelmingly) across items 3 through 12.  Symptom scores can range from 10 to 50. A score of 30 or greater indicates syndromal-level PGD."
    }
  }
}
