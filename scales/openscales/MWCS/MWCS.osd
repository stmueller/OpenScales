{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Multidimensional Workplace Compassion Scale",
      "code": "MWCS",
      "abbreviation": "MWCS",
      "description": "12-item self-report measure of other-oriented/expressed compassion in the workplace. Assesses four components of workplace compassion: noticing (recognizing distress), empathizing (feeling distress), sensemaking (understanding context), and acting (responding to distress).",
      "citation": "Mandliya, A., & Pandey, J. (2023). The development and validation of multidimensional workplace compassion scale: Linking its conceptualization and measurement. Frontiers in Psychology, 14, 1142309. https://doi.org/10.3389/fpsyg.2023.1142309",
      "license": "CC BY 4.0",
      "license_explanation": "Published in Frontiers in Psychology under Creative Commons Attribution 4.0 International License.",
      "license_url": "https://creativecommons.org/licenses/by/4.0/",
      "version": "1.0",
      "url": "https://doi.org/10.3389/fpsyg.2023.1142309",
      "domain": "Work"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 7,
      "min": 1,
      "max": 7,
      "labels": [
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4",
        "likert_5",
        "likert_6",
        "likert_7"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "noticing",
        "name": "Noticing",
        "description": "Recognizing and detecting the distress or pain of co-workers."
      },
      {
        "id": "empathizing",
        "name": "Empathizing",
        "description": "Feeling the distress experienced by others in the workplace."
      },
      {
        "id": "sensemaking",
        "name": "Sensemaking",
        "description": "Understanding the context and circumstances of others' distress."
      },
      {
        "id": "acting",
        "name": "Acting",
        "description": "Taking action to help those in distress in the workplace."
      }
    ],
    "items": [
