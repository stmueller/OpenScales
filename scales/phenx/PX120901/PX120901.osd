      "dominate_conversation_opt_3": "Slightly disagree",
      "dominate_conversation_opt_4": "Definitely disagree",
      "fascinated_by_numbers": "I am fascinated by numbers.",
      "fascinated_by_numbers_opt_1": "Definitely agree",
