          "kdqol36_symp_grid_8": -1,
          "kdqol36_symp_grid_9": -1,
          "kdqol36_symp_grid_10": -1,
          "kdqol36_symp_grid_11": -1,
          "kdqol36_symp_grid_12": -1
        },
        "transform": [
          {
