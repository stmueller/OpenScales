  "translations": {
    "en": {
      "instructions_050201": "Think about your usual eating habits over the past month.",
      "orange_juice_frequency": "How often do you drink 100% orange juice? Do not count fruit drinks like Tang� and Sunny D�.",
      "orange_juice_quantity": "Each time you drink orange juice, how much do you usually drink?",
      "orange_juice_calcium_fortified_frequency": "How often is the orange juice you drink calcium fortified?",
      "orange_juice_calcium_fortified_frequency_opt_1": "Almost never or never",
      "orange_juice_calcium_fortified_frequency_opt_2": "Sometimes",
      "orange_juice_calcium_fortified_frequency_opt_3": "Almost always or always",
      "orange_juice_calcium_fortified_frequency_opt_4": "Don't know",
      "milk_frequency": "How often do you drink milk as a beverage (NOT in cereal)?",
      "milk_frequency_opt_1": "Never or less than 1 time per month",
      "milk_frequency_opt_2": "1 time per month",
      "milk_frequency_opt_3": "2-3 times per month",
      "milk_frequency_opt_4": "1-2 times per week",
      "milk_frequency_opt_5": "3-4 times per week",
      "milk_frequency_opt_6": "5-6 times per week",
      "milk_frequency_opt_7": "1 time per day",
      "milk_frequency_opt_8": "2 times per day",
      "milk_frequency_opt_9": "3 or more times per day",
      "milk_quantity": "Each time you drink milk, how much do you usually drink?",
      "calcium_intake_image001": "8 ounce glass of milk - image",
      "milk_variety": "What kind of milk do you usually drink?",
      "milk_variety_opt_1": "Whole milk",
      "milk_variety_opt_2": "2% fat milk",
      "milk_variety_opt_3": "1% fat milk",
      "milk_variety_opt_4": "Skim or nonfat milk",
      "milk_variety_opt_5": "Chocolate milk",
      "milk_variety_opt_6": "Soy or rice milk",
      "milk_variety_opt_7": "Don't know",
      "yogurt_frequency": "How often do you eat yogurt?",
      "cereal_frequency": "How often do you eat cold cereal?",
      "cereal_frequency_opt_1": "Never or less than one time per month",
      "cereal_frequency_opt_2": "1 time per month",
      "cereal_frequency_opt_3": "2-3 times per month",
      "cereal_frequency_opt_4": "1-2 times per week",
      "cereal_frequency_opt_5": "3-4 times per week",
      "cereal_frequency_opt_6": "5-6 times per week",
      "cereal_frequency_opt_7": "1 time per day",
      "cereal_frequency_opt_8": "2 or more times per day",
      "cereal_quantity": "Each time you eat cold cereal, how much do you usually eat?",
      "cereal_quantity_opt_1": "Less than 2 cups",
      "cereal_quantity_opt_2": "2 cups",
      "cereal_quantity_opt_3": "More than 2 cups",
      "calcium_intake_image002": "Two cups of cold cereal - image",
      "mexican_food_frequency": "Think about your usual eating habits over the past month.  How often do you eat Mexican foods such as tacos, tostados, burritos, tamales, fajitas, enchiladas, quesadillas, or chimichangas?",
      "mexican_food_quantity": "Each time you eat Mexican foods, how much do you usually eat?",
      "mexican_food_quantity_opt_1": "Less than 1 taco or burrito",
      "mexican_food_quantity_opt_2": "1 taco or burrito",
      "mexican_food_quantity_opt_3": "More than 1 taco or burrito",
      "pizza_frequency": "How often do you eat pizza?",
      "pizza_quantity": "Think about your usual eating habits over the past month.  Each time you eat pizza, how much do you usually eat?",
      "pizza_quantity_opt_1": "1 slice",
      "pizza_quantity_opt_2": "2 slices or one mini pizza",
      "pizza_quantity_opt_3": "3 or more slices 5",
      "macaroni_cheese_frequency": "How often do you eat macaroni and cheese?",
      "macaroni_cheese_quantity": "Each time you eat macaroni and cheese, how much do you usually eat?",
      "macaroni_cheese_quantity_opt_1": "Less than 1 cup",
      "macaroni_cheese_quantity_opt_2": "1 cup (SEE THE PICTURE BELOW)",
      "macaroni_cheese_quantity_opt_3": "More than 1 cup",
      "calcium_intake_image003": "One cup of macaroni and cheese - image",
      "ice_cream_frequency": "How often do you eat ice cream, ice cream bars, milk shakes, or frozen yogurt?",
      "ice_cream_quantity": "Each time you eat ice cream, ice cream bars, milkshakes, or frozen yogurt, how much do you usually eat?",
      "ice_cream_quantity_opt_1": "Less than 1 cup",
      "ice_cream_quantity_opt_2": "1 cup (2 scoops)",
      "ice_cream_quantity_opt_3": "More than 1 cup",
      "cheese_frequency": "How often do you eat cheese (including on salads or in sandwiches or subs)?",
      "cheese_quantity": "Think about your usual eating habits over the past month.  Each time you eat cheese, how much do you usually eat?",
      "cheese_quantity_opt_1": "Less than 1 slice",
      "cheese_quantity_opt_2": "1 slice",
      "cheese_quantity_opt_3": "More than 1 slice",
      "bread_frequency": "Think about your usual eating habits over the past month.  How often do you eat bread, toast or dinner rolls, including bread as part of a sandwich (DO NOT count buns with hamburgers or hot dogs)?",
      "bread_quantity": "Think about your usual eating habits over the past month.  Each time you eat bread, toast or dinner rolls, how much do you usually eat?",
