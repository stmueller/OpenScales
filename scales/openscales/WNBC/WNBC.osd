  "translations": {
    "en": {
      "likert_1": "Totally disagree",
      "likert_2": "Disagree",
      "likert_3": "Neither agree nor disagree",
      "likert_4": "Agree",
      "likert_5": "Totally agree",
      "question_head": "Please indicate to what extent you agree or disagree with each of the following statements.",
      "wnbc1": "If I must get personal chores done during working time, I make sure that my work will not be negatively affected.",
      "wnbc2": "When I must get some work chores done, I come home later or go to work earlier, if necessary.",
      "wnbc3": "In some situations, I temporarily emphasize my work (e.g., work more before vacations to get things done).",
      "wnbc4": "In certain phases of my life, I temporarily prioritize my work life to achieve a work goal.",
      "wnbc5": "I try hard to meet my professional obligations, even if I'm demanded strongly by my private life.",
      "wnbc6": "When I'm in a bad mood because of personal matters, I try not to let this affect my work environment.",
      "wnbc7": "I make sure that I can enjoy the pleasant aspects of my work, even though I'm strongly demanded by my private life.",
      "wnbc8": "I tell people of my private environment when I'm unable to communicate with them during working time or to take care of private matters.",
      "wnbc9": "If I must get work chores done during leisure time, I make sure that my personal life will not be negatively affected.",
      "wnbc10": "When I must get some personal chores done, I come to work later or go home earlier, if necessary.",
      "wnbc11": "In some situations, I temporarily emphasize my private life (e.g., when a friend needs my support).",
      "wnbc12": "In certain phases of my life, I temporarily prioritize my private life to achieve a nonwork goal.",
      "wnbc13": "I try hard to meet my private obligations, even if I'm demanded strongly by my work.",
      "wnbc14": "When I'm in a bad mood because of work matters, I try not to let this affect my personal environment.",
      "wnbc15": "I make sure that I can enjoy the time with my partner, my family or my friends even though I'm strongly demanded by my work.",
      "wnbc16": "I tell my work colleagues when I'm unable to communicate with them during non-working time or to take care of work matters.",
      "debrief": "Thank you for completing the Work-Nonwork Balance Crafting Scale."
    }
  }
}
