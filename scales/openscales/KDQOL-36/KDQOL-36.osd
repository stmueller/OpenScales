          "kdqol36_symp_grid_11",
          "kdqol36_symp_grid_12"
        ],
        "description": "Mean of 12 symptom items (items 28a/28b optional, not scored). Columns: 1=Not at all…5=Extremely; reverse-coded so 5=not bothered. Transform: (mean−1)/4×100 → 0–100.",
        "item_coding": {
          "kdqol36_symp_grid_1": -1,
          "kdqol36_symp_grid_2": -1,
          "kdqol36_symp_grid_3": -1,
          "kdqol36_symp_grid_4": -1,
          "kdqol36_symp_grid_5": -1,
          "kdqol36_symp_grid_6": -1,
