  "translations": {
    "en": {
      "lk_opt_1": "Strongly disagree",
      "lk_opt_2": "Somewhat disagree",
      "lk_opt_3": "Neutral",
      "lk_opt_4": "Somewhat agree",
      "lk_opt_5": "Strongly agree",
      "physicalactivity_selfefficacy_physicalactivity_frequency": "In a typical week, how many days do you do physical activity for 60 minutes or more? Mark the answer that is true for you.",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_1": "0",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_2": "1",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_3": "2",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_4": "3",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_5": "4",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_6": "5",
      "physicalactivity_selfefficacy_physicalactivity_frequency_opt_7": "6+",
      "physicalactivity_selfefficacy_physicalactivity_highfrequency": "How many months have you been doing 60 minutes of physical activity on 5 or more days per week?",
      "physicalactivity_selfefficacy_physicalactivity_highfrequency_opt_1": "Less than 6 months",
      "physicalactivity_selfefficacy_physicalactivity_highfrequency_opt_2": "6 months or more",
      "physicalactivity_selfefficacy_physicalactivity_future": "Do you think you will start doing 60 minutes of physical activity 5 or more days a week in the next 6 months?",
      "physicalactivity_selfefficacy_physicalactivity_future_opt_1": "No I do not intend to in the next six months",
      "physicalactivity_selfefficacy_physicalactivity_future_opt_2": "Yes I intend to in the next six months",
      "physicalactivity_selfefficacy_physicalactivity_future_opt_3": "Yes I intend to in the next 30 days",
      "physicalactivity_selfefficacy_changestrategies_desc": "The following are activities, thoughts, and feelings people use to help them change their physical activity. Think of any similar experiences you may be having or have had in the past month. Then rate HOW OFTEN you do each of the following:",
      "physicalactivity_selfefficacy_changestrategies_1": "I look for information about physical activity or sports.",
      "physicalactivity_selfefficacy_changestrategies_2": "I keep track of how much physical activity I do.",
      "physicalactivity_selfefficacy_changestrategies_3": "I find ways to get around the things that get in the way of being physically active.",
      "physicalactivity_selfefficacy_changestrategies_4": "I think about how my surroundings affect the amount of physical activity I do. (Surroundings are things like having exercise equipment at home or a park nearby.)",
      "physicalactivity_selfefficacy_changestrategies_5": "I put reminders around my home to be physically active.",
      "physicalactivity_selfefficacy_changestrategies_6": "I reward myself for being physically active.",
      "physicalactivity_selfefficacy_changestrategies_7": "I do things to make physical activity more enjoyable.",
      "physicalactivity_selfefficacy_changestrategies_8": "I think about the benefits I will get from being physically active.",
      "physicalactivity_selfefficacy_changestrategies_9": "I try to think more about the benefits of physical activity and less about the hassles of being active.",
      "physicalactivity_selfefficacy_changestrategies_10": "I say positive things to myself about physical activity.",
      "physicalactivity_selfefficacy_changestrategies_11": "When I get off track with my physical activity plans, I tell myself I can start again and get right back on track.",
      "physicalactivity_selfefficacy_changestrategies_12": "I have a friend or family member who encourages me to do physical activity.",
      "physicalactivity_selfefficacy_changestrategies_13": "I try different kinds of physical activity so that I have more options to choose from.",
      "physicalactivity_selfefficacy_changestrategies_14": "I set goals to do physical activity.",
      "physicalactivity_selfefficacy_changestrategies_15": "I make back-up plans to be sure I get my physical activity.",
      "physicalactivity_selfefficacy_physicalactivity_proscons_desc": "HOW IMPORTANT IS EACH STATEMENT TO YOU WHEN DECIDING WHETHER OR NOT TO DO PHYSICAL ACTIVITY?",
      "physicalactivity_selfefficacy_physicalactivity_proscons_1": "I would feel embarrassed if people saw me doing physical activity.",
      "physicalactivity_selfefficacy_physicalactivity_proscons_2": "Physical activity would help me stay fit.",
      "physicalactivity_selfefficacy_physicalactivity_proscons_3": "My parents would be happy if I did physical activity.",
      "physicalactivity_selfefficacy_physicalactivity_proscons_4": "There is too much I would have to learn to do physical activity.",
      "physicalactivity_selfefficacy_physicalactivity_proscons_5": "I would feel better about myself if I did physical activity.",
      "physicalactivity_selfefficacy_physicalactivity_proscons_6": "I would need too much help from my parents to do physical activity.",
      "physicalactivity_selfefficacy_physicalactivity_proscons_7": "I do not like the way physical activity and exercise makes me feel.",
      "physicalactivity_selfefficacy_physicalactivity_proscons_8": "I would have fun doing physical activity or playing sports with my friends.",
      "physicalactivity_selfefficacy_physicalactivity_proscons_9": "I would have more energy if I did physical activity.",
      "physicalactivity_selfefficacy_physicalactivity_proscons_10": "Physical activity takes time away from being with my friends.",
      "physicalactivity_selfefficacy_confidence_desc": "There are many things that can get in the way of physical activity. Rate HOW SURE you are that you can do physical activity in each situation.",
      "physicalactivity_selfefficacy_confidence_1": "Do physical activity even when you feel sad or stressed?",
      "physicalactivity_selfefficacy_confidence_2": "Set aside time for physical activity on most days of the week?",
      "physicalactivity_selfefficacy_confidence_3": "Do physical activity even when your family or friends want you to do something else?",
      "physicalactivity_selfefficacy_confidence_4": "Get up early, even on weekends, to do physical activity?",
      "physicalactivity_selfefficacy_confidence_5": "Do physical activity even when you have a lot of schoolwork?",
      "physicalactivity_selfefficacy_confidence_6": "Do physical activity even when it is raining or really hot outside?",
      "physicalactivity_selfefficacy_familysupport_desc": "During a typical week, how often has a member of your household: (For example, your father, mother, brother, sister, grandparent, or other relatives):",
      "physicalactivity_selfefficacy_familysupport_1": "Watched you participate in physical activity or play sports?",
      "physicalactivity_selfefficacy_familysupport_2": "Encouraged you to do sports or physical activity?",
      "physicalactivity_selfefficacy_familysupport_3": "Provided transportation to a place where you can do physical activity or play sports?",
      "physicalactivity_selfefficacy_familysupport_4": "Done a physical activity or played sports with you?",
      "physicalactivity_selfefficacy_friendsupport_desc": "During a typical week, how often:",
      "physicalactivity_selfefficacy_friendsupport_1": "Do your friends encourage you to do sports or physical activities?",
      "physicalactivity_selfefficacy_friendsupport_2": "Do your friends do physical activity or play sports with you?",
      "physicalactivity_selfefficacy_friendsupport_3": "Do your friends or classmates tease you about not being good at physical activities or sports?",
      "physicalactivity_selfefficacy_friendsupport_4": "Do your friends ask you to walk or bike to school or to a friend's house?",
      "physicalactivity_selfefficacy_friendsupport_5": "Do your friends tell you that you are doing well in physical activities or sports?",
      "physicalactivity_selfefficacy_closestfriendsupport": "How many of your five closest friends are physically active on a regular basis?",
      "physicalactivity_selfefficacy_physicalactivity_enjoyment": "I enjoy doing physical activity.",
      "physicalactivity_selfefficacy_recreationchoices": "What do you usually do when you have a choice about how you spend recreational time?",
      "physicalactivity_selfefficacy_environmentalfactors_desc": "How much do you agree with the following statements?",
      "physicalactivity_selfefficacy_environmentalfactors_1": "At home there are enough supplies and pieces of sports equipment (like balls, bicycles, skates) to use for physical activity.",
      "physicalactivity_selfefficacy_environmentalfactors_2": "It is difficult to walk or jog in my neighborhood because of things like traffic, no sidewalks, dogs, gangs and so on.",
      "physicalactivity_selfefficacy_environmentalfactors_3": "There are playgrounds, parks, or gyms, close to my home or that I can get to easily.",
      "physicalactivity_selfefficacy_environmentalfactors_4": "It is safe to walk or jog in my neighborhood during the day."
    }
  }
}
