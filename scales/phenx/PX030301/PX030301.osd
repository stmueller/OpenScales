{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Alcohol - 30-Day Quantity and Frequency",
      "code": "PX030301",
      "abbreviation": "PX030301",
      "description": "Measurements of respondent’s 30-day quantity and frequency of consumption of alcohol.",
      "domain": "Tobacco & Alcohol Use",
      "citation": "For information regarding alcohol consumption during the last 30 days among women who are pregnant, please refer to the Centers for Disease Control and Prevention (CDC) National Center on Birth Defects & Developmental Disabilities Fetal Alcohol Syndrome website and the CDC Behavioral Risk Factor Surveillance System website. [PhenX: https://www.phenxtoolkit.org/protocols/view/30301]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/30301"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "items": [
      {
        "id": "alcohol_30day_frequency",
        "text_key": "alcohol_30day_frequency",
        "type": "short",
        "input_type": "number",
        "number_min": 0,
        "number_max": 30
      },
      {
        "id": "alcohol_30day_frequency_coded",
        "text_key": "alcohol_30day_frequency_coded",
        "type": "multi",
        "visible_when": {
          "any": [
            {
              "item": "alcohol_30day_frequency",
              "operator": "less_than",
              "value": 1
            },
            {
              "item": "alcohol_30day_frequency",
              "operator": "greater_than",
              "value": 29
            }
          ]
        },
        "options": [
          {
            "text_key": "alcohol_30day_frequency_coded_opt_97",
            "value": 97
          },
          {
            "text_key": "alcohol_30day_frequency_coded_opt_99",
            "value": 99
          }
        ]
      },
      {
        "id": "alcohol_30day_quantity",
        "text_key": "alcohol_30day_quantity",
        "type": "short",
        "input_type": "number",
        "number_min": 1,
        "number_max": 90
      },
      {
        "id": "alcohol_30day_quantity_coded",
        "text_key": "alcohol_30day_quantity_coded",
        "type": "multi",
        "visible_when": {
          "any": [
            {
              "item": "alcohol_30day_quantity",
              "operator": "less_than",
              "value": 2
            },
            {
              "item": "alcohol_30day_quantity",
              "operator": "greater_than",
              "value": 89
            }
          ]
        },
        "options": [
          {
            "text_key": "alcohol_30day_quantity_coded_opt_97",
            "value": 97
          },
          {
            "text_key": "alcohol_30day_quantity_coded_opt_99",
            "value": 99
          }
        ]
      },
      {
        "id": "alcohol_30day_desc_2",
        "text_key": "alcohol_30day_desc_2",
        "type": "inst"
