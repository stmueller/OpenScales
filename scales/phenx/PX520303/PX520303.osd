      "unable_to_stop_more_heroin_opt_6": "6",
      "unable_to_stop_more_heroin_opt_7": "STRONGLY AGREE",
      "heroin_almost_taste_it": "I want heroin so bad I can almost taste it.",
      "heroin_almost_taste_it_opt_1": "STRONGLY DISAGREE",
      "heroin_almost_taste_it_opt_2": "2",
      "heroin_almost_taste_it_opt_3": "3",
