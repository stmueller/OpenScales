  "translations": {
    "en": {
      "lk_opt_1": "Strongly disagree",
      "lk_opt_2": "Disagree",
      "lk_opt_3": "Neither agree nor disagree",
      "lk_opt_4": "Agree",
      "lk_opt_5": "Strongly agree",
      "teacher_understands_problems": "Teachers understand my problems",
      "teacher_interested_in_future": "Teachers and staff seem to take a real interest in my future",
      "teachers_available_to_talk": "Teachers are available when I need to talk with them",
      "easy_to_talk_with_teachers": "It is easy to talk with teachers",
      "students_get_along_with_teachers": "Students get along well with teachers",
      "teachers_notice_truancy": "At my school, there is a teacher or some other adult who notices when I'm not there",
      "teachers_help_with_problems": "Teachers at my school help us children with our problems",
      "teachers_care": "My teachers care about me",
      "teachers_feel_good": "My teacher makes me feel good about myself",
      "exciting_schoolwork": "My schoolwork is exciting",
      "students_influence_offered_courses": "Students can make suggestions on courses that are offered",
      "students_recognized_for_arts": "Students are publicly recognized for their outstanding performances in speech, drama, art, music, etc.",
      "take_additional_classes": "If this school had an extra period during the day, I would take an additional academic class",
      "schools_makes_students_enthusiastic": "This school makes students enthusiastic about learning",
      "students_recognized_for_following_rules": "Students are frequently rewarded or praised by faculty and staff for following school rules",
      "understand_homework": "I usually understand my homework assignments",
      "clear_expectations_for_grades": "Teachers make it clear what work needs to be done to get the grade I want",
      "teachers_expect_students_to_learn": "I believe that teachers expect all students to learn",
      "do_well_in_school": "I feel that I can do well in this school",
      "teachers_believe_in_students_abilities": "My teachers believe that I can do well in my school work",
      "try_to_succeed": "I try hard to succeed in my classes",
      "classroom_rules_applied_equally": "Classroom rules are applied equally",
      "problems_solved_by_staff_students": "Problems in this school are solved by students and staff",
      "students_punished_not_following_rules": "Students get in trouble if they do not follow school rules",
      "school_rules_are_fair": "The rules of the school are fair",
      "school_rules_enforced_fairly_consistently": "School rules are enforced consistently and fairly",
      "teachers_call_out_class_misbehavior": "My teachers make it clear to me when I have misbehaved in class",
      "discipline_is_fair": "Discipline is fair",
      "school_grounds_kept_clean": "The school grounds are kept clean",
      "school_neat_clean": "My school is neat and clean",
      "school_buildings_pleasant_maintained": "My school buildings are generally pleasant and well maintained",
      "school_usually_clean_tidy": "My school is usually clean and tidy",
      "happy_with_kinds_of_schoolmates": "I am happy with kinds of students who go to my school",
      "happy_with_other_students": "I am happy, in general, with the other students who go to my school",
      "same_person_helps_teacher": "At my school, the same person always gets to help the teacher",
      "same_kids_chosen_special_activities": "At my school, the same kids get chosen every time to take part in after-school or special activities",
      "same_kids_use_resources": "The same kids always get to use things, like a computer, a ball or a piano, when we play",
      "happy_about_number_tests": "I am happy about the number of tests I have",
      "happy_about_amount_of_homework": "I am happy about the amount of homework I have"
    }
  }
