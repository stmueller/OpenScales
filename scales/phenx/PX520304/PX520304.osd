      "making_plans_for_marijuana_opt_1": "STRONGLY DISAGREE",
      "making_plans_for_marijuana_opt_2": "2",
      "making_plans_for_marijuana_opt_3": "3",
      "making_plans_for_marijuana_opt_4": "4",
      "making_plans_for_marijuana_opt_5": "5",
      "making_plans_for_marijuana_opt_6": "6",
      "making_plans_for_marijuana_opt_7": "STRONGLY AGREE",
      "more_in_control_marijuana": "I would feel more in control of things right now if I could smoke marijuana.",
      "more_in_control_marijuana_opt_1": "STRONGLY DISAGREE",
      "more_in_control_marijuana_opt_2": "2",
      "more_in_control_marijuana_opt_3": "3",
