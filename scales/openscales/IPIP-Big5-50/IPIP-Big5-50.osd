  "translations": {
    "en": {
      "likert_1": "Very Inaccurate",
      "likert_2": "Moderately Inaccurate",
      "likert_3": "Neither Accurate Nor Inaccurate",
      "likert_4": "Moderately Accurate",
      "likert_5": "Very Accurate",
      "question_head": "<h3>How Accurately Can You Describe Yourself?</h3>\nDescribe yourself as you generally are now, not as you wish to be in the future. Describe yourself as you honestly see yourself, in relation to other people you know of the same sex as you are, and roughly your same age. So that you can describe yourself in an honest manner, your responses will be kept in absolute confidence. Indicate how accurately this statement describes you.",
      "i1": "Am the life of the party.",
      "i2": "Feel little concern for others.",
      "i3": "Am always prepared.",
      "i4": "Get stressed out easily.",
      "i5": "Have a rich vocabulary.",
      "i6": "Don't talk a lot.",
      "i7": "Am interested in people.",
      "i8": "Leave my belongings around.",
      "i9": "Am relaxed most of the time.",
      "i10": "Have difficulty understanding abstract ideas.",
      "i11": "Feel comfortable around people.",
      "i12": "Insult people.",
      "i13": "Pay attention to details.",
      "i14": "Worry about things.",
      "i15": "Have a vivid imagination.",
      "i16": "Keep in the background.",
      "i17": "Sympathize with others' feelings.",
      "i18": "Make a mess of things.",
      "i19": "Seldom feel blue.",
      "i20": "Am not interested in abstract ideas.",
      "i21": "Start conversations.",
      "i22": "Am not interested in other people's problems.",
      "i23": "Get chores done right away.",
      "i24": "Am easily disturbed.",
      "i25": "Have excellent ideas.",
      "i26": "Have little to say.",
      "i27": "Have a soft heart.",
      "i28": "Often forget to put things back in their proper place.",
      "i29": "Get upset easily.",
      "i30": "Do not have a good imagination.",
      "i31": "Talk to a lot of different people at parties.",
      "i32": "Am not really interested in others.",
      "i33": "Like order.",
      "i34": "Change my mood a lot.",
      "i35": "Am quick to understand things.",
      "i36": "Don't like to draw attention to myself.",
      "i37": "Take time out for others.",
      "i38": "Shirk my duties.",
      "i39": "Have frequent mood swings.",
      "i40": "Use difficult words.",
      "i41": "Don't mind being the center of attention.",
      "i42": "Feel others' emotions.",
      "i43": "Follow a schedule.",
      "i44": "Get irritated easily.",
      "i45": "Spend time reflecting on things.",
      "i46": "Am quiet around strangers.",
      "i47": "Make people feel at ease.",
      "i48": "Am exacting in my work.",
      "i49": "Often feel blue.",
      "i50": "Am full of ideas.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
