    "scale_info": {
      "name": "Youth Cigarette Purchase Behaviors and Experiences",
      "code": "PX751502",
      "abbreviation": "PX751502",
      "description": "This protocol includes five questions from the University of Michigan and National Institutes of Health’s 2022 Monitoring the Future (MTF) project survey that captures data related to youth purchase behaviors and experiences.",
      "domain": "Substance Use",
      "citation": "Feng, B., & Pesko, M. F. (2019). Revisiting the effects of tobacco retailer compliance inspections on youth tobacco use. American Journal of Health Economics, 5(4), 509-532. Johnston LD, O’malley PM, Terry-McElrath YM. (2004). Methods, locations, and ease of cigarette access for American youth, 1997-2002. Am J Prev Med; 27(4):267-76. Unger JB, Chaloupka FJ, Vallone D, Thrasher JF, Nettles DS, Hendershot TP, Swan GE. PhenX: environment measures for tobacco regulatory research. Tobacco Control. 2020 Jan;29(Suppl 1):s35. [PhenX: https://www.phenxtoolkit.org/protocols/view/751502]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/751502"
    },
