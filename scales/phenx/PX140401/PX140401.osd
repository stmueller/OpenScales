  "translations": {
    "en": {
      "diabetic_peripheral_neuropathy_intro": "Please take a few minutes to answer the questions below about the feeling in your legs and feet. Check yes or no based on how you usually feel.",
      "legs_feet_numb": "Are your legs and/or feet numb?",
      "legs_feet_numb_opt_1": "Yes",
      "legs_feet_numb_opt_2": "No",
      "burning_pain": "Do you ever have any burning pain in your legs and/or feet?",
      "burning_pain_opt_1": "Yes",
      "burning_pain_opt_2": "No",
      "feet_too_sensitive_to_touch": "Are your feet too sensitive to touch?",
      "feet_too_sensitive_to_touch_opt_1": "Yes",
      "feet_too_sensitive_to_touch_opt_2": "No",
      "muscle_cramps": "Do you get muscle cramps in your legs and/or feet?",
      "muscle_cramps_opt_1": "Yes",
      "muscle_cramps_opt_2": "No",
      "prickling_feelings": "Do you ever have any prickling feelings in your legs or feet?",
      "prickling_feelings_opt_1": "Yes",
      "prickling_feelings_opt_2": "No",
      "bed_covers_hurt": "Does it hurt when the bed covers touch your skin?",
      "bed_covers_hurt_opt_1": "Yes",
      "bed_covers_hurt_opt_2": "No",
      "tell_hot_water_from_cold": "When you get into the tub or shower, are you able to tell the hot water from the cold water?",
      "tell_hot_water_from_cold_opt_1": "Yes",
      "tell_hot_water_from_cold_opt_2": "No",
      "open_sore": "Have you ever had an open sore on your foot?",
      "open_sore_opt_1": "Yes",
      "open_sore_opt_2": "No",
      "diagnosed_diabetic_neuropathy": "Has your doctor ever told you that you have diabetic neuropathy?",
      "diagnosed_diabetic_neuropathy_opt_1": "Yes",
      "diagnosed_diabetic_neuropathy_opt_2": "No",
      "feel_weak_all_over": "Do you feel weak all over most of the time?",
      "feel_weak_all_over_opt_1": "Yes",
      "feel_weak_all_over_opt_2": "No",
      "symptoms_worse_at_night": "Are your symptoms worse at night?",
      "symptoms_worse_at_night_opt_1": "Yes",
      "symptoms_worse_at_night_opt_2": "No",
      "leg_hurt_when_walk": "Do your legs hurt when you walk?",
      "leg_hurt_when_walk_opt_1": "Yes",
      "leg_hurt_when_walk_opt_2": "No",
      "sense_feet_when_walking": "Are you able to sense your feet when you walk?",
      "sense_feet_when_walking_opt_1": "Yes",
      "sense_feet_when_walking_opt_2": "No",
      "skin_cracks_open": "Is the skin on your feet so dry that it cracks open?",
      "skin_cracks_open_opt_1": "Yes",
      "skin_cracks_open_opt_2": "No",
      "amputation": "Have you ever had an amputation?",
      "amputation_opt_1": "Yes",
      "amputation_opt_2": "No"
    }
  }
}
