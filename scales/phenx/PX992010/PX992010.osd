  "translations": {
    "en": {
      "long_covid_symptoms_respiratory_new_worsening_coughrecord_id": "Record ID",
      "long_covid_symptoms_respiratory_new_worsening_cough": "Do you still have the new or worsening cough?",
      "long_covid_symptoms_respiratory_new_worsening_cough_normal_activities": "Does/did the new or worsening cough affect your ability to do your normal activities?",
      "long_covid_symptoms_respiratory_new_worsening_cough_clear": "When did the new or worsening cough clear?",
      "long_covid_symptoms_respiratory_shortness_breath": "Do you still have the shortness of breath?",
      "long_covid_symptoms_respiratory_shortness_breath_normal_activities": "Does/did the shortness of breath affect your ability to do your normal activities?",
      "long_covid_symptoms_respiratory_shortness_breath_clear": "When did the shortness of breath clear?",
      "long_covid_symptoms_respiratory_discomfort_chest": "Do you still have the discomfort, tightness, or pressure in chest?",
      "long_covid_symptoms_respiratory_discomfort_chest_normal_activities": "Does/did the discomfort, tightness, or pressure in chest affect your ability to do your normal activities?",
      "long_covid_symptoms_respiratory_discomfort_chest_clear": "When did the discomfort, tightness, or pressure in chest rate clear?",
      "likert_1": "Yes, I still have this symptom",
      "likert_2": "Yes, I still have the symptom but it is less severe",
      "likert_3": "Yes, I still have the symptom but it comes and goes",
      "likert_4": "No, the symptom has cleared",
      "opt_1": "Less than 3 months after symptom started",
      "opt_2": "Between 3 to 6 months after symptom started",
      "opt_3": "Between 6 to 9 months after symptom started",
      "opt_4": "Greater than 9 months after symptom started",
      "opt_5": "Don't know",
      "opt_6": "Refuse to answer"
    }
  }
