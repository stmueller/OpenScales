      "burden_assessment_embarrassed_behavior_opt_5": "NA",
      "burden_assessment_guilty_help": "Because of name's illness, to what extent have you: felt guilty because you were not doing enough to help",
      "burden_assessment_guilty_help_opt_1": "Not at all",
      "burden_assessment_guilty_help_opt_2": "A little",
      "burden_assessment_guilty_help_opt_3": "Some",
      "burden_assessment_guilty_help_opt_4": "A lot",
      "burden_assessment_guilty_help_opt_5": "NA",
      "burden_assessment_guilty_problem": "Because of name's illness, to what extent have you: felt guilty because you felt responsible for causing (name's) problem",
      "burden_assessment_guilty_problem_opt_1": "Not at all",
      "burden_assessment_guilty_problem_opt_2": "A little",
      "burden_assessment_guilty_problem_opt_3": "Some",
      "burden_assessment_guilty_problem_opt_4": "A lot",
      "burden_assessment_guilty_problem_opt_5": "NA",
      "burden_assessment_resentment": "Because of name's illness, to what extent have you: resented (name) because s or he made too many demands on you",
      "burden_assessment_resentment_opt_1": "Not at all",
      "burden_assessment_resentment_opt_2": "A little",
      "burden_assessment_resentment_opt_3": "Some",
      "burden_assessment_resentment_opt_4": "A lot",
      "burden_assessment_resentment_opt_5": "NA",
      "burden_assessment_trapped": "Because of name's illness, to what extent have you: felt trapped by your caregiving role",
      "burden_assessment_trapped_opt_1": "Not at all",
