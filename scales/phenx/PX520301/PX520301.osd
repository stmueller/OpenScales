  "translations": {
    "en": {
      "info_520301": "Listed below are questions that ask about your feelings about drinking. The words \"drinking\" and \"have a drink\" refer to having a drink containing alcohol such as beer, wine, or liquor. Please indicate how much you agree or disagree with each of the following statements by selecting one number for each question between STRONGLY DISAGREE and STRONGLY AGREE. The closer you select a number to one end or the other indicates the strength of your disagreement or agreement. Please complete every item. We are interested in how you are thinking or feeling right now as you are filling out the questionnaire.",
      "all_want_is_drink": "All I want to do now is have a drink.",
      "all_want_is_drink_opt_1": "STRONGLY DISAGREE",
      "all_want_is_drink_opt_2": "2",
      "all_want_is_drink_opt_3": "3",
      "all_want_is_drink_opt_4": "4",
      "all_want_is_drink_opt_5": "5",
      "all_want_is_drink_opt_6": "6",
      "all_want_is_drink_opt_7": "STRONGLY AGREE",
      "do_not_need_drink": "I do not need to have a drink now.",
      "do_not_need_drink_opt_1": "STRONGLY DISAGREE",
      "do_not_need_drink_opt_2": "2",
      "do_not_need_drink_opt_3": "3",
      "do_not_need_drink_opt_4": "4",
      "do_not_need_drink_opt_5": "5",
      "do_not_need_drink_opt_6": "6",
      "do_not_need_drink_opt_7": "STRONGLY AGREE",
      "difficult_to_turn_downdrink": "It would be difficult to turn down a drink this minute.",
      "difficult_to_turn_downdrink_opt_1": "STRONGLY DISAGREE",
      "difficult_to_turn_downdrink_opt_2": "2",
      "difficult_to_turn_downdrink_opt_3": "3",
      "difficult_to_turn_downdrink_opt_4": "4",
      "difficult_to_turn_downdrink_opt_5": "5",
      "difficult_to_turn_downdrink_opt_6": "6",
      "difficult_to_turn_downdrink_opt_7": "STRONGLY AGREE",
      "having_a_drink_perfect": "Having a drink now would make things seem just perfect.",
      "having_a_drink_perfect_opt_1": "STRONGLY DISAGREE",
      "having_a_drink_perfect_opt_2": "2",
      "having_a_drink_perfect_opt_3": "3",
      "having_a_drink_perfect_opt_4": "4",
      "having_a_drink_perfect_opt_5": "5",
      "having_a_drink_perfect_opt_6": "6",
      "having_a_drink_perfect_opt_7": "STRONGLY AGREE",
      "want_drink_almost_taste": "I want a drink so bad I can almost taste it.",
      "want_drink_almost_taste_opt_1": "STRONGLY DISAGREE",
      "want_drink_almost_taste_opt_2": "2",
      "want_drink_almost_taste_opt_3": "3",
      "want_drink_almost_taste_opt_4": "4",
      "want_drink_almost_taste_opt_5": "5",
      "want_drink_almost_taste_opt_6": "6",
      "want_drink_almost_taste_opt_7": "STRONGLY AGREE",
      "nothing_better_than_drink": "Nothing would be better than having a drink right now.",
      "nothing_better_than_drink_opt_1": "STRONGLY DISAGREE",
      "nothing_better_than_drink_opt_2": "2",
      "nothing_better_than_drink_opt_3": "3",
      "nothing_better_than_drink_opt_4": "4",
      "nothing_better_than_drink_opt_5": "5",
      "nothing_better_than_drink_opt_6": "6",
      "nothing_better_than_drink_opt_7": "STRONGLY AGREE",
      "chance_to_drink_would_not": "If I had the chance to have a drink, I don't think I would drink it.",
      "chance_to_drink_would_not_opt_1": "STRONGLY DISAGREE",
      "chance_to_drink_would_not_opt_2": "2",
      "chance_to_drink_would_not_opt_3": "3",
      "chance_to_drink_would_not_opt_4": "4",
      "chance_to_drink_would_not_opt_5": "5",
      "chance_to_drink_would_not_opt_6": "6",
      "chance_to_drink_would_not_opt_7": "STRONGLY AGREE",
      "crave_a_drink": "I crave a drink right now.",
      "crave_a_drink_opt_1": "STRONGLY DISAGREE",
      "crave_a_drink_opt_2": "2",
      "crave_a_drink_opt_3": "3",
      "crave_a_drink_opt_4": "4",
      "crave_a_drink_opt_5": "5",
      "crave_a_drink_opt_6": "6",
      "crave_a_drink_opt_7": "STRONGLY AGREE",
      "scoring_520301": "Scoring Procedure and InterpretationEach item is scored on a 1 to 7 scale (Strongly Disagree = 1 and Strongly Agree = 7). Items 2 and 7 are reverse scored. A total score is computed by averaging the item scores. Higher scores reflect greater craving."
    }
  }
