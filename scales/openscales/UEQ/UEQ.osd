    "ta": {
      "LANGUAGE": "ta",
      "question_head": "தயவு செய்து ஒரு வட்டத்தில் மற்றும் ஒவ்வொரு வரியிலும் தேர்வு செய்யவும்",
      "ueq_inst_text": "தயவு செய்து உங்கள் மதிப்பீட்டை எங்களுக்கு வழங்கவும். தயவு செய்து பொருளை மதிப்பிடுவதற்கு பின்வரும் கேள்வித்தாளை பூர்த்தி செய்யவும். கேள்வித்தாளில் பொருள் பண்புகளின் ஜோடிகள் உள்ளன. எதிர் திசைகளுக்கு இடையிலான தரங்கள் வட்டங்களால் குறிக்கப்படுகின்றன. தனிப்பட்ட விதிமுறைகளுடன் உங்கள் ஒத்துக்கொள்ளும் அளவைக் குறிக்க வட்டங்களில் ஒன்றைச் சரிபார்க்கவும்.",
      "ueq_01_text": "எரிச்சலூட்டும்                    இன்பம்",
      "ueq_01_left": "எரிச்சலூட்டும்",
      "ueq_01_right": "இன்பம்",
      "ueq_02_text": "புரிந்து கொள்ள முடியவில்லை                    புரிகிறது",
      "ueq_02_left": "புரிந்து கொள்ள முடியவில்லை",
      "ueq_02_right": "புரிகிறது",
      "ueq_03_text": "ஆக்கப் பூர்வமான                    மந்தமான",
      "ueq_03_left": "ஆக்கப் பூர்வமான",
      "ueq_03_right": "மந்தமான",
      "ueq_04_text": "படிப்பதற்கு சுலபம்                    கற்பதற்கு கடினம்",
      "ueq_04_left": "படிப்பதற்கு சுலபம்",
      "ueq_04_right": "கற்பதற்கு கடினம்",
      "ueq_05_text": "மதிப்பு மிக்க                    தாழ்வான",
      "ueq_05_left": "மதிப்பு மிக்க",
      "ueq_05_right": "தாழ்வான",
      "ueq_06_text": "சலிப்பான                    ஆர்வமான",
      "ueq_06_left": "சலிப்பான",
      "ueq_06_right": "ஆர்வமான",
      "ueq_07_text": "சுவாரஸ்யம் இல்லை                    சுவாரஸ்யம்",
      "ueq_07_left": "சுவாரஸ்யம் இல்லை",
      "ueq_07_right": "சுவாரஸ்யம்",
      "ueq_08_text": "ஊகிக்க முடியவில்லை                    ஊகிக்கக் கூடிய",
      "ueq_08_left": "ஊகிக்க முடியவில்லை",
      "ueq_08_right": "ஊகிக்கக் கூடிய",
      "ueq_09_text": "வேகமாக                    நிதானம் /மெதுவாக",
      "ueq_09_left": "வேகமாக",
      "ueq_09_right": "நிதானம் /மெதுவாக",
      "ueq_10_text": "கண்டுபிடிப்பு                    வழக்கமான",
      "ueq_10_left": "கண்டுபிடிப்பு",
      "ueq_10_right": "வழக்கமான",
      "ueq_11_text": "தடை செய்யும்                    ஆதரவு",
      "ueq_11_left": "தடை செய்யும்",
      "ueq_11_right": "ஆதரவு",
      "ueq_12_text": "நல்ல                    கெட்ட",
      "ueq_12_left": "நல்ல",
      "ueq_12_right": "கெட்ட",
      "ueq_13_text": "சிக்கலான                    சுலபம்",
