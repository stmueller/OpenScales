      "personal_wellbeing_scale": "personal_wellbeing_scale",
      "personal_wellbeing_living_standard": "How satisfied are you with your standard of living?",
      "personal_wellbeing_health": "How satisfied are you with your health?",
      "personal_wellbeing_achievements": "How satisfied are you with what you are achieving in life?",
      "personal_wellbeing_relationships": "How satisfied are you with your personal relationships?",
      "personal_wellbeing_safety": "How satisfied are you with how safe you feel?",
      "personal_wellbeing_community": "How satisfied are you with feeling part of your community?",
