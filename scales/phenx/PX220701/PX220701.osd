  "translations": {
    "en": {
      "lk_opt_1": "Very poor",
      "lk_opt_2": "Poor",
      "lk_opt_3": "Fair",
      "lk_opt_4": "Good",
      "lk_opt_5": "Very good",
      "intro_220701": "The Newcastle Paediatric Mitochondrial Disease Scale (NPMDS)0 - 24 months",
      "disease_progressionregression_024mo_date": "Date of assessment:",
      "disease_progressionregression_024mo_age": "Age at assessment:",
      "disease_progressionregression_024mo_parental_consanguinity": "Parental consanguinity:",
      "disease_progressionregression_024mo_parental_agepresentation": "Age at presentation:",
      "disease_progressionregression_024mo_parentalage_agedx": "Age at clinical diagnosis:",
      "disease_progressionregression_024mo_genotype": "Genotype if known:",
      "disease_progressionregression_024mo_biochemical_phenotype": "Biochemical phenotype if known:",
      "disease_progressionregression_024mo_basis_diagnosis": "Basis of clinical diagnosis e.g. MRI, blood / CSF lactate",
      "disease_progressionregression_024mo_reduced_fetalmovement": "Information regarding pregnancy:reduced fetal movements",
      "disease_progressionregression_024mo_reduced_fetalmovement_opt_1": "Yes",
      "disease_progressionregression_024mo_reduced_fetalmovement_opt_2": "No",
      "disease_progressionregression_024mo_reduced_fetalmovement_opt_3": "Unknown",
      "disease_progressionregression_024mo_pregnancy_cardiomyopathy_antenatal": "Information regarding pregnancy:cardiomyopathy on antenatal scans",
      "disease_progressionregression_024mo_pregnancy_cardiomyopathy_antenatal_opt_1": "Yes",
      "disease_progressionregression_024mo_pregnancy_cardiomyopathy_antenatal_opt_2": "No",
      "disease_progressionregression_024mo_pregnancy_cardiomyopathy_antenatal_opt_3": "Unknown",
      "disease_progressionregression_024mo_abnormalities_fetalscan": "Information regarding pregnancy:abnormalities on fetal anomaly scan",
      "disease_progressionregression_024mo_abnormalities_fetalscan_opt_1": "Yes",
      "disease_progressionregression_024mo_abnormalities_fetalscan_opt_2": "No",
      "disease_progressionregression_024mo_abnormalities_fetalscan_opt_3": "Unknown - please specify below",
      "disease_progressionregression_024mo_abnormalities_specify": "Please specify",
      "disease_progressionregression_024mo_pregnancy_cardiomyopathy_pregnancyother": "Other",
      "disease_progressionregression_024mo_neonatal_gestationalage": "Neonatal information:gestational age ____weeks",
      "disease_progressionregression_024mo_neonatal_deliverymethod": "Neonatal information:delivery method (NVD vs instrumental vs C/S)",
      "disease_progressionregression_024mo_neonatal_birthweight": "Neonatal information:birth weight in kg",
      "disease_progressionregression_024mo_neonatal_resuscitationventilation": "Neonatal information:Resuscitation and ventilation",
      "disease_progressionregression_024mo_neonatal_resuscitationventilation_opt_1": "Yes",
      "disease_progressionregression_024mo_neonatal_resuscitationventilation_opt_2": "No",
      "disease_progressionregression_024mo_neonatal_resuscitationventilation_opt_3": "Unknown - please specify below",
      "disease_progressionregression_024mo_neonatal_specify": "Specify",
      "instructions_220701": "Section I: Current FunctionRate function during the preceding 2 week period only according to caregiver interview. Indicate the score that best fits patient's functional status independently of the nature of the signs.",
      "disease_progressionregression_024mo_currentfunction_vision": "Rate function during the preceding 2 week period only according to caregiver - Vision",
      "disease_progressionregression_024mo_currentfunction_vision_opt_1": "0. Normal. No parental concerns",
      "disease_progressionregression_024mo_currentfunction_vision_opt_2": "1. Mild. Limited eye or head movement to large objects or parental face in visual  field",
      "disease_progressionregression_024mo_currentfunction_vision_opt_3": "2. Moderate. No response to large objects or parental face in the visual field",
      "disease_progressionregression_024mo_currentfunction_vision_opt_4": "3. Severe. No response to light",
      "disease_progressionregression_024mo_currentfunction_hearing": "Rate function during the preceding 2 week period only according to caregiver - Hearing",
      "disease_progressionregression_024mo_currentfunction_hearing_opt_1": "0. Normal",
      "disease_progressionregression_024mo_currentfunction_hearing_opt_2": "1.  Mild. Body, head or eye movement only to loud noise",
      "disease_progressionregression_024mo_currentfunction_hearing_opt_3": "2. Moderate. No reaction to loud noise",
      "disease_progressionregression_024mo_currentfunction_hearing_opt_4": "3. Severe. No hearing (even with aid)",
      "disease_progressionregression_024mo_currentfunction_communication": "Rate function during the preceding 2 week period only according to caregiver - communication (assessed with appropriate regard for age)",
      "disease_progressionregression_024mo_currentfunction_communication_opt_1": "0.  Normal. Age appropriate communication",
      "disease_progressionregression_024mo_currentfunction_communication_opt_2": "1.  Mild. Delayed development of communication",
      "disease_progressionregression_024mo_currentfunction_communication_opt_3": "2. Moderate. Communication unintelligible to parents or completely reliant on  non-verbal communication",
      "disease_progressionregression_024mo_currentfunction_communication_opt_4": "3. Severe. Not communicating effectively in any form",
      "disease_progressionregression_024mo_currentfunction_feeding": "Rate function during the preceding 2 week period only according to caregiver - Feeding",
      "disease_progressionregression_024mo_currentfunction_feeding_opt_1": "0. Normal",
      "disease_progressionregression_024mo_currentfunction_feeding_opt_2": "1. Mild. Difficulties in sucking / coughing / anorexia / wheezy with feeds or  occasional choking",
      "disease_progressionregression_024mo_currentfunction_feeding_opt_3": "2. Moderate. Supplementary enteral feeding or recurrent aspiration pneumonia",
      "disease_progressionregression_024mo_currentfunction_feeding_opt_4": "3. Severe. Exclusive enteral feeding (gastrostomy / NG tube). Nil by mouth",
      "disease_progressionregression_024mo_currentfunction_mobility": "Rate function during the preceding 2 week period only according to caregiver - Mobility",
      "disease_progressionregression_024mo_currentfunction_mobility_opt_1": "0. Normal. No concerns. Age appropriate mobility",
      "disease_progressionregression_024mo_currentfunction_mobility_opt_2": "1. Mild. Clumsy age appropriate mode of mobility",
      "disease_progressionregression_024mo_currentfunction_mobility_opt_3": "2. Moderate. Mobile but through age inappropriate mode",
      "disease_progressionregression_024mo_currentfunction_mobility_opt_4": "3. Severe. Immobile",
      "section_ii_220701": "Section II: System Specific InvolvementRate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question. Scores should be assigned according to caregiver interview, clinician's knowledge of the patient and clinical notes.",
      "disease_progressionregression_024mo_systeminvolvement_seizures": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - Seizures",
      "disease_progressionregression_024mo_systeminvolvement_seizures_opt_1": "0. None",
      "disease_progressionregression_024mo_systeminvolvement_seizures_opt_2": "1. Mild. Myoclonic or absence seizures only or < 1 generalised tonic-clonic  seizure/month",
      "disease_progressionregression_024mo_systeminvolvement_seizures_opt_3": "2. Moderate. > 5 generalized tonic-clonic seizures/month or > 20 absence or  myoclonic seizures/month",
      "disease_progressionregression_024mo_systeminvolvement_seizures_opt_4": "3. Severe. Status epilepticus or intractable seizures",
      "disease_progressionregression_024mo_systeminvolvement_encephalopathy": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - Encephalopathy",
      "disease_progressionregression_024mo_systeminvolvement_encephalopathy_opt_1": "0. None",
      "disease_progressionregression_024mo_systeminvolvement_encephalopathy_opt_2": "1. Mild. Abnormal sleepiness / lethargy. Waking only for feeds",
      "disease_progressionregression_024mo_systeminvolvement_encephalopathy_opt_3": "2. Moderate. Recurrent episodes of mild encephalopathy (> 2/year)",
      "disease_progressionregression_024mo_systeminvolvement_encephalopathy_opt_4": "3. Severe. Life threatening encephalopathy - requires artificial ventilation",
      "disease_progressionregression_024mo_systeminvolvement_gastrointestinal": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - Gastrointestinal",
      "disease_progressionregression_024mo_systeminvolvement_gastrointestinal_opt_1": "0. Normal.",
      "disease_progressionregression_024mo_systeminvolvement_gastrointestinal_opt_2": "1. Mild. Constipation or unexplained vomiting / diarrhoea > 3/week",
      "disease_progressionregression_024mo_systeminvolvement_gastrointestinal_opt_3": "2. Moderate. Severe constipation (no relief with laxative treatment) or  unexplained vomiting / diarrhoea every day or surgical intervention for  dysmotility",
      "disease_progressionregression_024mo_systeminvolvement_gastrointestinal_opt_4": "3. Severe Malabsorption / Failure to thrive",
      "disease_progressionregression_024mo_systeminvolvement_endocrine": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - Endocrine",
      "disease_progressionregression_024mo_systeminvolvement_endocrine_opt_1": "0. Normal.",
      "disease_progressionregression_024mo_systeminvolvement_endocrine_opt_2": "1. Mild. Biochemical evidence of impaired function",
      "disease_progressionregression_024mo_systeminvolvement_endocrine_opt_3": "2. Moderate. Endocrine failure requiring replacement therapy",
      "disease_progressionregression_024mo_systeminvolvement_endocrine_opt_4": "3. Severe. Endocrine decompensation (e.g. diabetic ketoacidosis, Addisonian  crisis)",
      "disease_progressionregression_024mo_systeminvolvement_respiratory": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - respiratory",
      "disease_progressionregression_024mo_systeminvolvement_respiratory_opt_1": "0. Normal",
      "disease_progressionregression_024mo_systeminvolvement_respiratory_opt_2": "1. Mild. Abnormal respiratory pattern not requiring therapy / hospitalization",
      "disease_progressionregression_024mo_systeminvolvement_respiratory_opt_3": "2. Moderate. Abnormal respiration requiring oxygen flow or hospitalisation but  not ventilation",
      "disease_progressionregression_024mo_systeminvolvement_respiratory_opt_4": "3. Severe. Abnormal respiration requiring artificial ventilation",
      "disease_progressionregression_024mo_systeminvolvement_cardiovascular": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - cardiovascular",
      "disease_progressionregression_024mo_systeminvolvement_cardiovascular_opt_1": "0. Normal",
      "disease_progressionregression_024mo_systeminvolvement_cardiovascular_opt_2": "1. Mild. Asymptomatic ECG change",
      "disease_progressionregression_024mo_systeminvolvement_cardiovascular_opt_3": "2.  Moderate. Abnormal echocardiogram (e.g. cardiomegaly) or sustained /  symptomatic arrhythmia on ECG",
      "disease_progressionregression_024mo_systeminvolvement_cardiovascular_opt_4": "3. Severe. Decompensated cardiomyopathy or requiring pacing device /  defibrillator / ablation",
      "disease_progressionregression_024mo_systeminvolvement_renal": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - Renal",
      "disease_progressionregression_024mo_systeminvolvement_renal_opt_1": "0. Normal",
      "disease_progressionregression_024mo_systeminvolvement_renal_opt_2": "1. Mild. Impaired function but no change in diet or therapy required",
      "disease_progressionregression_024mo_systeminvolvement_renal_opt_3": "2. Moderate. Impaired function requiring restricted protein diet",
      "disease_progressionregression_024mo_systeminvolvement_renal_opt_4": "3.  Severe. Failure requiring transplant / dialysis",
      "disease_progressionregression_024mo_systeminvolvement_liver": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - Liver",
      "disease_progressionregression_024mo_systeminvolvement_liver_opt_1": "0. Normal",
      "disease_progressionregression_024mo_systeminvolvement_liver_opt_2": "1.  Mild. Mildly impaired Liver Function Tests (LFTs). Normal albumin and  coagulation. No symptoms of hepatic failure",
      "disease_progressionregression_024mo_systeminvolvement_liver_opt_3": "2. Moderate. Impaired LFTs with symptoms (e.g. jaundice, coagulation  anomalies, oedema)",
      "disease_progressionregression_024mo_systeminvolvement_liver_opt_4": "3. Severe. Failure requiring hospitalisation and / or transplantation",
      "disease_progressionregression_024mo_systeminvolvement_blood": "Rate system specific involvement during the preceding 6 month period only (or since birth if the child is less than 6 months old) unless otherwise stated in the question.  - blood",
      "disease_progressionregression_024mo_systeminvolvement_blood_opt_1": "0. Normal",
      "disease_progressionregression_024mo_systeminvolvement_blood_opt_2": "1. Mild. Anaemia only",
      "disease_progressionregression_024mo_systeminvolvement_blood_opt_3": "2. Moderate. Asymptomatic pancytopenia",
      "disease_progressionregression_024mo_systeminvolvement_blood_opt_4": "3. Severe. Pancytopenia requiring regular transfusion / transplantation",
      "section_iii_220701": "Section III: Current Clinical AssessmentRate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question.",
      "disease_progressionregression_024mo_currentclinical_growthweight": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Growth (weight) over preceding 6 months",
      "disease_progressionregression_024mo_currentclinical_growthweight_opt_1": "0. Normal. Following normal growth trajectory",
      "disease_progressionregression_024mo_currentclinical_growthweight_opt_2": "1. Mild. Weight less than second centile but growing parallel to it",
      "disease_progressionregression_024mo_currentclinical_growthweight_opt_3": "2. Moderate. Weight crossing one centile",
      "disease_progressionregression_024mo_currentclinical_growthweight_opt_4": "3.  Severe. Weight crossing >= 2 centiles or less than 2nd centile with divergent  trajectory",
      "disease_progression_and_regression": "IMAGE - disease_progression_and_regression",
      "disease_progressionregression_024mo_currentclinical_development": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Development over preceding 4 months __ Score",
      "disease_progressionregression_024mo_currentclinical_development_opt_0": "Development is age appropriate",
      "disease_progressionregression_024mo_currentclinical_development_opt_1": "Development is not age appropriate, child has not regressed in any area of development, child is not globally delayed in development, AND (1) evidence of delayed speech, language or hearing, or (2) evidence of delayed motor milestones, or (3) evidence of delay in social development, AND there is development progress",
      "disease_progressionregression_024mo_currentclinical_development_opt_2": "Development is not age appropriate, child has not regressed in any area of development, child is not globally delayed in development, AND (1) evidence of delayed speech, language or hearing, or (2) evidence of delayed motor milestones, or (3) evidence of delay in social development, AND there is NO development progress",
      "disease_progressionregression_024mo_currentclinical_development_opt_5": "Development is not age appropriate, child has not regressed in any area of development, child is globally delayed in development, but there is developmental progress",
      "disease_progressionregression_024mo_currentclinical_development_opt_6": "Development is not age appropriate, child has not regressed in any area of development, child is globally delayed in development, and there is no developmental progress",
      "disease_progressionregression_024mo_currentclinical_development_opt_7": "Development is not age appropriate and child has regressed in an area of development",
      "disease_progressionregression_024mo_currentclinical_vision": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. -Vision",
      "disease_progressionregression_024mo_currentclinical_vision_opt_1": "0. Normal. Normal fixation and tracking",
      "disease_progressionregression_024mo_currentclinical_vision_opt_2": "1. Mild. Impaired fixation and / or tracking of small objects",
      "disease_progressionregression_024mo_currentclinical_vision_opt_3": "2. Moderate. Impaired fixation and / or tracking of familiar faces",
      "disease_progressionregression_024mo_currentclinical_vision_opt_4": "3.  Severe. No response to light or registered blind",
      "disease_progressionregression_024mo_currentclinical_ptosiseyemovement": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Ptosis and Eye Movement",
      "disease_progressionregression_024mo_currentclinical_ptosiseyemovement_opt_1": "0. Normal",
      "disease_progressionregression_024mo_currentclinical_ptosiseyemovement_opt_2": "1. Mild. Gaze evoked nystagmus or unilateral ptosis or impaired eye movement  at extremities",
      "disease_progressionregression_024mo_currentclinical_ptosiseyemovement_opt_3": "2. Moderate. Intermittent nystagmus at rest or bilateral ptosis not obscuring pupils or restriction of >50% eye movement",
      "disease_progressionregression_024mo_currentclinical_ptosiseyemovement_opt_4": "3. Severe. Continuous nystagmus at rest or bilateral ptosis obscuring pupils or  only a flicker of eye movement",
      "disease_progressionregression_024mo_currentclinical_myopathy": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Myopathy",
      "disease_progressionregression_024mo_currentclinical_myopathy_opt_1": "0. Normal",
      "disease_progressionregression_024mo_currentclinical_myopathy_opt_2": "1. Mild. Mild symmetrical weakness of hip and / or shoulder girdle only",
      "disease_progressionregression_024mo_currentclinical_myopathy_opt_3": "2. Moderate. Moderate symmetrical weakness (proximal > distal) limiting  functional movement",
      "disease_progressionregression_024mo_currentclinical_myopathy_opt_4": "3. Severe. Wheelchair / carrier dependent or respiratory compromise due to  myopathy.",
      "disease_progressionregression_024mo_currentclinical_pyramidal": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Pyramidal",
      "disease_progressionregression_024mo_currentclinical_pyramidal_opt_1": "0. Normal",
      "disease_progressionregression_024mo_currentclinical_pyramidal_opt_2": "1. Mild. Unilateral pyramidal signs but retaining functional movement",
      "disease_progressionregression_024mo_currentclinical_pyramidal_opt_3": "2. Moderate. Dense hemiplegia with little movement of affected side",
      "disease_progressionregression_024mo_currentclinical_pyramidal_opt_4": "3.  Severe. Bilateral pyramidal weakness with little or no movement",
      "disease_progressionregression_024mo_currentclinical_extrapyramidal": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Extrapyramidal",
      "disease_progressionregression_024mo_currentclinical_extrapyramidal_opt_1": "0. Normal.",
      "disease_progressionregression_024mo_currentclinical_extrapyramidal_opt_2": "1. Mild. Unilateral extrapyramidal posturing and increased tone",
      "disease_progressionregression_024mo_currentclinical_extrapyramidal_opt_3": "2. Moderate. Bilateral extrapyramidal posturing and increased tone",
      "disease_progressionregression_024mo_currentclinical_extrapyramidal_opt_4": "3.  Severe. Severe extrapyramidal posturing resulting in very little movement",
      "disease_progressionregression_024mo_currentclinical_neuropathy": "Rate current status according to the clinician's examination at the time of assessment unless otherwise stated in the question. - Neuropathy",
      "disease_progressionregression_024mo_currentclinical_neuropathy_opt_1": "0. Normal.",
      "disease_progressionregression_024mo_currentclinical_neuropathy_opt_2": "1. Mild. Areflexia only",
      "disease_progressionregression_024mo_currentclinical_neuropathy_opt_3": "2. Moderate. Sensory ataxia or motor impairment (distal weakness) but mobile",
      "disease_progressionregression_024mo_currentclinical_neuropathy_opt_4": "3.  Severe. Reliant on mobility aids primarily due to neuropathy",
