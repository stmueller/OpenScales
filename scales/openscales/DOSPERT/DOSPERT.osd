{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Domain-Specific Risk-Taking Scale (Revised)",
      "code": "DOSPERT",
      "abbreviation": "DOSPERT",
      "description": "30-item scale with up to three response modes per item: risk-taking likelihood (RT), risk perception (RP), and expected benefits (EB). Assesses five content domains: ethical, financial, health/safety, recreational, and social. For each item, RT is rated first (7-point: Extremely Unlikely to Extremely Likely), then RP (7-point: Not at all Risky to Extremely Risky), then optionally EB (7-point: No benefits at all to Great benefits). The EB mode can be enabled via the show_expected_benefits parameter. Items are presented in triplets grouped into randomizable sections. Subscale scores are means of 6 items per domain within each response mode.",
      "citation": "Blais, A.-R., & Weber, E. U. (2006). A Domain-Specific Risk-Taking (DOSPERT) scale for adult populations. Judgment and Decision Making, 1(1), 33-47.",
      "license": "CC BY 4.0",
      "version": "1.0",
      "url": "https://doi.org/10.1017/S1930297500000334",
      "domain": "Cognition"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "parameters": {
      "show_expected_benefits": {
        "type": "boolean",
        "default": true,
        "description": "Include the Expected Benefits (EB) response mode for each item"
      }
    },
    "likert_options": {
      "points": 7,
      "min": 1,
      "max": 7,
      "labels": [
        "rt_l1",
        "rt_l2",
        "rt_l3",
        "rt_l4",
        "rt_l5",
        "rt_l6",
        "rt_l7"
      ],
      "question_head": "rt_head"
    },
    "randomize_sections": {
      "method": "shuffle",
      "fixed": [
        "sec_intro"
      ]
    },
    "dimensions": [
      {
        "id": "rt_ethical",
        "name": "Risk-Taking: Ethical"
      },
      {
        "id": "rt_financial",
        "name": "Risk-Taking: Financial"
      },
      {
        "id": "rt_health_safety",
        "name": "Risk-Taking: Health/Safety"
      },
      {
        "id": "rt_recreational",
        "name": "Risk-Taking: Recreational"
      },
      {
        "id": "rt_social",
        "name": "Risk-Taking: Social"
      },
      {
        "id": "rp_ethical",
        "name": "Risk Perception: Ethical"
      },
      {
        "id": "rp_financial",
        "name": "Risk Perception: Financial"
      },
      {
        "id": "rp_health_safety",
        "name": "Risk Perception: Health/Safety"
      },
      {
        "id": "rp_recreational",
        "name": "Risk Perception: Recreational"
      },
      {
        "id": "rp_social",
        "name": "Risk Perception: Social"
      },
      {
        "id": "eb_ethical",
        "name": "Expected Benefits: Ethical"
      },
      {
        "id": "eb_financial",
        "name": "Expected Benefits: Financial"
      },
      {
        "id": "eb_health_safety",
        "name": "Expected Benefits: Health/Safety"
      },
      {
        "id": "eb_recreational",
        "name": "Expected Benefits: Recreational"
      },
      {
        "id": "eb_social",
        "name": "Expected Benefits: Social"
      }
    ],
    "items": [
