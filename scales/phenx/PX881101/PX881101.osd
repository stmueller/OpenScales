      "scd_pain_menstruation_quality_of_life_days_sad_mad_upset_period": "How many days have you felt sad, mad, or upset because of sickle cell pain during this menstrual period?",
      "scd_pain_menstruation_quality_of_life_days_sad_mad_upset_period_opt_1": "None",
      "scd_pain_menstruation_quality_of_life_days_sad_mad_upset_period_opt_2": "A Few",
