  "translations": {
    "en": {
      "likert_1": "Not bothered at all",
      "likert_2": "Bothered a little",
      "likert_3": "Bothered a lot",
      "question_head": "During the <b>last 4 weeks</b>, how much have you been bothered by any of the following problems?",
      "phq15_1": "Stomach pain",
      "phq15_2": "Back pain",
      "phq15_3": "Pain in your arms, legs, or joints (knees, hips, etc.)",
      "phq15_4": "Menstrual cramps or other problems with your periods (women only)",
      "phq15_5": "Headaches",
      "phq15_6": "Chest pain",
      "phq15_7": "Dizziness",
      "phq15_8": "Fainting spells",
      "phq15_9": "Feeling your heart pound or race",
      "phq15_10": "Shortness of breath",
      "phq15_11": "Pain or problems during sexual intercourse",
      "phq15_12": "Constipation, loose bowels, or diarrhea",
      "phq15_13": "Nausea, gas, or indigestion",
      "phq15_14": "Feeling tired or having little energy",
      "phq15_15": "Trouble sleeping",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
