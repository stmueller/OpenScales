  "translations": {
    "en": {
      "EDDS5_ThreeMonths_desc": "Over the past 3 months:",
      "EDDS5_ThreeMonths_Felt_Fat": "have you felt fat?",
      "EDDS5_ThreeMonths_Felt_Fat_opt_0": "0 - Not at all",
      "EDDS5_ThreeMonths_Felt_Fat_opt_1": "1",
      "EDDS5_ThreeMonths_Felt_Fat_opt_2": "2 - Slightly",
      "EDDS5_ThreeMonths_Felt_Fat_opt_3": "3",
      "EDDS5_ThreeMonths_Felt_Fat_opt_4": "4 - Moderately",
      "EDDS5_ThreeMonths_Felt_Fat_opt_5": "5",
      "EDDS5_ThreeMonths_Felt_Fat_opt_6": "6 - Extremely",
      "EDDS5_ThreeMonths_Fear_GainWeight": "have you had a definite fear that you might gain weight or become fat?",
      "EDDS5_ThreeMonths_Fear_GainWeight_opt_0": "0 - Not at all",
      "EDDS5_ThreeMonths_Fear_GainWeight_opt_1": "1",
      "EDDS5_ThreeMonths_Fear_GainWeight_opt_2": "2 - Slightly",
      "EDDS5_ThreeMonths_Fear_GainWeight_opt_3": "3",
