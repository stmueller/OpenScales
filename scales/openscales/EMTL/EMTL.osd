  "translations": {
    "en": {
      "likert_1": "Strongly agree",
      "likert_2": "Agree",
      "likert_3": "Neither agree nor disagree",
      "likert_4": "Disagree",
      "likert_5": "Strongly disagree",
      "question_head": "Please indicate the extent to which you agree or disagree with each of the following statements about your manager.",
      "emtl1": "The information I share with my manager is kept confidential.",
      "emtl2": "My manager regularly communicates with me.",
      "emtl3": "My manager is honest.",
      "emtl4": "My manager makes me feel secure.",
      "emtl5": "I have confidence that my manager can be trusted.",
      "emtl6": "Trust is reciprocated between my manager and I.",
      "emtl7": "My manager respects me.",
      "emtl8": "My manager and I interact regularly.",
      "emtl9": "My manager does what they say they will do.",
      "emtl10": "My manager shares information with me regularly.",
      "emtl11": "I can share my inner thoughts openly to my manager.",
      "emtl12": "I can relate to my manager because we have something in common.",
      "emtl13": "My manager and I are similar.",
      "emtl14": "My manager is not afraid to be vulnerable around me.",
      "emtl15": "My manager and I have shared interests or values.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
