{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Reproductive History - Female",
      "code": "PX101301",
      "abbreviation": "PX101301",
      "description": "The female participant is first asked how many pregnancies she has had. If none, the protocol is complete. For each pregnancy she reports, she is asked a series of questions (e.g., whether pregnancy was a live birth, how long the pregnancy lasted, when did the pregnancy end, whether the participant ",
      "domain": "Education",
      "citation": "Centers for Disease Control and Prevention. (2009). Pregnancy Risk Assessment Monitoring System (PRAMS). Phase 6 Core Questionnaire. http://www.cdc.gov/PRAMS/References/Phase6MailCore_FINAL.doc National Cancer Institute. (n.d.). Women’s Interview Study of Health. http://seer.cancer.gov/studies/epidemiology/study15.html [PhenX: https://www.phenxtoolkit.org/protocols/view/101301]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/101301"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
