  "translations": {
    "en": {
      "no_menstrual_period_3_more_months": "Since the age of 18, have you ever experienced a time interval of 3 or more months when you did not have a menstrual period?",
      "no_menstrual_period_3_more_months_opt_1": "No",
      "no_menstrual_period_3_more_months_opt_2": "Yes One time only",
      "no_menstrual_period_3_more_months_opt_3": "Yes More than once",
      "no_menstrual_period_3_more_months_opt__8": "Don't know",
      "no_menstrual_period_breastfeeding": "Were you breastfeeding at the time?",
      "no_menstrual_period_breastfeeding_pregnant_always": "Were you breastfeeding or pregnant every time this happened?",
      "menstrual_cycle_pattern_age_18_22": "During ages 18-22 what was the pattern of your menstrual cycles? (excluding time around pregnancies)",
      "menstrual_cycle_pattern_age_18_22_opt_1": "Regular (within 8 days)",
      "menstrual_cycle_pattern_age_18_22_opt_2": "Usually irregular",
      "menstrual_cycle_pattern_age_18_22_opt_3": "Always irregular",
      "menstrual_cycle_pattern_age_18_22_opt_4": "No periods",
      "menstrual_cycle_typical_days_average": "On average, during the last year, how many days were there in a typical menstrual cycle, that is, from the beginning of bleeding of one menstrual period to the beginning of bleeding of the next period?",
      "menstrual_cycle_typical_days_average_opt_1": "Less than 21 days",
      "menstrual_cycle_typical_days_average_opt_2": "21-25 days",
      "menstrual_cycle_typical_days_average_opt_3": "26-32 days",
      "menstrual_cycle_typical_days_average_opt_4": "33-35 days",
      "menstrual_cycle_typical_days_average_opt_5": "36-90 days",
      "menstrual_cycle_typical_days_average_opt_6": "More than 90 days",
      "menstrual_cycle_typical_days_average_opt_7": "Too variable to say",
      "menstrual_cycle_typical_days_average_opt__8": "Don't know",
      "menstrual_period_stop_permanently": "Have your menstrual periods stopped permanently?",
      "menstrual_period_stop_permanently_opt_1": "Yes, no menstrual periods",
      "menstrual_period_stop_permanently_opt_2": "Yes, but have periods now due to female hormones",
      "menstrual_period_stop_permanently_opt_3": "No",
      "menstrual_period_stop_permanently_opt_4": "Not sure",
      "menstrual_period_stop_age": "How old were you when your periods stopped?",
      "menstrual_period_stop_age_opt_1": "Less than 35",
      "menstrual_period_stop_age_opt_2": "35 - 39",
      "menstrual_period_stop_age_opt_3": "40 - 44",
      "menstrual_period_stop_age_opt_4": "45 - 49",
      "menstrual_period_stop_age_opt_5": "50 - 54",
      "menstrual_period_stop_age_opt_6": "55 or more",
      "opt_1": "No",
      "opt_2": "Yes",
      "opt_3": "Don't know"
    }
  }
}
