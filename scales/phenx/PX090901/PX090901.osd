  "translations": {
    "en": {
      "resp_history_intro": "SYMPTOMSThese questions pertain mainly to your chest. Please answer yes or no, if possible. If a question does not appear to be applicable to you, check the \"Does Not Apply\" space. If you are in doubt about whether your answer is yes or no, record no.",
      "cough_history": "COUGH  Do you usually have a cough? (Count a cough with first smoke or on first going out-of-doors. Exclude clearing of throat.)",
      "cough_frequently": "COUGH  Do you usually cough as much as 4 to 6 times a day, 4 or more days out of the week?",
      "cough_in_morning": "COUGH  Do you usually cough at all on getting up, or first thing in the morning?",
      "cough_day_night": "COUGH  Do you usually cough at all during the rest of the day or at night?",
      "cough_consecutive_months": "COUGH  Do you usually cough like this on most days for 3 consecutive months or more during the year?",
      "cough_years": "COUGH  For how many years have you had this cough?",
      "cough_years_coded": "COUGH  For how many years have you had this cough?",
      "phlegm_history": "PHLEGM  Do you usually bring up phlegm from your chest? (Count phlegm with the first smoke or on first going out-of-doors. Exclude phlegm from the nose. Count swallowed phlegm.)",
      "phlegm_frequently": "PHLEGM  Do you usually bring up phlegm like this as much as twice a day, 4 or more days out of the week?",
      "phlegm_in_morning": "PHLEGM  Do you usually bring up phlegm at all on getting up or first thing in the morning?",
      "phlegm_day_night": "PHLEGM  Do you usually bring up phlegm at all during the rest of the day or at night?",
      "phlegm_consecutive_months": "PHLEGM  Do you bring up phlegm like this on most days for 3 consecutive months or more during the year?",
      "phlegm_years": "PHLEGM  For how many years have you had trouble with phlegm?",
      "phlegm_years_coded": "PHLEGM  For how many years have you had trouble with phlegm?",
      "cough_phlegm_period_episode": "EPISODES OF COUGH AND PHLEGM  Have you had periods or episodes of (increased*) cough and phlegm lasting for 3 weeks or more each year? (*For individuals who usually have cough and/or phlegm)",
      "cough_phlegm_episode_lasting_time": "EPISODES OF COUGH AND PHLEGM  For how long have you had at least 1 such episode per year?",
      "cough_phlegm_episode_lasting_time_coded": "EPISODES OF COUGH AND PHLEGM  For how long have you had at least 1 such episode per year?",
      "wheezing_have_cold": "WHEEZING  Does your chest ever sound wheezy or whistling:  When you have a cold?",
      "wheezing_apart_from_cold": "WHEEZING  Does your chest ever sound wheezy or whistling:  Occasionally apart from colds?",
      "wheezing_day_night": "WHEEZING  Does your chest ever sound wheezy or whistling:  Most days or nights?",
      "wheezing_years": "WHEEZING  For how many years has this been present?",
      "wheezing_years_coded": "WHEEZING  For how many years has this been present?",
      "wheezing_attack_ever": "WHEEZING  Have you ever had an ATTACK of wheezing that has made you feel short of breath?",
      "wheezing_first_age": "WHEEZING  How old were you when you had your first such attack?",
      "wheezing_first_age_coded": "WHEEZING  How old were you when you had your first such attack?",
      "wheezing_attack_multiple_episodes": "WHEEZING  Have you had 2 or more such episodes?",
      "wheezing_attack_medicine_treatment_ever": "WHEEZING  Have you ever required medicine or treatment for the(se) attack(s)?",
      "breathlessness_condition_nature": "BREATHLESSNESS  If disabled from walking by any condition other than heart or lung disease, please describe Nature of condition(s):",
      "inst2_090901": "If disabled from walking by any condition other than heart or lung disease, please describe and proceed to CHEST COLDS AND CHEST ILLNESSES Questions.",
      "breathlessness_hurrying_slight_hill": "BREATHLESSNESS  Are you troubled by shortness of breath when hurrying on the level or walking up a slight hill?",
      "breathlessness_need_walk_slower": "BREATHLESSNESS  Do you have to walk slower than people of your age on the level because of breathlessness?",
      "breathlessness_need_stop_own_pace": "BREATHLESSNESS  Do you ever have to stop for breath when walking at your own pace on the level?",
      "breathlessness_need_stop_100_yards": "BREATHLESSNESS  Do you ever have to stop for breath after walking about 100 yards (or after a few minutes) on the level?",
      "breathlessness_leave_house_dressing_undressing": "BREATHLESSNESS  Are you too breathless to leave the house or breathless on dressing or undressing?",
      "cold_usually_go_to_chest": "CHEST COLDS AND CHEST ILLNESSES  If you get a cold, does it usually go to your chest? (Usually means more than 1/2 the time.)",
      "cold_usually_go_to_chest_opt_8": "Don't get colds",
      "chest_illness_keep_home_bed": "CHEST COLDS AND CHEST ILLNESSES  During the past 3 years, have you had any chest illnesses that have kept you off work, indoors at home, or in bed?",
      "chest_illness_phlegm": "CHEST COLDS AND CHEST ILLNESSES  Did you produce phlegm with any of these chest illnesses?",
      "chest_illness_phlegm_number": "CHEST COLDS AND CHEST ILLNESSES In the last 3 years, how many such illnesses, with (increased) phlegm, did you have which lasted a week or more? Number of illnesses:",
      "chest_illness_phlegm_lasting_week": "CHEST COLDS AND CHEST ILLNESSES  In the last 3 years, how many such illnesses, with (increased) phlegm, did you have which lasted a week or more?",
      "chest_illness_phlegm_lasting_week_opt_2": "No such illnesses",
      "lung_trouble_before_age_16": "PAST ILLNESSES - Lung Trouble  Did you have any lung trouble before the age of 16?",
      "bronchitis_ever": "PAST ILLNESSES - Bronchitis  Have you ever had Attacks of bronchitis?",
      "bronchitis_doctor_confirmed": "PAST ILLNESSES - Bronchitis  Was it confirmed by a doctor?",
      "bronchitis_first_age": "PAST ILLNESSES - Bronchitis  At what age was your first attack?",
      "bronchitis_first_age_coded": "PAST ILLNESSES - Bronchitis  At what age was your first attack?",
      "pneumonia_ever": "PAST ILLNESSES - Pneumonia  Have you ever had Pneumonia (include bronchopneumonia)?",
      "pneumonia_doctor_confirmed": "PAST ILLNESSES - Pneumonia  Was it confirmed by a doctor?",
      "pneumonia_first_age": "PAST ILLNESSES - Pneumonia  At what age did you first have it?",
      "pneumonia_first_age_coded": "PAST ILLNESSES - Pneumonia  At what age did you first have it?",
      "hay_fever_ever": "PAST ILLNESSES - Hay fever  Have you ever had Hay fever?",
      "hay_fever_doctor_confirmed": "PAST ILLNESSES - Hay fever  Was it confirmed by a doctor?",
      "hay_fever_start_age": "PAST ILLNESSES - Hay fever  At what age did it start?",
      "hay_fever_start_age_coded": "PAST ILLNESSES - Hay fever  At what age did it start?",
      "chronic_bronchitis_ever": "PAST ILLNESSES - Chronic Bronchitis  Have you ever had chronic bronchitis?",
      "chronic_bronchitis_still_have": "PAST ILLNESSES - Chronic Bronchitis  Do you still have it?",
      "chronic_bronchitis_doctor_confirmed": "PAST ILLNESSES - Chronic Bronchitis  Was it confirmed by a doctor?",
