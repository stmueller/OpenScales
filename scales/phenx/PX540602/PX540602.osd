  "translations": {
    "en": {
      "not_fearful_when_bad_happens": "I do not become fearful or nervous, even when something bad happens to me.",
      "not_fearful_when_bad_happens_opt_0": "Not true",
      "not_fearful_when_bad_happens_opt_1": "Somewhat true",
      "not_fearful_when_bad_happens_opt_2": "True",
      "not_fearful_when_bad_happens_opt_3": "Very true",
      "do_everything_to_get_things": "I do everything to get the things that I want.",
      "do_everything_to_get_things_opt_0": "Not true",
      "do_everything_to_get_things_opt_1": "Somewhat true",
      "do_everything_to_get_things_opt_2": "True",
      "do_everything_to_get_things_opt_3": "Very true",
      "like_to_keep_doing": "When I am doing well at something, I like to keep doing this.",
      "like_to_keep_doing_opt_0": "Not true",
      "like_to_keep_doing_opt_1": "Somewhat true",
      "like_to_keep_doing_opt_2": "True",
      "like_to_keep_doing_opt_3": "Very true",
      "pxt540602_willing_to_try_something_new": "I am always willing to try something new, when I think it will be fun.",
      "pxt540602_willing_to_try_something_new_opt_0": "Not true",
      "pxt540602_willing_to_try_something_new_opt_1": "Somewhat true",
