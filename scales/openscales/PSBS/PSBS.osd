  "translations": {
    "en": {
      "likert_0": "Strongly Disagree",
      "likert_1": "Disagree",
      "likert_2": "Agree",
      "likert_3": "Strongly Agree",
      "question_head": "Please indicate your level of agreement with each of the following statements.",
      "psbs1": "Your mind or soul can leave your body.",
      "psbs2": "If you break a mirror, you will have bad luck.",
      "psbs3": "It is possible to be reincarnated.",
      "psbs4": "Mind reading is possible.",
      "psbs5": "A person's star sign can have a direct influence on their personality.",
      "psbs6": "Fairies and similar beings are real.",
      "psbs7": "Fortune tellers' predictions are typically based on guesswork.",
      "psbs8": "Reports of an apparent sixth sense are generally based on fantasies.",
      "psbs9": "Some health conditions can be treated with psychic healing.",
      "psbs10": "In some cultures, shamans or \"witch doctors\" exercise powers we cannot explain.",
      "psbs11": "Having a dream that comes true is not just a coincidence.",
      "psbs12": "Communicating with spirits or other supernatural entities through a Ouija board is not possible.",
      "psbs13": "It is possible to become possessed by an evil supernatural entity.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
