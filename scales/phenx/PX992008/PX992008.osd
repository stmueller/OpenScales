{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Long COVID - Symptoms Due to COVID-19 - Temperature Regulation and Cardiovascular",
      "code": "PX992008",
      "abbreviation": "PX992008",
      "description": "This protocol helps better describe and understand the patient experience and recovery of those with confirmed or suspected COVID-19, with a specific emphasis on Long COVID experience especially with temperature regulation and cardiovascular.",
      "domain": "Health",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/992008]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/992008"
    },
