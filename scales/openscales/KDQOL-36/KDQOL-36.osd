{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Kidney Disease Quality of Life 36-Item Short Form",
      "code": "KDQOL-36",
      "abbreviation": "KDQOL-36",
      "description": "36-item health-related quality of life measure for patients with kidney disease, including those on dialysis. Contains a 12-item SF-12 generic core plus 3 kidney disease-specific subscales: Burden of Kidney Disease (4 items), Symptoms/Problems of Kidney Disease (12 items), and Effects of Kidney Disease on Daily Life (8 items). One additional overall health rating item (0–10 scale). All subscales scored 0–100 (higher = better quality of life). NOTE: SF-12 items are scored per the SF-12 manual (Ware et al., 1996); kidney-specific subscales are scored as means recoded to 0–100.",
      "citation": "Ware, J.E., Kosinki, M., Keller, S.D. (1996). SF-12: How to score the SF-12 Physical and Mental Health Summary Scales. Boston: The Health Institute; and Hays, R.D., Kallich, J.D., Mapes, D.L., Coons, S.J., & Carter, W.B. (1994). Development of the kidney disease quality of life (KDQOL) instrument. Quality of Life Research, 3(5), 329–338.",
      "license": "Public Domain",
      "version": "1.0",
      "url": "https://www.rand.org/health-care/surveys_tools/kdqol.html",
      "domain": "Health",
      "license_explanation": "RAND Corporation places their health survey instruments in the public domain. RAND explicitly states these instruments are available for use without permission or fee.",
      "license_url": "https://www.rand.org/health-care/surveys_tools/kdqol.html"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "dimensions": [
      {
        "id": "burden_kidney",
        "name": "Burden of Kidney Disease",
        "abbreviation": "BKD",
        "description": "Extent to which kidney disease takes too much time, is frustrating, burdens family, and creates financial burden. Items: kdqol36_13–kdqol36_16.",
        "enabled_param": null
      },
      {
        "id": "symptoms_problems",
        "name": "Symptoms/Problems of Kidney Disease",
        "abbreviation": "SP",
        "description": "Bothersomeness of 12 symptoms associated with kidney disease. Items: kdqol36_17–kdqol36_28.",
        "enabled_param": null
      },
      {
        "id": "effects_daily_life",
        "name": "Effects of Kidney Disease on Daily Life",
        "abbreviation": "EDL",
        "description": "Extent to which kidney disease limits daily activities and life domains. Items: kdqol36_29–kdqol36_36.",
        "enabled_param": null
      },
      {
        "id": "sf12_physical",
        "name": "SF-12 Physical Component Summary",
        "abbreviation": "PCS",
        "description": "SF-12 Physical Component Summary score. Items: kdqol36_1–kdqol36_12. Computed per SF-12 scoring algorithm.",
        "enabled_param": null
      },
      {
        "id": "sf12_mental",
        "name": "SF-12 Mental Component Summary",
        "abbreviation": "MCS",
        "description": "SF-12 Mental Component Summary score. Items: kdqol36_1–kdqol36_12. Computed per SF-12 scoring algorithm.",
        "enabled_param": null
      },
      {
        "id": "overall_health",
        "name": "Overall Health Rating",
        "abbreviation": "OH",
        "description": "Overall health rating on a 0–10 scale (0=worst, 10=best). Item: kdqol36_12.",
        "enabled_param": null
      }
    ],
