        "cfq_r4",
        "cfq_r5",
        "cfq_r6",
        "cfq_r7"
      ],
      "question_head": "cfq_inst"
    },
    "dimensions": [
      {
        "id": "fusion",
        "name": "Cognitive Fusion",
        "abbreviation": "CF",
        "description": "Sum of all 7 items (range 7–49). Higher scores indicate greater cognitive fusion — thoughts more dominantly regulate behavior."
      }
    ],
    "items": [
      {
