  "translations": {
    "en": {
      "likert_1": "Not at all typical of me",
      "likert_2": "Rarely typical of me",
      "likert_3": "Somewhat typical of me",
      "likert_4": "Often typical of me",
      "likert_5": "Very typical of me",
      "question_head": "Rate each of the following statements on a scale of 1 to 5, indicating how typical it is of you.",
      "pswq1": "If I do not have enough time to do everything, I do not worry about it.",
      "pswq2": "My worries overwhelm me.",
      "pswq3": "I do not tend to worry about things.",
      "pswq4": "Many situations make me worry.",
      "pswq5": "I know I should not worry about things, but I just cannot help it.",
      "pswq6": "When I am under pressure I worry a lot.",
      "pswq7": "I am always worrying about something.",
      "pswq8": "I find it easy to dismiss worrying thoughts.",
      "pswq9": "As soon as I finish one task, I start to worry about everything else I have to do.",
      "pswq10": "I never worry about anything.",
      "pswq11": "When there is nothing more I can do about a concern, I do not worry about it anymore.",
      "pswq12": "I have been a worrier all my life.",
      "pswq13": "I notice that I have been worrying about things.",
      "pswq14": "Once I start worrying, I cannot stop.",
      "pswq15": "I worry all the time.",
      "pswq16": "I worry about projects until they are all done.",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}