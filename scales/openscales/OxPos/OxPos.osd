  "translations": {
    "en": {
      "likert_0": "Do not believe it",
      "likert_1": "Believe it slightly",
      "likert_2": "Believe it moderately",
      "likert_3": "Believe it very much",
      "likert_4": "Believe it totally",
      "question_head": "Below are a series of beliefs that people may hold about themselves. Please rate how much you believe each of these statements about yourself, based on how you have viewed yourself over the <b>past week</b>.",
      "oxpos1": "I can make a difference",
      "oxpos2": "I am useful",
      "oxpos3": "I have a purpose",
      "oxpos4": "I can achieve things",
      "oxpos5": "I can do things well",
      "oxpos6": "I can succeed",
      "oxpos7": "I am worthwhile",
      "oxpos8": "I am strong",
      "oxpos9": "I can keep going",
      "oxpos10": "I can succeed in challenging situations",
      "oxpos11": "I can cope with anything",
      "oxpos12": "I rise to the challenge",
      "oxpos13": "I don't give up",
      "oxpos14": "I will be okay",
      "oxpos15": "I can do things as well as anyone else",
      "oxpos16": "I can enjoy things",
      "oxpos17": "I can relax",
      "oxpos18": "I can switch off",
      "oxpos19": "I can have fun",
      "oxpos20": "I can do fun things",
      "oxpos21": "I am reliable",
      "oxpos22": "I am thoughtful",
      "oxpos23": "I am a good person",
      "oxpos24": "I am helpful",
      "debrief": "Thank you for completing this questionnaire."
    }
  }
}
