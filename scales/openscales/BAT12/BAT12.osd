{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Burnout Assessment Tool – Short Form",
      "code": "BAT12",
      "abbreviation": "BAT-12",
      "description": "12-item short form of the Burnout Assessment Tool measuring core burnout symptoms across four subscales: Exhaustion (4 items), Mental Distance (3 items), Emotional Impairment (3 items), and Cognitive Impairment (2 items). Items use a 5-point frequency scale (1=Never to 5=Always). Subscale scores are means (range 1–5); a core burnout score is computed as the mean of Exhaustion and Mental Distance subscales. Higher scores indicate greater burnout.",
      "citation": "Schaufeli, W. B., De Witte, H., & Desart, S. (2020). Manual Burnout Assessment Tool (BAT) – Version 2.0. KU Leuven, Belgium. https://burnoutassessmenttool.be",
      "license": "CC BY 4.0",
      "version": "1.0",
      "url": "https://burnoutassessmenttool.be",
      "domain": "Work",
      "license_explanation": "CC BY 4.0. Published in IJERPH (MDPI open access).",
      "license_url": "https://doi.org/10.3390/ijerph17249495"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "bat_r1",
        "bat_r2",
        "bat_r3",
        "bat_r4",
        "bat_r5"
      ],
      "question_head": "bat_inst"
    },
    "dimensions": [
      {
        "id": "exhaustion",
        "name": "Exhaustion",
        "abbreviation": "EX",
        "description": "Feeling physically and mentally depleted by work (items 1–4). Mean range 1–5; higher = more exhaustion. Cut-off ≥3.00."
      },
      {
        "id": "mental_distance",
        "name": "Mental Distance",
        "abbreviation": "MD",
        "description": "Feeling aversion to and growing distance from work (items 5–7). Mean range 1–5; higher = more distancing. Cut-off ≥2.00."
      },
      {
        "id": "emotional_impairment",
        "name": "Emotional Impairment",
        "abbreviation": "EI",
        "description": "Difficulty controlling emotions at work (items 8–10). Mean range 1–5; higher = more emotional impairment."
      },
      {
        "id": "cognitive_impairment",
        "name": "Cognitive Impairment",
        "abbreviation": "CI",
        "description": "Difficulty concentrating and making decisions at work (items 11–12). Mean range 1–5; higher = more cognitive impairment."
      }
    ],
    "items": [
      {
        "id": "bat1",
        "text_key": "bat1",
        "type": "likert",
        "dimension": "exhaustion"
      },
      {
        "id": "bat2",
        "text_key": "bat2",
        "type": "likert",
        "dimension": "exhaustion"
      },
      {
        "id": "bat3",
