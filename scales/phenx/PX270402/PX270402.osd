  "translations": {
    "en": {
      "health_literacy_confidence_completing": "How confident are you filling out medical forms by yourself?",
      "health_literacy_confidence_completing_opt_1": "Extremely",
      "health_literacy_confidence_completing_opt_2": "Quite a bit",
      "health_literacy_confidence_completing_opt_3": "Somewhat",
      "health_literacy_confidence_completing_opt_4": "A little bit",
      "health_literacy_confidence_completing_opt_5": "Not at all",
      "health_literacy_help_reading": "How often do you have someone help you read health-related materials?",
      "health_literacy_help_reading_opt_1": "Always",
      "health_literacy_help_reading_opt_2": "Often",
      "health_literacy_help_reading_opt_3": "Sometimes",
      "health_literacy_help_reading_opt_4": "Occasionally",
      "health_literacy_help_reading_opt_5": "Never",
      "health_literacy_difficulty_understanding": "How often do you have problems learning about your medical condition because of difficulty understanding written information?",
