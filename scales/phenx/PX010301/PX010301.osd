    "scale_info": {
      "name": "Birthplace of Parents",
      "code": "PX010301",
      "abbreviation": "PX010301",
      "description": "The respondent completes the self-administered questionnaire by indicating his or her biological mothers place of birth. If he or she was born in the United States, an additional question captures the state, if known. If he or she was not born in the United States another open-ended question asks fo",
      "domain": "Demographics",
      "citation": "Public Population Project in Genomics (P3G) Data Schema and Harmonization Platform for Epidemiological Research (DataSHaPER). U.S. Census Bureau. (2007). 2006 American Community Survey Content Test Report P.1. Evaluation report covering place of birth, U.S. citizenship status, and year of arrival. Washington, DC: Author. [PhenX: https://www.phenxtoolkit.org/protocols/view/10301]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/10301"
    },
    "implementation": {
