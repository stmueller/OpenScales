    "scoring": {
      "physical_functioning": {
        "description": "Physical Functioning (2 items). Higher = less limitation.",
        "method": "mean_coded",
        "items": [
          "sf12_2",
          "sf12_3"
        ]
      },
      "role_physical": {
        "description": "Role Limitations — Physical (2 items). Higher = less limitation.",
        "method": "mean_coded",
        "items": [
          "sf12_4",
          "sf12_5"
        ]
      },
      "role_emotional": {
        "description": "Role Limitations — Emotional (2 items). Higher = less limitation.",
        "method": "mean_coded",
        "items": [
          "sf12_6",
          "sf12_7"
        ]
      },
      "mental_health": {
        "description": "Mental Health (2 items: calm/peaceful, downhearted). Item 12 reverse-coded. Higher = better mental health.",
        "method": "mean_coded",
        "items": {
          "sf12_10": -1,
          "sf12_12": 1
        }
      }
    },
    "report": {
      "template": "standard",
