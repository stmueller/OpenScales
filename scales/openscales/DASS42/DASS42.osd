  "translations": {
    "ar": {
      "likert_1": "لا ينطبق علي بتاتاً",
      "likert_2": "ينطبق علي بعض الشيء أو قليلاً من الأوقات",
      "likert_3": "ينطبق علي بدرجة ملحوظة أو بعض الأوقات",
      "likert_4": "ينطبق علي كثيراً جداً، أو معظم الأوقات",
      "d1": "وجدت أنني مضطرب ومنزعج بسبب أمور تافهة جداً",
      "d2": "شعرت بجفاف في حلقي",
      "d3": "لم يبدو لي أن بإمكاني الإحساس بمشاعر إيجابية على الإطلاق",
      "d4": "شعرت بصعوبة في التنفس (شدة التنفس السريع، اللهثان بدون القيام بمجهود جسدي مثلاً)",
      "d5": "لم يبدو لي أن بإمكاني أن أبدأ في القيام بأعمالي",
      "d6": "كنت أميل إلى ردة فعل مفرطة للظروف والأحداث",
      "d7": "شعرت بالرجفة (إن رجلي لا تقوى على حملي مثلاً)",
      "d8": "أجد صعوبة في الاسترخاء",
      "d9": "وجدت نفسي في مواقف جعلتني قلقاً جداً، وكنت مرتاحاً للغاية بزوالها",
      "d10": "شعرت بأن ليس لدي أي شيء أتطلع إليه",
      "d11": "وجدت نفسي أميل إلى الاضطراب والانزعاج بسهولة",
      "d12": "شعرت بأنني أستهلك الكثير في الطاقة العصبية (شعرت بأنني أستهلك الكثير من قدرتي على تحمل التوتر العصبي)",
      "d13": "شعرت بالحزن والاكتئاب",
      "d14": "وجدت أنني قليل الصبر كلما أخرني شيء (عند انتظار المصعد، إشارات المرور، أو كلما طُلب مني الانتظار، مثلاً)",
      "d15": "انتابني شعور بالإغماء",
      "d16": "شعرت بأنني فقدت الاهتمام بكل شيء تقريباً",
      "d17": "كشخص شعرت بأن قيمتي قليلة",
      "d18": "شعرت بأنني أميل إلى الغيظ بسرعة",
      "d19": "عرقت بشكل ملحوظ (عرق غزير من اليدين مثلاً) بدون أن يكون الطقس حاراً وبدون بذل مجهود جسدي",
      "d20": "شعرت بالخوف بدون أي سبب وجيه",
      "d21": "شعرت بأن الحياة لا قيمة لها",
      "d22": "وجدت صعوبة في الاسترخاء والراحة",
      "d23": "كان لدي صعوبة في البلع",
      "d24": "لم أشعر بالاستمتاع بأي شيء أفعله",
      "d25": "شعرت بضربات قلبي بدون مجهود جسدي (زيادة في معدل الدقات، أو غياب دقة قلب، مثلاً)",
      "d26": "شعرت بالحزن والغم",
      "d27": "شعرت بأنني أنزعج بسرعة",
      "d28": "شعرت بأنني على وشك الوقوع في حالة من الرعب المفاجئ بدون سبب",
      "d29": "أجد صعوبة في استعادة هدوئي بعد انزعاجي من شيء ما",
      "d30": "كنت أخاف من مواجهة عمل بديهي لكنه غير مألوف لدي",
      "d31": "فقدت الشعور بالحماس لأي شيء",
      "d32": "لم أعد أحتمل مقاطعة الآخرين لأعمالي",
      "d33": "كنت في حالة توتر عصبي",
      "d34": "شعرت بعدم القيمة إلى حد ما",
      "d35": "كنت لا أستطيع تحمل أي شيء يحول بيني وبين ما أرغب في القيام به",
      "d36": "شعرت بالهلع والرعب",
      "d37": "لم أر في المستقبل ما يبعث على الأمل",
      "d38": "شعرت بأن الحياة ليس لها معنى",
      "d39": "شعرت بأنني مضطرب ومنزعج",
      "d40": "كنت خائفاً من مواقف قد أفقد فيها السيطرة على أعصابي وأسبب إحراجاً لنفسي",
      "d41": "شعرت برجفة (باليدين مثلاً)",
      "d42": "وجدت صعوبة في أخذ المبادرة بعمل الأشياء",
      "debrief": ""
    },
    "bg": {
      "d1": "Разстройвам се от напълно обикновени неща",
      "d2": "Усещам сухота в устата си",
      "d3": "Не изпитвам положителни емоции",
      "d4": "Имам трудности с дишането",
      "d5": "Не мога да се задействам да се занимавам с нещата си",
      "d6": "Реагирам прекалено категорично на ситуациите",
      "d7": "Усещам слабост в крайниците си",
      "d8": "Трудно ми е да се отпусна (и релаксирам)",
      "d9": "Повечето ситуации ме правят толкова тревожен и напрегнат, че чувствам облекчение когато свършат",
      "d10": "Не очаквам нищо с нетърпение",
      "d11": "Разстройвам се прекалено лесно",
      "d12": "Лесно се нервирам",
      "d13": "Чувствам се тъжен и депресиран",
      "d14": "Нямам търпение да изчакам в ситуации, които ме бавят",
      "d15": "Имам усещане, че мога да припадна",
      "d16": "Изгубил съм интерес към почти всичко",
      "d17": "Чувствам се малоценен",
      "d18": "Станал съм докачлив",
      "d19": "Изпотявам се значително при липса на физическо усилие",
      "d20": "Чувствам се уплашен без причина",
      "d21": "Чувствам, че живота не си заслужава",
      "d22": "Трудно ми е да се успокоя (след изпитано напрежение)",
      "d23": "Имам трудности с преглъщането",
      "d24": "Нещата, с които се занимавам не ми доставят удоволствие",
      "d25": "Усещам учестен или променен сърдечния си пулс",
      "d26": "Чувствам се обезсърчен и потиснат",
      "d27": "Станал съм много раздразнителен",
      "d28": "Лесно се паникьосвам",
      "d29": "Трудно се успокоявам, след като нещо ме е разстроило",
      "d30": "Страхувам се, че няма да мога да се справя с някоя тривиална, но непозната за мен задача",
      "d31": "Нищо не ме вълнува и ентусиазира",
      "d32": "Трудно понасям да бъда прекъсван",
      "d33": "Чувствам се напрегнат",
      "d34": "Чувствам се безполезен",
      "d35": "Трудно се сдържам да не се ядосам когато нещо ми попречи да продължа с това, с което се занимавам",
      "d36": "Чувствам се ужасѐн",
      "d37": "Не виждам нищо в бъдещето, което да ме радва",
      "d38": "Чувствам, че живота е безсмислен",
      "d39": "Лесно се превъзбуждам и започвам да се безпокоя",
      "d40": "Притеснен съм да не попадна в ситуация, в която мога да се паникьосам и да се изложа",
      "d41": "Чувствам тялото ми да трепери",
      "d42": "Трудно поемам инициативата при изпълнението на задачи",
      "debrief": ""
    },
    "bs": {
      "likert_1": "Nimalo",
      "likert_2": "Pomalo ili ponekad",
      "likert_3": "U priličnoj mjeri ili često",
      "likert_4": "Uglavnom ili skoro uvijek",
      "d1": "Primjetio sam da me i sitnice uznemire.",
      "d2": "Usta su mi se sušila.",
      "d3": "Nisam mogao doživjeti bilo kakvo pozitivno osjećanje.",
      "d4": "Imao sam poteškoća sa disanjem (npr, pretjerano ubrzano disanje, zadihanost i",
      "d5": "Izgledalo je kao da se nisam mogao pokrenuti.",
      "d6": "Sklon sam pretjeranim reakcijama u nekim situacijama.",
      "d7": "Osjećao sam nestabilnost (npr. kao da će me noge izdati).",
      "d8": "Bilo mi je teško opustiti se.",
      "d9": "Neke situacije su mi bile tako tjeskobne da mi je baš laknulo kada su se završile.",
      "d10": "Osjećao sam da se nemam čemu radovati.",
      "d11": "Primjetio sam da se prilično lako uzrujam.",
      "d12": "Puno sam energije trošio na brige, strepnje i slično.",
      "d13": "Osjećao sam se tužno i depresivno.",
      "d14": "Primjetio sam da postajem nestrpljiv kada moram nešto čekati (npr. lift, u nekom",
      "d15": "Imao sam osjećaj slabosti, kao da ću se onesvijestiti.",
      "d16": "Primjetio sam da sam izgubio interes za većinu stvari.",
      "d17": "Osjećao sam da nisam osoba koja puno vrijedi.",
      "d18": "Bio sam jako osetljiv.",
      "d19": "Vidno sam se znojio (npr. mokri dlanovi), iako nije bilo vruće niti sam se fizički",
      "d20": "Osjećao sam se uplašeno bez nekog razloga.",
      "d21": "Osjećao sam da život nije vrijedan.",
      "d22": "Bilo mi je teško smiriti se.",
      "d23": "Imao sam poteškoća sa gutanjem.",
      "d24": "Nisam mogao uživati u onome što sam radio.",
      "d25": "Osjećao sam lupanje srca i bez fizičkog napora (npr. ubrzano lupanje srca,",
      "d26": "Osjećao sam se sjetno i potišteno.",
      "d27": "Bio sam veoma razdražljiv.",
      "d28": "Osjećao sam da sam blizu panike.",
      "d29": "Bilo mi je teško smiriti se nakon što me nešto uzruja.",
      "d30": "Plašim se da se ne zbunim pred nekim laganim ali nepoznatim zadatkom.",
      "d31": "Ništa nije moglo da me zainteresuje.",
      "d32": "Bilo mi je teško tolerisati da me nešto ili neko prekida u onome što sam radio.",
      "d33": "Osjećao sam napetost.",
      "d34": "Osjećao sam se prilično bezvrijedno.",
      "d35": "Bio sam netolerantan prema svemu što me je ometalo u onome što sam radio.",
      "d36": "Bio sam prestrašen.",
      "d37": "U budućnosti nisam mogao vidjeti ništa optimistično.",
      "d38": "Osjećao sam da je život besmislen.",
      "d39": "Primjetio sam da se vidljivo uznemirim.",
      "d40": "Bojao sam se situacija u kojima bih mogao da se uspaničim i napravim budalu",
      "d41": "Doživio sam da se tresem (npr. tresle su mi se ruke).",
      "d42": "Bilo mi je teško pokrenuti se da bilo šta započnem.",
      "debrief": ""
    },
    "cs": {
      "likert_1": "Neplatí to pro mě vůbec",
      "likert_2": "Platí to pro mě částečně, někdy",
      "likert_3": "Platí to pro mě do značné míry nebo značnou část času",
      "likert_4": "Platí to pro mě úplně nebo většinu času",
      "d1": "Rozzlobily mě triviální věci.",
      "d2": "Pociťoval/a jsem sucho v ústech.",
      "d3": "Neprožíval/a jsem žádné pozitivní pocity.",
      "d4": "Měl/a jsem problém s dýcháním (např. dýchal/a jsem velmi rychle nebo jsem lapal/a po dechu, i když jsem nevykonával/a fyzickou aktivitu).",
      "d5": "Neměl/a jsem sílu pokračovat.",
      "d6": "V určitých situacích jsem reagoval/a přehnaně.",
      "d7": "Měl/a jsem pocit, že se třesu (např. nohy, kolena apod.).",
      "d8": "Bylo pro mě těžké relaxovat.",
      "d9": "Ocitl/a jsem se v situacích, ve kterých jsem cítil/a takovou úzkost, že se mi ulevilo, když skončily.",
      "d10": "Měl/a jsem pocit, že neexistuje nic, na co bych se těšil/a.",
      "d11": "Zjistil/a jsem, že se velmi rychle rozzlobím.",
      "d12": "Cítil/a jsem se velmi nervózně a musel/a jsem s tím něco udělat.",
      "d13": "Cítil/a jsem se smutný/á a depresivní.",
      "d14": "Byl/a jsem neklidný, když jsem se opozdil/a (kvůli výtahu, provozu, když jsem musel/a někde čekat apod.).",
      "d15": "Měl/a jsem pocit, že omdlím.",
      "d16": "Měl/a jsem pocit, že jsem ztratil/a zájem o všechno.",
      "d17": "Měl/a jsem pocit, že jako člověk za moc nestojím.",
      "d18": "Cítil/a jsem, že reaguji přecitlivěle.",
      "d19": "Potil/a jsem se, i když nebylo teplo a nevykonával/a jsem fyzickou aktivitu (např. dlaně).",
      "d20": "Bál/a jsem se i bez zjevného důvodu.",
      "d21": "Cítil/a jsem, že život nemá smysl.",
      "d22": "Měl/a jsem problém se uklidnit.",
      "d23": "Měl/a jsem potíže s polykáním.",
      "d24": "Nenacházel/a jsem žádné potěšení ve věcech, které jsem dělal/a.",
      "d25": "Vnímal/a jsem tlukot svého srdce (např. zrychlená činnost srdce,",
      "d26": "Cítil/a jsem se smutně a sklíčeně.",
      "d27": "Byl/a jsem podrážděný/á.",
      "d28": "Cítil/a jsem, že podléhám panice.",
      "d29": "Bylo pro mě těžké uklidnit se po tom, když mě něco rozzlobilo.",
      "d30": "Obával/a jsem se, že mě rozhodí nějaká jednoduchá, ale neznámá úloha.",
      "d31": "Nedokázal/a jsem se pro nic nadchnout.",
      "d32": "Těžko jsem snášel/a, když mě něco vyrušilo při práci.",
      "d33": "Byl/a jsem napjatý/á.",
      "d34": "Cítil/a jsem se úplně bezcenný/á.",
      "d35": "Nesnesl/a jsem, když mě něco odvádělo od toho, co jsem dělal/a.",
      "d36": "Cítil/a jsem se vyděšeně/vystrašeně.",
      "d37": "Budoucnost se mi zdála beznadějná.",
      "d38": "Cítil/a jsem, že život nemá smysl.",
      "d39": "Cítil/a jsem se rozrušený/á.",
      "d40": "Obával/a jsem se situací, ve kterých bych mohl/a podlehnout",
      "d41": "Třásl/a jsem se (např. ruce).",
      "d42": "Bylo pro mě těžké převzít iniciativu (začít něco dělat).",
      "debrief": ""
    },
    "da": {
      "likert_1": "Passede ikke på mig",
      "likert_2": "Passede en smule eller noget af tiden på mig",
      "likert_3": "Passede I betydelig grad eller en stor del af tiden på mig",
      "likert_4": "Passede rigtigt meget eller det meste af tiden på mig",
      "d1": "Jeg blev bragt ud af ligevægt af ret ligegyldige ting",
      "d2": "Jeg var opmærksom på tørhed i munden",
      "d3": "Jeg kunne ikke opleve nogen som helst positive følelser",
      "d4": "Jeg oplevede vejrtrækningsbesvær (fx udtalt hurtig vejrtrækning, åndenød uden fysisk anstrengelse)",
      "d5": "Jeg kunne bare ikke komme i gang",
      "d6": "Jeg var tilbøjelig til at overreagere på situationer",
      "d7": "Jeg havde en fornemmelse af rysten eller sitren (fx som om benene ville give efter under mig)",
      "d8": "Jeg havde svært ved at slappe af",
      "d9": "Jeg befandt mig i situationer, der gjorde mig så angst, at jeg var særdeles lettet, når de var overstået",
      "d10": "Jeg følte, at jeg ikke havde noget at se frem til",
      "d11": "Jeg blev meget let blev bragt ud af fatning",
      "d12": "Jeg følte, at jeg brugte en masse psykisk energi",
      "d13": "Jeg følte mig trist og deprimeret",
      "d14": "Jeg blev utålmodig, hvis jeg på nogen måde blev forsinket (fx ved elevatorer, trafiklys, at skulle vente)",
      "d15": "Jeg følte mig svimmel",
      "d16": "Jeg følte, at jeg havde mistet interessen for stort set alt",
      "d17": "Jeg følte mig ikke meget værd som person",
      "d18": "Jeg følte mig noget nærtagende",
      "d19": "Jeg svedte mærkbart (fx svedige hænder), selvom det ikke var varmt, og jeg ikke havde anstrengt mig fysisk",
      "d20": "Jeg følte mig bange uden nogen rimelig grund",
      "d21": "Jeg følte, at livet ikke var værd at leve",
      "d22": "Det var svært for mig at slappe af",
      "d23": "Jeg oplevede synkebesvær",
      "d24": "Jeg kunne ikke finde glæde ved de ting, jeg foretog mig",
      "d25": "Jeg var opmærksom på min hjerterytme, selvom jeg ikke anstrengte mig fysisk (fx fornemmelse af øget puls, overspring af hjerteslag)",
      "d26": "Jeg følte mig modløs og trist",
      "d27": "Jeg var meget irritabel",
      "d28": "Jeg følte mig tæt på panik",
      "d29": "Jeg havde svært ved at berolige mig selv, hvis noget bragte mig ud af balance",
      "d30": "Jeg frygtede, at jeg ville blive ”væltet” af en eller anden simpel, men uvant opgave",
      "d31": "Jeg kunne ikke være entusiastisk over noget som helst",
      "d32": "Det var svært at tåle afbrydelser i det, jeg foretog mig",
      "d33": "Jeg var nervøs og anspændt",
      "d34": "Jeg følte mig temmelig værdiløs",
      "d35": "Jeg kunne ikke holde ud at blive afbrudt, når jeg var i gang med noget",
      "d36": "Jeg følte mig rædselsslagen",
      "d37": "Jeg kunne ikke se noget håb for fremtiden",
      "d38": "Jeg følte, at livet var meningsløst",
      "d39": "Jeg følte mig urolig og rastløs",
      "d40": "Jeg var bekymret for situationer, hvor jeg kunne gå i panik og gøre mig selv til grin",
      "d41": "Jeg oplevede at ryste (fx på hænderne)",
      "d42": "Jeg fandt det svært at tage initiativ til at foretage mig noget",
      "debrief": ""
    },
    "de": {
      "likert_1": "Traf überhaupt nie zu",
      "likert_2": "Traf manchmal zu",
      "likert_3": "Traf häufig zu",
      "likert_4": "Traf meistens zu",
      "d1": "Ich merkte, dass ich mich über ganz banale Kleinigkeiten aufregte.",
      "d2": "Ich hatte einen trockenen Mund.",
      "d3": "Ich konnte kein positives Gefühl empfinden.",
      "d4": "Ich hatte Atembeschwerden. (z. B. übermässig schnelles Atmen oder Kurzatmigkeit trotz fehlender körperlicher Anstrengung)",
      "d5": "Ich bin nicht in die Gänge gekommen.",
      "d6": "Ich habe auf Situationen überreagiert.",
      "d7": "Ich fühlte mich zittrig. (z. B. ein Gefühl wackeliger Beine)",
      "d8": "Ich hatte Mühe, mich zu entspannen.",
      "d9": "Ich befand mich in Situationen, in denen ich solche Angst verspürte, dass ich extrem erleichtert war, als sie dann vorbei waren.",
      "d10": "Ich fühle mich, als ob es nichts gebe, worauf ich mich hätte freuen können.",
      "d11": "Ich habe mich schnell aufgeregt.",
      "d12": "Ich habe viel Energie mit meiner Nervosität verbraucht.",
      "d13": "Ich fühlte mich traurig und depressiv.",
      "d14": "Ich wurde schnell ungeduldig, wenn ich auf etwas warten musste. (z. B. den Fahrstuhl oder die grüne Ampel)",
      "d15": "Ich hatte ein Gefühl der Ohnmacht.",
      "d16": "Ich fühlte mich, als ob ich das Interesse an so ziemlich allem verloren hatte.",
      "d17": "Ich glaubte, dass ich als Mensch nicht viel wert war.",
      "d18": "Ich merkte, dass ich ziemlich empfindlich sein konnte.",
      "d19": "Ich habe ziemlich geschwitzt (z. B. an den Händen), obwohl keine hohen Temperaturen herrschten oder ich mich körperlich angestrengt hätte.",
      "d20": "Ich fühlte mich grundlos ängstlich.",
      "d21": "Ich hatte den Gedanken, dass sich das Leben nicht lohnt.",
      "d22": "Es fiel mir schwer, abzuschalten und mich zu entspannen.",
      "d23": "Ich hatte Mühe mit dem Schlucken.",
      "d24": "Ich verspürte überhaupt keine Freude, an dem, was ich tat.",
      "d25": "Ich fühlte, wie mein Herzschlag sich veränderte, obwohl ich mich körperlich nicht anstrengte. (z. B. Erhöhte Herzfrequenz oder Herzaussetzer)",
      "d26": "Ich war niedergeschlagen und trübsinnig.",
      "d27": "Ich merkte, dass ich sehr reizbar war.",
      "d28": "Ich fühlte mich, als ob ich kurz davor war, in Panik zu geraten.",
      "d29": "Es fiel mir schwer mich zu beruhigen, nachdem mich etwas aufgeregt hatte.",
      "d30": "Ich befürchtete, dass mich eine triviale, jedoch ungewohnte Aufgabe gleich aus der Bahn werfen würde.",
      "d31": "Es gelang mir nicht, mich für irgendetwas zu begeistern.",
      "d32": "Ich fand es schwierig, Unterbrechungen meiner Arbeit zu tolerieren.",
      "d33": "Ich befand mich in einem Zustand nervöser Anspannung.",
      "d34": "Ich kam mir ziemlich wertlos vor.",
      "d35": "Ich war intolerant gegenüber allem, das mich davon abhielt, meine Beschäftigung fortzusetzen.",
      "d36": "Ich fühlte mich angsterfüllt.",
      "d37": "Ich hatte keine hoffnungsvollen Gedanken für die Zukunft.",
      "d38": "Ich dachte, das Leben sei sinnlos.",
      "d39": "Ich fühlte mich aufgewühlt.",
      "d40": "Ich sorgte mich über Situationen, in denen ich panisch reagieren und mich blamieren könnte.",
      "d41": "Ich habe gezittert (z. B. in den Händen)",
      "d42": "Es fiel mir schwer, aus Eigeninitiative etwas zu tun.",
      "debrief": ""
    },
    "el": {
      "likert_1": "Δεν μου ταιριάζει καθόλου",
      "likert_2": "Μου ταιριάζει σε κάποιο βαθμό ή σε κάποιες στιγμές",
      "likert_3": "μου ταιριάζει σε μεγάλο βαθμό ή το για μεγάλο  χρονικό διάστημα",
      "likert_4": "Μου ταιριάζει πάρα πολύ ή το μεγαλύτερο χρονικό διάστημα",
      "d1": "Έπιασα  τον εαυτό μου να αναστατώνεται  από αρκετά  ασήμαντα πράγματα",
      "d2": "Ένιωθα  ότι το στόμα μου ήταν ξηρό",
      "d3": "Δεν μπορούσα   να βιώσω κανένα  θετικό συναίσθημα",
      "d4": "Δυσκολευόμουν  ν’ ανασάνω (π.χ., υπερβολικά γρήγορη αναπνοή, κόψιμο της ανάσας μου χωρίς να έχω κάνει σωματική προσπάθεια )",
      "d5": "Μου φαινόταν πως δεν μπορούσα να κινητοποιηθώ",
      "d6": "Είχα την τάση να αντιδρώ υπερβολικά στις καταστάσεις που αντιμετώπιζα",
      "d7": "Είχα ένα αίσθημα τρεμούλας  (π.χ., σαν να μου κόβονται τα πόδια)",
      "d8": "Μου ήταν  δύσκολο να χαλαρώσω",
      "d9": "Βρέθηκα σε καταστάσεις  που με έκαναν  να έχω τόσο  άγχος που ένιωσα   ανακουφισμένος όταν τελείωσαν",
      "d10": "Ένιωσα  ότι δεν είχα τίποτα να προσμένω με ενδιαφέρον",
      "d11": "Έπιασα τον εαυτό μου να αναστατώνεται αρκετά  εύκολα",
      "d12": "Αισθανόμουν συχνά νευρικότητα",
      "d13": "Ένιωθα  λυπημένα και καταθλιπτικά",
      "d14": "Έπιασα τον εαυτό μου να γίνεται ανυπόμονος όταν καθυστερούσα με οποιοδήποτε τρόπο (π.χ., σε ανελκυστήρες,  στα φανάρια  κυκλοφορίας,  όταν με έκαναν να περιμένω)",
      "d15": "Είχα μια αίσθηση λιποθυμίας",
      "d16": "Ένιωθα  ότι είχα χάσει το ενδιαφέρον μου σχεδόν για όλα τα πράγματα",
      "d17": "Ένιωσα  ότι δεν άξιζα πολύ ως άτομο",
      "d18": "Ένιωσα  ότι ήμουν αρκετά ευερέθιστος",
      "d19": "Ίδρωνα σε εμφανή σημεία (π.χ.,  χέρια ιδρωμένα) χωρίς να υπάρχουν  υψηλές θερμοκρασίες ή να έχω κάνει σωματική άσκηση",
      "d20": "Ένιωσα φοβισμένος χωρίς να υπάρχει λόγος",
      "d21": "Ένιωσα πως η ζωή δεν είναι σημαντική",
