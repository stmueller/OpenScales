  "translations": {
    "en": {
      "info_630501": "Medical Outcomes Study (MOS) Social Support SurveyPeople sometimes look to others for companionship, assistance, or other types of support. How often is each of the following kinds of support available to you if you need it? Select one in each box.",
      "support_confined_bed": "Someone to help you if you were confined to bed.",
      "support_confined_bed_opt_1": "1- none of the time",
      "support_confined_bed_opt_2": "2- A little of the time",
      "support_confined_bed_opt_3": "3- Some of the Time",
      "support_confined_bed_opt_4": "4- Most of the Time",
      "support_confined_bed_opt_5": "5- All of the Time",
      "support_listen": "Someone you can count on to listen to you when you need to talk.",
      "support_listen_opt_1": "1- none of the time",
      "support_listen_opt_2": "2- A little of the time",
      "support_listen_opt_3": "3- Some of the Time",
      "support_listen_opt_4": "4- Most of the Time",
      "support_listen_opt_5": "5- All of the Time",
      "support_good_advice": "Someone to give you good advice about a crisis.",
      "support_good_advice_opt_1": "1- none of the time",
      "support_good_advice_opt_2": "2- A little of the time",
      "support_good_advice_opt_3": "3- Some of the Time",
      "support_good_advice_opt_4": "4- Most of the Time",
      "support_good_advice_opt_5": "5- All of the Time",
      "support_transport_doctor": "Someone to take you to the doctor if you needed it.",
      "support_transport_doctor_opt_1": "1- none of the time",
      "support_transport_doctor_opt_2": "2- A little of the time",
      "support_transport_doctor_opt_3": "3- Some of the Time",
      "support_transport_doctor_opt_4": "4- Most of the Time",
      "support_transport_doctor_opt_5": "5- All of the Time",
      "support_love_affection": "Someone who shows you love and affection.",
      "support_love_affection_opt_1": "1- none of the time",
      "support_love_affection_opt_2": "2- A little of the time",
      "support_love_affection_opt_3": "3- Some of the Time",
      "support_love_affection_opt_4": "4- Most of the Time",
      "support_love_affection_opt_5": "5- All of the Time",
      "support_good_time": "Someone to have a good time with.",
      "support_good_time_opt_1": "1- none of the time",
      "support_good_time_opt_2": "2- A little of the time",
      "support_good_time_opt_3": "3- Some of the Time",
      "support_good_time_opt_4": "4- Most of the Time",
      "support_good_time_opt_5": "5- All of the Time",
      "support_information_help": "Someone to give you information to help you understand a situation.",
      "support_information_help_opt_1": "1- none of the time",
      "support_information_help_opt_2": "2- A little of the time",
      "support_information_help_opt_3": "3- Some of the Time",
      "support_information_help_opt_4": "4- Most of the Time",
      "support_information_help_opt_5": "5- All of the Time",
      "support_confide_problems": "Someone to confide in or talk to about yourself or your problems.",
      "support_confide_problems_opt_1": "1- none of the time",
      "support_confide_problems_opt_2": "2- A little of the time",
      "support_confide_problems_opt_3": "3- Some of the Time",
      "support_confide_problems_opt_4": "4- Most of the Time",
      "support_confide_problems_opt_5": "5- All of the Time",
      "support_hugs": "Someone who hugs you.",
