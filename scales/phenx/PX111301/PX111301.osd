          {
            "text_key": "contact_lenses_sleep_with_opt_3",
            "value": 3
          }
        ]
      }
    ]
  },
  "translations": {
    "en": {
      "contact_lenses_currently": "Do you currently wear contact lenses?",
      "contact_lenses_currently_opt_1": "yes",
      "contact_lenses_currently_opt_2": "no",
      "contact_lenses_ever": "Have you ever worn contact lenses?",
      "contact_lenses_ever_opt_1": "yes",
      "contact_lenses_ever_opt_2": "no",
      "contact_lenses_consider_next_year": "Are you considering wearing contact lenses in the next year?",
      "contact_lenses_consider_next_year_opt_1": "yes",
      "contact_lenses_consider_next_year_opt_2": "no",
      "contact_lenses_type": "What type of contact lenses do you wear?",
      "contact_lenses_type_opt_1": "soft",
      "contact_lenses_type_opt_2": "hard",
      "contact_lenses_type_opt_3": "gas permeable",
      "contact_lenses_type_opt_4": "not known",
      "contact_lenses_sleep_with": "Do you sleep with your contact lenses in?",
      "contact_lenses_sleep_with_opt_1": "no",
      "contact_lenses_sleep_with_opt_2": "sometimes",
      "contact_lenses_sleep_with_opt_3": "usually"
    }
  }
