  "translations": {
    "en": {
      "amblyopia_crossed_wandering_eye_ever": "Have you ever had a crossed or wandering eye (amblyopia)?",
      "double_vision_ever": "Have you ever had double vision?",
      "tilt_head_looking_straight_ever": "Do you ever tilt your head when looking straight?",
      "eye_muscle_surgery": "Have you ever undergone eye muscle surgery?",
      "patch_eye_drops_correction_ever": "Have you ever worn a patch or used eye drops (atropine penalization) for eye correction?",
      "glasses_contacts_ever": "Have you ever worn glasses or contacts?",
      "details_question_1_to_6": "If you answered YES to any of the above questions (about wandering eye/amblyopia, double vision, tilting head when looking straight, eye muscle surgery, patch/eye drops, glasses/contacts), please provide further details (i.e., age of onset of eye condition, dates of surgery, name of procedure if known, reason for glasses, etc.)",
      "coloboma_absence_defect_ocular_tissue": "Do you have a coloboma? (Absence or defect of ocular tissue ranging from a small pit in the optic disk to extensive defects in the iris, ciliary body, choroid, retina, or optic disk)",
      "microphthalmia_abnormally_small_eye": "Do you have microphthalmia? (Abnormally small eye)",
      "epibulbar_dermoids_eye_tumor": "Do you have epibulbar dermoid? (Eye tumors that are not recurrent or progressive)",
      "abnormal_ocular_features": "Do you have any abnormal ocular features? (e.g., epicanthal folds---tissue overlapping the nasal corner of the eye, telecanthus---increased distance between the inner corners of the eyes, slanting of the palpebral fissure(s)---opening for the eyes between the eyelids?)",
      "retinal_defect_tear_detachment": "Do you have any retinal defects? (retinal tears, detachments, etc.)",
      "other_visual_impairment": "Do you have any visual impairment other than previously noted?",
      "details_question_8_to_13": "If you answered YES to any question above (coloboma, microphthalmia, epibulbar dermoids, abnormal ocular features, retinal defects, other visual impairment), please describe.",
      "family_ocular_history_heading": "Family Ocular History Chart:",
      "glasses_before_6_other_relative_enum": "Glasses before age 6:",
      "glasses_before_6_other_relative_enum_opt_UNDEFINED_CODE_Mother": "Mother",
      "glasses_before_6_other_relative_enum_opt_UNDEFINED_CODE_Father": "Father",
      "glasses_before_6_other_relative_enum_opt_UNDEFINED_CODE_Brother": "Brother",
      "glasses_before_6_other_relative_enum_opt_UNDEFINED_CODE_Sister": "Sister",
      "glasses_before_6_other_relative_enum_opt_UNDEFINED_CODE_Sibling": "1/2 sibling through mother/father",
      "glasses_before_6_other_relative_enum_opt_UNDEFINED_CODE_Grandparent": "Grandfather/mother",
      "glasses_before_6_other_relative_enum_opt_UNDEFINED_CODE_Uncle": "Aunt/uncle",
      "glasses_before_6_other_relative_enum_opt_UNDEFINED_CODE_Relative": "Other",
      "glasses_before_6_other_relative_specify": "Specify other relative (glasses before age 6):",
      "patching_other_relative_enum": "Patching:",
      "patching_other_relative_enum_opt_UNDEFINED_CODE_Mother": "Mother",
      "patching_other_relative_enum_opt_UNDEFINED_CODE_Father": "Father",
      "patching_other_relative_enum_opt_UNDEFINED_CODE_Brother": "Brother",
      "patching_other_relative_enum_opt_UNDEFINED_CODE_Sister": "Sister",
      "patching_other_relative_enum_opt_UNDEFINED_CODE_Sibling": "1/2 sibling through mother/father",
      "patching_other_relative_enum_opt_UNDEFINED_CODE_Grandparent": "Grandfather/mother",
      "patching_other_relative_enum_opt_UNDEFINED_CODE_Uncle": "Aunt/uncle",
      "patching_other_relative_enum_opt_UNDEFINED_CODE_Relative": "Other",
      "patching_other_relative_specify": "Specify other relative (patching):",
      "eye_muscle_surgery_other_relative_enum": "Eye muscle surgery:",
      "eye_muscle_surgery_other_relative_enum_opt_UNDEFINED_CODE_Mother": "Mother",
      "eye_muscle_surgery_other_relative_enum_opt_UNDEFINED_CODE_Father": "Father",
      "eye_muscle_surgery_other_relative_enum_opt_UNDEFINED_CODE_Brother": "Brother",
      "eye_muscle_surgery_other_relative_enum_opt_UNDEFINED_CODE_Sister": "Sister",
