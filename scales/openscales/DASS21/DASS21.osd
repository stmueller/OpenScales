    "eu": {
      "likert_1": "Ez zait egokitzen bat ere",
      "likert_2": "Nolabait edo une batzuetan egokitzen zait",
      "likert_3": "Nahiko edo une askotan egokitzen zait",
      "likert_4": "Asko edo denbora gehienean egokitzen zait",
      "d1": "Funtsik gabeko gauzengatik atsekabetzen nintzela ikusten nuen",
      "d2": "Ahoa lehor nuela konturatu nintzen.",
      "d3": "Bazirudien ezin nuela sentimendu positiborik izan.",
      "d4": "Zailtasunak nituen arnas egiteko (adibidez, arnasketa azkarregia,",
      "d5": "Bazirudien ezin nuela martxan jarri.",
      "d6": "Egoeren aurrean gehiegizko erreakzioak nituen.",
      "d7": "Dardarak sentitzen nituen (adibidez, hankek ez zidatela ondo erantzungo).",
      "d8": "Zaila egiten zitzaidan erlaxatzea.",
      "d9": "Oso larri sentitu nintzen egoera batzuetan eta asko lasaitzen nintzen",
      "d10": "Ezer espero ezin nezakeela sentitzen nuen.",
      "d11": "Nahiko erraz atsekabetzen nintzela nabaritzen nuen.",
      "d12": "Energia nerbioso pila erabiltzen ari nintzela sentitzen nuen.",
      "d13": "Triste eta deprimituta sentitzen nintzen.",
      "d14": "Edonola atzeratzen nindutenean urduritzen nintzela nabaritzen nuen",
      "d15": "Zorabio sentsazioa izan nuen.",
      "d16": "Ia denaren inguruko interesa galdu nuela sentitzen nuen.",
      "d17": "Pertsona gisa asko balio ez nuela sentitzen nuen.",
      "d18": "Nahiko haserrekor nengoela sentitzen nuen.",
      "d19": "Nahiko izerditzen nintzen (adibidez, esku izerditsuak) nahiz eta bero",
      "d20": "Beldur nintzen arrazoi onik gabe.",
      "d21": "Bizitzak merezi ez zuela sentitzen nuen.",
      "debrief": ""
    },
    "fa": {
      "likert_1": "اصلاً در مورد من صدق نمی‌کرد",
      "likert_2": "تا حدودی یا بعضی وقت‌ها در مورد من صدق می‌کرد",
      "likert_3": "قابل توجهی یا بیشتر وقت‌ها در مورد من صدق می‌کرد",
      "likert_4": "خیلی زیاد یا اکثر مواقع در مورد من صدق می‌کرد",
      "d1": "رفع خستگی بعد از فعالیت برایم سخت بود",
      "d2": "احساس می‌کردم دهانم خشک شده بود",
      "d3": "اصلاً احساس مثبتی نداشتم",
      "d4": "نفس کشیدن برایم مشکل بود (برای مثال تنفس خیلی سریع یا احساس خفگی در هنگام عدم فعالیت)",
      "d5": "شروع هر کار تازه‌ای برایم سخت بود",
      "d6": "به اتفاقات واکنش شدید نشان می‌دادم",
      "d7": "لرزش داشتم (بطور مثال در دست‌ها)",
      "d8": "احساس می‌کردم که انرژی عصبی زیادی مصرف می‌کنم",
      "d9": "نگران موقعیت‌هایی بودم که ممکن بود هول شده و دست و پا چلفتی به نظر برسم",
      "d10": "احساس می‌کردم چیزی ندارم که به آن امیدوار باشم",
      "d11": "احساس نگرانی و آشفتگی می‌کردم",
      "d12": "نمی‌توانستم آرامش پیدا کنم",
      "d13": "احساس دلتنگی و غمگینی می‌کردم",
      "d14": "اگر چیزی مانع ادامه کارم می‌شد نمی‌توانستم آن را تحمل کنم",
      "d15": "احساس می‌کردم که نزدیک است دچار وحشت شوم",
      "d16": "نمی‌توانستم خودم را به چیزی علاقمند کنم",
      "d17": "احساس می‌کردم هیچ ارزشی ندارم",
      "d18": "احساس می‌کردم زود رنجیده می‌شوم",
      "d19": "در مواقعی که حتی فعالیت بدنی نداشتم ضربان قلب خود را احساس می‌کردم (بطور مثال طپش قلب یا احساس نامنظم بودن ضربان)",
      "d20": "بدون دلیل احساس ترس می‌کردم",
      "d21": "احساس می‌کردم که زندگی بی‌معنی است",
      "debrief": ""
    },
    "fi": {
      "likert_1": "Ei pitänyt paikkaansa lainkaan",
      "likert_2": "Piti paikkansa jonkin verran tai silloin tällöin",
      "likert_3": "Piti paikkansa huomattavissa määrin tai usein",
      "likert_4": "Piti paikkansa hyvin paljon tai melkein koko ajan",
      "d1": "Minun oli vaikea rauhoittua",
      "d2": "Huomasin, että suutani kuivasi",
      "d3": "Minusta tuntui, etten pystynyt kokemaan myönteisiä tunteita lainkaan Minulla oli hengitysvaikeuksia (esim. hyvin nopeaa hengittämistä tai hengästymistä",
      "d4": "0 ilman fyysistä rasitusta)",
      "d5": "Minun oli vaikea tarttua toimeen",
      "d6": "Minulla oli taipumusta ylireagoida asioihin",
      "d7": "Minulla oli vapinan tunnetta (esim. käsien vapinaa)",
      "d8": "Olin hyvin levoton ja hermostunut",
      "d9": "Murehdin tilanteita, joissa saattaisin joutua paniikkiin ja tehdä itseni naurunalaiseksi",
      "d10": "Minusta tuntui, ettei minulla ole mitään odotettavaa tulevaisuudelta",
      "d11": "Huomasin ärsyyntyväni",
      "d12": "Minun oli vaikea rentoutua",
      "d13": "Olin alakuloinen ja surullinen",
      "d14": "En voinut sietää mitään, mikä esti minua jatkamasta sitä, mitä olin tekemässä",
      "d15": "Tunsin olevani lähellä paniikkia",
      "d16": "En pystynyt innostumaan mistään",
      "d17": "Minusta tuntui, etten ole kovinkaan arvokas ihmisenä",
      "d18": "Loukkaannuin melko herkästi Olin tietoinen sydämeni toiminnasta (sydän tykytti tai löi epätahtiin), vaikka ei ollut",
      "d19": "0 kyse fyysisestä rasituksesta",
      "d20": "Minua pelotti, vaikkei siihen ollut järkevää syytä",
      "d21": "Minusta tuntui, ettei elämällä ole merkitystä",
      "debrief": ""
    },
    "fr": {
      "likert_1": "ne s’applique pas du tout à moi",
      "likert_2": "s’applique un peu à moi, ou une partie du temps",
      "likert_3": "s’applique beaucoup à moi, ou une bonne partie du temps",
      "likert_4": "s’applique entièrement à moi, ou la grande majorité du temps",
      "d1": "J’ai trouvé difficile de décompresser.",
      "d2": "J’ai été conscient(e) d’avoir la bouche sèche.",
      "d3": "J’ai eu l’impression de ne pas pouvoir ressentir d’émotion positive.",
      "d4": "J’ai eu de la difficulté à respirer (par exemple, respirations excessivement rapides, essoufflement sans effort physique).",
      "d5": "J’ai eu de la difficulté à initier de nouvelles activités.",
      "d6": "J’ai eu tendance à réagir de façon exagérée.",
      "d7": "J’ai eu des tremblements (par exemple, des mains).",
      "d8": "J’ai eu l’impression de dépenser beaucoup d’énergie nerveuse.",
      "d9": "Je me suis inquiété(e) en pensant à des situations où je pourrais paniquer et faire de moi un(e) idiot(e).",
      "d10": "J’ai eu le sentiment de ne rien envisager avec plaisir.",
      "d11": "Je me suis aperçu(e) que je devenais agité(e).",
      "d12": "J’ai eu de la difficulté à me détendre.",
      "d13": "Je me suis senti(e) abattu(e) et triste.",
      "d14": "J’ai été intolérant(e) à tout ce qui m’empêchait de faire ce que j’avais à faire.",
      "d15": "J’ai eu le sentiment d’être presque pris(e) de panique.",
      "d16": "J’ai été incapable de me sentir enthousiaste au sujet de quoi que ce soit.",
      "d17": "J’ai eu le sentiment de ne pas valoir grand chose comme personne.",
      "d18": "J’ai eu l’impression d’être assez susceptible.",
      "d19": "J’ai été conscient(e) des palpitations de mon coeur en l’absence d’effort physique (sensation d’augmentation de mon rythme cardiaque ou l’impression que mon cœur venait de sauter).",
      "d20": "J’ai eu peur sans bonne raison.",
      "d21": "J’ai eu l’impression que la vie n’avait pas de sens.",
      "debrief": ""
    },
    "hi": {
      "d1": "धीरे धीरे काय मता म ीणता / कमी ने मुझे परे शान िकया था।",
      "d2": "मुझे पता है िक मेरा मुँह सू ख जाता था।",
      "d3": "म कोई सकारा क भाव अनु भव नही ं कर सका।",
      "d4": "मने साँस लेने म तकलीफ महसू स की (जै से िक सामा शारी रक म के िबना भी साँ स का फूलना महसूस िकया)।",
      "d5": "िकसी भी काय की शु आत करने म मुझे िद",
      "d6": "मने प र थितयों को ज रत से",
      "d7": "मने क न महसू स िकया (जै से- हां थो म)।",
      "d8": "मने ऐसा महसू स िकया िक म कई बार कुछ",
      "d9": "म उस प र थित के बारे म ब त िचं ितत था, िजसमे म ब त बेचैन हो गया था और मने बेवकूफी की।",
      "d10": "मने अपने आपको",
      "d11": "मने अपने आपको ब त घबराया आ महसू स िकया।",
      "d12": "मने िव ाम करना मु",
      "d13": "मने अपने आपको उदास और दु खी महसू स िकया ।",
      "d14": "िकसी िवशेष उप म या मुझे बदा",
      "d15": "मने आतं िकत महसू स िकया था।",
      "d16": "िकसी भी काय को करने के िलए म अपने आपको उ ािहत कर पाने म असमथ पता था।",
      "d17": "मने महसू स िकया िक म",
      "d18": "मने महसू स िकया िक म",
      "d19": "शारी रक प र म के िबना भी म अपने िदल की धड़कनों को महसू स करता था (जैसे- तेज गित से धड़कना या कभी क जाना)।",
      "d20": "मने िबना िकसी कारण के डर महसू स िकया ।",
      "d21": "मुझे लगा िक जीवन साथक नही ं था।",
      "debrief": ""
    },
