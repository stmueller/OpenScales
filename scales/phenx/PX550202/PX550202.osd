    "scale_info": {
      "name": "Disapproval of Substance Use",
      "code": "PX550202",
      "abbreviation": "PX550202",
      "description": "Respondents complete a self-administered question from the Monitoring the Future (MTF) 2015 questionnaire, related to whether or not they approve of people participating in tobacco, alcohol, and drug use.",
      "domain": "Substance Use",
      "citation": "Miech, R. A., Johnston, L. D., O’Malley, P. M., Bachman, J. G., & Schulenberg, J. E. (2015). Monitoring the Future national survey results on drug use, 1975-2014: Volume I, Secondary school students . Ann Arbor: Institute for Social Research, University of Michigan. [PhenX: https://www.phenxtoolkit.org/protocols/view/550202]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/550202"
    },
