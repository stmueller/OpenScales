      "psychopathologyquestionnaire_judgeyourself_influence_shape_opt_4": "Moderately",
      "psychopathologyquestionnaire_judgeyourself_influence_shape_opt_5": "5",
      "psychopathologyquestionnaire_judgeyourself_influence_shape_opt_6": "Markedly",
      "psychopathologyquestionnaire_upset_weigh_yourself": "Over the past 28 days, how much would it have upset you if you had been asked to weigh yourself once a week (no more, or less, often) for the next four weeks?",
      "psychopathologyquestionnaire_upset_weigh_yourself_opt_0": "Not at all",
      "psychopathologyquestionnaire_upset_weigh_yourself_opt_1": "1",
      "psychopathologyquestionnaire_upset_weigh_yourself_opt_2": "Slightly",
