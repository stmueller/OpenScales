  "translations": {
    "en": {
      "thirthydays_cigarette_smoking": "Now think about the past 30 days - that is, from [DATEFILL*] up to and including today. During the past 30 days, have you smoked part or all of a cigarette?",
      "thirthydays_cigarette_smoking_opt_1": "Yes",
      "thirthydays_cigarette_smoking_opt_2": "No",
      "thirthydays_frequency_count": "During the past 30 days, that is, since [DATEFILL*], on how many days did you smoke part or all of a cigarette?",
      "thirthydays_frequency_count_coded": "During the past 30 days, that is, since [DATEFILL*], on how many days did you smoke part or all of a cigarette?",
      "thirthydays_frequency_count_coded_opt_1": "Don't Know / Refused",
      "thirthydays_frequency_estimate": "What is your best estimate of the number of days you smoked part or all of a cigarette during the past 30 days?",
      "thirthydays_frequency_estimate_opt_1": "1 or 2 days",
      "thirthydays_frequency_estimate_opt_2": "3 to 5 days",
      "thirthydays_frequency_estimate_opt_3": "6 to 9 days",
      "thirthydays_frequency_estimate_opt_4": "10 to 19 days",
      "thirthydays_frequency_estimate_opt_5": "20 to 29 days",
      "thirthydays_frequency_estimate_opt_6": "All 30 days",
      "thirthydays_frequency_estimate_opt_7": "Don't Know / Refused",
      "thirthydays_quantity": "On the [NUMBER OF DAYS REPORTED IN 2a OR 2b] you smoked cigarettes during the past 30 days, how many cigarettes did you smoke per day, on average?",
      "thirthydays_quantity_opt_1": "Less than one cigarette per day",
      "thirthydays_quantity_opt_2": "1 cigarette per day",
      "thirthydays_quantity_opt_3": "2 to 5 cigarettes per day",
      "thirthydays_quantity_opt_4": "6 to 15 cigarettes per day (about 1/2 pack)",
      "thirthydays_quantity_opt_5": "16 to 25 cigarettes per day (about 1 pack)",
      "thirthydays_quantity_opt_6": "26 to 35 cigarettes per day (about 1 1/2 packs)",
      "thirthydays_quantity_opt_7": "More than 35 cigarettes per day (about 2 packs or more)",
      "thirthydays_quantity_opt_8": "Don't Know / Refused"
    }
  }
