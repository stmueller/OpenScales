{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Aided and Confirmed Awareness of Televised Anti-tobacco Advertisements",
      "code": "PX750101",
      "abbreviation": "PX750101",
      "description": "This protocol includes two questions from Sly et al. (2001) and Niederdeppe (2005). Questions assess whether or not a respondent has seen any televised anti-tobacco/anti-smoking advertisements; if so, the respondent is asked to describe the advertisement. In assessing aided awareness, respondents co",
      "domain": "Substance Use",
      "citation": "Sly, D., et al. The Florida \"truth\" anti-tobacco media evaluation: Design, first-year results, and implications for planning future state media evaluations. TOB CONTROL, 2001. As implemented in: PhenX Toolkit. Aided and Confirmed Awareness of Televised Anti-tobacco Advertisements. https://www.phenxtoolkit.org/protocols/view/750101",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/750101"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "items": [
      {
        "id": "tv_antismoking_ad",
        "text_key": "tv_antismoking_ad",
        "type": "multi",
        "options": [
          {
            "text_key": "tv_antismoking_ad_opt_1",
            "value": 1
          },
          {
            "text_key": "tv_antismoking_ad_opt_2",
            "value": 2
          }
        ]
      },
      {
        "id": "tv_antismoking_ad_content",
        "text_key": "tv_antismoking_ad_content",
        "type": "short"
      }
    ]
  },
  "translations": {
    "en": {
      "tv_antismoking_ad": "Have you recently seen an anti-smoking or anti-tobacco ad on TV that shows - [provide either brief verbal, text or visual (screenshot or video)]?",
      "tv_antismoking_ad_opt_1": "Yes",
      "tv_antismoking_ad_opt_2": "No",
      "tv_antismoking_ad_content": "What happens in this advertisement?"
    }
  }
}