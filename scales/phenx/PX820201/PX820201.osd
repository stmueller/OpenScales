  "translations": {
    "en": {
      "lk_opt_1": "Never",
      "lk_opt_2": "Rarely",
      "lk_opt_3": "Sometimes",
      "lk_opt_4": "Often",
      "lk_opt_5": "Always",
      "info_820201": "Adult Sickle Cell Quality of Life Measurement Information System (ASCQ-Me)Answer all the questions by checking the box to the left of your answer.Emotional Impact",
      "qualityoflife_scdadult_completely_hopeless_past7days": "In the past 7 days, how often did you feel completely hopeless because of your health?",
      "qualityoflife_scdadult_lonely_past7days": "In the past 7 days, how lonely did you feel because of your health problems?",
      "qualityoflife_scdadult_lonely_past7days_opt_1": "Not at all",
      "qualityoflife_scdadult_lonely_past7days_opt_2": "A little",
      "qualityoflife_scdadult_lonely_past7days_opt_3": "Somewhat",
      "qualityoflife_scdadult_lonely_past7days_opt_4": "Quite",
      "qualityoflife_scdadult_lonely_past7days_opt_5": "Very",
      "qualityoflife_scdadult_depressed_past7days": "In the past 7 days, how depressed were you about your health problems?",
      "qualityoflife_scdadult_depressed_past7days_opt_1": "Not at all",
      "qualityoflife_scdadult_depressed_past7days_opt_2": "A little",
      "qualityoflife_scdadult_depressed_past7days_opt_3": "Somewhat",
      "qualityoflife_scdadult_depressed_past7days_opt_4": "Quite",
      "qualityoflife_scdadult_depressed_past7days_opt_5": "Very",
      "qualityoflife_scdadult_worry_past7days": "In the past 7 days, how much did you worry about getting sick?",
      "qualityoflife_scdadult_worry_past7days_opt_1": "Not at all",
      "qualityoflife_scdadult_worry_past7days_opt_2": "A little bit",
      "qualityoflife_scdadult_worry_past7days_opt_3": "Somewhat",
      "qualityoflife_scdadult_worry_past7days_opt_4": "Quite a bit",
      "qualityoflife_scdadult_worry_past7days_opt_5": "Very much",
      "qualityoflife_scdadult_often_worried_past7days": "In the past 7 days, how often were you very worried about needing to go to the hospital?",
      "social_820201": "Social Functioning Impact",
      "qualityoflife_scdadult_relyon_others_past30days": "In the past 30 days, how much did you rely on others to take care of you because of your health?",
      "qualityoflife_scdadult_relyon_others_past30days_opt_1": "Not at all",
      "qualityoflife_scdadult_relyon_others_past30days_opt_2": "A little bit",
      "qualityoflife_scdadult_relyon_others_past30days_opt_3": "Somewhat",
      "qualityoflife_scdadult_relyon_others_past30days_opt_4": "Quite a bit",
      "qualityoflife_scdadult_relyon_others_past30days_opt_5": "Very much",
      "qualityoflife_scdadult_often_slowdown_past30days": "In the past 30 days, how often did your health slow you down?",
      "qualityoflife_scdadult_oftenhard_dothings_past30days": "In the past 30 days, how often did your health make it hard for you to do things?",
      "qualityoflife_scdadult_oftenprevent_going_past30days": "In the past 30 days, how often did your health keep you from going out?",
      "qualityoflife_scdadult_howmuch_dothings_past30days": "In the past 30 days, how much did your health make it hard for you to do things with your friends?",
      "qualityoflife_scdadult_howmuch_dothings_past30days_opt_1": "Not at all",
