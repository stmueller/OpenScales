  "translations": {
    "ar": {
      "LANGUAGE": "ar",
      "question_head": "يُرجى منك تظليل دائرة واحدة فقط في كل سطر.",
      "ueq_inst_text": "أكمل رجاءً الاستبيان التالي كي تقيّم المنتج. يشتمل الاستبيان على أزواج متضادة من خواص المنتج. تُمثَّل التدرجات بين الخواص المتناقضة بواسطة دوائر. ظلل واحدةً من الدوائر لتمييز درجة توافقك مع البنود المفردة.",
      "ueq_01_text": "مزعج                    ممتع",
      "ueq_01_left": "مزعج",
      "ueq_01_right": "ممتع",
      "ueq_02_text": "غير مفهوم                    مفهوم",
      "ueq_02_left": "غير مفهوم",
      "ueq_02_right": "مفهوم",
      "ueq_03_text": "إبداعية                    مبتذلة",
      "ueq_03_left": "إبداعية",
      "ueq_03_right": "مبتذلة",
      "ueq_04_text": "سهل التعلّم                    صعب التعلّم",
      "ueq_04_left": "سهل التعلّم",
      "ueq_04_right": "صعب التعلّم",
      "ueq_05_text": "قيّم                    متدني",
      "ueq_05_left": "قيّم",
      "ueq_05_right": "متدني",
      "ueq_06_text": "ممل                    مثير",
      "ueq_06_left": "ممل",
      "ueq_06_right": "مثير",
      "ueq_07_text": "غير مثير للاهتمام                    مثير للاهتمام",
      "ueq_07_left": "غير مثير للاهتمام",
      "ueq_07_right": "مثير للاهتمام",
      "ueq_08_text": "غير متوقعة                    متوقعة",
      "ueq_08_left": "غير متوقعة",
      "ueq_08_right": "متوقعة",
      "ueq_09_text": "سريع                    بطيء",
      "ueq_09_left": "سريع",
      "ueq_09_right": "بطيء",
      "ueq_10_text": "مستحدثة                    تقليدية",
      "ueq_10_left": "مستحدثة",
      "ueq_10_right": "تقليدية",
      "ueq_11_text": "عائقة                    داعمة",
      "ueq_11_left": "عائقة",
      "ueq_11_right": "داعمة",
      "ueq_12_text": "جيد                    سيء",
      "ueq_12_left": "جيد",
      "ueq_12_right": "سيء",
      "ueq_13_text": "معقَّد                    سهل",
      "ueq_13_left": "معقَّد",
      "ueq_13_right": "سهل",
      "ueq_14_text": "غير جذابة                    جذابه",
      "ueq_14_left": "غير جذابة",
      "ueq_14_right": "جذابه",
      "ueq_15_text": "اعتيادية                    استشرافية",
      "ueq_15_left": "اعتيادية",
      "ueq_15_right": "استشرافية",
      "ueq_16_text": "غير مريح                    مريح",
      "ueq_16_left": "غير مريح",
      "ueq_16_right": "مريح",
      "ueq_17_text": "مضمونة                    غير مضمونة",
      "ueq_17_left": "مضمونة",
      "ueq_17_right": "غير مضمونة",
      "ueq_18_text": "مشجّع                    غير مُشجّع",
      "ueq_18_left": "مشجّع",
      "ueq_18_right": "غير مُشجّع",
      "ueq_19_text": "لا تفي بالتوقعات                    لا تفي بالتوقعات",
      "ueq_19_left": "لا تفي بالتوقعات",
      "ueq_19_right": "لا تفي بالتوقعات",
      "ueq_20_text": "غير فعّال                    فعّال",
      "ueq_20_left": "غير فعّال",
      "ueq_20_right": "فعّال",
      "ueq_21_text": "واضح                    مُربك",
      "ueq_21_left": "واضح",
      "ueq_21_right": "مُربك",
      "ueq_22_text": "غير عملي                    عملي",
      "ueq_22_left": "غير عملي",
      "ueq_22_right": "عملي",
      "ueq_23_text": "منظّم                    مبعثر",
      "ueq_23_left": "منظّم",
      "ueq_23_right": "مبعثر",
      "ueq_24_text": "جذّاب                    غير جذّاب",
      "ueq_24_left": "جذّاب",
      "ueq_24_right": "غير جذّاب",
      "ueq_25_text": "ودود                    غير ودود",
      "ueq_25_left": "ودود",
      "ueq_25_right": "غير ودود",
      "ueq_26_text": "محافظة                    ابتكارية",
      "ueq_26_left": "محافظة",
      "ueq_26_right": "ابتكارية",
      "blank": "",
      "debrief": "شكراً لإكمالك استبيان تجربة المستخدم."
    },
    "bg": {
      "LANGUAGE": "bg",
      "question_head": "Моля, оценете продукта, като зачертете по едно кръгче на всеки ред.",
      "ueq_inst_text": "За оценяването на продукта, моля попълнете въпросника, който следва. Въпросникът се състои от двойки въпроси с противоположни определения, които може да се отнасят за продукта. Кръгчетата между стойностите на въпросите, показват градацията между двете противоположности. Задраскайте съответното кръгче, което най-близо отговаря на вашето впечатление. Вземете своето решение спонтанно. Не мислете много за това какво решение да вземете, защото така ще се отклоните от първото си впечатление. Понякога може да не сте напълно съгласни с някое определение или да смятате, че то не отговаря напълно на конкретния продукт, въпреки това моля отбележете кръгче на всеки ред от въпросника. От значение е вашето лично мнение. Запомнете, че няма правилен или грешен отговор!",
      "ueq_01_text": "дразнещ                    приятен",
      "ueq_01_left": "дразнещ",
      "ueq_01_right": "приятен",
      "ueq_02_text": "неразбираем                    разбираем",
      "ueq_02_left": "неразбираем",
      "ueq_02_right": "разбираем",
      "ueq_03_text": "творчески                    скучен",
      "ueq_03_left": "творчески",
      "ueq_03_right": "скучен",
      "ueq_04_text": "лесен за научаване                    труден за научаване",
      "ueq_04_left": "лесен за научаване",
      "ueq_04_right": "труден за научаване",
      "ueq_05_text": "стойностен                    посредствен",
      "ueq_05_left": "стойностен",
      "ueq_05_right": "посредствен",
      "ueq_06_text": "скучен                    вълнуващ",
      "ueq_06_left": "скучен",
      "ueq_06_right": "вълнуващ",
      "ueq_07_text": "безинтересен                    интересен",
      "ueq_07_left": "безинтересен",
      "ueq_07_right": "интересен",
      "ueq_08_text": "непредсказуем                    предсказуем",
      "ueq_08_left": "непредсказуем",
      "ueq_08_right": "предсказуем",
      "ueq_09_text": "бърз                    бавен",
      "ueq_09_left": "бърз",
      "ueq_09_right": "бавен",
      "ueq_10_text": "идеен                    конвенционален",
      "ueq_10_left": "идеен",
      "ueq_10_right": "конвенционален",
      "ueq_11_text": "възпрепятстващ                    помагащ",
      "ueq_11_left": "възпрепятстващ",
      "ueq_11_right": "помагащ",
      "ueq_12_text": "добър                    лош",
      "ueq_12_left": "добър",
      "ueq_12_right": "лош",
      "ueq_13_text": "сложен                    лесен",
      "ueq_13_left": "сложен",
      "ueq_13_right": "лесен",
      "ueq_14_text": "неприятен                    приятен",
      "ueq_14_left": "неприятен",
      "ueq_14_right": "приятен",
      "ueq_15_text": "обикновен                    иновативен",
      "ueq_15_left": "обикновен",
      "ueq_15_right": "иновативен",
      "ueq_16_text": "противен                    приятен",
      "ueq_16_left": "противен",
      "ueq_16_right": "приятен",
      "ueq_17_text": "сигурен                    несигурен",
