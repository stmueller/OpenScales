    "scoring": {
      "family": {
        "method": "sum_coded",
        "items": [
          "socq1",
          "socq2",
          "socq3",
          "socq4"
        ],
        "description": "Family subscale: sum of items 1-4 (range 4-24). Higher scores indicate stronger family relationships.",
        "item_coding": {
          "socq1": 1,
          "socq2": 1,
          "socq3": 1,
          "socq4": 1
        }
      },
      "friends": {
        "method": "sum_coded",
        "items": [
          "socq5",
          "socq6",
          "socq7",
          "socq8"
        ],
        "description": "Friends subscale: sum of items 5-8 (range 4-24). Higher scores indicate stronger friendships.",
        "item_coding": {
          "socq5": 1,
          "socq6": 1,
          "socq7": 1,
          "socq8": 1
        }
      },
      "acquaintances": {
        "method": "sum_coded",
        "items": [
          "socq9",
          "socq10",
          "socq11",
          "socq12"
        ],
        "description": "Acquaintances subscale: sum of items 9-12 (range 4-24). Items 10 and 12 are reverse scored. Higher scores indicate easier acquaintance interactions.",
        "item_coding": {
          "socq9": 1,
          "socq10": -1,
          "socq11": 1,
          "socq12": -1
        }
      },
      "peers": {
        "method": "sum_coded",
        "items": [
          "socq13",
          "socq14",
          "socq15",
          "socq16"
        ],
        "description": "Peers subscale: sum of items 13-16 (range 4-24). Higher scores indicate stronger peer relationships.",
        "item_coding": {
          "socq13": 1,
          "socq14": 1,
          "socq15": 1,
          "socq16": 1
        }
      }
    }
  },
  "translations": {
    "en": {
      "likert_0": "Never",
      "likert_1": "Hardly Ever",
      "likert_2": "Sometimes",
      "likert_3": "Often",
      "likert_4": "Usually",
      "likert_5": "Always",
      "question_head": "Please indicate how often each of the following statements applies to you.",
      "socq1": "I speak and relate with my family.",
      "socq2": "My family is important for me.",
      "socq3": "The family members care about me.",
      "socq4": "I have fun and laugh with my family.",
      "socq5": "I speak and relate with my friends.",
      "socq6": "I have friends to tell and share problems.",
      "socq7": "I consider important to maintain relationships with friends.",
      "socq8": "I have fun and laugh with my friends.",
      "socq9": "I speak and relate comfortably with acquaintances.",
      "socq10": "It costs me make conversation with people I do not know.",
      "socq11": "It is easy for me to win support from acquaintances.",
      "socq12": "Relations with my acquaintances are forced.",
      "socq13": "I speak and relate satisfactorily with my peers.",
      "socq14": "I have personal trust in my peers.",
      "socq15": "When talking with peers they take me into account.",
      "socq16": "I feel valued by my peers.",
      "debrief": "Thank you for completing the Sociotype Questionnaire."
    }
  }
}