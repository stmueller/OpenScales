  "translations": {
    "en": {
      "join_games": "Does s/he join in playing games with other children easily?",
      "chat_spontaneously": "Does s/he come up to you spontaneously for a chat?",
      "speaking_by_two": "Was s/he speaking by 2 years old?",
      "enjoy_sports": "Does s/he enjoy sports?",
      "important_to_fit_in": "Is it important to him/her to fit in with the peer group?",
      "pxt120903_notice_details": "Does s/he appear to notice unusual details that others miss?",
      "take_things_literally": "Does s/he tend to take things literally?",
      "pretending_at_age_three": "When s/he was 3 years old, did s/he spend a lot of time pretending (e.g., play-acting being a superhero, or holding teddy's tea parties)?",
      "enjoy_repetition": "Does s/he like to do things over and over again, in the same way all the time?",
      "easy_interact_other_children": "Does s/he find it easy to interact with other children?",
      "keep_conversation_going": "Can s/he keep a two-way conversation going?",
      "reads_at_age_level": "Can s/he read appropriately for his/her age?",
      "same_interests_as_peers": "Does s/he mostly have the same interests as his/her peers?",
      "dominating_interest": "Does s/he have an interest which takes up so much time that s/he does little else?",
      "friends_or_acquaintances": "Does s/he have friends, rather than just acquaintances?",
      "share_things": "Does s/he often bring you things s/he is interested in to show you?",
      "enjoy_joking_around": "Does s/he enjoy joking around?",
      "difficulty_with_polite_behavior": "Does s/he have difficulty understanding the rules for polite behavior?",
      "unusual_memory_for_details": "Does s/he appear to have an unusual memory for details?",
      "unusual_voice": "Is his/her voice unusual (e.g., overly adult, flat, or very monotonous)?",
      "people_are_important": "Are people important to him/her?",
      "get_dressed": "Can s/he dress him/herself?",
      "conversation_turn_taking": "Is s/he good at turn-taking in conversation?",
      "engage_in_role_play": "Does s/he play imaginatively with other children, and engage in role-play?",
      "socially_inappropriate_behavior": "Does s/he often do or say things that are tactless or socially inappropriate?",
      "count_to_fifty": "Can s/he count to 50 without leaving out any numbers?",
      "make_eye_contact": "Does s/he make normal eye-contact?",
      "repetitive_movements": "Does s/he have any unusual and repetitive movements?",
      "one_sided_social_behavior": "Is his/her social behavior very one-sided and always on his/her own terms?",
      "you_or_i": "Does s/he sometimes say \"you\" or \"s/he\" when s/he means \"I\"?",
      "imagination_or_facts": "Does s/he prefer imaginative activities such as play-acting or story-telling, rather than numbers or lists of facts?",
      "does_not_explain_topic": "Does s/he sometimes lose the listener because of not explaining what s/he is talking about?",
      "ride_bicycle": "Can s/he ride a bicycle (even if with stabilizers)?",
      "self_imposed_routines": "Does s/he try to impose routines on himself/herself, or on others, in such a way that it causes problems?",
      "care_how_perceived": "Does s/he care how s/he is perceived by the rest of the group?",
      "redirects_conversation": "Does s/he often turn conversations to his/her favorite subject rather than following what the other person wants to talk about?",
      "unusual_phrases": "Does s/he have odd or unusual phrases?",
      "teacher_concerns": "Have teachers/health visitors ever expressed any concerns about his/her development?",
      "teacher_concerns_specify": "Have teachers/health visitors ever expressed any concerns about his/her development?  If yes, please specify",
      "diagnosed_physical_disability_enum": "Has s/he ever been diagnosed with any of the following?",
      "diagnosed_physical_disability_enum_opt_1": ":  Language delay",
      "diagnosed_physical_disability_enum_opt_2": ":  Hyperactivity/Attention Deficit Disorder (ADHD",
      "diagnosed_physical_disability_enum_opt_3": ":  Hearing or visual difficulties",
      "diagnosed_physical_disability_enum_opt_4": ":  Autism Spectrum Condition, including Asperger's Syndrome",
      "diagnosed_physical_disability_enum_opt_5": ":  A physical disability",
      "diagnosed_other": "Has s/he ever been diagnosed with any of the following?:  Other (please specify)",
      "opt_1": "Yes",
      "opt_2": "No"
    }
  }
}
