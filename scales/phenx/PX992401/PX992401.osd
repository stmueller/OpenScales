      "comorbidities_covid_impact_pre_existing_condition_opt_29": "Multiple Sclerosis",
      "comorbidities_covid_impact_pre_existing_condition_opt_30": "Peripheral neuropathy",
      "comorbidities_covid_impact_pre_existing_condition_opt_31": "Coronary Heart Disease",
      "comorbidities_covid_impact_pre_existing_condition_opt_32": "Heart failure",
      "comorbidities_covid_impact_pre_existing_condition_opt_33": "Hypertension (high blood pressure)",
      "comorbidities_covid_impact_pre_existing_condition_opt_34": "Hypotension (low blood pressure)",
      "comorbidities_covid_impact_pre_existing_condition_opt_35": "History of clotting",
