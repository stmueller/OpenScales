      "asthma_ever": "PAST ILLNESSES - Asthma  Have you ever had asthma?",
      "asthma_still_have": "PAST ILLNESSES - Asthma  Do you still have it?",
      "asthma_doctor_confirmed": "PAST ILLNESSES - Asthma  Was it confirmed by a doctor?",
