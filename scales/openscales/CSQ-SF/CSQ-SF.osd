{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Cognitive Style Questionnaire — Short Form",
      "code": "CSQ-SF",
      "abbreviation": "CSQ-SF",
      "description": "72-item measure (8 scenarios × 9 items) of negative cognitive style. 5 subscales: Internality, Globality, Stability, Negative Consequences, Self-Worth Implications. 5-point Likert (1=Strongly agree to 5=Strongly disagree). Higher scores = more negative cognitive style. Many items reverse-scored.",
      "citation": "Meins, E., McCarthy-Jones, S., Fernyhough, C., Lewis, G., Bentall, R. P., & Alloy, L. B. (2012). Assessing negative cognitive style: Development and validation of a short-form version of the Cognitive Style Questionnaire. Personality and Individual Differences, 52, 581-585.",
      "license": "CC BY 3.0",
      "license_explanation": "Published under Creative Commons Attribution license. Meins, E., McCarthy-Jones, S., Fernyhough, C., Lewis, G., Bentall, R. P., & Alloy, L. B. (2012). Assessing negative cognitive style: Development and validation of a short-form version of the Cognitive Style Questionnaire. Personality and Individual Differences, 52, 581-585. doi:10.1016/j.paid.2011.11.026",
      "license_url": "https://doi.org/10.1016/j.paid.2011.11.026",
      "version": "1.0",
      "url": "https://arc.psych.wisc.edu/self-report/cognitive-style-questionnaire-short-form-csq-sf/",
      "domain": "Mental Health"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 1,
      "max": 5,
      "labels": [
        "csq_r1",
        "csq_r2",
        "csq_r3",
        "csq_r4",
        "csq_r5"
      ]
    },
    "dimensions": [
      {
        "id": "internality",
        "name": "Internality",
        "description": "Items 1 & 6 across all 8 scenarios (16 items, range 16-80)."
      },
      {
        "id": "globality",
        "name": "Globality",
        "description": "Items 2 & 7 across all 8 scenarios (16 items, range 16-80)."
      },
      {
        "id": "stability",
        "name": "Stability",
        "description": "Items 3 & 8 across all 8 scenarios (16 items, range 16-80)."
      },
      {
        "id": "negative_consequences",
        "name": "Negative Consequences",
        "description": "Item 4 across all 8 scenarios (8 items, range 8-40)."
      },
      {
        "id": "self_worth",
        "name": "Self-Worth Implications",
        "description": "Items 5 & 9 across all 8 scenarios (16 items, range 16-80)."
      },
      {
        "id": "total",
        "name": "Total",
        "description": "Sum of all 72 items (range 72-360)."
      }
    ],
