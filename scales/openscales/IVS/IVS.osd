{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Integrative Vitality Scale",
      "code": "IVS",
      "abbreviation": "IVS",
      "description": "22-item self-report measure of integrative vitality based on traditional Eastern medicine and modern psychology. Assesses two subscales: physical vitality (items 1-11) and psychological vitality (items 12-22). Item 11 is reverse-scored.",
      "citation": "Yoon, S. I., Park, H. Y., Chung, S. Y., & Kim, J. W. (2024). Development and validation of the Integrative Vitality Scale. Frontiers in Public Health, 12, 1452068. https://doi.org/10.3389/fpubh.2024.1452068",
      "license": "CC BY 4.0",
      "license_explanation": "Published in Frontiers in Public Health under Creative Commons Attribution 4.0 International License.",
      "license_url": "https://creativecommons.org/licenses/by/4.0/",
      "version": "1.0",
      "url": "https://doi.org/10.3389/fpubh.2024.1452068",
      "domain": "Mental Health"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 0,
      "max": 4,
      "labels": [
        "likert_0",
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "physical",
        "name": "Physical Vitality",
        "description": "Bodily energy, strength, comfort, and physical well-being (items 1-11)."
      },
      {
        "id": "psychological",
        "name": "Psychological Vitality",
        "description": "Passion, enthusiasm, confidence, hopefulness, and positive psychological outlook (items 12-22)."
      }
    ],
