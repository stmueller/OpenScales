  "translations": {
    "en": {
      "instructions_0100602": "Think about when the following events happened to you. Was this earlier than most of your friends, around the same time, or later?",
      "voice_changed_peer_comparison": "Your voice changed. Compared to your friends was this:",
      "voice_changed_peer_comparison_opt_1": "Earlier",
      "voice_changed_peer_comparison_opt_2": "About the same time",
      "voice_changed_peer_comparison_opt_3": "Later",
      "voice_changed_peer_comparison_opt_4": "Don't know",
      "voice_changed_age": "How old were you when your voice changed?",
      "voice_changed_age_coded": "How old were you when your voice changed?",
      "voice_changed_age_coded_opt_1": "Don't know",
      "penis_size_increased_peer_comparison": "Your penis started increasing in size. Compared to your friends was this:",
      "penis_size_increased_peer_comparison_opt_1": "Earlier",
      "penis_size_increased_peer_comparison_opt_2": "About the same time",
      "penis_size_increased_peer_comparison_opt_3": "Later",
      "penis_size_increased_peer_comparison_opt_4": "Don't know",
      "penis_size_increased_age": "How old were you when your penis started increasing in size?",
      "penis_size_increased_age_coded": "How old were you when your penis started increasing in size?",
      "penis_size_increased_age_coded_opt_1": "Don't know",
      "testicles_size_increased_peer_comparison": "Your testicles started increasing in size. Compared to your friends was this:",
      "testicles_size_increased_peer_comparison_opt_1": "Earlier",
      "testicles_size_increased_peer_comparison_opt_2": "About the same time",
      "testicles_size_increased_peer_comparison_opt_3": "Later",
      "testicles_size_increased_peer_comparison_opt_4": "Don't know",
      "testicles_size_increased_age": "How old were you when your testicles started increasing in size?",
      "testicles_size_increased_age_coded": "How old were you when your testicles started increasing in size?",
      "testicles_size_increased_age_coded_opt_1": "Don't know",
      "developed_pubic_hair_peer_comparison": "You developed pubic hair. Compared to your friends was this:",
      "developed_pubic_hair_peer_comparison_opt_1": "Earlier",
      "developed_pubic_hair_peer_comparison_opt_2": "About the same time",
      "developed_pubic_hair_peer_comparison_opt_3": "Later",
      "developed_pubic_hair_peer_comparison_opt_4": "Don't know",
      "developed_pubic_hair_age": "How old were you when you developed pubic hair?",
      "developed_pubic_hair_age_coded": "How old were you when you developed pubic hair?",
      "developed_pubic_hair_age_coded_opt_1": "Don't know",
      "puberty_reach": "People reach puberty at different ages. Signs of puberty for males include physical changes such as developing pubic or facial hair, or the voice cracking or lowering. Would you say these changes:",
      "puberty_reach_opt_1": "Have not yet begun",
      "puberty_reach_opt_2": "Have barely started",
      "puberty_reach_opt_3": "Are definitely underway",
      "puberty_reach_opt_4": "Seem completed",
      "puberty_enter_began_first_age": "How old were you when you entered puberty (that is, when these changes began)?",
      "likert_1": "Earlier",
      "likert_2": "About the same time",
      "likert_3": "Later",
      "likert_4": "Don't know"
    }
  }
