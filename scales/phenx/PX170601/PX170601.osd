  "definition": {
    "scale_info": {
      "name": "Skin Cancer",
      "code": "PX170601",
      "abbreviation": "PX170601",
      "description": "The protocol developed by Quereux et al. (2010) includes a self administered questionnaire that captures the main skin cancer risk factors, such as skin type, presence of freckles and moles, occurrence of blistering sunburns and personal and family history of melanoma. After the respondent completes",
      "domain": "Health",
      "citation": "None [PhenX: https://www.phenxtoolkit.org/protocols/view/170601]",
      "license": "PhenX Toolkit freely available protocol",
      "version": "1.0",
      "url": "https://www.phenxtoolkit.org/protocols/view/170601"
    },
