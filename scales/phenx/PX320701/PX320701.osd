  "translations": {
    "en": {
      "lk_opt_1": "Never",
      "lk_opt_2": "Rarely",
      "lk_opt_3": "Sometimes",
      "lk_opt_4": "Often",
      "lk_opt_5": "Always",
      "sharing_information": "Sharing Information",
      "sec_how_often_do_your_doctors_and_other_heal_title": "How often do your doctors and other health professionals...",
      "health_professionals_questions": "Talk with you about your concerns and questions?",
      "health_professionals_information": "Give you helpful information, even when you don't ask for it?",
      "health_professionals_information_need": "Make sure you have the information you need?",
      "health_professionals_information_understand": "Help you understand the information you need to know?",
      "health_professionals_questions_answered": "Make sure your questions are answered?",
      "health_professional_question_comfort": "How much do your doctors and other health professionals make you feel comfortable asking questions? *",
      "relationships_health_professionals": "Relationships with Doctors and Other Health Professionals",
      "health_professional_depend": "How much can you depend on your doctors and other health professionals to give you the care you need?",
      "health_professional_often_care": "Show they care about you?",
      "health_professional_often_detail": "Remember details about you between visits?",
      "health_professional_often_communication": "Have open and honest communication with you? *",
      "health_professional_often_listen": "Listen carefully to what you have to say?",
      "health_professional_informed": "How much do your doctors and other health professionals seem well informed about your type of cancer?",
      "health_professional_explain": "Different doctors and health professionals are often involved in a patient's care. How well do your doctors and other health professionals explain what they each do?",
      "making_decisions": "Making Decisions",
      "decisions_care_remember": "Many decisions need to be made in cancer care, such as decisions about treatment choices, where to go for care, or how to manage side effects. Please think about all of the decisions there have been in your care.",
      "health_professional_care_decision": "How often do your doctors and other health professionals involve you in making decisions about your care?",
      "sec_how_well_do_your_doctors_and_other_healt_title": "How well do your doctors and other health professionals...",
      "health_professional_explain_choices": "Explain the different choices you have?",
      "health_professional_explain_recommend": "Explain what they recommended?",
      "sec_how_much_do_your_doctors_and_other_healt_title": "How much do your doctors and other health professionals help you understand...",
      "health_professional_decision_interest": "Show interest in what you say about the decisions?",
      "health_professional_decision_help": "Give you information and resources to help you make decisions? *",
      "attention_emotions": "Attention to Your Emotions",
      "health_professional_attention_emotion": "How often do your doctors and other health professionals give the attention you need to your feelings and emotions?",
      "health_professional_emotion_attention": "Pay attention to how you are doing emotionally?",
      "health_professional_emotion_concern": "Show concern for your feelings, not just your illness?",
      "health_professional_emotion_concern_family": "Show concern for how your family is doing emotionally?",
      "health_professional_emotion_comfort": "Make you feel comfortable to talk about your fears, stress, and other feelings?",
      "health_professional_help_cope": "How well do your doctors and other health professionals talk with you about how to cope with any fears, stress, and other feelings? *",
      "care_self": "Taking Care of Yourself",
      "health_professional_help_understand": "How well do your doctors and other health professionals help you understand ways you can take care of your health?",
      "health_professional_communicate_everyday_life": "How cancer is affecting your everyday life?",
      "health_professional_communicate_manage_symptom": "Ways you can manage any side effects or symptoms?",
      "health_professional_communicate_family_help": "How your family can help care for you?",
      "health_professional_communicate_concern_care": "Any concerns you have about taking care of yourself?",
      "health_professional_care_help_understand": "How often do your doctors and other health professionals make sure you understand the steps in your care? *",
      "dealing_uncertainty": "Dealing with Uncertainty",
      "health_professional_help_uncertainty": "Cancer patients often face uncertainties about their cancer. For example, patients may not know what will happen, how treatment is working, and how to make sense of different information and opinions. How well do your doctors and other health professionals help you deal with the uncertainties about your cancer? *",
      "health_professional_understand_condition": "If you are getting better or worse?",
      "health_professional_understand_goal": "The goal of your care?",
      "health_professional_understand_likely_outcome": "What is likely to happen with your cancer?",
      "health_professional_understand_symptom_change": "How your symptoms may change?",
      "health_professional_help_understand_information": "Patients often get information from different places. How well do your doctors and other health professionals help you understand what information is most important?"
    }
  }
