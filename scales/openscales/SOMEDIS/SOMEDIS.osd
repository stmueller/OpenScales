{
  "osd_version": "1.0",
  "definition": {
    "scale_info": {
      "name": "Social Media Use Disorder Scale for Adolescents",
      "code": "SOMEDIS",
      "abbreviation": "SOMEDIS-A",
      "description": "10-item ICD-11-based self-report scale assessing social media use disorder in adolescents aged 10–17 years, adapted from the Gaming Disorder Scale for Adolescents (GADIS-A). Two factors: Cognitive Behavioral Symptoms (items 1,2,4,5; cutoff >8) and Negative Consequences (items 3,6,7,8,9; cutoff >6). Item 10 is a time criterion. Disorder is indicated when both factor cutoffs are reached and the time criterion is met.",
      "citation": "Paschke, K., Austermann, M. I., Simon-Kutscher, K., & Thomasius, R. (2021). ICD-11-Based Assessment of Social Media Use Disorder in Adolescents: Development and Validation of the Social Media Use Disorder Scale for Adolescents. Frontiers in Psychiatry, 12, 661483.",
      "license": "CC BY 4.0",
      "version": "1.0",
      "url": "https://doi.org/10.3389/fpsyt.2021.661483",
      "domain": "Technology"
    },
    "implementation": {
      "author": "Shane T. Mueller",
      "organization": "OpenScales Project",
      "date": "2026-04-01",
      "license": "CC BY 4.0",
      "license_url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "likert_options": {
      "points": 5,
      "min": 0,
      "max": 4,
      "labels": [
        "likert_0",
        "likert_1",
        "likert_2",
        "likert_3",
        "likert_4"
      ],
      "question_head": "question_head"
    },
    "dimensions": [
      {
        "id": "cognitive_behavioral",
        "name": "Cognitive Behavioral Symptoms",
        "description": "Items 1, 2, 4, 5 (sum 0–16, cutoff >8)."
      },
      {
        "id": "negative_consequences",
        "name": "Negative Consequences",
        "description": "Items 3, 6, 7, 8, 9 (sum 0–20, cutoff >6)."
      },
      {
        "id": "time_criterion",
        "name": "Time Criterion",
        "description": "Item 10. Criterion met if response is 'during longer periods' or 'almost daily' (value ≥2)."
      }
    ],
    "items": [
